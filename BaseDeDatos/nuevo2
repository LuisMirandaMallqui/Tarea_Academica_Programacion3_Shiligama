        REFERENCES `shiligama`.`usuarios` (`USUARIO_ID`)
        ON DELETE CASCADE ON UPDATE CASCADE
) ENGINE = InnoDB
AUTO_INCREMENT = 1
DEFAULT CHARACTER SET = utf8mb4
COMMENT = 'Subclase Cliente. Hereda de usuarios (joined strategy).';

