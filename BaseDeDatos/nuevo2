    UNIQUE INDEX `uq_usuarios_dni` (`DNI` ASC) VISIBLE
) ENGINE = InnoDB
AUTO_INCREMENT = 1
DEFAULT CHARACTER SET = utf8mb4
COMMENT = 'Tabla padre de la jerarquía de usuarios. Clase abstracta Usuario.';

