-- Table `shiligama`.`usuarios`
-- Tabla padre (clase abstracta Usuario)
-- Estrategia: Joined / Table-per-Subclass
-- -----------------------------------------------------
DROP TABLE IF EXISTS `shiligama`.`usuarios`;

CREATE TABLE IF NOT EXISTS `shiligama`.`usuarios` (
    -- Primary Key
    `USUARIO_ID` INT NOT NULL AUTO_INCREMENT COMMENT 'Identificador único del usuario (PK padre de la herencia).',
    -- Atributos
    `NOMBRE_USUARIO` VARCHAR(50) NOT NULL COMMENT 'Nombre de usuario para login (único).',
    `CONTRASENA` VARCHAR(255) NOT NULL COMMENT 'Contraseña cifrada con bcrypt (RNF005).',
    `NOMBRES` VARCHAR(100) NOT NULL COMMENT 'Nombres de la persona.',
    `APELLIDOS` VARCHAR(100) NOT NULL COMMENT 'Apellidos de la persona.',
    `DNI` VARCHAR(8) NOT NULL COMMENT 'Documento Nacional de Identidad (8 dígitos).',
    `TELEFONO` VARCHAR(15) NULL DEFAULT NULL COMMENT 'Número de teléfono de contacto.',
    `EMAIL` VARCHAR(100) NOT NULL COMMENT 'Correo electrónico (único).',
    `DIRECCION` VARCHAR(255) NULL DEFAULT NULL COMMENT 'Dirección domiciliaria.',
    `ESTADO` TINYINT NOT NULL DEFAULT 1 COMMENT 'Flag estado (1=Activo, 0=Inactivo).',
    `FECHA_CREACION` DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT 'Fecha y hora de creación del registro.',
