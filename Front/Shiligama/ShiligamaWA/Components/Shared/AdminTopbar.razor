@inject INotificacionService NotifSvc
@inject ISesionService Sesion
@inject NavigationManager Nav
@implements IDisposable

<header class="admin-topbar">
    <div class="topbar-inner">
        @* Spacer mobile (espacio para el menu hamburguesa) *@
        <div class="d-lg-none" style="width:42px;"></div>

        <div class="topbar-search">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="search" class="form-control" placeholder="Buscar productos, pedidos, clientes..." />
        </div>

        <div class="topbar-actions">
            <a href="/admin/notificaciones" class="topbar-icon-btn" title="Notificaciones">
                <i class="fa-solid fa-bell"></i>
                @if (NoLeidas > 0)
                {
                    <span class="topbar-badge">@NoLeidas</span>
                }
            </a>

            <div class="topbar-user dropdown">
                <button class="btn btn-link p-0 d-flex align-items-center gap-2 text-decoration-none"
                        type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <div class="user-avatar">@Iniciales</div>
                    <div class="d-none d-md-block text-start">
                        <div class="user-name">@Nombre</div>
                        <div class="user-role">@RolLabel</div>
                    </div>
                    <i class="fa-solid fa-chevron-down d-none d-md-inline" style="font-size:0.7rem;color:var(--color-muted-foreground);"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                    <li><h6 class="dropdown-header">Mi cuenta</h6></li>
                    <li><a class="dropdown-item" href="/admin/perfil"><i class="fa-solid fa-user me-2"></i>Perfil</a></li>
                    <li><a class="dropdown-item" href="/admin/configuracion"><i class="fa-solid fa-gear me-2"></i>Configuraci&oacute;n</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" href="/" @onclick="Logout" @onclick:preventDefault><i class="fa-solid fa-right-from-bracket me-2"></i>Cerrar sesi&oacute;n</a></li>
                </ul>
            </div>
        </div>
    </div>
</header>

@code {
    private int NoLeidas;
    private string Iniciales = "AD";
    private string Nombre = "Admin Principal";
    private string RolLabel = "Administrador";

    protected override void OnInitialized()
    {
        NoLeidas = NotifSvc.CantidadNoLeidas();
        Sesion.OnChange += OnSesionChange;
        ApplySesion();
    }

    private void ApplySesion()
    {
        if (Sesion.Actual.Autenticado)
        {
            Iniciales = string.IsNullOrEmpty(Sesion.Actual.Iniciales) ? "AD" : Sesion.Actual.Iniciales;
            Nombre = string.IsNullOrEmpty(Sesion.Actual.NombreCompleto) ? "Admin Principal" : Sesion.Actual.NombreCompleto;
            RolLabel = Sesion.Actual.RolLabel;
        }
    }

    private void OnSesionChange()
    {
        ApplySesion();
        InvokeAsync(StateHasChanged);
    }

    private void Logout()
    {
        Sesion.CerrarSesion();
        Nav.NavigateTo("/", forceLoad: true);
    }

    public void Dispose() => Sesion.OnChange -= OnSesionChange;
}
