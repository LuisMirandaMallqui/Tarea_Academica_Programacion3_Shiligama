@* Item de navegacion con active-state automatico *@
<NavLink class="sidebar-link" href="@Href" Match="@(MatchAll ? NavLinkMatch.All : NavLinkMatch.Prefix)">
    <i class="@Icon"></i>
    <span>@((MarkupString)Label)</span>
    @if (BadgeCount.HasValue && BadgeCount.Value > 0)
    {
        <span class="badge rounded-pill bg-light text-dark ms-auto">@BadgeCount.Value</span>
    }
</NavLink>

@code {
    [Parameter, EditorRequired] public string Href { get; set; } = "";
    [Parameter, EditorRequired] public string Icon { get; set; } = "";
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter] public bool MatchAll { get; set; }
    [Parameter] public int? BadgeCount { get; set; }
}
