@inject INotificacionService NotifSvc
@inject ISesionService Sesion
@inject NavigationManager Nav

@* Feedback JP: "Mis turnos" eliminado del menu de trabajador (no esta en requisitos ni BD) *@

<header class="admin-topbar">
    <div class="topbar-inner">
        <div class="d-flex align-items-center gap-3 ms-lg-0 ps-5 ps-lg-0">
            <h1 class="page-title">@Title</h1>
        </div>

        <div class="topbar-actions">
            <a href="#" class="topbar-icon-btn" title="Notificaciones"
               data-bs-toggle="dropdown" aria-expanded="false">
                <i class="fa-solid fa-bell"></i>
                @if (NoLeidas > 0)
                {
                    <span class="topbar-badge">@NoLeidas</span>
                }
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="min-width:280px;">
                <li><h6 class="dropdown-header">Notificaciones</h6></li>
                @foreach (var n in Recientes)
                {
                    <li>
                        <a class="dropdown-item py-2" href="@(n.EnlaceAccion ?? "#")">
                            <div class="fw-semibold small">@n.Titulo</div>
                            <div class="text-muted" style="font-size:0.72rem;">@FormatoFecha(n.Fecha)</div>
                        </a>
                    </li>
                }
            </ul>

            <div class="topbar-user dropdown">
                <button class="btn btn-link p-0 d-flex align-items-center gap-2 text-decoration-none"
                        type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <div class="user-avatar">@Iniciales</div>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                    <li>
                        <h6 class="dropdown-header">
                            <div>@Nombre</div>
                            <div class="text-muted" style="font-weight:400;font-size:0.72rem;">Trabajador</div>
                        </h6>
                    </li>
                    <li><a class="dropdown-item" href="/trabajador/perfil"><i class="fa-solid fa-user me-2"></i>Mi perfil</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" href="/" @onclick="Logout" @onclick:preventDefault><i class="fa-solid fa-right-from-bracket me-2"></i>Cerrar sesi&oacute;n</a></li>
                </ul>
            </div>
        </div>
    </div>
</header>

@code {
    [Parameter] public string Title { get; set; } = "Panel";

    private int NoLeidas;
    private List<Notificacion> Recientes = new();
    private string Iniciales = "CM";
    private string Nombre = "Carlos Mendoza";

    protected override void OnInitialized()
    {
        NoLeidas = NotifSvc.CantidadNoLeidas();
        Recientes = NotifSvc.Listar().Take(3).ToList();
        if (Sesion.Actual.Autenticado)
        {
            Iniciales = string.IsNullOrEmpty(Sesion.Actual.Iniciales) ? "CM" : Sesion.Actual.Iniciales;
            Nombre = string.IsNullOrEmpty(Sesion.Actual.NombreCompleto) ? "Carlos Mendoza" : Sesion.Actual.NombreCompleto;
        }
    }

    private string FormatoFecha(DateTime f)
    {
        var diff = DateTime.Now - f;
        if (diff.TotalMinutes < 1) return "ahora";
        if (diff.TotalMinutes < 60) return $"hace {(int)diff.TotalMinutes} min";
        if (diff.TotalHours < 24) return $"hace {(int)diff.TotalHours} h";
        return f.ToString("dd/MM HH:mm");
    }

    private void Logout()
    {
        Sesion.CerrarSesion();
        Nav.NavigateTo("/", forceLoad: true);
    }
}
