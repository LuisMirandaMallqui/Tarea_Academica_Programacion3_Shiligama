@inherits LayoutComponentBase

<div class="public-shell">
    <CatalogNavbar />
    <main class="public-content">
        @Body
    </main>
    <footer class="public-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <div class="fw-bold fs-5 text-shiligama">
                            <i class="fa-solid fa-cart-shopping me-1"></i> Shiligama
                        </div>
                    </div>
                    <p class="text-muted small mb-0">Tu minimarket de confianza, con entrega a domicilio en Lima.</p>
                </div>
                <div class="col-md-4">
                    <h6 class="fw-semibold mb-2">Atencion al cliente</h6>
                    <p class="text-muted small mb-1"><i class="fa-solid fa-phone me-2"></i>(01) 555-0100</p>
                    <p class="text-muted small mb-0"><i class="fa-solid fa-envelope me-2"></i>contacto@shiligama.com</p>
                </div>
                <div class="col-md-4">
                    <h6 class="fw-semibold mb-2">Enlaces</h6>
                    <a href="/catalogo" class="d-block text-muted text-decoration-none small mb-1">Catalogo</a>
                    <a href="/ofertas" class="d-block text-muted text-decoration-none small mb-1">Ofertas</a>
                    <a href="/mis-pedidos" class="d-block text-muted text-decoration-none small">Mis pedidos</a>
                </div>
            </div>
            <hr class="my-3" />
            <div class="text-center text-muted small">
                &copy; @DateTime.Now.Year Shiligama. Todos los derechos reservados.
            </div>
        </div>
    </footer>
</div>
