@page "/"
@layout Components.Layout.EmptyLayout
@inject NavigationManager Navigation

<div class="login-container">
    <div class="left-panel">
        <div class="brand-section">
            <div class="d-flex align-items-center mb-5">
                <i class="fas fa-shopping-basket fa-2x me-3 text-warning"></i>
                <div>
                    <h2 class="m-0">Shiligama</h2>
                    <p class="small text-white-50 m-0">Sistema de Gestión de Minimarket</p>
                </div>
            </div>

            <div class="feature-list">
                <h3 class="mb-4 fw-light text-white">Tu negocio centralizado en un solo lugar</h3>
                
                <div class="feature-item">
                    <i class="fas fa-boxes feature-icon"></i>
                    <div>
                        <p class="fw-bold m-0 text-white">Control de Inventario Automático</p>
                        <small class="text-white-50">Alertas de stock mínimo sincronizadas con la base de datos de Almacén.</small>
                    </div>
                </div>

                <div class="feature-item">
                    <i class="fas fa-file-invoice-dollar feature-icon"></i>
                    <div>
                        <p class="fw-bold m-0 text-white">Ventas y Facturación</p>
                        <small class="text-white-50">Módulo de caja rápido con soporte transaccional maestro-detalle.</small>
                    </div>
                </div>

                <div class="feature-item">
                    <i class="fas fa-users-cog feature-icon"></i>
                    <div>
                        <p class="fw-bold m-0 text-white">Seguridad por Roles</p>
                        <small class="text-white-50">Accesos y permisos restringidos para Administradores, Trabajadores y Clientes.</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="footer-left text-white-50 small">
            <span>&copy; 2026 Shiligama. Sistema de Trabajo Académico.</span>
        </div>

        <svg class="circle-decoration" width="280" height="280" viewBox="0 0 200 200">
            <circle cx="100" cy="100" r="90" stroke="#ffffff" stroke-width="1.5" fill="none" />
            <circle cx="100" cy="100" r="65" stroke="#ffffff" stroke-width="1" stroke-dasharray="4 2" fill="none" />
            <circle cx="60" cy="140" r="80" stroke="#ffffff" stroke-width="1" fill="none" />
        </svg>
    </div>

    <div class="right-panel">
        <div class="login-card">
            <h2 class="text-dark fw-bold mb-1">Iniciar Sesión</h2>
            <p class="text-muted small mb-4">Selecciona tu rol e ingresa al sistema</p>

            <div class="role-tabs">
                <button type="button" class="role-tab @(selectedRole == "Cliente" ? "active" : "")" @onclick='() => SeleccionarRol("Cliente")'>Cliente</button>
                <button type="button" class="role-tab @(selectedRole == "Trabajador" ? "active" : "")" @onclick='() => SeleccionarRol("Trabajador")'>Trabajador</button>
                <button type="button" class="role-tab @(selectedRole == "Administrador" ? "active" : "")" @onclick='() => SeleccionarRol("Administrador")'>Admin</button>
            </div>

            <EditForm Model="loginModel" OnValidSubmit="ProcesarAutenticacion">
                <div class="mb-3">
                    <label class="form-label small fw-bold text-secondary">Correo Electrónico</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="far fa-envelope"></i></span>
                        <input type="email" class="form-control" placeholder="nombre@correo.com" @bind="loginModel.Email" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-bold text-secondary">Contraseña</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="fas fa-lock"></i></span>
                        <input type="password" class="form-control" placeholder="••••••••" @bind="loginModel.Password" required />
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check mb-0">
                        <input type="checkbox" class="form-check-input" id="chkRecordar">
                        <label class="form-check-label small text-muted user-select-none" for="chkRecordar">Recordarme</label>
                    </div>
                    <a href="#" class="link-forgot">¿Olvidaste tu contraseña?</a>
                </div>

                <button type="submit" class="btn btn-login mb-4">
                    <i class="fas fa-sign-in-alt me-2"></i>Ingresar al Sistema
                </button>
            </EditForm>

            <div class="credentials-box p-3 shadow-sm">
                <div class="d-flex align-items-center mb-1 text-dark fw-bold small">
                    <i class="fas fa-key text-warning me-2"></i>
                    <span>Credenciales de acceso (@selectedRole):</span>
                </div>
                <div class="font-monospace text-secondary small style-code" style="font-size: 0.82rem; line-height: 1.4;">
                    <strong>Usuario:</strong> @credencialEmail<br />
                    <strong>Clave:</strong> @credencialPassword
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string selectedRole = "Administrador";
    private LoginCredentials loginModel = new();

    // Variables para renderizar las credenciales dinámicamente en pantalla
    private string credencialEmail = "test1234@admin.com";
    private string credencialPassword = "eldelegadolavandoselasmanos";

    protected override void OnInitialized()
    {
        CargarCredencialesPorDefecto();
    }

    private void SeleccionarRol(string rol)
    {
        selectedRole = rol;
        CargarCredencialesPorDefecto();
    }

    private void CargarCredencialesPorDefecto()
    {
        if (selectedRole == "Administrador")
        {
            credencialEmail = "test1234@admin.com";
            credencialPassword = "eldelegadolavandoselasmanos";
        }
        else if (selectedRole == "Trabajador")
        {
            credencialEmail = "trabajador@shiligama.com";
            credencialPassword = "trabajador123";
        }
        else
        {
            credencialEmail = "cliente@shiligama.com";
            credencialPassword = "cliente123";
        }

        // Asignación automática al modelo para agilizar pruebas del profesor
        loginModel.Email = credencialEmail;
        loginModel.Password = credencialPassword;
    }

    private void ProcesarAutenticacion()
    {
        // Aquí conectarás con tu inyección de dependencias (UsuarioBoImpl a través de API REST)
        // Por ahora redirige directo al catálogo de productos para la simulación
        Navigation.NavigateTo("/productos");
    }

    public class LoginCredentials
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
}