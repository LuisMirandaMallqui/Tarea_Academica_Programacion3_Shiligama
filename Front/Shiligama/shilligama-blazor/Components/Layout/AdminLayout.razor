@inherits LayoutComponentBase
@inject AuthService Auth
@inject NavigationManager Navigation
@inject NotificacionService NotificacionSvc

<RoleGate RequiredRole="administrador">
<div class="d-flex flex-column min-vh-100 bg-background text-foreground">

    <!-- Mobile toggle -->
    <button type="button" @onclick="ToggleMobileSidebar"
            class="btn btn-primary d-lg-none position-fixed z-3 d-flex align-items-center justify-content-center"
            style="width:44px;height:44px;left:15px;top:10px;border-radius:var(--radius);background-color:#073a1e;border-color:#073a1e;">
        <i class="fas fa-bars text-white" style="font-size:1.25rem;"></i>
    </button>

    <!-- Sidebar desktop -->
    <aside class="d-none d-lg-flex flex-column position-fixed top-0 bottom-0 start-0 z-2 bg-sidebar-formal text-white shadow-sm" style="width:300px;">
        <div class="sidebar-brand-container">
            <a href="/admin" class="d-flex align-items-center gap-3 text-decoration-none text-white">
                <div class="sidebar-logo-box"><i class="fas fa-shopping-cart sidebar-logo-icon"></i></div>
                <div>
                    <h1 class="sidebar-brand-title">Shiligama</h1>
                    <p class="sidebar-brand-subtitle">Administración</p>
                </div>
            </a>
        </div>

        <nav class="flex-grow-1 sidebar-nav-container overflow-y-auto">
            <a href="/admin"
               class="sidebar-link-formal @(IsActive("/admin") && !IsActive("/admin/categorias") && !IsActive("/admin/pedidos") && !IsActive("/admin/productos") && !IsActive("/admin/promociones") && !IsActive("/admin/ventas") && !IsActive("/admin/registrar-venta") && !IsActive("/admin/personal") && !IsActive("/admin/reportes") && !IsActive("/admin/devoluciones") && !IsActive("/admin/perfil") ? "active" : "")">
                <i class="fas fa-store-alt"></i> Dashboard
            </a>
            <a href="/admin/pedidos"
               class="sidebar-link-formal @(IsActive("/admin/pedidos") ? "active" : "")">
                <i class="fas fa-clipboard-list"></i> Pedidos
            </a>
            <a href="/admin/productos"
               class="sidebar-link-formal @(IsActive("/admin/productos") ? "active" : "")">
                <i class="fas fa-cube"></i> Productos
            </a>
            <a href="/admin/categorias"
               class="sidebar-link-formal @(IsActive("/admin/categorias") ? "active" : "")">
                <i class="fas fa-sitemap"></i> Categorías
            </a>
            <a href="/admin/promociones"
               class="sidebar-link-formal @(IsActive("/admin/promociones") ? "active" : "")">
                <i class="fas fa-tags"></i> Promociones
            </a>
            <a href="/admin/registrar-venta"
               class="sidebar-link-formal @(IsActive("/admin/registrar-venta") ? "active" : "")">
                <i class="far fa-credit-card"></i> Registrar Venta
            </a>
            <a href="/admin/ventas"
               class="sidebar-link-formal @(IsActive("/admin/ventas") ? "active" : "")">
                <i class="fas fa-chart-line"></i> Historial Venta
            </a>
            <a href="/admin/personal"
               class="sidebar-link-formal @(IsActive("/admin/personal") ? "active" : "")">
                <i class="fas fa-users"></i> Personal
            </a>
            <a href="/admin/reportes"
               class="sidebar-link-formal @(IsActive("/admin/reportes") ? "active" : "")">
                <i class="fas fa-file-alt"></i> Reportes
            </a>
            <a href="/admin/devoluciones"
               class="sidebar-link-formal @(IsActive("/admin/devoluciones") ? "active" : "")">
                <i class="fas fa-undo"></i> Devoluciones
            </a>
            
        </nav>

        <div class="sidebar-footer-container">
            <a href="/admin/perfil" class="sidebar-profile-info text-decoration-none">
                <i class="far fa-user"></i>
                <div>
                    <p class="sidebar-profile-name" style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                        @(Auth.CurrentUser?.Name ?? "Administrador")
                    </p>
                    <p class="sidebar-profile-role">Administrador</p>
                </div>
            </a>
            <button type="button" @onclick="HandleLogout" class="sidebar-logout-btn">
                <i class="fas fa-sign-out-alt"></i> Cerrar sesión
            </button>
        </div>
    </aside>

    <!-- Mobile drawer -->
    <div class="sheet-backdrop @(_isMobileSidebarOpen ? "show" : "")" @onclick="ToggleMobileSidebar"></div>
    <div class="sheet-panel @(_isMobileSidebarOpen ? "show" : "") bg-sidebar-formal d-flex flex-column p-0" style="width: 300px;">
        <div class="sidebar-brand-container d-flex justify-content-between align-items-center">
            <a href="/admin" @onclick="ToggleMobileSidebar" class="d-flex align-items-center gap-3 text-decoration-none text-white">
                <div class="sidebar-logo-box"><i class="fas fa-shopping-cart sidebar-logo-icon"></i></div>
                <div>
                    <h1 class="sidebar-brand-title">Shiligama</h1>
                    <p class="sidebar-brand-subtitle">Administración</p>
                </div>
            </a>
            <button type="button" class="btn-close btn-close-white" @onclick="ToggleMobileSidebar" style="font-size:0.75rem;"></button>
        </div>

        <nav class="flex-grow-1 sidebar-nav-container overflow-y-auto">
            <a href="/admin" @onclick="ToggleMobileSidebar"
               class="sidebar-link-formal @(IsActive("/admin") && !IsActive("/admin/categorias") && !IsActive("/admin/pedidos") && !IsActive("/admin/productos") && !IsActive("/admin/promociones") && !IsActive("/admin/ventas") && !IsActive("/admin/registrar-venta") && !IsActive("/admin/personal") && !IsActive("/admin/reportes") && !IsActive("/admin/devoluciones") && !IsActive("/admin/perfil")? "active" : "")">
                <i class="fas fa-store-alt"></i> Dashboard
            </a>
            <a href="/admin/pedidos" @onclick="ToggleMobileSidebar"
               class="sidebar-link-formal @(IsActive("/admin/pedidos") ? "active" : "")">
                <i class="fas fa-clipboard-list"></i> Pedidos
            </a>
            <a href="/admin/productos" @onclick="ToggleMobileSidebar"
               class="sidebar-link-formal @(IsActive("/admin/productos") ? "active" : "")">
                <i class="fas fa-cube"></i> Productos
            </a>
            <a href="/admin/categorias" @onclick="ToggleMobileSidebar"
               class="sidebar-link-formal @(IsActive("/admin/categorias") ? "active" : "")">
                <i class="fas fa-sitemap"></i> Categorías
            </a>
            <a href="/admin/promociones" @onclick="ToggleMobileSidebar"
               class="sidebar-link-formal @(IsActive("/admin/promociones") ? "active" : "")">
                <i class="fas fa-tags"></i> Promociones
            </a>
            <a href="/admin/registrar-venta" @onclick="ToggleMobileSidebar"
               class="sidebar-link-formal @(IsActive("/admin/registrar-venta") ? "active" : "")">
                <i class="far fa-credit-card"></i> Registrar Venta
            </a>
            <a href="/admin/ventas" @onclick="ToggleMobileSidebar"
               class="sidebar-link-formal @(IsActive("/admin/ventas") ? "active" : "")">
                <i class="fas fa-chart-line"></i> Historial Venta
            </a>
            <a href="/admin/personal" @onclick="ToggleMobileSidebar"
               class="sidebar-link-formal @(IsActive("/admin/personal") ? "active" : "")">
                <i class="fas fa-users"></i> Personal
            </a>
            <a href="/admin/reportes" @onclick="ToggleMobileSidebar"
               class="sidebar-link-formal @(IsActive("/admin/reportes") ? "active" : "")">
                <i class="fas fa-file-alt"></i> Reportes
            </a>
            <a href="/admin/devoluciones" @onclick="ToggleMobileSidebar"
               class="sidebar-link-formal @(IsActive("/admin/devoluciones") ? "active" : "")">
                <i class="fas fa-undo"></i> Devoluciones
            </a>
            
        </nav>

        <div class="sidebar-footer-container">
            <a href="/admin/perfil" @onclick="ToggleMobileSidebar" class="sidebar-profile-info text-decoration-none">
                <i class="far fa-user"></i>
                <div>
                    <p class="sidebar-profile-name" style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                        @(Auth.CurrentUser?.Name ?? "Administrador")
                    </p>
                    <p class="sidebar-profile-role">Administrador</p>
                </div>
            </a>
            <button type="button" @onclick="HandleLogout" class="sidebar-logout-btn">
                <i class="fas fa-sign-out-alt"></i> Cerrar sesión
            </button>
        </div>
    </div>

    <!-- Content -->
    <div class="flex-grow-1 d-flex flex-column admin-content" style="max-width: 100%;">
        
        <!-- Top Bar Header -->
        <header class="sticky-top bg-card border-bottom py-3 px-3 px-lg-4 border-color-default" style="z-index: 1; backdrop-filter: blur(8px); background-color: rgba(var(--bs-body-bg-rgb), 0.95);">
            <div class="d-flex align-items-center justify-content-between gap-3">
                <!-- Mobile Spacer left (for float button) -->
                <div class="d-lg-none" style="width: 48px;"></div>
                
                <!-- Search bar filter mock -->
                <div class="flex-grow-1 max-w-md" style="max-width: 400px;">
                    <div class="position-relative w-100">
                       @*  <Icons Name="Search" Class="admin-search-icon position-absolute start-3 top-50 translate-middle-y mt-2 pt-1 w-4 h-4 text-muted-foreground" style="left: 12px;" />
                        <input
                            type="search"
                            placeholder="Buscar productos, pedidos, personal..."
                            class="form-control pl-9 border-0 bg-muted text-foreground py-2"
                            style="padding-left: 36px; background-color: var(--secondary) !important; font-size: 0.9rem;"
                        /> *@
                    </div>
                </div>

                <!-- Right items -->
                <div class="d-flex align-items-center gap-3">
                    
                    <!-- Theme Selector -->
                    <ThemeSelector />

                    <!-- Notifications Link -->
                    <a href="/admin/notificaciones" class="btn btn-ghost p-2 position-relative text-foreground" style="border-radius: var(--radius);" title="Notificaciones">
                        <i class="fas fa-bell" style="font-size:1.1rem;"></i>
                        @if (_unreadCount > 0)
                        {
                            <span class="position-absolute top-1 start-100 translate-middle badge bg-danger border border-light rounded-circle d-flex align-items-center justify-content-center" style="width: 18px; height: 18px; font-size: 0.65rem; left: 80%;">
                                @(_unreadCount > 9 ? "9+" : _unreadCount.ToString())
                            </span>
                        }
                    </a>

                    <!-- User drop menu -->
                    <div class="dropdown">
                        <button class="btn btn-ghost p-1 rounded-circle border-0 d-flex align-items-center justify-content-center" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="width: 40px; height: 40px;">
                            <div class="d-flex align-items-center justify-content-center rounded-circle text-white" style="width: 32px; height: 32px; background-color:#064420;font-weight:600;font-size:0.8rem;">
                                @((Auth.CurrentUser?.Name?.Length > 0 ? Auth.CurrentUser.Name[..1].ToUpper() : "A") +
                                  (Auth.CurrentUser?.Name?.Split(' ')?.Length > 1 ? Auth.CurrentUser.Name.Split(' ')[1][..1].ToUpper() : ""))
                            </div>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end  border shadow-lg p-2" style="width: 220px; border-radius: var(--radius);">
                            <li class="px-3 py-2 border-bottom border-color-default mb-1">
                                <p class="text-sm font-semibold text-foreground m-0">@(Auth.CurrentUser?.Name ?? "Administrador")</p>
                                <p class="text-xs text-muted-foreground m-0 text-truncate">@(Auth.CurrentUser?.Email ?? "admin@shiligama.com")</p>
                            </li>
                            <li>
                                <a class="dropdown-item d-flex align-items-center text-foreground py-2" href="/admin/perfil" style="border-radius: var(--radius);">
                                    <i class="fas fa-user me-2 text-muted-foreground" style="width: 16px;text-align:center;"></i>
                                    Mi Perfil
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item d-flex align-items-center text-foreground py-2" href="/admin/configuracion" style="border-radius: var(--radius);">
                                    <i class="fas fa-cog me-2 text-muted-foreground" style="width: 16px;text-align:center;"></i>
                                    Configuración
                                </a>
                            </li>
                            <li><hr class="dropdown-divider border-color-default"></li>
                            <li>
                                <button type="button" @onclick="HandleLogout" class="dropdown-item d-flex align-items-center text-danger py-2" style="border-radius: var(--radius);">
                                    <i class="fas fa-sign-out-alt me-2" style="width:16px;text-align:center;"></i>
                                    Cerrar Sesión
                                </button>
                            </li>
                        </ul>
                    </div>

                </div>
            </div>
        </header>

        <!-- Main Body Content -->
        <main class="flex-grow-1 p-3 p-lg-4">
            @Body
        </main>
    </div>
</div>
<style>
    .bg-sidebar-formal { background-color: #073a1e !important; color: #fff !important; }

    .sidebar-brand-container { padding: 1.75rem 1.5rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.08); }
    .sidebar-logo-box { width: 48px; height: 48px; background: rgba(255,255,255,0.08); border-radius: 0.75rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .sidebar-logo-icon { font-size: 1.35rem; color: #fff; }
    .sidebar-brand-title { font-family: 'Outfit', sans-serif; font-size: 1.35rem; font-weight: 700; color: #fff; margin: 0; line-height: 1.2; }
    .sidebar-brand-subtitle { font-size: 0.78rem; color: rgba(255,255,255,0.6); margin: 0; }

    .sidebar-nav-container { padding: 1.5rem 1.25rem; display: flex; flex-direction: column; gap: 0.5rem; }
    .sidebar-link-formal { display: flex; align-items: center; gap: 1rem; padding: 0.85rem 1.25rem; border-radius: 0.75rem; text-decoration: none; color: rgba(255,255,255,0.75); font-weight: 500; font-size: 0.95rem; transition: all 0.2s ease; }
    .sidebar-link-formal i { font-size: 1.1rem; width: 22px; text-align: center; }
    .sidebar-link-formal:hover { background-color: rgba(255,255,255,0.06); color: #fff; }
    .sidebar-link-formal.active { background-color: rgba(255,255,255,0.1) !important; color: #fff !important; font-weight: 600; }

    .sidebar-footer-container { padding: 1.5rem; border-top: 1px solid rgba(255,255,255,0.08); display: flex; flex-direction: column; gap: 1.25rem; }
    .sidebar-profile-info { display: flex; align-items: center; gap: 1rem; color: #fff; }
    .sidebar-profile-info i { font-size: 1.2rem; width: 22px; text-align: center; }
    .sidebar-profile-name { font-weight: 600; font-size: 0.9rem; margin: 0; color: #fff; }
    .sidebar-profile-role { font-size: 0.78rem; color: rgba(255,255,255,0.55); margin: 0; }
    .sidebar-logout-btn { display: flex; align-items: center; gap: 1rem; padding: 0.5rem 0; background: transparent; border: none; color: rgba(255,255,255,0.7); font-weight: 500; font-size: 0.9rem; width: 100%; transition: all 0.2s ease; }
    .sidebar-logout-btn:hover { color: #fff; }
    .sidebar-logout-btn i { font-size: 1.1rem; width: 22px; text-align: center; }

    .sheet-backdrop { position:fixed; top:0; right:0; bottom:0; left:0; background:rgba(0,0,0,0.5); z-index:1040; display:none; }
    .sheet-backdrop.show { display:block; }
    .sheet-panel { position:fixed; top:0; bottom:0; left:0; z-index:1045; transform:translateX(-100%); transition:transform 0.3s ease; overflow-y:auto; }
    .sheet-panel.show { transform:translateX(0); }

    .admin-content { padding-left: 300px; }
    @@media (max-width: 991.98px) {
        .admin-content { padding-left: 0 !important; }
    }
</style>
</RoleGate>

@code {
    private bool _isMobileSidebarOpen = false;
    private int _unreadCount = 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _unreadCount = await NotificacionSvc.ContarNoLeidasAsync(Auth.CurrentUser?.Id ?? 0);
        }
        catch
        {
            _unreadCount = 0;
        }
    }


    private void ToggleMobileSidebar()
    {
        _isMobileSidebarOpen = !_isMobileSidebarOpen;
    }

    private void HandleLogout()
    {
        Auth.Logout();
        Navigation.NavigateTo("/");
    }

    private bool IsActive(string href)
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
        var target = href.TrimStart('/');
        
        if (string.IsNullOrEmpty(target))
        {
            return string.IsNullOrEmpty(relative) || relative.Equals("admin", StringComparison.OrdinalIgnoreCase);
        }
        
        return relative.StartsWith(target, StringComparison.OrdinalIgnoreCase);
    }
}
