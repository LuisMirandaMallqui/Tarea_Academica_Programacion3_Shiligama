@inherits LayoutComponentBase
@inject AuthService Auth
@inject NavigationManager Navigation

<RoleGate RequiredRole="trabajador">
<div class="d-flex flex-column min-vh-100 bg-background text-foreground">

    <!-- Mobile toggle -->
    <button type="button" @onclick="ToggleMobileSidebar"
            class="btn btn-primary d-lg-none position-fixed z-3 d-flex align-items-center justify-content-center"
            style="width:44px;height:44px;left:15px;top:10px;border-radius:var(--radius);background-color:#073a1e;border-color:#073a1e;">
        <i class="fas fa-bars text-white" style="font-size:1.25rem;"></i>
    </button>

    <!-- Sidebar desktop -->
    <aside class="d-none d-lg-flex flex-column position-fixed top-0 bottom-0 start-0 z-2 bg-sidebar-formal text-white shadow-sm" style="width:300px;">
        <div class="sidebar-brand-container">
            <a href="/trabajador" class="d-flex align-items-center gap-3 text-decoration-none text-white">
                <div class="sidebar-logo-box"><i class="fas fa-shopping-cart sidebar-logo-icon"></i></div>
                <div>
                    <h1 class="sidebar-brand-title">Shiligama</h1>
                    <p class="sidebar-brand-subtitle">Portal Trabajador</p>
                </div>
            </a>
        </div>

        <nav class="flex-grow-1 sidebar-nav-container overflow-y-auto">
            <a href="/trabajador"
               class="sidebar-link-formal @(IsActive("/trabajador") && !IsActive("/trabajador/productos") && !IsActive("/trabajador/registrar-venta") && !IsActive("/trabajador/devoluciones") && !IsActive("/trabajador/perfil") ? "active" : "")">
                <i class="fas fa-clipboard-list"></i> Pedidos Clientes
            </a>
            <a href="/trabajador/registrar-venta"
               class="sidebar-link-formal @(IsActive("/trabajador/registrar-venta") ? "active" : "")">
                <i class="far fa-credit-card"></i> Registrar Venta (POS)
            </a>
            <a href="/trabajador/productos"
               class="sidebar-link-formal @(IsActive("/trabajador/productos") ? "active" : "")">
                <i class="fas fa-cube"></i> Productos
            </a>
            <a href="/trabajador/devoluciones"
               class="sidebar-link-formal @(IsActive("/trabajador/devoluciones") ? "active" : "")">
                <i class="fas fa-undo"></i> Devoluciones
            </a>
        </nav>

        <div class="sidebar-footer-container">
            <a href="/trabajador/perfil" class="sidebar-profile-info text-decoration-none">
                <i class="far fa-user"></i>
                <div>
                    <p class="sidebar-profile-name" style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                        @(Auth.CurrentUser?.Name ?? "Trabajador")
                    </p>
                    <p class="sidebar-profile-role">@(Auth.CurrentUser?.Cargo ?? "Trabajador")</p>
                </div>
            </a>
            <button type="button" @onclick="HandleLogout" class="sidebar-logout-btn">
                <i class="fas fa-sign-out-alt"></i> Cerrar sesión
            </button>
        </div>
    </aside>

    <!-- Mobile drawer -->
    @if (_isMobileSidebarOpen)
    {
        <div class="position-fixed" style="inset:0;z-index:998;background:rgba(0,0,0,.5);" @onclick="ToggleMobileSidebar"></div>
        <div class="position-fixed top-0 start-0 bottom-0 bg-sidebar-formal text-white d-flex flex-column z-3" style="width:260px;">
            <div class="sidebar-brand-container d-flex align-items-center justify-content-between py-3">
                <a href="/trabajador" @onclick="ToggleMobileSidebar" class="d-flex align-items-center gap-3 text-decoration-none text-white">
                    <div class="sidebar-logo-box" style="width:40px;height:40px;">
                        <i class="fas fa-shopping-cart sidebar-logo-icon" style="font-size:1.15rem;"></i>
                    </div>
                    <div>
                        <h1 class="sidebar-brand-title" style="font-size:1.15rem;">Shiligama</h1>
                        <p class="sidebar-brand-subtitle" style="font-size:0.72rem;">Portal Trabajador</p>
                    </div>
                </a>
                <button type="button" class="btn-close btn-close-white" @onclick="ToggleMobileSidebar"></button>
            </div>
            <nav class="sidebar-nav-container overflow-y-auto flex-grow-1">
                <a href="/trabajador" @onclick="ToggleMobileSidebar"
                   class="sidebar-link-formal @(IsActive("/trabajador") && !IsActive("/trabajador/productos") && !IsActive("/trabajador/registrar-venta") && !IsActive("/trabajador/devoluciones") && !IsActive("/trabajador/perfil") ? "active" : "")">
                    <i class="fas fa-clipboard-list"></i> Pedidos Clientes
                </a>
                <a href="/trabajador/registrar-venta" @onclick="ToggleMobileSidebar"
                   class="sidebar-link-formal @(IsActive("/trabajador/registrar-venta") ? "active" : "")">
                    <i class="far fa-credit-card"></i> Registrar Venta (POS)
                </a>
                <a href="/trabajador/productos" @onclick="ToggleMobileSidebar"
                   class="sidebar-link-formal @(IsActive("/trabajador/productos") ? "active" : "")">
                    <i class="fas fa-cube"></i> Productos
                </a>
                <a href="/trabajador/devoluciones" @onclick="ToggleMobileSidebar"
                   class="sidebar-link-formal @(IsActive("/trabajador/devoluciones") ? "active" : "")">
                    <i class="fas fa-undo"></i> Devoluciones
                </a>
            </nav>
            <div class="sidebar-footer-container">
                <a href="/trabajador/perfil" @onclick="ToggleMobileSidebar" class="sidebar-profile-info text-decoration-none">
                    <i class="far fa-user"></i>
                    <div>
                        <p class="sidebar-profile-name">@(Auth.CurrentUser?.Name ?? "Trabajador")</p>
                        <p class="sidebar-profile-role">@(Auth.CurrentUser?.Cargo ?? "Trabajador")</p>
                    </div>
                </a>
                <button type="button" @onclick="HandleLogout" class="sidebar-logout-btn">
                    <i class="fas fa-sign-out-alt"></i> Cerrar sesión
                </button>
            </div>
        </div>
    }

    <!-- Workspace -->
    <div class="flex-grow-1 d-flex flex-column trabajador-content">
        <!-- Topbar -->
        <header class="sticky-top bg-card border-bottom py-3 px-3 px-lg-4 border-color-default" style="z-index:900;">
            <div class="d-flex align-items-center justify-content-between gap-3">
                <div class="d-lg-none" style="width:48px;"></div>
                <div class="flex-grow-1 ms-2">
                    <span class="h5 m-0 fw-bold text-foreground" style="font-family:'Outfit',sans-serif;">@HeaderTitle</span>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <ThemeSelector />

                    <!-- Dropdown usuario -->
                    <div class="position-relative">
                        <button class="btn p-0 border-0 d-flex align-items-center justify-content-center"
                                type="button" @onclick="ToggleDropdown"
                                style="width:40px;height:40px;border-radius:50%;background:transparent;">
                            <div class="d-flex align-items-center justify-content-center rounded-circle text-white fw-bold"
                                 style="width:34px;height:34px;background-color:#064420;font-size:0.8rem;">
                                @GetInitials(Auth.CurrentUser?.Name ?? "T")
                            </div>
                        </button>

                        @if (_isDropdownOpen)
                        {
                            <div class="position-fixed" @onclick="CloseDropdown"
                                 style="inset:0;z-index:998;background:transparent;"></div>
                            <div class="card border shadow-lg p-2 position-absolute"
                                 style="width:230px;border-radius:var(--radius);right:0;top:calc(100% + 6px);z-index:999;">
                                <div class="px-3 py-2 border-bottom border-color-default mb-1">
                                    <p class="fw-semibold text-foreground m-0 small">@(Auth.CurrentUser?.Name ?? "Trabajador")</p>
                                    <p class="text-muted-foreground m-0 text-truncate" style="font-size:0.78rem;">@(Auth.CurrentUser?.Email ?? "")</p>
                                </div>
                                <a class="dropdown-item d-flex align-items-center gap-2 text-foreground py-2"
                                   href="/trabajador/perfil" @onclick="CloseDropdown" style="border-radius:var(--radius);">
                                    <i class="fas fa-user fa-fw text-muted-foreground"></i> Mi Perfil
                                </a>
                                <button class="dropdown-item d-flex align-items-center gap-2 text-foreground py-2"
                                        type="button" @onclick="ShowTurnosModal"
                                        style="border-radius:var(--radius);border:none;background:transparent;width:100%;text-align:left;">
                                    <i class="fas fa-calendar-alt fa-fw text-muted-foreground"></i> Mis Turnos
                                </button>
                                <hr class="dropdown-divider border-color-default my-1">
                                <button class="dropdown-item d-flex align-items-center gap-2 text-danger py-2"
                                        type="button" @onclick="HandleLogout"
                                        style="border-radius:var(--radius);border:none;background:transparent;width:100%;text-align:left;">
                                    <i class="fas fa-sign-out-alt fa-fw"></i> Cerrar Sesión
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </header>

        <main class="flex-grow-1 p-3 p-md-4">@Body</main>
    </div>
</div>

<!-- Modal Mis Turnos -->
@if (_showTurnosModal)
{
    <div class="modal-overlay" @onclick="CloseTurnosModal">
        <div class="modal-container fade-in" style="max-width:480px;" @onclick:stopPropagation>
            <div class="p-4 border-bottom border-color-default d-flex align-items-center justify-content-between" style="background:var(--card);">
                <div>
                    <h5 class="fw-bold text-foreground m-0 d-flex align-items-center gap-2">
                        <i class="fas fa-calendar-alt text-primary"></i> Mis Turnos de Trabajo
                    </h5>
                    <p class="text-muted-foreground small m-0">Horario asignado para esta semana</p>
                </div>
                <button class="btn btn-ghost p-1" @onclick="CloseTurnosModal" style="border-radius:50%;border:none;background:transparent;">
                    <i class="fas fa-times text-muted-foreground"></i>
                </button>
            </div>
            <div class="modal-body-scroll p-4">
                <div class="alert d-flex align-items-center gap-3 mb-4"
                     style="background:rgba(22,163,74,0.1);border:1px solid rgba(22,163,74,0.2);border-radius:var(--radius);">
                    <i class="fas fa-info-circle text-success fs-5"></i>
                    <div>
                        <span class="fw-bold text-success small d-block">Turno Activo</span>
                        <span class="text-muted-foreground" style="font-size:0.78rem;">Turno Mañana (Regular)</span>
                    </div>
                </div>
                <div class="d-flex flex-column gap-2">
                    <div class="d-flex align-items-center justify-content-between p-3 rounded border border-color-default" style="background:var(--card);">
                        <span class="fw-semibold text-foreground small">Lunes – Viernes</span>
                        <span class="badge bg-primary px-3 py-1" style="border-radius:var(--radius);font-size:0.8rem;">08:00 – 17:00</span>
                    </div>
                    <div class="d-flex align-items-center justify-content-between p-3 rounded border border-color-default" style="background:var(--card);">
                        <span class="fw-semibold text-foreground small">Sábado</span>
                        <span class="badge bg-secondary px-3 py-1" style="border-radius:var(--radius);font-size:0.8rem;">08:00 – 13:00</span>
                    </div>
                    <div class="d-flex align-items-center justify-content-between p-3 rounded border border-color-default" style="background:var(--muted);opacity:0.85;">
                        <span class="fw-semibold text-muted-foreground small">Domingo</span>
                        <span class="badge px-3 py-1" style="border-radius:var(--radius);background:#ffebee;color:#c62828;font-size:0.8rem;">Descanso</span>
                    </div>
                </div>
            </div>
            <div class="p-4 border-top border-color-default d-flex justify-content-end" style="background:var(--card);">
                <button class="btn btn-secondary" @onclick="CloseTurnosModal" style="border-radius:var(--radius);">Entendido</button>
            </div>
        </div>
    </div>
}

<style>
    .bg-sidebar-formal { background-color: #073a1e !important; color: #fff !important; }

    .sidebar-brand-container { padding: 1.75rem 1.5rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.08); }
    .sidebar-logo-box { width: 48px; height: 48px; background: rgba(255,255,255,0.08); border-radius: 0.75rem; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .sidebar-logo-icon { font-size: 1.35rem; color: #fff; }
    .sidebar-brand-title { font-family: 'Outfit', sans-serif; font-size: 1.35rem; font-weight: 700; color: #fff; margin: 0; line-height: 1.2; }
    .sidebar-brand-subtitle { font-size: 0.78rem; color: rgba(255,255,255,0.6); margin: 0; }

    .sidebar-nav-container { padding: 1.5rem 1.25rem; display: flex; flex-direction: column; gap: 0.5rem; }
    .sidebar-link-formal { display: flex; align-items: center; gap: 1rem; padding: 0.85rem 1.25rem; border-radius: 0.75rem; text-decoration: none; color: rgba(255,255,255,0.75); font-weight: 500; font-size: 0.95rem; transition: all 0.2s ease; }
    .sidebar-link-formal i { font-size: 1.1rem; width: 22px; text-align: center; }
    .sidebar-link-formal:hover { background-color: rgba(255,255,255,0.06); color: #fff; }
    .sidebar-link-formal.active { background-color: rgba(255,255,255,0.1) !important; color: #fff !important; font-weight: 600; }

    .sidebar-footer-container { padding: 1.5rem; border-top: 1px solid rgba(255,255,255,0.08); display: flex; flex-direction: column; gap: 1.25rem; }
    .sidebar-profile-info { display: flex; align-items: center; gap: 1rem; color: #fff; }
    .sidebar-profile-info i { font-size: 1.2rem; width: 22px; text-align: center; }
    .sidebar-profile-name { font-weight: 600; font-size: 0.9rem; margin: 0; color: #fff; }
    .sidebar-profile-role { font-size: 0.78rem; color: rgba(255,255,255,0.55); margin: 0; }
    .sidebar-logout-btn { display: flex; align-items: center; gap: 1rem; padding: 0.5rem 0; background: transparent; border: none; color: rgba(255,255,255,0.7); font-weight: 500; font-size: 0.9rem; width: 100%; transition: all 0.2s ease; }
    .sidebar-logout-btn:hover { color: #fff; }
    .sidebar-logout-btn i { font-size: 1.1rem; width: 22px; text-align: center; }

    .trabajador-content { padding-left: 300px; }

    @@media (max-width: 991.98px) {
        .trabajador-content { padding-left: 0 !important; }
    }
</style>
</RoleGate>

@code {
    private bool _isMobileSidebarOpen = false;
    private bool _isDropdownOpen = false;
    private bool _showTurnosModal = false;

    private void ToggleMobileSidebar() => _isMobileSidebarOpen = !_isMobileSidebarOpen;
    private void ToggleDropdown()      => _isDropdownOpen = !_isDropdownOpen;
    private void CloseDropdown()       => _isDropdownOpen = false;
    private void ShowTurnosModal()     { _showTurnosModal = true; _isDropdownOpen = false; }
    private void CloseTurnosModal()    => _showTurnosModal = false;

    private void HandleLogout()
    {
        Auth.Logout();
        Navigation.NavigateTo("/");
    }

    private bool IsActive(string href)
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
        var target   = href.TrimStart('/');
        if (string.IsNullOrEmpty(target))
            return string.IsNullOrEmpty(relative) || relative.Equals("trabajador", StringComparison.OrdinalIgnoreCase);
        return relative.StartsWith(target, StringComparison.OrdinalIgnoreCase);
    }

    private string HeaderTitle
    {
        get
        {
            var rel = Navigation.ToBaseRelativePath(Navigation.Uri).ToLower();
            if (rel.Contains("productos"))        return "Catálogo de Productos";
            if (rel.Contains("registrar-venta"))  return "Registrar Venta (POS)";
            if (rel.Contains("devoluciones"))      return "Mis Devoluciones";
            if (rel.Contains("perfil"))            return "Mi Perfil";
            return "Pedidos Clientes";
        }
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "T";
        var parts = name.Split(' ', System.StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][0].ToString().ToUpper();
        return (parts[0][0].ToString() + parts[parts.Length - 1][0].ToString()).ToUpper();
    }
}
