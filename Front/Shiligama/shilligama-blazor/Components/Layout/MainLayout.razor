@inherits LayoutComponentBase
@implements IDisposable
@inject CartService Cart
@inject AuthService Auth
@inject ProductService Product
@inject PromocionService PromoSvc
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<style>
    .dropdown-menu {
        background-color: var(--card) !important;
        border-color: var(--border) !important;
    }

    .dropdown-item {
        color: var(--foreground) !important;
        background-color: transparent;
        transition: background-color 0.15s;
    }

        .dropdown-item:hover,
        .dropdown-item:focus {
            background-color: var(--secondary) !important;
            color: var(--foreground) !important;
        }

        .dropdown-item:active {
            background-color: color-mix(in srgb, #1A6B3C 18%, transparent) !important;
            color: var(--foreground) !important;
        }

        .dropdown-item.text-danger:hover,
        .dropdown-item.text-danger:focus {
            background-color: color-mix(in srgb, var(--destructive) 12%, transparent) !important;
            color: var(--destructive) !important;
        }

        .dropdown-item.text-danger:active {
            background-color: color-mix(in srgb, var(--destructive) 20%, transparent) !important;
            color: var(--destructive) !important;
        }

    .dropdown-divider {
        border-color: var(--border) !important;
    }

    .search-results-dropdown {
        position: absolute;
        top: calc(100% + 4px);
        left: 0;
        right: 0;
        z-index: 1050;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: 0 8px 24px rgba(0,0,0,.12);
        max-height: 360px;
        overflow-y: auto;
    }

    .search-result-item {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: .55rem 1rem;
        cursor: pointer;
        transition: background-color .15s;
    }

    .search-result-item:hover {
        background-color: var(--secondary);
    }

    .search-result-item img {
        width: 38px;
        height: 38px;
        object-fit: cover;
        border-radius: 6px;
        flex-shrink: 0;
    }

    .search-result-name {
        font-size: .875rem;
        font-weight: 500;
        color: var(--foreground);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .search-result-price {
        font-size: .78rem;
        color: var(--primary);
        font-weight: 600;
    }

    .search-result-stock-out {
        font-size: .72rem;
        color: #ef4444;
        font-weight: 600;
        margin-left: auto;
        white-space: nowrap;
        flex-shrink: 0;
    }
</style>

<div class="d-flex flex-column min-vh-100 bg-background text-foreground" @onclick="CloseDropdowns">
    <!-- Navbar Header -->
    <header class="sticky-top z-3 w-100 border-bottom bg-card shadow-sm border-color-default" style="backdrop-filter: blur(8px); background-color: rgba(var(--bs-body-bg-rgb), 0.95);">
        <div class="container-xl px-3 px-sm-4">
            <div class="d-flex align-items-center justify-content-between gap-3" style="height: 64px;">

                <!-- Logo -->
                <a href="/catalogo" class="d-flex align-items-center gap-2 text-decoration-none shrink-0">
                    <div class="d-flex align-items-center justify-content-center rounded-circle bg-primary text-white" style="width: 40px; height: 40px;">
                        <Icons Name="ShoppingCart" Class="w-5 h-5" />
                    </div>
                    <span class="d-none d-sm-block text-xl font-bold text-foreground" style="font-size: 1.25rem;">
                        Shiligama
                    </span>
                </a>

                <!-- Search Bar - Desktop -->
                @if (ShouldShowSearchBar)
                {
                    <div class="d-none d-md-flex align-items-center flex-grow-1 mx-auto" style="max-width: 500px;">
                        <div class="position-relative w-100 d-flex align-items-center" @onclick:stopPropagation>
                            <i class="fa-solid fa-magnifying-glass text-muted-foreground position-absolute" style="left: 14px; top: 50%; transform: translateY(-50%); font-size: 0.95rem; pointer-events: none;"></i>
                            <input
                                type="search"
                                placeholder="Buscar productos..."
                                @bind="SearchQuery"
                                @bind:event="oninput"
                                @onkeypress="HandleSearchKeyPress"
                                class="form-control w-100 border-0 bg-muted text-foreground"
                                style="padding-left: 42px; height: 40px; background-color: var(--secondary) !important; border-radius: var(--radius);"
                            />
                            @if (_isSearchDropdownOpen && SearchResults.Any())
                            {
                                <div class="search-results-dropdown">
                                    @foreach (var p in SearchResults)
                                    {
                                        var promo     = PromoSvc.GetVigentes().FirstOrDefault(pr => pr.ProductoIds.Contains(p.Id));
                                        var efectivo  = PromocionHelper.PrecioEfectivo(p.Price, 1, promo);
                                        var tieneDesc = promo != null && efectivo < p.Price;
                                        <div class="search-result-item" @onclick="() => NavigateToProduct(p.Id)">
                                            <img src="@p.Image" alt="@p.Name"
                                                 onerror="this.src='https://placehold.co/38x38/e8f5e9/1A6B3C?text=🛒'" />
                                            <div style="overflow:hidden;flex:1;">
                                                <div class="search-result-name">@p.Name</div>
                                                <div style="display:flex;align-items:center;gap:4px;">
                                                    <span class="search-result-price">S/. @efectivo.ToString("0.00")</span>
                                                    @if (tieneDesc)
                                                    {
                                                        <span style="font-size:.72rem;color:var(--muted-foreground);text-decoration:line-through;">
                                                            S/. @p.Price.ToString("0.00")
                                                        </span>
                                                    }
                                                </div>
                                            </div>
                                            @if (p.Stock == 0)
                                            {
                                                <span class="search-result-stock-out">Agotado</span>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="flex-grow-1 d-none d-md-block"></div>
                }

                <!-- Nav links desktop -->
                <nav class="d-none d-lg-flex align-items-center gap-1">
                    <a href="/catalogo"
                       class="btn btn-ghost text-foreground d-flex align-items-center gap-1 px-3 py-2"
                       style="border-radius:var(--radius);font-weight:500;font-size:.9rem;">
                        <Icons Name="ShoppingCart" Class="w-4 h-4" style="color:#1A6B3C;" />
                        Catálogo
                    </a>
                    <a href="/ofertas"
                       class="btn btn-ghost text-foreground d-flex align-items-center gap-1 px-3 py-2"
                       style="border-radius:var(--radius);font-weight:500;font-size:.9rem;">
                        <Icons Name="Tag" Class="w-4 h-4" style="color:#1A6B3C;" />
                        Ofertas
                    </a>
                </nav>

                <!-- Right Actions -->
                <div class="d-flex align-items-center gap-2">

                    <!-- Mobile Search Trigger -->
                    @if (ShouldShowSearchBar)
                    {
                        <button type="button" @onclick="ToggleMobileSearch" @onclick:stopPropagation class="btn btn-ghost p-2 d-md-none text-foreground" style="border-radius: var(--radius);">
                            <Icons Name="Search" Class="w-5 h-5" />
                        </button>
                    }

                    <!-- Theme Switcher -->
                    <ThemeSelector />

                    <!-- Cart Link -->
                    <a href="/carrito" class="btn btn-secondary p-0 d-flex align-items-center justify-content-center border-0 shadow-sm position-relative" style="width: 40px; height: 40px; border-radius: var(--radius); background-color: var(--secondary);" title="Ver Carrito">
                        <i class="fa-solid fa-cart-shopping text-foreground" style="font-size: 1.1rem;"></i>
                        @if (Cart.GetCartCount() > 0)
                        {
                            <span class="position-absolute badge bg-primary rounded-circle d-flex align-items-center justify-content-center notification-badge" style="width: 24px; height: 24px; font-size: 0.7rem; font-weight: 700; top: -6px; right: -6px; padding: 0 4px; border: 2px solid var(--card);">
                                @(Cart.GetCartCount() > 99 ? "99+" : Cart.GetCartCount().ToString())
                            </span>
                        }
                    </a>

                    <!-- User Account Menu (Dropdown) -->
                    <div class="dropdown position-relative">
                        <button class="btn btn-secondary p-0 d-flex align-items-center justify-content-center border-0 shadow-sm" type="button" @onclick="ToggleUserDropdown" @onclick:stopPropagation style="width: 40px; height: 40px; border-radius: var(--radius); background-color: var(--secondary);" title="Menú de Usuario">
                            <i class="fa-solid fa-user text-foreground" style="font-size: 1.1rem;"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end card border shadow-lg p-2 @(_isUserDropdownOpen ? "show" : "")"
                            style="width: 240px; border-radius: var(--radius); position: absolute; right: 0; top: 100%; display: @(_isUserDropdownOpen ? "block" : "none"); margin-top: 8px; z-index: 1000;"
                            @onclick="CloseDropdowns" @onclick:stopPropagation>
                            @if (Auth.IsCliente())
                            {
                                <li class="px-3 py-2 border-bottom border-color-default mb-1">
                                    <p class="text-sm font-semibold text-foreground m-0">@(Auth.CurrentUser?.Name ?? "Cliente")</p>
                                    <p class="text-xs text-muted-foreground m-0 text-truncate">@(Auth.CurrentUser?.Email ?? "")</p>
                                </li>
                                <li>
                                    <a class="dropdown-item d-flex align-items-center text-foreground py-2" href="/mis-pedidos" style="border-radius: var(--radius);">
                                        <Icons Name="Package" Class="w-4 h-4 me-2 text-muted-foreground" />
                                        Mis Pedidos
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item d-flex align-items-center text-foreground py-2" href="/cliente/devoluciones" style="border-radius: var(--radius);">
                                        <Icons Name="RotateCcw" Class="w-4 h-4 me-2 text-muted-foreground" />
                                        Mis Devoluciones
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item d-flex align-items-center text-foreground py-2" href="/configuracion" style="border-radius: var(--radius);">
                                        <Icons Name="Settings" Class="w-4 h-4 me-2 text-muted-foreground" />
                                        Configuración
                                    </a>
                                </li>

                                <li><hr class="dropdown-divider border-color-default"></li>
                                <li>
                                    <button type="button" @onclick="HandleLogout" class="dropdown-item d-flex align-items-center text-danger py-2" style="border-radius: var(--radius);">
                                        <Icons Name="LogOut" Class="w-4 h-4 me-2" />
                                        Cerrar Sesión
                                    </button>
                                </li>
                            }
                            else
                            {
                                <li class="px-3 py-2 border-bottom border-color-default mb-1">
                                    <p class="text-sm text-muted-foreground m-0">No has iniciado sesión</p>
                                </li>
                                <li>
                                    <a class="dropdown-item d-flex align-items-center text-foreground py-2" href="/" style="border-radius: var(--radius);">
                                        <i class="fa-solid fa-right-to-bracket me-2 text-muted-foreground" style="width:16px;"></i>
                                        Iniciar Sesión
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>

                    <!-- Mobile Drawer Menu Trigger -->
                    <button type="button" @onclick="ToggleMobileMenu" class="btn btn-ghost p-2 d-lg-none text-foreground" style="border-radius: var(--radius);">
                        <Icons Name="Menu" Class="w-5 h-5" />
                    </button>

                </div>
            </div>
        </div>

        <!-- Mobile Search Dropdown Drawer -->
        @if (_isMobileSearchOpen && ShouldShowSearchBar)
        {
            <div class="d-md-none border-top bg-card p-3 shadow-inner border-color-default border-bottom">
                <div class="position-relative" @onclick:stopPropagation>
                    <Icons Name="Search" Class="position-absolute start-3 top-50 translate-middle-y w-5 h-5 text-muted-foreground" style="left: 14px;" />
                    <input
                        type="search"
                        placeholder="Buscar productos..."
                        @bind="SearchQuery"
                        @bind:event="oninput"
                        @onkeypress="HandleSearchKeyPress"
                        class="form-control pl-10 bg-muted"
                        style="padding-left: 42px; background-color: var(--secondary) !important;"
                        autofocus
                    />
                    @if (_isSearchDropdownOpen && SearchResults.Any())
                    {
                        <div class="search-results-dropdown">
                            @foreach (var p in SearchResults)
                            {
                                var promoM    = PromoSvc.GetVigentes().FirstOrDefault(pr => pr.ProductoIds.Contains(p.Id));
                                var efectivoM = PromocionHelper.PrecioEfectivo(p.Price, 1, promoM);
                                var tieneDescM = promoM != null && efectivoM < p.Price;
                                <div class="search-result-item" @onclick="() => NavigateToProduct(p.Id)">
                                    <img src="@p.Image" alt="@p.Name"
                                         onerror="this.src='https://placehold.co/38x38/e8f5e9/1A6B3C?text=🛒'" />
                                    <div style="overflow:hidden;flex:1;">
                                        <div class="search-result-name">@p.Name</div>
                                        <div style="display:flex;align-items:center;gap:4px;">
                                            <span class="search-result-price">S/. @efectivoM.ToString("0.00")</span>
                                            @if (tieneDescM)
                                            {
                                                <span style="font-size:.72rem;color:var(--muted-foreground);text-decoration:line-through;">
                                                    S/. @p.Price.ToString("0.00")
                                                </span>
                                            }
                                        </div>
                                    </div>
                                    @if (p.Stock == 0)
                                    {
                                        <span class="search-result-stock-out">Agotado</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </header>

    <!-- Mobile Navigation Drawer (Offcanvas style) -->
    @if (_isMobileMenuOpen)
    {
        <div class="sheet-backdrop" @onclick="ToggleMobileMenu"></div>
        <div class="sheet-panel show p-4 d-flex flex-column justify-between bg-card text-foreground" style="width: 280px; max-width: 85%;">
            <div>
                <div class="d-flex align-items-center justify-content-between pb-3 mb-3 border-bottom border-color-default">
                    <h5 class="m-0 font-bold">Menú</h5>
                    <button type="button" class="btn-close" @onclick="ToggleMobileMenu"></button>
                </div>
                <nav class="d-flex flex-column gap-2">
                    <a href="/catalogo" @onclick="ToggleMobileMenu" class="d-flex align-items-center gap-3 px-3 py-2.5 rounded text-decoration-none text-foreground hover:bg-muted" style="border-radius: var(--radius); font-weight: 500;">
                        <Icons Name="ShoppingCart" Class="w-5 h-5" style="color:#1A6B3C;" />
                        Catálogo
                    </a>
                    <a href="/ofertas" @onclick="ToggleMobileMenu" class="d-flex align-items-center gap-3 px-3 py-2.5 rounded text-decoration-none text-foreground hover:bg-muted" style="border-radius: var(--radius); font-weight: 500;">
                        <Icons Name="Calendar" Class="w-5 h-5" style="color:#1A6B3C;" />
                        Ofertas
                    </a>
                    <a href="/mis-pedidos" @onclick="ToggleMobileMenu" class="d-flex align-items-center gap-3 px-3 py-2.5 rounded text-decoration-none text-foreground hover:bg-muted" style="border-radius: var(--radius); font-weight: 500;">
                        <Icons Name="Package" Class="w-5 h-5" style="color:#1A6B3C;" />
                        Mis Pedidos
                    </a>
                    <a href="/cliente/devoluciones" @onclick="ToggleMobileMenu" class="d-flex align-items-center gap-3 px-3 py-2.5 rounded text-decoration-none text-foreground hover:bg-muted" style="border-radius: var(--radius); font-weight: 500;">
                        <Icons Name="RotateCcw" Class="w-5 h-5" style="color:#1A6B3C;" />
                        Mis Devoluciones
                    </a>
                    <a href="/configuracion" @onclick="ToggleMobileMenu" class="d-flex align-items-center gap-3 px-3 py-2.5 rounded text-decoration-none text-foreground hover:bg-muted" style="border-radius: var(--radius); font-weight: 500;">
                        <Icons Name="Settings" Class="w-5 h-5" style="color:#1A6B3C;" />
                        Configuración
                    </a>

                </nav>
            </div>

            <div class="pt-3 border-top border-color-default">
                <button type="button" @onclick="HandleLogout" class="btn btn-outline-danger w-100 d-flex align-items-center justify-content-center gap-2" style="border-radius: var(--radius);">
                    <Icons Name="LogOut" Class="w-4 h-4" />
                    Cerrar Sesión
                </button>
            </div>
        </div>
    }

    <!-- Main Content Body -->
    <main class="flex-grow-1">
        @Body
    </main>

    <!-- Scroll to Top Button -->
    <button type="button" class="scroll-to-top @(_showScrollToTop ? "" : "hidden")" @onclick="ScrollToTop" title="Volver arriba">
        <i class="fas fa-arrow-up"></i>
    </button>

    <!-- Footer -->
    <footer class="border-top bg-card py-4 mt-auto border-color-default">
        <div class="container-xl text-center">
            <p class="text-sm text-muted-foreground m-0">
                &copy; 2026 Shiligama. Todos los derechos reservados.
            </p>
        </div>
    </footer>
</div>

@code {
    private string SearchQuery
    {
        get => Product.SearchQuery;
        set
        {
            Product.NotifySearch(value);
            _isSearchDropdownOpen = !string.IsNullOrWhiteSpace(value);
        }
    }

    private bool _isMobileMenuOpen    = false;
    private bool _isMobileSearchOpen  = false;
    private bool _isUserDropdownOpen  = false;
    private bool _isSearchDropdownOpen = false;
    private bool _showScrollToTop = false;

    private bool ShouldShowSearchBar =>
        !new[] { "/checkout", "/configuracion", "/mis-pedidos", "/carrito" }
         .Any(path => Navigation.Uri.Contains(path, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<Product> SearchResults =>
        string.IsNullOrWhiteSpace(Product.SearchQuery)
            ? Enumerable.Empty<Product>()
            : Product.GetProducts()
                     .Where(p => p.Name.Contains(Product.SearchQuery, StringComparison.OrdinalIgnoreCase))
                     .Take(8);

    private void NavigateToProduct(int productId)
    {
        CloseDropdowns();
        Product.NotifySearch("");
        Navigation.NavigateTo($"/catalogo/{productId}");
    }

    private void CloseDropdowns()
    {
        _isUserDropdownOpen  = false;
        _isSearchDropdownOpen = false;
    }

    private void ToggleUserDropdown()
    {
        _isUserDropdownOpen = !_isUserDropdownOpen;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Cart.InitializeAsync();
            await Auth.InitializeAsync();
            Cart.OnChange += StateHasChanged;
            Auth.OnChange += StateHasChanged;
            Navigation.LocationChanged += OnLocationChanged;
            try
            {
                var dotNetRef = DotNetObjectReference.Create(this);
                await JSRuntime.InvokeVoidAsync("eval", $@"
                    window.__scrollDotNet = {dotNetRef};
                    window.__scrollHandler = function() {{
                        if (window.__scrollDotNet) {{
                            window.__scrollDotNet.invokeMethodAsync('HandleScroll');
                        }}
                    }};
                    window.addEventListener('scroll', window.__scrollHandler);
                ");
            }
            catch { }
            StateHasChanged();
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        Product.NotifySearch("");
        _isSearchDropdownOpen = false;
        InvokeAsync(StateHasChanged);
    }

    private void ToggleMobileMenu()
    {
        _isMobileMenuOpen = !_isMobileMenuOpen;
    }

    private void ToggleMobileSearch()
    {
        _isMobileSearchOpen = !_isMobileSearchOpen;
    }

    private void HandleSearchKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            if (!Navigation.Uri.Contains("/catalogo", StringComparison.OrdinalIgnoreCase))
            {
                Navigation.NavigateTo("/catalogo");
            }
            _isMobileSearchOpen   = false;
            _isSearchDropdownOpen = false;
        }
    }

    private void HandleLogout()
    {
        Auth.Logout();
        Navigation.NavigateTo("/");
    }

    private async Task ScrollToTop()
    {
        await JSRuntime.InvokeVoidAsync("eval", "window.scrollTo({ top: 0, behavior: 'smooth' })");
        _showScrollToTop = false;
    }

    private async Task OnScroll()
    {
        var scrollY = await JSRuntime.InvokeAsync<double>("eval", "window.scrollY");
        var newVal = scrollY > 300;
        if (newVal != _showScrollToTop)
        {
            _showScrollToTop = newVal;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task HandleScroll()
    {
        await OnScroll();
    }

    public void Dispose()
    {
        Cart.OnChange -= StateHasChanged;
        Auth.OnChange -= StateHasChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
