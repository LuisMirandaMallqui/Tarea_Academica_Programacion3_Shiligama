@inject AuthService Auth
@inject NavigationManager Navigation

@code {
    [Parameter] public EventCallback OnBackToLogin { get; set; }
    [Parameter] public string? ReturnUrl { get; set; }

    private string _nombres          = "";
    private string _apellidos        = "";
    private string _dni              = "";
    private string _email            = "";
    private string _password         = "";
    private string _confirmPassword  = "";
    private bool   _showPassword     = false;
    private bool   _showConfirm      = false;
    private string _error            = "";
    private bool   _isLoading        = false;

    private async Task HandleSubmit()
    {
        _error = "";

        if (string.IsNullOrWhiteSpace(_nombres))
            { _error = "El nombre es obligatorio"; return; }
        if (string.IsNullOrWhiteSpace(_apellidos))
            { _error = "Los apellidos son obligatorios"; return; }
        if (!System.Text.RegularExpressions.Regex.IsMatch(_dni.Trim(), @"^\d{8}$"))
            { _error = "El DNI debe tener exactamente 8 dígitos"; return; }
        if (_password.Length < 6)
            { _error = "La contraseña debe tener al menos 6 caracteres"; return; }
        if (_password != _confirmPassword)
            { _error = "Las contraseñas no coinciden"; return; }

        _isLoading = true;
        bool ok = await Auth.RegisterAsync(
            _nombres.Trim(), _apellidos.Trim(), _dni.Trim(), _email.Trim(), _password);

        if (ok)
            Navigation.NavigateTo(GetSafeReturnUrl() ?? "/catalogo");
        else
        {
            _error = "No se pudo crear la cuenta. Verifica los datos o intenta con otro correo/DNI.";
            _isLoading = false;
        }
    }

    private string? GetSafeReturnUrl()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl)) return null;
        if (!ReturnUrl.StartsWith('/') || ReturnUrl.StartsWith("//")) return null;
        return ReturnUrl;
    }
}

<div class="d-flex flex-column gap-4">

    <!-- Logo móvil -->
    <div class="d-flex d-lg-none align-items-center gap-3">
        <div class="d-flex align-items-center justify-content-center rounded-3 bg-primary text-white"
             style="width:40px;height:40px;">
            <Icons Name="ShoppingCart" Class="w-6 h-6" />
        </div>
        <div>
            <h1 class="fs-4 fw-bold text-foreground m-0" style="font-family:'Outfit',sans-serif;">Shiligama</h1>
            <p class="text-muted-foreground small m-0">Sistema de Gestión</p>
        </div>
    </div>

    <!-- Cabecera -->
    <div>
        <h2 class="fs-4 fw-semibold text-foreground m-0">Crear cuenta</h2>
        <p class="text-muted-foreground mt-1 mb-0">Únete a Shiligama y empieza a comprar</p>
    </div>

    <EditForm Model="this" OnValidSubmit="HandleSubmit" class="d-flex flex-column gap-3">

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="p-3 rounded-3 small text-danger"
                 style="background:color-mix(in srgb,var(--destructive) 10%,transparent);
                        border:1px solid color-mix(in srgb,var(--destructive) 20%,transparent);">
                <i class="fa-solid fa-circle-exclamation me-1"></i>@_error
            </div>
        }

        <!-- Nombres + Apellidos -->
        <div class="row g-2">
            <div class="col-6">
                <label class="form-label fw-medium text-foreground small mb-1">Nombres</label>
                <input type="text" @bind="_nombres" required
                       class="form-control text-foreground"
                       style="height:48px;" placeholder="Juan" />
            </div>
            <div class="col-6">
                <label class="form-label fw-medium text-foreground small mb-1">Apellidos</label>
                <input type="text" @bind="_apellidos" required
                       class="form-control text-foreground"
                       style="height:48px;" placeholder="Pérez García" />
            </div>
        </div>

        <!-- DNI -->
        <div>
            <label class="form-label fw-medium text-foreground small">DNI</label>
            <div class="position-relative">
                <i class="fas fa-id-card position-absolute top-50 translate-middle-y text-muted-foreground"
                   style="left:14px;font-size:0.95rem;"></i>
                <input type="text" @bind="_dni" required maxlength="8" pattern="\d{8}"
                       class="form-control text-foreground"
                       style="height:48px;padding-left:42px;" placeholder="12345678" />
            </div>
        </div>

        <!-- Separador entre datos personales y datos de acceso -->
        <div class="d-flex align-items-center gap-2 my-1">
            <hr class="flex-grow-1 m-0" style="border-color:var(--border);" />
            <span class="text-muted-foreground fw-medium" style="font-size:0.75rem;white-space:nowrap;">
                Datos de acceso
            </span>
            <hr class="flex-grow-1 m-0" style="border-color:var(--border);" />
        </div>

        <!-- Correo -->
        <div>
            <label class="form-label fw-medium text-foreground small">Correo electrónico</label>
            <div class="position-relative">
                <i class="fas fa-envelope position-absolute top-50 translate-middle-y text-muted-foreground"
                   style="left:14px;font-size:0.95rem;"></i>
                <input type="email" @bind="_email" required
                       class="form-control text-foreground"
                       style="height:48px;padding-left:42px;" placeholder="tu@correo.com" />
            </div>
        </div>

        <!-- Contraseña -->
        <div>
            <label class="form-label fw-medium text-foreground small">Contraseña</label>
            <div class="position-relative">
                <i class="fas fa-lock position-absolute top-50 translate-middle-y text-muted-foreground"
                   style="left:14px;font-size:0.95rem;"></i>
                <input type="@(_showPassword ? "text" : "password")" @bind="_password" required
                       class="form-control text-foreground"
                       style="height:48px;padding-left:42px;padding-right:44px;"
                       placeholder="Mínimo 6 caracteres" />
                <button type="button" @onclick="@(() => _showPassword = !_showPassword)"
                        class="btn btn-link position-absolute top-50 translate-middle-y border-0 p-0 text-muted-foreground"
                        style="right:14px;">
                    <i class="fas @(_showPassword ? "fa-eye-slash" : "fa-eye")"></i>
                </button>
            </div>
        </div>

        <!-- Confirmar contraseña -->
        <div>
            <label class="form-label fw-medium text-foreground small">Confirmar contraseña</label>
            <div class="position-relative">
                <i class="fas fa-lock position-absolute top-50 translate-middle-y text-muted-foreground"
                   style="left:14px;font-size:0.95rem;"></i>
                <input type="@(_showConfirm ? "text" : "password")" @bind="_confirmPassword" required
                       class="form-control text-foreground"
                       style="height:48px;padding-left:42px;padding-right:44px;"
                       placeholder="Repite tu contraseña" />
                <button type="button" @onclick="@(() => _showConfirm = !_showConfirm)"
                        class="btn btn-link position-absolute top-50 translate-middle-y border-0 p-0 text-muted-foreground"
                        style="right:14px;">
                    <i class="fas @(_showConfirm ? "fa-eye-slash" : "fa-eye")"></i>
                </button>
            </div>
        </div>

        <button type="submit" disabled="@_isLoading"
                class="btn btn-primary w-100 fw-medium fs-6 d-flex align-items-center justify-content-center gap-2"
                style="height:48px;">
            @if (_isLoading)
            {
                <span class="spinner-border spinner-border-sm"></span>
                <span>Creando cuenta…</span>
            }
            else
            {
                <span>Crear cuenta</span>
            }
        </button>

    </EditForm>

    <p class="text-center text-muted-foreground small m-0">
        ¿Ya tienes una cuenta?&nbsp;
        <button type="button" @onclick="OnBackToLogin"
                class="btn btn-link p-0 fw-medium text-primary text-decoration-none small">
            Inicia sesión
        </button>
    </p>
</div>
