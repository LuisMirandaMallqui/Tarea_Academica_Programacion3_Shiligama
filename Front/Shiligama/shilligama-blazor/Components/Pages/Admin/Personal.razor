@page "/admin/personal"
@layout AdminLayout
@implements IDisposable
@inject StaffService StaffSvc
@inject AuthService Auth
@inject IJSRuntime JS
@using Microsoft.JSInterop

<PageTitle>Personal – Shiligama Admin</PageTitle>

<style>
    @@keyframes cartTrip {
        0%   { transform: translateX(-120px);                        opacity: 0; }
        12%  { transform: translateX(-30px)  translateY(0);         opacity: 1; }
        25%  { transform: translateX(20px)   translateY(-18px)   rotate(90deg); }
        40%  { transform: translateX(0)      translateY(-38px)   rotate(180deg); }
        55%  { transform: translateX(-20px)  translateY(-18px)   rotate(270deg); }
        68%  { transform: translateX(30px)   translateY(0)       rotate(360deg); }
        85%  { transform: translateX(120px);                        opacity: 0; }
        100% { transform: translateX(120px);                        opacity: 0; }
    }
</style>

<div class="d-flex flex-column gap-4">

    <!-- ── Encabezado ── -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h1 class="fs-4 fw-bold text-foreground mb-0">Gestión de Personal</h1>
            <p class="text-muted-foreground small mt-1 mb-0">Administra los accesos y roles del staff de trabajadores</p>
        </div>
        <button @onclick="OpenCreate" class="btn btn-primary d-flex align-items-center gap-2 fw-semibold" style="border-radius:var(--radius);">
            <i class="fas fa-plus"></i> Registrar Trabajador
        </button>
    </div>

    <!-- ── KPI ── -->
    <div class="row g-3">
        <div class="col-md-4">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value text-foreground">@_staff.Count</div><div class="metric-kpi-label">Total Personal</div></div>
                <div class="metric-kpi-icon" style="background:color-mix(in srgb,var(--primary) 15%,transparent);color:var(--primary);"><i class="fas fa-users"></i></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value" style="color:#2e7d32;">@_staff.Count(s => s.Estado == "activo")</div><div class="metric-kpi-label">Activos</div></div>
                <div class="metric-kpi-icon" style="background:color-mix(in srgb,#2e7d32 15%,transparent);color:#2e7d32;"><i class="fas fa-user-check"></i></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value text-foreground">@_staff.Select(s => s.Rol).Distinct().Count()</div><div class="metric-kpi-label">Roles</div></div>
                <div class="metric-kpi-icon" style="background:color-mix(in srgb,#7C3AED 15%,transparent);color:#7C3AED;"><i class="fas fa-id-badge"></i></div>
            </div>
        </div>
    </div>

    <!-- ── Filtros ── -->
    <div class="card p-4" style="border-radius:12px;">
        <div class="row g-2 align-items-center">
            <div class="col-md-5">
                <div class="position-relative">
                    <i class="fa-solid fa-magnifying-glass position-absolute top-50 translate-middle-y text-muted" style="left:16px;font-size:14px;"></i>
                    <input type="search" @bind="_search" @bind:event="oninput"
                           class="form-control text-foreground" placeholder="Buscar por nombre, DNI o correo..."
                           style="height:56px;border-radius:10px;padding-left:42px;" />
                </div>
            </div>
            <div class="col-md-4">
                <select @bind="_roleFilter" class="form-select text-foreground" style="height:56px;border-radius:10px;">
                    <option value="">Todos los roles</option>
                    <option value="administrador">Administradores</option>
                    <option value="trabajador">Trabajadores</option>
                </select>
            </div>
            <div class="col-md-3">
                <select @bind="_estadoFilter" class="form-select text-foreground" style="height:56px;border-radius:10px;">
                    <option value="">Todos los estados</option>
                    <option value="activo">Activos</option>
                    <option value="inactivo">Inactivos</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Tabla -->
    <div class="card overflow-hidden">

        @if (_loading)
        {
            <div class="d-flex flex-column align-items-center justify-content-center py-5"
                 style="min-height:350px;">

                <div style="font-size:4rem;
                    color:#1A6B3C;
                    animation:cartTrip 3.5s ease-in-out infinite;">
                    <i class="fas fa-shopping-cart"></i>
                </div>

                <div class="mt-3"
                     style="color:#1A6B3C;font-weight:600;">
                    Cargando personal...
                </div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-borderless mb-0 align-middle">
                    <thead class="border-bottom border-color-default">
                        <tr>
                            <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Trabajador</th>
                            <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Rol</th>
                            <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase d-none d-md-table-cell" style="letter-spacing:.05em;">DNI</th>
                            <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase d-none d-md-table-cell" style="letter-spacing:.05em;">Fecha Ingreso</th>
                            <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Estado</th>
                            <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-end" style="letter-spacing:.05em;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Filtered)
                        {
                            var esMiPerfil = Auth.CurrentUser?.Id.ToString() == s.Id;
                            <tr class="border-bottom border-color-default">
                                <td class="px-4 py-3 d-flex align-items-center gap-3">
                                    <img src="@s.Avatar" alt="@s.Nombre"
                                         class="rounded-circle flex-shrink-0 object-fit-cover"
                                         style="width:40px;height:40px;"
                                         onerror="this.src='https://placehold.co/40/e0e0e0/555?text=U'" />
                                    <div>
                                        <span class="fw-semibold text-foreground d-block small">
                                            @s.Nombre
                                            @if (esMiPerfil)
                                            {
                                                <span class="badge bg-primary ms-1" style="font-size:.6rem;">Tú</span>
                                            }
                                        </span>
                                        <span class="text-xs text-muted-foreground">@s.Correo</span>
                                    </div>
                                </td>
                                <td class="px-4 py-3 small">
                                    <span class="badge @(s.Rol == "administrador" ? "bg-primary-subtle text-primary" : "bg-secondary text-muted-foreground")" style="border-radius:var(--radius);">
                                        @s.Rol
                                    </span>
                                </td>
                                <td class="px-4 py-3 text-muted-foreground small d-none d-md-table-cell">@s.Dni</td>
                                <td class="px-4 py-3 text-muted-foreground small d-none d-md-table-cell">@s.FechaIngreso.ToString("dd MMM yyyy")</td>
                                <td class="px-4 py-3">
                                    <span class="badge @(s.Estado == "activo" ? "bg-success" : "bg-danger") px-2 py-1" style="border-radius:var(--radius);">
                                        @s.Estado
                                    </span>
                                </td>
                                <td class="px-4 py-3 text-end">
                                    <div class="d-flex align-items-center justify-content-end gap-2">
                                        <button @onclick="@(() => OpenEdit(s))" class="btn btn-sm btn-light text-muted @(esMiPerfil ? "opacity-50" : "")" style="border-radius:var(--radius);" title="@(esMiPerfil ? "No puedes editar tu propio perfil aquí" : "Editar")" disabled="@esMiPerfil">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </button>
                                        <button @onclick="@(() => AskToggleEstado(s))"
                                                class="btn btn-sm btn-light @(esMiPerfil ? "opacity-50" : (s.Estado == "activo" ? "text-warning" : "text-success"))"
                                                style="border-radius:var(--radius);" title="@(esMiPerfil ? "No puedes desactivar tu propio perfil" : (s.Estado == "activo" ? "Suspender" : "Activar"))" disabled="@esMiPerfil">
                                            <i class="fa-solid @(s.Estado == "activo" ? "fa-eye-slash" : "fa-eye")"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Filtered.Any())
                        {
                            <tr><td colspan="6" class="text-center py-5 text-muted-foreground">No se encontraron miembros del personal</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>

    
</div>

<!-- ── Modal: Confirmar toggle estado ── -->
@if (_showToggleConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45);z-index:1060;" @onclick="@(() => _showToggleConfirm = false)">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;" @onclick:stopPropagation>
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">@(_toggleStaff?.Estado == "activo" ? "🔒" : "🔓")</div>
                    <h5 class="fw-bold text-foreground mb-1">¿@(_toggleStaff?.Estado == "activo" ? "Suspender" : "Activar") miembro?</h5>
                    <p class="text-muted-foreground small mb-4">
                        <strong>@_toggleStaff?.Nombre</strong> quedará @(_toggleStaff?.Estado == "activo" ? "suspendido sin acceso al sistema" : "activo con acceso al sistema").
                    </p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="@(() => _showToggleConfirm = false)">Cancelar</button>
                        <button class="btn @(_toggleStaff?.Estado == "activo" ? "btn-warning" : "btn-success")" style="border-radius:var(--radius);" @onclick="ConfirmToggleEstado">Confirmar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- ── Modal: Confirmar guardar ── -->
@if (_showSaveConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.55);z-index:1060;" @onclick="@(() => _showSaveConfirm = false)">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;" @onclick:stopPropagation>
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">💾</div>
                    <h5 class="fw-bold text-foreground mb-1">¿@(_isEditing ? "Actualizar" : "Registrar") trabajador?</h5>
                    <p class="text-muted-foreground small mb-4">Se @(_isEditing ? "actualizarán los datos de" : "registrará a") <strong>@_form.Nombre</strong>.</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="@(() => _showSaveConfirm = false)">Cancelar</button>
                        <button class="btn btn-primary" style="border-radius:var(--radius);" @onclick="Save">Guardar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- ── Modal: Salir sin guardar ── -->
@if (_showUnsavedConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45);z-index:1070;" @onclick="@(() => _showUnsavedConfirm = false)">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;" @onclick:stopPropagation>
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">⚠️</div>
                    <h5 class="fw-bold text-foreground mb-1">¿Salir sin guardar?</h5>
                    <p class="text-muted-foreground small mb-4">Los cambios se perderán.</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="@(() => _showUnsavedConfirm = false)">Seguir editando</button>
                        <button class="btn btn-danger" style="border-radius:var(--radius);" @onclick="ForceCloseModal">Salir sin guardar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- ── Modal: Crear / Editar miembro ── -->
@if (_showModal)
{
    <div class="modal show d-block fade-in" tabindex="-1" style="background:rgba(0,0,0,.5);" @onclick="TryCloseModal">
        <div class="modal-dialog modal-dialog-centered modal-lg" @onclick:stopPropagation>
            <div class="modal-content bg-card border-border">
                <div class="modal-header border-border">
                    <h5 class="modal-title text-foreground fw-bold">@(_isEditing ? "Editar Miembro del Staff" : "Registrar Miembro")</h5>
                    <button type="button" class="btn-close" @onclick="TryCloseModal"></button>
                </div>
                <div class="modal-body p-4">
                    @if (!string.IsNullOrEmpty(_formError))
                    { <div class="alert alert-danger py-2 small mb-3">@_formError</div> }
                    <div class="row g-3">

                        <!-- Nombre: solo letras -->
                        <div class="col-md-6">
                            <label class="form-label small fw-medium text-foreground">Nombres * <span class="text-muted-foreground fw-normal">(solo letras)</span></label>
                            <input type="text"
                                   value="@_form.Nombres"
                                   @oninput="OnNombresInput"
                                   onkeypress="return /[a-zA-ZáéíóúÁÉÍÓÚñÑ\s]/.test(event.key)"
                                   class="form-control text-foreground @(_submitted && string.IsNullOrWhiteSpace(_form.Nombres) ? "is-invalid" : "")"
                                   placeholder="Marcos" />
                            @if (_submitted && string.IsNullOrWhiteSpace(_form.Nombres))
                            { <div class="invalid-feedback">El nombre es obligatorio.</div> }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium text-foreground">Apellidos * <span class="text-muted-foreground fw-normal">(solo letras)</span></label>
                            <input type="text"
                                   value="@_form.Apellidos"
                                   @oninput="OnApellidosInput"
                                   onkeypress="return /[a-zA-ZáéíóúÁÉÍÓÚñÑ\s]/.test(event.key)"
                                   class="form-control text-foreground @(_submitted && string.IsNullOrWhiteSpace(_form.Apellidos) ? "is-invalid" : "")"
                                   placeholder="Díaz García" />
                            @if (_submitted && string.IsNullOrWhiteSpace(_form.Apellidos))
                            { <div class="invalid-feedback">Los apellidos son obligatorios.</div> }
                        </div>

                        <!-- DNI: solo dígitos, 8 -->
                        <div class="col-md-6">
                            <label class="form-label small fw-medium text-foreground">DNI * <span class="text-muted-foreground fw-normal">(8 dígitos)</span></label>
                            <input type="text"
                                   step=".01"
                                   min="0"
                                   value="@_form.Dni"
                                   @oninput="OnDniInput"
                                   onkeypress="return /[0-9]/.test(event.key)"
                                   inputmode="numeric"
                                   maxlength="8"
                                   class="form-control text-foreground @(_submitted && _form.Dni.Length != 8 ? "is-invalid" : "")"
                                   placeholder="45632178" />
                            @if (_submitted && _form.Dni.Length != 8)
                            { <div class="invalid-feedback">El DNI debe tener exactamente 8 dígitos numéricos.</div> }
                        </div>

                        <!-- Teléfono: solo dígitos, 9 -->
                        <div class="col-md-6">
                            <label class="form-label small fw-medium text-foreground">Teléfono * <span class="text-muted-foreground fw-normal">(9 dígitos)</span></label>
                            <input type="text"
                                   step=".01"
                                   min="0"
                                   value="@_form.Telefono"
                                   @oninput="OnTelefonoInput"
                                   onkeypress="return /[0-9]/.test(event.key)"
                                   inputmode="numeric"
                                   maxlength="9"
                                   class="form-control text-foreground @(_submitted && _form.Telefono.Length != 9 ? "is-invalid" : "")"
                                   placeholder="963852741" />
                            @if (_submitted && _form.Telefono.Length != 9)
                            { <div class="invalid-feedback">Debe tener exactamente 9 dígitos.</div> }
                        </div>

                        <!-- Correo -->
                        <div class="col-12">
                            <label class="form-label small fw-medium text-foreground">Correo electrónico *</label>
                            <input type="email"
                                   value="@_form.Correo"
                                   @oninput="@(e => { _form.Correo = e.Value?.ToString() ?? ""; _formDirty = true; })"
                                   class="form-control text-foreground @(_submitted && !EsCorreoValido(_form.Correo) ? "is-invalid" : "")"
                                   placeholder="marcos@shiligama.com" />
                            @if (_submitted && !EsCorreoValido(_form.Correo))
                            { <div class="invalid-feedback">Ingresa un correo válido (debe contener @@ y un dominio).</div> }
                        </div>

                        <!-- Rol y Turno -->
                        <div class="col-md-6">
                            <label class="form-label small fw-medium text-foreground">Rol</label>
                            @if (_isEditingSelf)
                            {
                                <input type="text" value="@_form.Rol" disabled class="form-control text-muted-foreground" />
                                <div class="form-text text-muted-foreground small"><i class="fas fa-lock me-1"></i>No puedes cambiar tu propio rol.</div>
                            }
                            else
                            {
                                <select value="@_form.Rol"
                                        @onchange="@(e => { _form.Rol = e.Value?.ToString() ?? "trabajador"; _formDirty = true; })"
                                        class="form-select text-foreground">
                                    <option value="trabajador">Trabajador</option>
                                    <option value="administrador">Administrador</option>
                                </select>
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium text-foreground">Turno</label>
                            <select value="@_form.Turno"
                                    @onchange="@(e => { _form.Turno = e.Value?.ToString() ?? "tiempo-completo"; _formDirty = true; })"
                                    class="form-select text-foreground">
                                <option value="tiempo-completo">Tiempo completo</option>
                                <option value="mañana">Mañana (6am – 2pm)</option>
                                <option value="tarde">Tarde (2pm – 10pm)</option>
                                <option value="noche">Noche (10pm – 6am)</option>
                            </select>
                        </div>

                        <!-- Estado -->
                        <div class="col-md-6">
                            <label class="form-label small fw-medium text-foreground">Estado</label>
                            <select value="@_form.Estado"
                                    @onchange="@(e => { _form.Estado = e.Value?.ToString() ?? "activo"; _formDirty = true; })"
                                    class="form-select text-foreground">
                                <option value="activo">Activo</option>
                                <option value="inactivo">Inactivo</option>
                            </select>
                        </div>

                        <!-- Avatar -->
                        <div class="col-12">
                            <label class="form-label small fw-medium text-foreground">Avatar</label>
                            @if (!string.IsNullOrEmpty(_form.Avatar))
                            {
                                <div class="mb-2">
                                    <img src="@_form.Avatar" alt="Avatar" class="rounded-circle object-fit-cover border" style="width:60px;height:60px;"
                                         onerror="this.style.display='none'" />
                                </div>
                            }
                            <div class="mb-2">
                                <label class="form-label small text-muted-foreground mb-1">Subir imagen (JPG / PNG / WebP, máx. 5 MB)</label>
                                <input type="file" id="avatarImageInput"
                                       accept="image/jpeg,image/png,image/gif,image/webp"
                                       class="form-control text-foreground"
                                       disabled="@_uploadingAvatar"
                                       @onchange="HandleAvatarSelected" />
                                @if (_uploadingAvatar) { <div class="small text-muted-foreground mt-1"><span class="spinner-border spinner-border-sm me-1"></span>Subiendo…</div> }
                                @if (!string.IsNullOrEmpty(_uploadError)) { <div class="small text-danger mt-1">@_uploadError</div> }
                            </div>
                            <div>
                                <label class="form-label small text-muted-foreground mb-1">O ingresar URL directamente (opcional)</label>
                                <input type="url"
                                       value="@_form.Avatar"
                                       @oninput="@(e => { _form.Avatar = e.Value?.ToString() ?? ""; _formDirty = true; })"
                                       class="form-control text-foreground" placeholder="https://..." />
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" @onclick="TryCloseModal" class="btn btn-secondary" style="border-radius:var(--radius);">Cancelar</button>
                        <button type="button" @onclick="AskSave" class="btn btn-primary fw-semibold" style="border-radius:var(--radius);">
                            @(_isEditing ? "Guardar cambios" : "Registrar")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- ── Toast éxito ── -->
@if (_showSavedToast)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
        <div class="toast show text-white border-0 px-3 py-2" style="background:#1A6B3C;border-radius:var(--radius);min-width:260px;">
            <i class="fa-solid fa-circle-check me-2"></i>
            <span class="small">Miembro @(_isEditing ? "actualizado" : "registrado") correctamente</span>
        </div>
    </div>
}

@code {
    private bool _loading = true;

    private List<Staff> _staff = new();
    private string _search       = "";
    private string _roleFilter   = "";
    private string _estadoFilter = "";

    private bool  _showModal          = false;
    private bool  _isEditing          = false;
    private bool  _isEditingSelf      = false;
    private bool  _formDirty          = false;
    private bool  _submitted          = false;
    private Staff _form               = new();
    private string _formError         = "";

    private bool   _showSaveConfirm    = false;
    private bool   _showUnsavedConfirm = false;
    private bool   _showToggleConfirm  = false;
    private bool   _showSavedToast     = false;
    private Staff? _toggleStaff        = null;

    private bool   _uploadingAvatar = false;
    private string _uploadError     = "";
    private DotNetObjectReference<Personal>? _avatarUploadRef;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _avatarUploadRef = DotNetObjectReference.Create(this);

        await StaffSvc.EnsureLoadedAsync();
        _staff = StaffSvc.GetStaff();

        _loading = false;
    }

    public void Dispose() => _avatarUploadRef?.Dispose();

    private IEnumerable<Staff> Filtered => _staff.Where(s =>
        (string.IsNullOrEmpty(_search) ||
         s.Nombre.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
         s.Dni.Contains(_search) ||
         s.Correo.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_roleFilter)   || s.Rol.Equals(_roleFilter, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_estadoFilter) || s.Estado.Equals(_estadoFilter, StringComparison.OrdinalIgnoreCase))
    );

    // ── Validaciones de input ─────────────────────────────────────────────────
    private void OnNombresInput(ChangeEventArgs e)
    {
        _form.Nombres = new string(
            (e.Value?.ToString() ?? "").Where(c => char.IsLetter(c) || char.IsWhiteSpace(c)).ToArray()
        );
        _formDirty = true;
    }

    private void OnApellidosInput(ChangeEventArgs e)
    {
        _form.Apellidos = new string(
            (e.Value?.ToString() ?? "").Where(c => char.IsLetter(c) || char.IsWhiteSpace(c)).ToArray()
        );
        _formDirty = true;
    }

    // Solo dígitos, máx 8
    private void OnDniInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";

        _form.Dni = new string(
            value.Where(char.IsDigit).Take(8).ToArray()
        );

        _formDirty = true;
    }

    // Solo dígitos, máx 9
    private void OnTelefonoInput(ChangeEventArgs e)
    {
        _form.Telefono = new string((e.Value?.ToString() ?? "").Where(char.IsDigit).Take(9).ToArray());
        _formDirty = true;
    }

    private bool EsCorreoValido(string c) =>
        !string.IsNullOrWhiteSpace(c) && c.Contains('@') && c.LastIndexOf('.') > c.IndexOf('@');

    private bool FormValido() =>
        !string.IsNullOrWhiteSpace(_form.Nombres) &&
        !string.IsNullOrWhiteSpace(_form.Apellidos) &&
        _form.Dni.Length == 8 &&
        _form.Telefono.Length == 9 &&
        EsCorreoValido(_form.Correo);

    private bool EsDuplicado() => _staff.Any(s =>
        s.Id != _form.Id &&
        (s.Dni == _form.Dni ||
         s.Correo.Equals(_form.Correo, StringComparison.OrdinalIgnoreCase) ||
         s.Telefono == _form.Telefono));

    private void OpenCreate()
    {
        _form = new Staff();
        _isEditing = false; _isEditingSelf = false; _formDirty = false; _submitted = false; _formError = "";
        _showModal = true;
    }

    private void OpenEdit(Staff s)
    {
        _form = new Staff
        {
            Id = s.Id, Nombres = s.Nombres, Apellidos = s.Apellidos, Dni = s.Dni, Rol = s.Rol,
            Telefono = s.Telefono, Correo = s.Correo, Avatar = s.Avatar,
            FechaIngreso = s.FechaIngreso, Estado = s.Estado, Turno = s.Turno
        };
        _isEditingSelf = Auth.CurrentUser?.Id.ToString() == s.Id;
        _isEditing = true; _formDirty = false; _submitted = false; _formError = "";
        _showModal = true;
    }

    private void TryCloseModal()  { if (_formDirty) _showUnsavedConfirm = true; else ForceCloseModal(); }
    private void ForceCloseModal(){ _showUnsavedConfirm = false; _showModal = false; }

    private void AskSave()
    {
        _submitted = true; _formError = "";
        if (!FormValido()) return;
        if (EsDuplicado()) { _formError = "Ya existe un miembro con el mismo DNI, correo o teléfono."; return; }
        _showSaveConfirm = true;
    }


    private async Task Save()
    {
        _showSaveConfirm = false;
        if (_isEditing) await StaffSvc.UpdateStaffAsync(_form);
        else            await StaffSvc.AddStaffAsync(_form);
        _showModal = false; _formDirty = false;
        _staff = StaffSvc.GetStaff();
        _showSavedToast = true; StateHasChanged();
        await Task.Delay(3000); _showSavedToast = false; StateHasChanged();
    }

    private void AskToggleEstado(Staff s) { _toggleStaff = s; _showToggleConfirm = true; }
    private void ConfirmToggleEstado()
    {
        if (_toggleStaff != null) StaffSvc.ToggleStatus(_toggleStaff.Id);
        _showToggleConfirm = false;
        _staff = StaffSvc.GetStaff();
        StateHasChanged();
    }

    private async Task HandleAvatarSelected(ChangeEventArgs _)
    {
        _uploadError = "";
        _uploadingAvatar = true;
        try
        {
            await JS.InvokeVoidAsync(
                "shiligamaStartUpload", _avatarUploadRef, "avatarImageInput", "/api/img-upload");
        }
        catch (Exception ex)
        {
            _uploadingAvatar = false;
            _uploadError = ex.Message;
        }
    }

    [JSInvokable]
    public async Task OnUploadComplete(string? url, string? error)
    {
        await InvokeAsync(() =>
        {
            _uploadingAvatar = false;
            if (!string.IsNullOrEmpty(url))
            {
                _form.Avatar = url;
                _formDirty   = true;
                _uploadError = "";
            }
            else
            {
                _uploadError = error ?? "Error desconocido al subir imagen.";
            }
            StateHasChanged();
        });
    }
}
