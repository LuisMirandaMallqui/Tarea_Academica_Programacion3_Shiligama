@page "/admin/personal"
@layout AdminLayout
@inject StaffService StaffSvc
@inject AuthService Auth

<PageTitle>Personal – Shiligama Admin</PageTitle>

<div class="d-flex flex-column gap-4">
    <!-- Header -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h1 class="fs-4 fw-bold text-foreground mb-0">
                <i class="fas fa-users me-2 text-primary"></i>Gestión de Personal
            </h1>
            <p class="text-muted-foreground small mt-1 mb-0">Administra los accesos y roles del staff de trabajadores</p>
        </div>
        <button @onclick="OpenCreate" class="btn btn-primary d-flex align-items-center gap-2 fw-semibold" style="border-radius: var(--radius);">
            <i class="fas fa-plus"></i> Registrar Trabajador
        </button>
    </div>

    <!-- KPI Cards -->
    <div class="row g-3">
        <div class="col-md-4">
            <div class="metric-card-kpi">
                <div>
                    <div class="metric-kpi-value text-foreground">@_staff.Count</div>
                    <div class="metric-kpi-label">Total Personal</div>
                </div>
                <div class="metric-kpi-icon" style="background:color-mix(in srgb,var(--primary) 15%,transparent);color:var(--primary);">
                    <i class="fas fa-users"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-card-kpi">
                <div>
                    <div class="metric-kpi-value" style="color:#2e7d32;">@_staff.Count(s => s.Estado == "activo")</div>
                    <div class="metric-kpi-label">Miembros Activos</div>
                </div>
                <div class="metric-kpi-icon" style="background:color-mix(in srgb,#2e7d32 15%,transparent);color:#2e7d32;">
                    <i class="fas fa-user-check"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-card-kpi">
                <div>
                    <div class="metric-kpi-value text-foreground">@_staff.Select(s => s.Rol).Distinct().Count()</div>
                    <div class="metric-kpi-label">Roles Configurados</div>
                </div>
                <div class="metric-kpi-icon" style="background:color-mix(in srgb,#7C3AED 15%,transparent);color:#7C3AED;">
                    <i class="fas fa-id-badge"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card p-4" style="border-radius: 12px;">
        <div class="row g-2 align-items-center">

            <!-- Buscar usuario -->
            <div class="col-md-8">
                <div class="position-relative">
                    <i class="fa-solid fa-magnifying-glass position-absolute top-50 translate-middle-y text-muted"
                       style="left: 16px; font-size: 14px;"></i>

                    <input type="search"
                           @bind="_search"
                           @bind:event="oninput"
                           class="form-control text-foreground"
                           placeholder="Buscar por nombre, DNI o correo..."
                           style="height: 56px; border-radius: 10px; padding-left: 42px;" />
                </div>
            </div>

            <!-- Filtro de roles -->
            <div class="col-md-4">
                <select @bind="_roleFilter"
                        class="form-select text-foreground"
                        style="height: 56px; border-radius: 10px;">
                    <option value="">Todos los roles</option>
                    <option value="administrador">Administradores</option>
                    <option value="trabajador">Trabajadores</option>
                </select>
            </div>

        </div>
    </div>

    <!-- Table -->
    <div class="card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-borderless mb-0 align-middle">
                <thead class="border-bottom border-color-default">
                    <tr>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Trabajador</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Rol</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase d-none d-md-table-cell" style="letter-spacing:.05em;">DNI</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase d-none d-md-table-cell" style="letter-spacing:.05em;">Fecha Ingreso</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Estado</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-end" style="letter-spacing:.05em;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Filtered)
                    {
                        <tr class="border-bottom border-color-default">
                            <td class="px-4 py-3 d-flex align-items-center gap-3">
                                <img src="@s.Avatar"
                                     alt="@s.Nombre"
                                     class="rounded-circle flex-shrink-0 object-fit-cover"
                                     style="width:40px;height:40px;"
                                     onerror="this.src='https://placehold.co/40/e0e0e0/555?text=U'" />

                                <div>
                                    <span class="fw-semibold text-foreground d-block small">@s.Nombre</span>
                                    <span class="text-xs text-muted-foreground">@s.Correo</span>
                                </div>
                            </td>

                            <td class="px-4 py-3 text-capitalize small">
                                <span class="badge @(s.Rol == "administrador" ? "bg-primary-subtle text-primary" : "bg-secondary text-muted-foreground")" style="border-radius: var(--radius);">
                                    @s.Rol
                                </span>
                            </td>

                            <td class="px-4 py-3 text-muted-foreground small d-none d-md-table-cell">
                                @s.Dni
                            </td>

                            <td class="px-4 py-3 text-muted-foreground small d-none d-md-table-cell">
                                @s.FechaIngreso.ToString("dd MMM yyyy")
                            </td>

                            <td class="px-4 py-3">
                                <span class="badge @(s.Estado == "activo" ? "bg-success" : "bg-danger") px-2 py-1" style="border-radius: var(--radius);">
                                    @s.Estado
                                </span>
                            </td>

                            <td class="px-4 py-3 text-end">
                                <div class="d-flex align-items-center justify-content-end gap-2">

                                    <button @onclick="@(() => OpenEdit(s))"
                                            class="btn btn-sm btn-light text-muted"
                                            style="border-radius: var(--radius);"
                                            title="Editar">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </button>

                                    <button @onclick="@(() => ToggleStatus(s.Id))"
                                            class="btn btn-sm btn-light @(s.Estado == "activo" ? "text-warning" : "text-success")"
                                            style="border-radius: var(--radius);"
                                            title="@(s.Estado == "activo" ? "Suspender" : "Activar")">
                                        <i class="fa-solid @(s.Estado == "activo" ? "fa-eye-slash" : "fa-eye")"></i>
                                    </button>

                                    @if (s.Id != Auth.CurrentUser?.Id.ToString())
                                    {
                                        <button @onclick="@(() => AskDelete(s))"
                                                class="btn btn-sm btn-light text-danger"
                                                style="border-radius: var(--radius);"
                                                title="Eliminar">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Filtered.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted-foreground">
                                No se encontraron miembros del personal
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Confirmar Eliminación Trabajador -->
@if (_showConfirmDelete)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <i class="fa-solid fa-triangle-exclamation text-danger mb-3" style="font-size:2rem;"></i>
                    <h5 class="fw-bold text-foreground mb-1">¿Eliminar trabajador?</h5>
                    <p class="text-muted-foreground small mb-3">
                        <strong>@_deleteName</strong> será eliminado del sistema de forma permanente.
                    </p>
                    <div class="d-flex justify-content-center gap-2">
                        <button class="btn btn-secondary" @onclick="@(() => _showConfirmDelete = false)">Cancelar</button>
                        <button class="btn btn-danger fw-medium" @onclick="ConfirmDelete">Sí, eliminar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal Confirmar Guardar -->
@if (_showSaveConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.55);z-index:1060;">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">💾</div>
                    <h5 class="fw-bold text-foreground mb-1">¿@(_isEditing ? "Actualizar" : "Registrar") trabajador?</h5>
                    <p class="text-muted-foreground small mb-4">Se @(_isEditing ? "actualizarán los datos de" : "registrará a") <strong>@_form.Nombre</strong>.</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="@(() => _showSaveConfirm = false)">Cancelar</button>
                        <button class="btn btn-primary" style="border-radius:var(--radius);" @onclick="Save">Guardar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Staff Modal -->
@if (_showModal)
{
    <div class="modal show d-block fade-in" tabindex="-1" style="background:rgba(0,0,0,.5);" @onclick="@(() => _showModal = false)">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content bg-card border-border">
                <div class="modal-header border-border">
                    <h5 class="modal-title text-foreground fw-bold">@(_isEditing ? "Editar Miembro de Staff" : "Registrar Miembro")</h5>
                    <button type="button" class="btn-close" @onclick="@(() => _showModal = false)"></button>
                </div>
                <div class="modal-body p-4">
                    <EditForm Model="_form" OnValidSubmit="AskSave" class="d-flex flex-column gap-3">
                        <div>
                            <label class="form-label small fw-medium text-foreground">Nombre Completo</label>
                            <input type="text" @bind="_form.Nombre" required class="form-control text-foreground" placeholder="Marcos Díaz" />
                        </div>
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label small fw-medium text-foreground">DNI</label>
                                <input type="text" value="@_form.Dni" @oninput="OnDniInput" required maxlength="8" inputmode="numeric" class="form-control text-foreground" placeholder="45632178" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-medium text-foreground">Teléfono</label>
                                <input type="tel" value="@_form.Telefono" @oninput="OnTelefonoInput" required maxlength="9" inputmode="numeric" class="form-control text-foreground" placeholder="963852741" />
                            </div>
                        </div>
                        <div>
                            <label class="form-label small fw-medium text-foreground">Correo electrónico</label>
                            <input type="email" @bind="_form.Correo" required class="form-control text-foreground" placeholder="marcos@shiligama.com" />
                        </div>
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label small fw-medium text-foreground">Rol</label>
                                @if (_isEditingSelf)
                                {
                                    <input type="text" value="@_form.Rol" disabled
                                           class="form-control text-muted-foreground" />
                                    <div class="form-text text-muted-foreground small">
                                        <i class="fas fa-lock me-1"></i>No puedes cambiar tu propio rol.
                                    </div>
                                }
                                else
                                {
                                    <select @bind="_form.Rol" class="form-select text-foreground">
                                        <option value="trabajador">Trabajador</option>
                                        <option value="administrador">Administrador</option>
                                    </select>
                                }
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-medium text-foreground">Turno</label>
                                <select @bind="_form.Turno" class="form-select text-foreground">
                                    <option value="tiempo-completo">Tiempo completo</option>
                                    <option value="mañana">Mañana (6am – 2pm)</option>
                                    <option value="tarde">Tarde (2pm – 10pm)</option>
                                    <option value="noche">Noche (10pm – 6am)</option>
                                </select>
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label small fw-medium text-foreground">Estado</label>
                                <select @bind="_form.Estado" class="form-select text-foreground">
                                    <option value="activo">Activo</option>
                                    <option value="inactivo">Inactivo</option>
                                </select>
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-medium text-foreground">Avatar URL (opcional)</label>
                                <input type="url" @bind="_form.Avatar" class="form-control text-foreground" placeholder="https://..." />
                            </div>
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <button type="button" @onclick="@(() => _showModal = false)" class="btn btn-secondary" style="border-radius: var(--radius);">Cancelar</button>
                            <button type="submit" class="btn btn-primary fw-semibold" style="border-radius: var(--radius);">
                                @(_isEditing ? "Guardar cambios" : "Registrar")
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Staff> _staff = new();
    private string _search = "";
    private string _roleFilter = "";

    // Form Modal state
    private bool _showModal = false;
    private bool _isEditing = false;
    private Staff _form = new();
    private bool _isEditingSelf = false;   // true cuando el admin edita su propio registro

    // Permite solo dígitos en el DNI (máx. 8), bloqueando letras.
    private void OnDniInput(ChangeEventArgs e)
        => _form.Dni = new string((e.Value?.ToString() ?? "").Where(char.IsDigit).Take(8).ToArray());

    // Permite solo dígitos en el Teléfono (máx. 9 dígitos peruanos).
    private void OnTelefonoInput(ChangeEventArgs e)
        => _form.Telefono = new string((e.Value?.ToString() ?? "").Where(char.IsDigit).Take(9).ToArray());

    // Confirmación guardar
    private bool _showSaveConfirm = false;
    private void AskSave() => _showSaveConfirm = true;

    // Confirmación de eliminación
    private bool _showConfirmDelete = false;
    private string _deleteId = "";
    private string _deleteName = "";

    protected override async Task OnInitializedAsync()
    {
        await StaffSvc.EnsureLoadedAsync();
        _staff = StaffSvc.GetStaff();
    }

    private IEnumerable<Staff> Filtered => _staff.Where(s =>
        (string.IsNullOrEmpty(_search) || s.Nombre.Contains(_search, StringComparison.OrdinalIgnoreCase) || s.Dni.Contains(_search) || s.Correo.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_roleFilter) || s.Rol.Equals(_roleFilter, StringComparison.OrdinalIgnoreCase))
    );

    private void OpenCreate()
    {
        _form = new Staff();
        _isEditing = false;
        _showModal = true;
    }

    private void OpenEdit(Staff s)
    {
        _form = new Staff
        {
            Id          = s.Id,
            Nombre      = s.Nombre,
            Dni         = s.Dni,
            Rol         = s.Rol,
            Telefono    = s.Telefono,
            Correo      = s.Correo,
            Avatar      = s.Avatar,
            FechaIngreso= s.FechaIngreso,
            Estado      = s.Estado,
            Turno       = s.Turno
        };
        // Detectar si el admin está editando su propio registro (para bloquear cambio de rol)
        _isEditingSelf = Auth.CurrentUser?.Id.ToString() == s.Id;
        _isEditing = true;
        _showModal = true;
    }

    private void Save()
    {
        _showSaveConfirm = false;
        if (_isEditing) StaffSvc.UpdateStaff(_form);
        else            StaffSvc.AddStaff(_form);
        _showModal = false;
        _staff = StaffSvc.GetStaff();
    }

    private void AskDelete(Staff s)
    {
        _deleteId   = s.Id;
        _deleteName = s.Nombre;
        _showConfirmDelete = true;
    }

    private void ConfirmDelete()
    {
        _showConfirmDelete = false;
        StaffSvc.DeleteStaff(_deleteId);
        _staff = StaffSvc.GetStaff();
    }

    private void ToggleStatus(string id)
    {
        StaffSvc.ToggleStatus(id);
        StateHasChanged();
    }
}
