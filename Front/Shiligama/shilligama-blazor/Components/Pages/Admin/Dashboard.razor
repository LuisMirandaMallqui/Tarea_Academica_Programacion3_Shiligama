@page "/admin"
@layout AdminLayout
@inject SalesService SalesSvc
@inject ProductService ProductSvc
@inject SupplierService SupplierSvc
@inject StaffService StaffSvc
@inject IJSRuntime JS

<PageTitle>Dashboard – Shiligama Admin</PageTitle>

<div class="d-flex flex-column gap-4">
    <!-- Header -->
    <div>
        <h1 class="fs-4 fw-bold text-foreground mb-0">Dashboard</h1>
        <p class="text-muted-foreground small mt-1 mb-0">Resumen general de operaciones y métricas clave</p>
    </div>

    <!-- KPI Cards -->
    <div class="row g-3">
        @foreach (var kpi in _kpis)
        {
            <div class="col-6 col-xl-3">
                <div class="metric-card-kpi">
                    <div class="flex-grow-1">
                        <div class="metric-kpi-label mb-1">@kpi.Title</div>
                        <div class="metric-kpi-value text-foreground lh-1 mb-1">@kpi.Value</div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-muted-foreground" style="font-size:0.75rem;">@kpi.Subtitle</span>
                            @if (!string.IsNullOrEmpty(kpi.Trend))
                            {
                                <span class="badge small py-1" style="@(kpi.TrendUp?"background:color-mix(in srgb,#1A6B3C 15%,transparent);color:#1A6B3C;":"background:color-mix(in srgb,#c62828 15%,transparent);color:#c62828;") border-radius:var(--radius);">
                                    <i class="fas @(kpi.TrendUp?"fa-arrow-up":"fa-arrow-down") me-1" style="font-size:0.6rem;"></i>@kpi.Trend
                                </span>
                            }
                        </div>
                    </div>
                    <div class="metric-kpi-icon" style="background:color-mix(in srgb,@kpi.Color 15%,transparent);color:@kpi.Color;">
                        <i class="fas @kpi.FaIcon"></i>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Charts Row (2 columns) -->
    <div class="row g-4">
        <!-- Sales Line Chart -->
        <div class="col-lg-7">
            <div class="card p-4 h-100">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div>
                        <h2 class="fs-5 fw-semibold text-foreground mb-0">
                            <i class="fas fa-chart-line me-2 text-primary"></i>Ventas de la Semana
                        </h2>
                        <p class="text-muted-foreground small m-0">Resumen de ventas diarias en soles (S/.)</p>
                    </div>
                    <span class="badge small py-1 px-2" style="background:color-mix(in srgb,#1A6B3C 12%,transparent);color:#1A6B3C;border-radius:var(--radius);">
                        En tiempo real
                    </span>
                </div>
                <div style="height:240px; position:relative;">
                    <canvas id="salesChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Channels Bar Chart -->
        <div class="col-lg-5">
            <div class="card p-4 h-100">
                <div class="mb-3">
                    <h2 class="fs-5 fw-semibold text-foreground mb-0">
                        <i class="fas fa-chart-bar me-2" style="color:#e67e22;"></i>Pedidos: Presencial vs Online
                    </h2>
                    <p class="text-muted-foreground small m-0">Distribución de canales esta semana</p>
                </div>
                <div style="height:240px; position:relative;">
                    <canvas id="channelsChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Sales + Quick Stats -->
    <div class="row g-4">
        <!-- Recent Transactions Table -->
        <div class="col-12">
            <div class="card overflow-hidden">
                <div class="d-flex align-items-center justify-content-between p-4 border-bottom border-color-default">
                    <div>
                        <h2 class="fs-5 fw-semibold text-foreground mb-0">Ventas Recientes</h2>
                        <p class="text-muted-foreground small m-0">Últimas ventas realizadas en el sistema</p>
                    </div>
                    <a href="/admin/ventas" class="btn btn-secondary btn-sm" style="border-radius:var(--radius);">Ver todas</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-borderless mb-0 align-middle">
                        <thead class="border-bottom border-color-default">
                            <tr>
                                <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Venta</th>
                                <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Cliente</th>
                                <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Total</th>
                                <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Canal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (_recentSales.Any())
                            {
                                @foreach (var sale in _recentSales)
                                {
                                    <tr class="border-bottom border-color-default">
                                        <td class="px-4 py-3 fw-bold text-primary small">@sale.Id</td>
                                        <td class="px-4 py-3">
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="d-flex align-items-center justify-content-center rounded-circle bg-primary text-white flex-shrink-0"
                                                     style="width:28px;height:28px;font-size:.75rem;">
                                                    @((sale.Cliente?.Length > 0 ? sale.Cliente[0] : 'C').ToString())
                                                </div>
                                                <span class="text-foreground small">@sale.Cliente</span>
                                            </div>
                                        </td>
                                        <td class="px-4 py-3 fw-semibold text-foreground small">S/. @sale.Total.ToString("0.00")</td>
                                        <td class="px-4 py-3">
                                            <span class="badge" style="background:color-mix(in srgb,#1976d2 15%,transparent);color:#1976d2;font-size:0.7rem;border-radius:9999px;">
                                                <i class="fas @(sale.Canal == "presencial" ? "fa-store" : "fa-globe") me-1"></i>@sale.Canal
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-5 text-muted-foreground">Sin ventas recientes</td>
                                </tr>
                            }
                        </tbody>    
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

@code {
    private List<KpiItem> _kpis = new();
    private List<Sale> _recentSales = new();

    private record KpiItem(string Title, string Value, string Subtitle, string FaIcon, string Color, string Trend, bool TrendUp);

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            ProductSvc.EnsureLoadedAsync(),
            SalesSvc.EnsureLoadedAsync()
        );
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var sales    = SalesSvc.GetSales();
        var products = ProductSvc.GetProducts();
        var todaySales = sales.Where(s => s.Fecha.Date == DateTime.Today).Sum(s => s.Total);

        _kpis = new()
        {
            new("Ventas hoy",
                $"S/. {todaySales:0.00}",
                "8 transacciones hoy",
                "fa-wallet", "#1A6B3C", "+12.5%", true),
            new("Pedidos pendientes",
                $"{SalesSvc.GetRecentOrders().Count(o => o.Status == "pendiente")}",
                "+3 nuevos hoy",
                "fa-clock", "#e67e22", "+3", true),
            new("Productos con bajo stock",
                $"{products.Count(p => p.Stock < 10)}",
                "-5 requieren atención",
                "fa-box-open", "#c62828", "-5", false),
            new("Ingresos del mes",
                $"S/. {sales.Sum(s => s.Total):0.00}",
                "vs. mes anterior",
                "fa-chart-line", "#2563EB", "+8.2%", true),
        };

        _recentSales = sales.OrderByDescending(s => s.Fecha).Take(6).ToList();

        StateHasChanged();
        await RenderCharts();
    }

    private async Task RenderCharts()
    {
        // Sales chart
        var labels = Enumerable.Range(-6, 7).Select(d => DateTime.Today.AddDays(d).ToString("dd/MM")).ToArray();
        var data   = Enumerable.Range(-6, 7).Select(d =>
            SalesSvc.GetSales().Where(s => s.Fecha.Date == DateTime.Today.AddDays(d)).Sum(s => s.Total)
        ).ToArray();
        await JS.InvokeVoidAsync("chartHelper.renderSalesChart", "salesChart", labels, data);

        // Channels chart
        var presencialData = new[] { 8, 10, 9, 12, 15, 18, 14 };
        var onlineData     = new[] { 5, 7,  6,  8, 10, 12, 9  };
        await JS.InvokeVoidAsync("chartHelper.renderChannelsChart", "channelsChart",
            Enumerable.Range(-6, 7).Select(d => DateTime.Today.AddDays(d).ToString("ddd")).ToArray(),
            presencialData, onlineData);
    }
}
