@page "/admin"
@layout AdminLayout
@inject SalesService SalesSvc
@inject ProductService ProductSvc
@inject SupplierService SupplierSvc
@inject StaffService StaffSvc
@inject IJSRuntime JS

<PageTitle>Dashboard – Shiligama Admin</PageTitle>

<div class="d-flex flex-column gap-4">
    <!-- Header -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h1 class="fs-4 fw-bold text-foreground mb-0">Dashboard</h1>
            <p class="text-muted-foreground small mt-1 mb-0">Resumen general de operaciones y métricas clave</p>
        </div>
    </div>

@if (_loading)
{
    <LoadingIndicator />
}
else
{
    <!-- KPI Cards -->
    <div class="row g-3">
        @foreach (var kpi in _kpis)
        {
            <div class="col-6 col-xl-3">
                <div class="admin-kpi-card" style="--kpi-color:@kpi.Color;">
                    <div class="flex-grow-1">
                        <div class="metric-kpi-label mb-1">@kpi.Title</div>
                        <div class="metric-kpi-value text-foreground lh-1 mb-1">@kpi.Value</div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-muted-foreground" style="font-size:0.75rem;">@kpi.Subtitle</span>
                            @if (!string.IsNullOrEmpty(kpi.Trend))
                            {
                                <span class="badge small py-1" style="@(kpi.TrendUp ? "background:color-mix(in srgb,#1A6B3C 15%,transparent);color:#1A6B3C;" : "background:color-mix(in srgb,#c62828 15%,transparent);color:#c62828;") border-radius:var(--radius);">
                                    <i class="fas @(kpi.TrendUp ? "fa-arrow-up" : "fa-arrow-down") me-1" style="font-size:0.6rem;"></i>@kpi.Trend
                                </span>
                            }
                        </div>
                    </div>
                    <div class="metric-kpi-icon" style="background:color-mix(in srgb,@kpi.Color 15%,transparent);color:@kpi.Color;">
                        <i class="fas @kpi.FaIcon"></i>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Charts Row -->
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card p-4 h-100">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div>
                        <h2 class="fs-5 fw-semibold text-foreground mb-0">
                            <i class="fas fa-chart-line me-2 text-primary"></i>Ventas de la Semana
                        </h2>
                        <p class="text-muted-foreground small m-0">Resumen de ventas diarias en soles (S/.)</p>
                    </div>
                    <span class="badge small py-1 px-2" style="background:color-mix(in srgb,#1A6B3C 12%,transparent);color:#1A6B3C;border-radius:var(--radius);">
                        En tiempo real
                    </span>
                </div>
                <div style="height:240px; position:relative;">
                    <canvas id="salesChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card p-4 h-100">
                <div class="mb-3">
                    <h2 class="fs-5 fw-semibold text-foreground mb-0">
                        <i class="fas fa-chart-bar me-2" style="color:#e67e22;"></i>Pedidos: Presencial vs Online
                    </h2>
                    <p class="text-muted-foreground small m-0">Distribución de canales esta semana</p>
                </div>
                <div style="height:240px; position:relative;">
                    <canvas id="channelsChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Sales -->
    <div class="row g-4">
        <div class="col-12">
            <div class="card overflow-hidden">
                <div class="d-flex align-items-center justify-content-between p-4 border-bottom border-color-default">
                    <div>
                        <h2 class="fs-5 fw-semibold text-foreground mb-0">Ventas Recientes</h2>
                        <p class="text-muted-foreground small m-0">Últimas ventas realizadas en el sistema</p>
                    </div>
                    <a href="/admin/ventas" class="btn btn-secondary btn-sm" style="border-radius:var(--radius);">Ver todas</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-borderless mb-0 align-middle">
                        <thead class="border-bottom border-color-default">
                            <tr>
                                <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Venta</th>
                                <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Cliente</th>
                                <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Total</th>
                                <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Canal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (_recentSales.Any())
                            {
                                @foreach (var sale in _recentSales)
                                {
                                    <tr class="border-bottom border-color-default">
                                        <td class="px-4 py-3 fw-bold text-primary small">@sale.Id</td>
                                        <td class="px-4 py-3">
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="d-flex align-items-center justify-content-center rounded-circle bg-primary text-white flex-shrink-0"
                                                     style="width:28px;height:28px;font-size:.75rem;">
                                                    @((sale.Cliente?.Length > 0 ? sale.Cliente[0] : 'C').ToString())
                                                </div>
                                                <span class="text-foreground small">@sale.Cliente</span>
                                            </div>
                                        </td>
                                        <td class="px-4 py-3 fw-semibold text-foreground small">S/. @sale.Total.ToString("0.00")</td>
                                        <td class="px-4 py-3">
                                            <span class="badge" style="background:color-mix(in srgb,#1976d2 15%,transparent);color:#1976d2;font-size:0.7rem;border-radius:9999px;">
                                                <i class="fas @(sale.Canal == "presencial" ? "fa-store" : "fa-globe") me-1"></i>@sale.Canal
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-5 text-muted-foreground">Sin ventas recientes</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}
</div>

<style>
    .admin-kpi-card {
        background: var(--card);
        border: 2px solid var(--kpi-color, var(--primary));
        border-left: 4px solid var(--kpi-color, var(--primary));
        border-radius: var(--radius);
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        box-shadow: 0 4px 12px color-mix(in srgb, var(--kpi-color, var(--primary)) 8%, transparent);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        position: relative;
    }
    .admin-kpi-card:hover {
        transform: translateY(-4px) scale(1.01);
        box-shadow: 0 12px 24px color-mix(in srgb, var(--kpi-color, var(--primary)) 20%, transparent);
        z-index: 10;
    }
</style>

@code {
    private bool _loading = true;
    private bool _chartsRendered = false;
    private List<KpiItem> _kpis = new();
    private List<Sale> _recentSales = new();

    private record KpiItem(string Title, string Value, string Subtitle, string FaIcon, string Color, string Trend, bool TrendUp);

    // ── Toda la carga de datos ocurre aquí, ANTES del primer render con contenido ──
    //
    // Problema raíz del bug "primera vez no carga":
    //   EnsureLoadedAsync() hace muchas llamadas HTTP (ventas + pedidos + N×detalles)
    //   y cede el hilo varias veces. Blazor aprovecha esos yields para hacer renders
    //   preliminares (spinner) y dispara OnAfterRenderAsync MIENTRAS OnInitializedAsync
    //   aún está corriendo. Si la lectura de GetSales() ocurría en OnAfterRenderAsync,
    //   llegaba antes de que EnsureLoadedAsync terminase → lista vacía → datos vacíos.
    //
    //   Al mover TODO aquí, Blazor espera a que OnInitializedAsync complete antes de
    //   hacer el primer render con _loading=false, garantizando que GetSales() ya tiene
    //   los datos cargados cuando los lee.
    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            ProductSvc.EnsureLoadedAsync(),
            SalesSvc.EnsureLoadedAsync()
        );

        SalesService.KpiAdminDto? kpiReal = null;
        try { kpiReal = await SalesSvc.GetKpisAdminAsync(); } catch { }

        var sales    = SalesSvc.GetSales();
        var products = ProductSvc.GetProducts();

        if (kpiReal != null)
        {
            _kpis = new()
            {
                new("Ventas hoy",
                    $"S/. {kpiReal.VentasHoy:0.00}",
                    "Facturado hoy",
                    "fa-wallet", "#1A6B3C", "", true),
                new("Pedidos pendientes",
                    $"{kpiReal.PedidosPendientes}",
                    "Recibidos y en proceso de atención",
                    "fa-clock", "#e67e22", "", true),
                new("Productos bajo stock",
                    $"{kpiReal.ProductosBajoStock}",
                    "Con inventario bajo el mínimo",
                    "fa-box-open", "#c62828", "", false),
                new("Ingresos del mes",
                    $"S/. {kpiReal.IngresosMes:0.00}",
                    "Facturado este mes",
                    "fa-chart-line", "#2563EB", "", true),
            };
        }
        else
        {
            var todaySales = sales.Where(s => s.Fecha.Date == DateTime.Today).Sum(s => s.Total);
            _kpis = new()
            {
                new("Ventas hoy",
                    $"S/. {todaySales:0.00}",
                    "Calculado desde caché",
                    "fa-wallet", "#1A6B3C", "", true),
                new("Pedidos pendientes",
                    $"{SalesSvc.GetRecentOrders().Count(o => o.Status is "recibido" or "en_proceso")}",
                    "Recibidos o en proceso",
                    "fa-clock", "#e67e22", "", true),
                new("Productos bajo stock",
                    $"{products.Count(p => p.Stock <= p.MinStock)}",
                    "Con inventario bajo el mínimo",
                    "fa-box-open", "#c62828", "", false),
                new("Ingresos del mes",
                    $"S/. {sales.Sum(s => s.Total):0.00}",
                    "Total en caché",
                    "fa-chart-line", "#2563EB", "", true),
            };
        }

        _recentSales = sales.OrderByDescending(s => s.Fecha).Take(6).ToList();
        _loading = false;
        // No se necesita StateHasChanged(): Blazor re-renderiza automáticamente
        // cuando OnInitializedAsync completa con cambios de estado.
    }

    // OnAfterRenderAsync solo maneja los charts. Los renders con _loading=true
    // (spinner, sin <canvas>) son ignorados gracias al guard !_loading.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_loading && !_chartsRendered)
        {
            _chartsRendered = true;
            await RenderCharts();
        }
    }

    private async Task RenderCharts()
    {
        var labels = Enumerable.Range(-6, 7)
            .Select(d => DateTime.Today.AddDays(d).ToString("dd/MM"))
            .ToArray();
        var salesData = Enumerable.Range(-6, 7)
            .Select(d => SalesSvc.GetSales()
                .Where(s => s.Fecha.Date == DateTime.Today.AddDays(d))
                .Sum(s => s.Total))
            .ToArray();
        await JS.InvokeVoidAsync("chartHelper.renderSalesChart", "salesChart", labels, salesData);

        var dayLabels = Enumerable.Range(-6, 7)
            .Select(d => DateTime.Today.AddDays(d).ToString("ddd"))
            .ToArray();
        // Contar por día exacto (longitud siempre 7) — sin datos ficticios de fallback
        var presencialData = Enumerable.Range(-6, 7)
            .Select(d => SalesSvc.GetRecentOrders()
                .Count(o => o.Date.Date == DateTime.Today.AddDays(d).Date
                         && o.Channel == "Presencial"))
            .ToArray();
        var onlineData = Enumerable.Range(-6, 7)
            .Select(d => SalesSvc.GetRecentOrders()
                .Count(o => o.Date.Date == DateTime.Today.AddDays(d).Date
                         && o.Channel != "Presencial"))
            .ToArray();

        await JS.InvokeVoidAsync("chartHelper.renderChannelsChart", "channelsChart",
            dayLabels, presencialData, onlineData);
    }
}
