@page "/admin/productos"
@layout AdminLayout
@implements IDisposable
@inject ProductService ProductSvc
@inject PromocionService PromoSvc
@inject IJSRuntime JS
@inject HttpClient Http
@using System.Security.Cryptography
@using Microsoft.JSInterop
<PageTitle>Productos – Shiligama Admin</PageTitle>

<style>
    @@keyframes cartTrip {
        0%   { transform: translateX(-120px);                        opacity: 0; }
        12%  { transform: translateX(-30px)  translateY(0);         opacity: 1; }
        25%  { transform: translateX(20px)   translateY(-18px)   rotate(90deg); }
        40%  { transform: translateX(0)      translateY(-38px)   rotate(180deg); }
        55%  { transform: translateX(-20px)  translateY(-18px)   rotate(270deg); }
        68%  { transform: translateX(30px)   translateY(0)       rotate(360deg); }
        85%  { transform: translateX(120px);                        opacity: 0; }
        100% { transform: translateX(120px);                        opacity: 0; }
    }
</style>

<div class="d-flex flex-column gap-4">
     @if (_loading)
    {
        <div class="d-flex flex-column align-items-center justify-content-center py-5 w-100" style="min-height:400px;">
            <div style="font-size:4rem;color:#1A6B3C;animation:cartTrip 3.5s ease-in-out infinite;">
                <i class="fas fa-shopping-cart"></i>
            </div>
            <div class="mt-3" style="color:#1A6B3C;font-weight:600;font-size:1.1rem;">Cargando...</div>
        </div>
    }
    else
    {
            <!-- ── Encabezado ── -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h1 class="fs-4 fw-bold text-foreground mb-0">Gestión de Productos</h1>
            <p class="text-muted-foreground small mt-1 mb-0">@_products.Count productos registrados</p>
        </div>
        <button @onclick="OpenCreate" class="btn btn-primary d-flex align-items-center gap-2 fw-medium" style="border-radius:var(--radius);">
            <i class="fa-solid fa-plus"></i> Nuevo Producto
        </button>
    </div>

    <!-- ── KPI ── -->
    <div class="row g-3">
        <div class="col-6 col-xl-3">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value text-foreground">@_products.Count</div><div class="metric-kpi-label">Total Productos</div></div>
                <div class="metric-kpi-icon" style="background:color-mix(in srgb,var(--primary) 15%,transparent);color:var(--primary);"><i class="fas fa-box"></i></div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value" style="color:#f59e0b;">@_products.Count(p => p.Stock > 0 && p.Stock <= p.MinStock)</div><div class="metric-kpi-label">Stock Bajo</div></div>
                <div class="metric-kpi-icon" style="background:color-mix(in srgb,#f59e0b 15%,transparent);color:#f59e0b;"><i class="fas fa-exclamation-triangle"></i></div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value" style="color:#c62828;">@_products.Count(p => p.Stock == 0)</div><div class="metric-kpi-label">Agotados</div></div>
                <div class="metric-kpi-icon" style="background:color-mix(in srgb,#c62828 15%,transparent);color:#c62828;"><i class="fas fa-times-circle"></i></div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value text-foreground" style="font-size:1rem;">Hoy, @DateTime.Now.ToString("HH:mm")</div><div class="metric-kpi-label">Sincronizado</div></div>
                <div class="metric-kpi-icon" style="background:color-mix(in srgb,#2563EB 15%,transparent);color:#2563EB;"><i class="fas fa-clock"></i></div>
            </div>
        </div>
    </div>

    <!-- ── Alerta agotados — fondo rojo clarito ── -->
    @if (_products.Any(p => p.Stock == 0))
    {
        <div class="d-flex align-items-center gap-3 p-3 rounded-3" style="background:#fff0f0;border:1px solid #f5c6c6;">
            <div class="d-flex align-items-center justify-content-center rounded-3 flex-shrink-0"
                 style="width:40px;height:40px;background:color-mix(in srgb,#c62828 18%,transparent);color:#c62828;">
                <i class="fas fa-times-circle"></i>
            </div>
            <div>
                <p class="fw-semibold mb-0 small" style="color:#8b1a1a;">Productos Agotados</p>
                <p class="small mb-0" style="color:#a93226;">Hay <strong>@_products.Count(p => p.Stock == 0)</strong> producto(s) sin stock. Se desactivaron automáticamente.</p>
            </div>
        </div>
    }

    <!-- ── Alerta stock bajo ── -->
    @if (_products.Any(p => p.Stock > 0 && p.Stock <= p.MinStock))
    {
        <div class="stock-alert-banner">
            <div class="metric-kpi-icon flex-shrink-0" style="background:color-mix(in srgb,#f59e0b 20%,transparent);color:#f59e0b;"><i class="fas fa-exclamation-triangle"></i></div>
            <div>
                <p class="fw-semibold text-foreground m-0 small">Alerta de Existencias Bajas</p>
                <p class="text-muted-foreground small m-0">Hay <strong>@_products.Count(p => p.Stock > 0 && p.Stock <= p.MinStock)</strong> producto(s) con stock por debajo del mínimo configurado.</p>
            </div>
        </div>
    }

    <!-- ── Filtros ── -->
    <div class="card p-3">
        <div class="row g-2">
            <div class="col-12">
                <div class="position-relative">
                    <i class="fa-solid fa-magnifying-glass position-absolute top-50 translate-middle-y text-muted" style="left:14px;"></i>
                    <input type="search" @bind="_search" @bind:event="oninput" @bind:after="ResetPage"
                           class="form-control text-foreground" placeholder="Buscar productos..." style="padding-left:40px;" />
                </div>
            </div>
            <div class="col-md-4">
                <select @bind="_categoryFilter" @bind:after="ResetPage" class="form-select text-foreground">
                    <option value="">Categorías (todas)</option>
                    @foreach (var cat in _categories)
                    { <option value="@cat.Id">@cat.Name</option> }
                </select>
            </div>
            <div class="col-md-8 d-flex gap-2 align-items-center justify-content-end flex-wrap">
                <button @onclick='() => SetFilterOption("")'
                        class="btn btn-sm @BtnClass("")"
                        style="border-radius:9999px;font-size:.8rem;">Todos</button>
                <button @onclick='() => SetFilterOption("activos")'
                        class="btn btn-sm @BtnClass("activos")"
                        style="border-radius:9999px;font-size:.8rem;">Solo activos</button>
                <button @onclick='() => SetFilterOption("stock_bajo")'
                        class="btn btn-sm @BtnClass("stock_bajo", "btn-warning text-dark")"
                        style="border-radius:9999px;font-size:.8rem;">Stock bajo</button>
                <button @onclick='() => SetFilterOption("agotados")'
                        class="btn btn-sm @BtnClass("agotados", "btn-danger")"
                        style="border-radius:9999px;font-size:.8rem;">Agotados</button>
                <button @onclick='() => SetFilterOption("en_oferta")'
                        class="btn btn-sm @BtnClass("en_oferta")"
                        style="border-radius:9999px;font-size:.8rem;">En oferta</button>
            </div>
        </div>
    </div>

    <!-- ── Tabla ── -->
    <div class="card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-borderless mb-0">
                <thead class="border-bottom border-color-default">
                    <tr>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase d-none d-md-table-cell" style="letter-spacing:.05em;">Código</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Producto</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase d-none d-md-table-cell" style="letter-spacing:.05em;">Categoría</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Precio</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-center" style="letter-spacing:.05em;">Stock</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-end" style="letter-spacing:.05em;">Ajuste Rápido</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-end" style="letter-spacing:.05em;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Paged)
                    {
                        var promoActiva = _promos.FirstOrDefault(pr =>
                            pr.Activo && pr.FechaFin >= DateTime.Today && pr.ProductoIds.Contains(product.Id));
                        decimal? precioPromo = promoActiva != null ? CalcularPrecioPromo(product.Price, promoActiva) : null;

                        var stockBadgeClass = product.Stock == 0
                            ? "bg-danger"
                            : product.Stock <= product.MinStock
                                ? "bg-warning text-dark"
                                : "bg-success-subtle text-success";

                        // El producto está agotado (stock == 0) → solo puede activarse
                        // cuando alguien le agregue stock. No tiene sentido ofrecer "activar"
                        // si stock == 0 porque volvería a desactivarse al instante.
                        var puedeToggleEstado = product.Stock > 0;

                        <tr class="border-bottom border-color-default align-middle" style="transition:background .15s;">
                            <td class="px-4 py-3 fw-medium text-muted-foreground small d-none d-md-table-cell">PROD-@product.Id.ToString("D3")</td>
                            <td class="px-4 py-3 d-flex align-items-center gap-3">
                                <img src="@product.Image" alt="@product.Name" class="rounded-3 flex-shrink-0 object-fit-cover" style="width:44px;height:44px;"
                                     onerror="this.src='https://placehold.co/44x44/e8f5e9/1A6B3C?text=🛒'" />
                                <div>
                                    <p class="fw-medium text-foreground mb-0 small">@product.Name</p>
                                    <div class="d-flex gap-1 mt-1">
                                        @if (product.IsPromo) { <span class="badge bg-danger" style="font-size:.65rem;">Promo</span> }
                                        @if (!product.Estado) { <span class="badge bg-secondary" style="font-size:.65rem;">Inactivo</span> }
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-3 text-muted-foreground small d-none d-md-table-cell">@ProductSvc.GetCategoryName(product.Category)</td>
                            <td class="px-4 py-3 small">
                                @if (precioPromo.HasValue)
                                {
                                    <span class="fw-bold text-danger d-block">S/. @precioPromo.Value.ToString("0.00")</span>
                                    <span class="text-decoration-line-through text-muted-foreground" style="font-size:.75rem;">S/. @product.Price.ToString("0.00")</span>
                                    @if (promoActiva!.TipoDescuento == "PORCENTAJE")
                                    { <span class="badge bg-danger ms-1" style="font-size:.65rem;">-@promoActiva.ValorDescuento%</span> }
                                }
                                else
                                { <span class="fw-medium text-foreground">S/. @product.Price.ToString("0.00")</span> }
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="badge @stockBadgeClass" style="border-radius:var(--radius);font-size:.8rem;padding:.3em .7em;">
                                    @product.Stock ud.
                                </span>
                                @if (product.Stock > 0 && product.Stock <= product.MinStock)
                                { <div class="text-muted-foreground" style="font-size:.68rem;margin-top:2px;">mín: @product.MinStock</div> }
                            </td>
                            <td class="px-4 py-3 text-end">
                                <div class="d-flex align-items-center justify-content-end gap-1">
                                    <button @onclick="@(() => AdjustStock(product, -1))" disabled="@(product.Stock == 0)"
                                            class="btn btn-outline-secondary btn-sm rounded-circle d-flex align-items-center justify-content-center"
                                            style="width:30px;height:30px;" title="Reducir 1">−</button>
                                    <button @onclick="@(() => AdjustStock(product, 1))"
                                            class="btn btn-outline-secondary btn-sm rounded-circle d-flex align-items-center justify-content-center"
                                            style="width:30px;height:30px;" title="Agregar 1">+</button>
                                    <button @onclick="@(() => AdjustStock(product, 10))"
                                            class="btn btn-primary btn-sm px-2 ms-1"
                                            style="border-radius:var(--radius);font-size:.75rem;">+10</button>
                                </div>
                            </td>
                            <td class="px-4 py-3 text-end">
                                <div class="d-flex align-items-center justify-content-end gap-1">
                                    <button @onclick="@(() => OpenEdit(product))"
                                            class="btn btn-ghost btn-sm text-muted-foreground"
                                            style="border-radius:var(--radius);" title="Editar">
                                        <Icons Name="Edit2" Class="w-4 h-4" />
                                    </button>

                                    @if (puedeToggleEstado)
                                    {
                                        <!-- Stock > 0: puede activar/desactivar normalmente -->
                                        <button @onclick="@(() => AskToggleEstado(product))"
                                                class="btn btn-ghost btn-sm @(product.Estado ? "text-warning" : "text-success")"
                                                style="border-radius:var(--radius);"
                                                title="@(product.Estado ? "Desactivar" : "Activar")">
                                            <i class="fa-solid @(product.Estado ? "fa-eye-slash" : "fa-eye")"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <!-- Stock == 0: botón deshabilitado, solo se activa cuando tenga stock -->
                                        <button disabled
                                                class="btn btn-ghost btn-sm text-muted-foreground"
                                                style="border-radius:var(--radius);opacity:.35;"
                                                title="Sin stock — agrega stock para poder activar este producto">
                                            <i class="fa-solid fa-eye-slash"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Paged.Any())
                    { <tr><td colspan="7" class="text-center py-5 text-muted-foreground">No se encontraron productos</td></tr> }
                </tbody>
            </table>
        </div>
    </div>

    @if (TotalPages > 1)
    {
        <div class="d-flex justify-content-center align-items-center gap-2 py-2">
            <button class="btn btn-sm rounded-circle pag-btn" @onclick="@(() => GoToPage(_currentPage - 1))" disabled="@(_currentPage == 1)" style="width:36px;height:36px;">
                <i class="fa-solid fa-chevron-left" style="font-size:.75rem;"></i>
            </button>
            @for (int p = 1; p <= TotalPages; p++) { var pg = p;
                <button class="btn btn-sm rounded-circle pag-btn @(pg == _currentPage ? "pag-active" : "")"
                        @onclick="@(() => GoToPage(pg))" style="width:36px;height:36px;font-size:.85rem;font-weight:600;">@pg</button>
            }
            <button class="btn btn-sm rounded-circle pag-btn" @onclick="@(() => GoToPage(_currentPage + 1))" disabled="@(_currentPage == TotalPages)" style="width:36px;height:36px;">
                <i class="fa-solid fa-chevron-right" style="font-size:.75rem;"></i>
            </button>
        </div>
    }
    }

</div>

<!-- Modal: Confirmar guardar -->
@if (_showSaveConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.55);z-index:1060;">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">💾</div>
                    <h5 class="fw-bold text-foreground mb-1">¿@(_isEditing ? "Actualizar" : "Crear") producto?</h5>
                    <p class="text-muted-foreground small mb-4">Se @(_isEditing ? "guardarán los cambios de" : "creará") <strong>@_form.Name</strong>.</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="@(() => _showSaveConfirm = false)">Cancelar</button>
                        <button class="btn btn-primary" style="border-radius:var(--radius);" disabled="@_saving" @onclick="Save">
                            @(_saving ? "Guardando…" : "Guardar")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal: Confirmar toggle estado -->
@if (_showToggleConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45);z-index:1060;">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">@(_toggleProduct?.Estado == true ? "🔒" : "🔓")</div>
                    <h5 class="fw-bold text-foreground mb-1">¿@(_toggleProduct?.Estado == true ? "Desactivar" : "Activar") producto?</h5>
                    <p class="text-muted-foreground small mb-4">
                        <strong>@_toggleProduct?.Name</strong> quedará @(_toggleProduct?.Estado == true ? "inactivo y no visible para clientes" : "activo y visible en el catálogo").
                    </p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="@(() => _showToggleConfirm = false)">Cancelar</button>
                        <button class="btn @(_toggleProduct?.Estado == true ? "btn-warning" : "btn-success")" style="border-radius:var(--radius);" @onclick="ConfirmToggleEstado">Confirmar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal: Salir sin guardar -->
@if (_showUnsavedConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45);z-index:1070;">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">⚠️</div>
                    <h5 class="fw-bold text-foreground mb-1">¿Salir sin guardar?</h5>
                    <p class="text-muted-foreground small mb-4">Los cambios en <strong>@_form.Name</strong> se perderán.</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="@(() => _showUnsavedConfirm = false)">Seguir editando</button>
                        <button class="btn btn-danger" style="border-radius:var(--radius);" @onclick="ForceCloseModal">Salir sin guardar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal: Crear / Editar producto -->
@if (_showModal)
{
<ErrorBoundary>
    <ChildContent>
    <div class="modal show d-block fade-in" tabindex="-1" style="background:rgba(0,0,0,.5);" @onclick="TryCloseModal">
        <div class="modal-dialog modal-lg modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content bg-card border-border">
                <div class="modal-header border-border">
                    <h5 class="modal-title text-foreground fw-semibold">@(_isEditing ? "Editar Producto" : "Nuevo Producto")</h5>
                    <button type="button" class="btn-close" @onclick="TryCloseModal"></button>
                </div>
                <div class="modal-body p-4">
                    @if (!string.IsNullOrEmpty(_saveError))
                    { <div class="alert alert-danger py-2 small mb-3">@_saveError</div> }
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-medium text-foreground">Nombre *</label>
                            <input type="text" value="@_form.Name"
                                   @oninput="@(e => { _form.Name = e.Value?.ToString() ?? ""; _formDirty = true; })"
                                   class="form-control text-foreground @(_submitted && string.IsNullOrWhiteSpace(_form.Name) ? "is-invalid" : "")"
                                   placeholder="Ej: Arroz Costeño 5kg" />
                            @if (_submitted && string.IsNullOrWhiteSpace(_form.Name))
                            { <div class="invalid-feedback">El nombre es obligatorio.</div> }
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-medium text-foreground">Descripción</label>
                            <textarea value="@_form.Description"
                                      @oninput="@(e => { _form.Description = e.Value?.ToString() ?? ""; _formDirty = true; })"
                                      class="form-control text-foreground" rows="2"></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-medium text-foreground">Precio de venta * (S/.)</label>
                            <div class="input-group">
                                <span class="input-group-text text-foreground">S/.</span>
                                <input type="number" step=".01" min="0" inputmode="decimal"
                                   value="@_precioRaw" @oninput="OnPrecioInput"
                                   class="form-control text-foreground @(_precioError != null ? "is-invalid" : "")"
                                   placeholder="0.00" />
                            </div>
                            @if (_precioError != null)
                            { <div class="text-danger small mt-1">@_precioError</div> }
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-medium text-foreground">Categoría *</label>
                            <select value="@_form.Category"
                                    @onchange="@(e => { _form.Category = e.Value?.ToString() ?? ""; _formDirty = true; })"
                                    class="form-select text-foreground @(_submitted && string.IsNullOrEmpty(_form.Category) ? "is-invalid" : "")">
                                <option value="">-- Seleccionar --</option>
                                @foreach (var cat in _categories)
                                { <option value="@cat.Id">@cat.Name</option> }
                            </select>
                            @if (_submitted && string.IsNullOrEmpty(_form.Category))
                            { <div class="invalid-feedback">Selecciona una categoría.</div> }
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-medium text-foreground">Unidad de medida</label>
                            <input type="text" value="@_form.UnidadMedida"
                                   @oninput="@(e => { _form.UnidadMedida = e.Value?.ToString() ?? ""; _formDirty = true; })"
                                   class="form-control text-foreground" placeholder="Bolsa, Botella…" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-medium text-foreground">Stock *</label>
                            <input type="number" min="0" value="@_form.Stock"
                                   @oninput="@(e => { if(int.TryParse(e.Value?.ToString(), out var v)) _form.Stock = Math.Max(0,v); _formDirty = true; })"
                                   class="form-control text-foreground" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-medium text-foreground">Stock mínimo <span class="text-muted-foreground fw-normal">(alerta)</span></label>
                            <input type="number" min="0" value="@_form.MinStock"
                                   @oninput="@(e => { if(int.TryParse(e.Value?.ToString(), out var v)) _form.MinStock = Math.Max(0,v); _formDirty = true; })"
                                   class="form-control text-foreground" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-medium text-foreground">Código de barras *</label>
                            <input type="text" value="@_form.CodigoBarras"
                                   @oninput="@(e => { _form.CodigoBarras = e.Value?.ToString() ?? ""; _formDirty = true; })"
                                   class="form-control text-foreground @(_codigoError != null ? "is-invalid" : "")"
                                   placeholder="7750001000001" />
                            @if (_codigoError != null)
                            { <div class="invalid-feedback">@_codigoError</div> }
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-medium text-foreground">Imagen del producto</label>
                            @if (!string.IsNullOrEmpty(_form.Image))
                            {
                                <div class="mb-2">
                                    <img src="@_form.Image" alt="Vista previa" class="rounded-3 object-fit-cover border"
                                         style="width:80px;height:80px;" onerror="this.style.display='none'" />
                                </div>
                            }
                            <div class="mb-2">
                                <label class="form-label small text-muted-foreground mb-1">Subir archivo (JPG / PNG / WebP)</label>
                                @* Input HTML puro — evita el módulo JS interno de InputFile de Blazor
                                   que mata el circuito cuando se re-renderiza al cambiar "disabled". *@
                                <div class="d-flex align-items-center gap-2">
                                    <div class="flex-grow-1">
                                        <input type="file" id="productImageInput"
                                               accept="image/jpeg,image/png,image/gif,image/webp"
                                               class="form-control text-foreground" />
                                    </div>
                                    <button type="button" @onclick="UploadImage"
                                            class="btn btn-outline-secondary btn-sm text-nowrap flex-shrink-0"
                                            disabled="@_uploadingImage">
                                        @if (_uploadingImage) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                        Máx. 5 MB
                                    </button>
                                </div>
                                @if (_uploadingImage) { <div class="small text-muted-foreground mt-1"><span class="spinner-border spinner-border-sm me-1"></span>Subiendo…</div> }
                                @if (!string.IsNullOrEmpty(_uploadError)) { <div class="small text-danger mt-1">@_uploadError</div> }
                            </div>
                            <div>
                                <label class="form-label small text-muted-foreground mb-1">O ingresar URL directamente</label>
                                <input type="url" value="@_form.Image"
                                       @oninput="@(e => { _form.Image = e.Value?.ToString() ?? ""; _formDirty = true; })"
                                       class="form-control text-foreground" placeholder="https://..." />
                            </div>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" @onclick="TryCloseModal" class="btn btn-secondary" style="border-radius:var(--radius);" disabled="@_saving">Cancelar</button>
                        <button type="button" @onclick="AskSave" class="btn btn-primary fw-medium" style="border-radius:var(--radius);" disabled="@_saving">
                            @(_saving ? "Guardando…" : _isEditing ? "Guardar cambios" : "Crear producto")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </ChildContent>
    <ErrorContent>
        <div class="alert alert-danger m-3 small">Ocurrió un error al renderizar el formulario. Cierra el modal e intenta de nuevo.</div>
    </ErrorContent>
</ErrorBoundary>
}

@if (_showSavedToast)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
        <div class="toast show text-white border-0 px-3 py-2" style="background:#1A6B3C;border-radius:var(--radius);min-width:260px;">
            <i class="fa-solid fa-circle-check me-2"></i>
            <span class="small">@_toastMsg</span>
        </div>
    </div>
}

<style>
    .pag-btn { background:var(--card); border:1px solid var(--border); color:var(--foreground); transition:all .15s; }
    .pag-btn:hover:not(:disabled) { background:var(--secondary); }
    .pag-btn:disabled { opacity:.4; }
    .pag-active { background:#1A6B3C !important; color:#fff !important; border-color:#1A6B3C !important; }
</style>

@code {
    private List<Product>   _products   = new();
    private List<Category>  _categories = new();
    private List<Promocion> _promos     = new();
    private bool _loading = true;

    private string _search = ""; private string _categoryFilter = "";
    private string _filterOption = "";

    private int _pageSize = 10; private int _currentPage = 1;

    private bool    _showModal = false; private bool _isEditing = false;
    private bool    _formDirty = false; private bool _submitted = false;
    private Product _form = new(); private string _precioRaw = "";
    private string? _precioError = null; private string? _codigoError = null;
    private string  _saveError = ""; private bool _saving = false;
    private bool    _showSaveConfirm = false; private bool _showUnsavedConfirm = false;
    private bool    _showSavedToast = false; private string _toastMsg = "";
    private bool    _showToggleConfirm = false; private Product? _toggleProduct = null;
    private bool    _uploadingImage = false; private string _uploadError = "";

    // Referencia JS para el patrón callback (JS llama a OnUploadComplete cuando termina).
    private DotNetObjectReference<Productos>? _uploadRef;

    protected override void OnInitialized()
    {
        // Crea la referencia .NET que el JS usará para llamar a OnUploadComplete.
        _uploadRef = DotNetObjectReference.Create(this);
    }

    public void Dispose()
    {
        _uploadRef?.Dispose();
    }

    protected override async Task OnInitializedAsync()
    {

          try
        {
            await ProductSvc.EnsureLoadedAsync(recargar: true);
            // PromocionService ya carga con /con-productos — una sola llamada, sin N+1
            await PromoSvc.EnsureLoadedAsync();
            _products   = ProductSvc.GetProducts();
            _categories = ProductSvc.GetCategories();
            _promos     = new List<Promocion>(PromoSvc.GetPromociones());
            // NO hay loop aquí de GetProductosDePromocionAsync — ya vienen incluidos
            SyncProductBadges(); 
            
        }
        finally
        {
            _loading = false;
        }
        
    }

    private void SyncProductBadges()
    {
        foreach (var p in _products)
            p.IsPromo = _promos.Any(pr => pr.Activo && pr.FechaFin >= DateTime.Today && pr.ProductoIds.Contains(p.Id));
    }

    private decimal? CalcularPrecioPromo(decimal orig, Promocion pr) => pr.TipoDescuento switch
    {
        "PORCENTAJE" => Math.Round(orig * (1 - (decimal)pr.ValorDescuento / 100), 2),
        "MONTO_FIJO" => Math.Max(0, orig - (decimal)pr.ValorDescuento),
        _ => null
    };

    private IEnumerable<Product> Filtered => _products
        .Where(p =>
            (string.IsNullOrEmpty(_search)         || p.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(_categoryFilter) || p.Category == _categoryFilter) &&
            (_filterOption switch
            {
                "activos"    => p.Estado,
                "stock_bajo" => p.Stock > 0 && p.Stock <= p.MinStock,
                "agotados"   => p.Stock == 0,
                "en_oferta"  => p.IsPromo,
                _            => true
            })
        )
        .OrderBy(p => p.Stock == 0 || !p.Estado ? 2 : p.Stock <= p.MinStock ? 1 : 0)
        .ThenByDescending(p => p.Id);

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(Filtered.Count() / (double)_pageSize));
    private IEnumerable<Product> Paged => Filtered.Skip((_currentPage - 1) * _pageSize).Take(_pageSize);
    private void SetFilterOption(string opt) { _filterOption = opt; _currentPage = 1; }
    private string BtnClass(string opt, string activeClass = "btn-dark")
        => _filterOption == opt ? activeClass : "btn-outline-secondary";
    private void ResetPage() => _currentPage = 1;
    private void GoToPage(int p) { if (p >= 1 && p <= TotalPages) _currentPage = p; }

    private void OnPrecioInput(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? "";
        var filtrado = new string(raw.Where(c => char.IsDigit(c) || c == '.' || c == ',').ToArray());
        _precioRaw = filtrado; _formDirty = true;
        var norm = filtrado.Replace(',', '.');
        if (decimal.TryParse(norm, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var val))
        { _form.Price = val; _precioError = val <= 0 ? "El precio debe ser mayor a 0." : null; }
        else if (string.IsNullOrEmpty(filtrado)) { _form.Price = 0; _precioError = "El precio es obligatorio."; }
        else { _precioError = "Ingresa un número válido (ej: 12.50)."; }
    }

    private bool EsDuplicadoCodigo() =>
        !string.IsNullOrWhiteSpace(_form.CodigoBarras) &&
        _products.Any(p => p.CodigoBarras == _form.CodigoBarras && p.Id != _form.Id);

    private void OpenCreate()
    {
        _form = new Product { CodigoBarras = GenerarEAN13() };
        _precioRaw = ""; _isEditing = false; _formDirty = false; _submitted = false;
        _saveError = ""; _precioError = null; _codigoError = null; _showModal = true;
    }

    private void OpenEdit(Product p)
    {
        _form = new Product { Id=p.Id, Name=p.Name, Description=p.Description, Price=p.Price,
            Stock=p.Stock, MinStock=p.MinStock, Category=p.Category, Image=p.Image,
            CodigoBarras=p.CodigoBarras, UnidadMedida=p.UnidadMedida, Estado=p.Estado };
        _precioRaw = p.Price.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);
        _isEditing = true; _formDirty = false; _submitted = false;
        _saveError = ""; _precioError = null; _codigoError = null; _showModal = true;
    }

    private void TryCloseModal()   { if (_formDirty) _showUnsavedConfirm = true; else ForceCloseModal(); }
    private void ForceCloseModal() { _showUnsavedConfirm = false; _showModal = false; }

    private void AskSave()
    {
        _submitted = true; _codigoError = null;
        if (string.IsNullOrWhiteSpace(_form.Name)) return;
        if (_form.Price <= 0 || _precioError != null) { _precioError ??= "El precio debe ser mayor a 0."; return; }
        if (EsDuplicadoCodigo()) { _codigoError = "Ya existe un producto con este código de barras."; return; }
        _showSaveConfirm = true;
    }

    private async Task Save()
    {
        _showSaveConfirm = false; _saving = true; _saveError = "";
        try
        {
            if (_isEditing) await ProductSvc.UpdateProductAsync(_form);
            else            await ProductSvc.AddProductAsync(_form);
            _products = ProductSvc.GetProducts();
            SyncProductBadges();
            _showModal = false; _formDirty = false;
            _toastMsg = $"Producto {(_isEditing ? "actualizado" : "creado")} correctamente";
            _showSavedToast = true; StateHasChanged();
            await Task.Delay(3000); _showSavedToast = false; StateHasChanged();
        }
        catch (Exception ex) { _saveError = $"Error al guardar: {ex.Message}"; }
        finally { _saving = false; }
    }

    private void AskToggleEstado(Product p) { _toggleProduct = p; _showToggleConfirm = true; }

    private async Task ConfirmToggleEstado()
    {
        if (_toggleProduct == null) return;
        _toggleProduct.Estado = !_toggleProduct.Estado;
        try { await ProductSvc.UpdateProductAsync(_toggleProduct); } catch { }
        _showToggleConfirm = false;
        StateHasChanged();
    }

    private async Task AdjustStock(Product p, int amount)
    {
        var stockAnterior = p.Stock;
        p.Stock = Math.Max(0, p.Stock + amount);

        // Auto-desactivar al llegar a 0, reactivar al subir de 0
        if (p.Stock == 0 && p.Estado)       p.Estado = false;
        else if (stockAnterior == 0 && p.Stock > 0 && !p.Estado) p.Estado = true;

        try { await ProductSvc.UpdateProductAsync(p); } catch { }
        StateHasChanged();
    }

    // Patrón fire-and-forget + callback JS→.NET:
    // UploadImage() retorna de inmediato; el JS hace el fetch() en background
    // y llama a OnUploadComplete cuando termina.
    // Esto evita que el circuit quede en estado "esperando JS interop" durante
    // el upload, lo cual en .NET 10 Blazor Server puede matar el circuit.
    private async Task UploadImage()
    {
        try
        {
            _uploadError = ""; _uploadingImage = true;

            // Ruta relativa al servidor Blazor. JS la resuelve contra window.location
            // → https://localhost:7282/api/img-upload (HTTPS, mismo origen).
            // El endpoint /api/img-upload reenvía server-to-server a GlassFish,
            // eliminando el mixed-content y los bloqueos CORS de Brave/Edge.
            const string uploadUrl = "/api/img-upload";

            // Función JS NO-async: inicia el upload en background y retorna de inmediato.
            // El resultado llega vía dotNetRef.invokeMethodAsync → OnUploadComplete.
            await JS.InvokeVoidAsync("shiligamaStartUpload", _uploadRef, "productImageInput", uploadUrl);
            // UploadImage() retorna aquí. _uploadingImage sigue true hasta que OnUploadComplete lo cambie.
        }
        catch (Exception ex)
        {
            // Si InvokeVoidAsync falla (JS no cargado, circuit cerrando, etc.) mostramos el error
            // sin matar el circuit.
            _uploadingImage = false;
            _uploadError = ex.Message;
        }
    }

    /// <summary>
    /// Llamado desde JavaScript (dotNetRef.invokeMethodAsync) cuando el upload termina.
    /// </summary>
    [JSInvokable]
    public async Task OnUploadComplete(string? url, string? error)
    {
        await InvokeAsync(() =>
        {
            _uploadingImage = false;
            if (!string.IsNullOrEmpty(url))
            {
                _form.Image = url;
                _formDirty  = true;
                _uploadError = "";
            }
            else
            {
                _uploadError = error ?? "Error desconocido al subir imagen.";
            }
            StateHasChanged();
        });
    }

    private int CalcularChecksumEAN13(string code12)
    {
        int sum = 0;
        for (int i = 0; i < 12; i++) { int d = code12[i]-'0'; sum += (i%2==0)?d:d*3; }
        int mod = sum%10; return mod==0?0:10-mod;
    }

    private string GenerarEAN13()
    {
        string base12; string codigoCompleto;
        do {
            base12 = "775" + RandomNumberGenerator.GetInt32(100_000_000,999_999_999).ToString();
            codigoCompleto = base12 + CalcularChecksumEAN13(base12);
        } while (_products.Any(p => p.CodigoBarras == codigoCompleto));
        return codigoCompleto;
    }
}
