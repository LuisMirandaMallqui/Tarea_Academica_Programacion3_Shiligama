@page "/admin/pedidos"
@layout AdminLayout
@inject SalesService SalesSvc

<PageTitle>Pedidos – Shiligama Admin</PageTitle>

<div class="d-flex flex-column gap-4">
    <!-- Header -->
    <div>
        <h1 class="fs-4 fw-bold text-foreground mb-0">Gestión de Pedidos</h1>
        <p class="text-muted-foreground small mt-1 mb-0">Monitorea y despacha pedidos realizados por clientes</p>
    </div>

    <!-- Filtros -->
    <div class="card p-4" style="border-radius:12px;">
        <div class="row g-3 align-items-end">

            <!-- Buscar -->
            <div class="col-md-5">
                <label class="form-label small fw-medium text-foreground mb-1">Buscar</label>
                <div class="position-relative">
                    <i class="fa-solid fa-magnifying-glass position-absolute top-50 translate-middle-y text-muted" style="left:14px;font-size:14px;"></i>
                    <input type="search" value="@_search"
                           @oninput="@(e => { _search = e.Value?.ToString() ?? ""; _currentPage = 1; })"
                           class="form-control text-foreground"
                           placeholder="Buscar por cliente o código de pedido..."
                           style="height:44px;padding-left:40px;" />
                </div>
            </div>

            <!-- Estado -->
            <div class="col-md-3">
                <label class="form-label small fw-medium text-foreground mb-1">Estado</label>
                <select value="@_statusFilter"
                        @onchange="@(e => { _statusFilter = e.Value?.ToString() ?? ""; _currentPage = 1; })"
                        class="form-select text-foreground" style="height:44px;">
                    <option value="">Todos los estados</option>
                    <option value="recibido">Recibido</option>
                    <option value="en_proceso">En proceso</option>
                    <option value="atendido">Atendido</option>
                    <option value="rechazado">Rechazado</option>
                    <option value="cancelado">Cancelado</option>
                </select>
            </div>

            <!-- Activo / Inactivo (equivale a estados "vivos" vs terminados) -->
            <div class="col-md-4">
                <label class="form-label small fw-medium text-foreground mb-1">Actividad</label>
                <select value="@_actividadFilter"
                        @onchange="@(e => { _actividadFilter = e.Value?.ToString() ?? ""; _currentPage = 1; })"
                        class="form-select text-foreground" style="height:44px;">
                    <option value="">Todos</option>
                    <option value="activo">Activos (recibido / en proceso)</option>
                    <option value="inactivo">Inactivos (atendido / rechazado / cancelado)</option>
                </select>
            </div>

            <!-- Rango de fechas -->
            <div class="col-12">
                <div class="card border rounded-3 p-3" style="background:var(--secondary);">
                    <div class="row g-3 align-items-end">
                        <div class="col-auto d-flex align-items-center gap-2" style="margin-bottom:8px;">
                            <i class="fa-regular fa-calendar text-primary" style="font-size:1.1rem;"></i>
                            <span class="small fw-semibold text-foreground">Rango de fechas</span>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small text-muted-foreground mb-1">Desde</label>
                            <input type="date" @bind="_fechaDesde" @bind:after="OnFechaChange"
                                   class="form-control text-foreground" style="height:40px;" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small text-muted-foreground mb-1">Hasta</label>
                            <input type="date" @bind="_fechaHasta" @bind:after="OnFechaChange"
                                   class="form-control text-foreground" style="height:40px;" />
                        </div>
                        <div class="col-auto d-flex gap-2 align-items-end">
                            <button class="btn btn-outline-secondary btn-sm" style="height:40px;border-radius:8px;" @onclick="SetHoy">Hoy</button>
                            <button class="btn btn-outline-secondary btn-sm" style="height:40px;border-radius:8px;" @onclick="Set7Dias">7 días</button>
                            <button class="btn btn-outline-secondary btn-sm" style="height:40px;border-radius:8px;" @onclick="Set30Dias">30 días</button>
                            @if (_fechaDesde.HasValue || _fechaHasta.HasValue)
                            {
                                <button class="btn btn-ghost btn-sm text-muted-foreground" style="height:40px;" @onclick="LimpiarFechas" title="Limpiar fechas">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Rango de monto total -->
            <div class="col-md-6">
                <label class="form-label small fw-medium text-foreground mb-1">Monto mínimo (S/.)</label>
                <input type="number" min="0" step="0.01" @bind="_montoMin" @bind:after="OnMontoChange"
                       class="form-control text-foreground" placeholder="0.00" style="height:44px;" />
            </div>
            <div class="col-md-6">
                <label class="form-label small fw-medium text-foreground mb-1">Monto máximo (S/.)</label>
                <input type="number" min="0" step="0.01" @bind="_montoMax" @bind:after="OnMontoChange"
                       class="form-control text-foreground" placeholder="Sin límite" style="height:44px;" />
            </div>

        </div>
    </div>

    <!-- Resumen de filtros activos -->
    @if (TieneFiltrosaActivos)
    {
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="small text-muted-foreground">Filtros activos:</span>
            @if (!string.IsNullOrEmpty(_search))
            {
                <span class="badge bg-primary-subtle text-primary">
                    Búsqueda: "@_search"
                    <button class="btn-close btn-close-sm ms-1" style="font-size:.6rem;" @onclick="@(() => { _search = ""; _currentPage = 1; })"></button>
                </span>
            }
            @if (_fechaDesde.HasValue || _fechaHasta.HasValue)
            {
                <span class="badge bg-info-subtle text-info">
                    Fechas: @(_fechaDesde?.ToString("dd/MM/yy") ?? "…") → @(_fechaHasta?.ToString("dd/MM/yy") ?? "…")
                    <button class="btn-close btn-close-sm ms-1" style="font-size:.6rem;" @onclick="LimpiarFechas"></button>
                </span>
            }
            @if (_montoMin.HasValue || _montoMax.HasValue)
            {
                <span class="badge bg-warning-subtle text-warning">
                    Monto: S/. @(_montoMin?.ToString("0.00") ?? "0") – @(_montoMax?.ToString("0.00") ?? "∞")
                    <button class="btn-close btn-close-sm ms-1" style="font-size:.6rem;" @onclick="@(() => { _montoMin = null; _montoMax = null; _currentPage = 1; })"></button>
                </span>
            }
            <span class="small text-muted-foreground ms-2">@Filtered.Count() resultado(s)</span>
        </div>
    }

    <!-- Tabla -->
    <div class="card" style="overflow:visible;">
        <div class="table-responsive" style="overflow:visible;">
            <table class="table table-borderless mb-0">
                <thead class="border-bottom border-color-default">
                    <tr>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Código</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Cliente</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase d-none d-md-table-cell" style="letter-spacing:.05em;">Fecha</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase d-none d-md-table-cell" style="letter-spacing:.05em;">Items</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Total</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Estado</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-end" style="letter-spacing:.05em;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in PagedOrders)
                    {
                        <tr class="border-bottom border-color-default align-middle">
                            <td class="px-4 py-3 fw-bold text-primary small">@order.Id</td>
                            <td class="px-4 py-3">
                                <span class="fw-medium text-foreground small d-block">@order.Customer</span>
                                <span class="text-xs text-muted-foreground">Vía @order.Channel</span>
                            </td>
                            <td class="px-4 py-3 text-muted-foreground small d-none d-md-table-cell">
                                @order.Date.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td class="px-4 py-3 text-foreground small d-none d-md-table-cell">@order.Items items</td>
                            <td class="px-4 py-3 fw-semibold text-foreground small">S/. @order.Total.ToString("0.00")</td>
                            <td class="px-4 py-3">
                                <span class="badge @GetStatusClass(order.Status) py-1 px-2" style="border-radius:var(--radius);font-size:.8rem;">
                                    @GetStatusLabel(order.Status)
                                </span>
                            </td>
                            <td class="px-4 py-3 text-end">
                                <div class="d-flex align-items-center justify-content-end gap-1">
                                    <!-- Cambio de estado -->
                                    <div class="dropdown d-inline-block">
                                        <button class="btn btn-ghost btn-sm text-muted-foreground"
                                                type="button" data-bs-toggle="dropdown" aria-expanded="false"
                                                style="border-radius:var(--radius);" title="Cambiar estado">
                                            <i class="fa-solid fa-gear"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow border p-1" style="border-radius:var(--radius);">
                                            <li><h6 class="dropdown-header small">Cambiar estado</h6></li>
                                            <li><button type="button" @onclick="@(() => AskStatusChange(order.Id, "recibido"))" class="dropdown-item py-1 small rounded"><i class="fa-solid fa-inbox me-2 text-secondary"></i>Recibido</button></li>
                                            <li><button type="button" @onclick="@(() => AskStatusChange(order.Id, "en_proceso"))" class="dropdown-item py-1 small rounded"><i class="fa-solid fa-box-open me-2 text-warning"></i>En proceso</button></li>
                                            <li><button type="button" @onclick="@(() => AskStatusChange(order.Id, "atendido"))" class="dropdown-item py-1 small rounded text-success"><i class="fa-solid fa-circle-check me-2"></i>Atendido</button></li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li><button type="button" @onclick="@(() => AskStatusChange(order.Id, "rechazado"))" class="dropdown-item py-1 small rounded text-danger"><i class="fa-solid fa-xmark me-2"></i>Rechazado</button></li>
                                            <li><button type="button" @onclick="@(() => AskStatusChange(order.Id, "cancelado"))" class="dropdown-item py-1 small rounded text-danger"><i class="fa-solid fa-ban me-2"></i>Cancelado</button></li>
                                        </ul>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!PagedOrders.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted-foreground">No se encontraron pedidos con los filtros seleccionados</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Paginación -->
    @if (TotalPages > 1)
    {
        <div class="d-flex justify-content-center align-items-center gap-2 py-2">
            <button class="btn btn-sm rounded-circle pag-btn" @onclick="@(() => GoToPage(_currentPage - 1))" disabled="@(_currentPage == 1)" style="width:36px;height:36px;">
                <i class="fa-solid fa-chevron-left" style="font-size:.75rem;"></i>
            </button>
            @for (int p = 1; p <= TotalPages; p++)
            {
                var pg = p;
                <button class="btn btn-sm rounded-circle pag-btn @(pg == _currentPage ? "pag-active" : "")"
                        @onclick="@(() => GoToPage(pg))"
                        style="width:36px;height:36px;font-size:.85rem;font-weight:600;">
                    @pg
                </button>
            }
            <button class="btn btn-sm rounded-circle pag-btn" @onclick="@(() => GoToPage(_currentPage + 1))" disabled="@(_currentPage == TotalPages)" style="width:36px;height:36px;">
                <i class="fa-solid fa-chevron-right" style="font-size:.75rem;"></i>
            </button>
        </div>
    }
</div>

<!-- Modal: Confirmar Cambio de Estado -->
@if (_showEditConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45);">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">⚙️</div>
                    <h5 class="fw-bold text-foreground mb-1">¿Cambiar estado?</h5>
                    <p class="text-muted-foreground small mb-4">El pedido <strong>@_pendingEditId</strong> pasará a <strong>@GetStatusLabel(_pendingEditStatus ?? "")</strong>.</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="button" class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="CancelEdit">Cancelar</button>
                        <button type="button" class="btn btn-primary" style="border-radius:var(--radius);" @onclick="ConfirmEdit">Confirmar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Toast: Estado actualizado -->
@if (_showEditedToast)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
        <div class="toast show align-items-center text-white border-0" style="background:#1A6B3C;border-radius:var(--radius);min-width:280px;">
            <div class="d-flex align-items-center gap-2 px-3 py-2">
                <i class="fa-solid fa-circle-check"></i>
                <span class="small">Estado actualizado correctamente</span>
            </div>
        </div>
    </div>
}

<style>
    .pag-btn { background:var(--card); border:1px solid var(--border); color:var(--foreground); transition:all .15s; }
    .pag-btn:hover:not(:disabled) { background:var(--secondary); }
    .pag-btn:disabled { opacity:.4; }
    .pag-active { background:#1A6B3C !important; color:#fff !important; border-color:#1A6B3C !important; }
</style>

@code {
    private List<Order> _orders = new();
    private string _search        = "";
    private string _statusFilter  = "";
    private string _actividadFilter = "";
    private DateTime? _fechaDesde = null;
    private DateTime? _fechaHasta = null;
    private decimal? _montoMin    = null;
    private decimal? _montoMax    = null;

    // Paginación
    private int _pageSize    = 8;
    private int _currentPage = 1;

    // Modales
    private bool _showEditConfirm  = false;
    private bool _showEditedToast  = false;
    private string? _pendingEditId;
    private string? _pendingEditStatus;

    protected override async Task OnInitializedAsync()
    {
        await SalesSvc.EnsureLoadedAsync(recargar: true);
        _orders = SalesSvc.GetRecentOrders();
    }

    private static readonly Dictionary<string,int> StatusOrder = new(StringComparer.OrdinalIgnoreCase)
    {
        {"recibido",0}, {"en_proceso",1}, {"atendido",2}, {"rechazado",3}, {"cancelado",4}
    };

    private static readonly HashSet<string> EstadosActivos   = new(StringComparer.OrdinalIgnoreCase) { "recibido", "en_proceso" };
    private static readonly HashSet<string> EstadosInactivos = new(StringComparer.OrdinalIgnoreCase) { "atendido", "rechazado", "cancelado" };

    private IEnumerable<Order> Filtered => _orders.Where(o =>
        (string.IsNullOrEmpty(_search) ||
         o.Customer.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
         o.Id.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_statusFilter) ||
         o.Status.Equals(_statusFilter, StringComparison.OrdinalIgnoreCase)) &&
        (_actividadFilter switch {
            "activo"   => EstadosActivos.Contains(o.Status),
            "inactivo" => EstadosInactivos.Contains(o.Status),
            _          => true
        }) &&
        (!_fechaDesde.HasValue || o.Date.Date >= _fechaDesde.Value.Date) &&
        (!_fechaHasta.HasValue || o.Date.Date <= _fechaHasta.Value.Date) &&
        (!_montoMin.HasValue || o.Total >= _montoMin.Value) &&
        (!_montoMax.HasValue || o.Total <= _montoMax.Value)
    )
    .OrderBy(o => StatusOrder.TryGetValue(o.Status, out var r) ? r : 99)
    .ThenByDescending(o => o.Date);

    private bool TieneFiltrosaActivos =>
        !string.IsNullOrEmpty(_search) || _fechaDesde.HasValue || _fechaHasta.HasValue ||
        _montoMin.HasValue || _montoMax.HasValue;

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(Filtered.Count() / (double)_pageSize));

    private IEnumerable<Order> PagedOrders => Filtered
        .Skip((_currentPage - 1) * _pageSize)
        .Take(_pageSize);

    private void GoToPage(int page) { if (page >= 1 && page <= TotalPages) _currentPage = page; }

    private void OnFechaChange()  { _currentPage = 1; }
    private void OnMontoChange()  { _currentPage = 1; }

    private void SetHoy()    { _fechaDesde = DateTime.Today; _fechaHasta = DateTime.Today; _currentPage = 1; }
    private void Set7Dias()  { _fechaDesde = DateTime.Today.AddDays(-7); _fechaHasta = DateTime.Today; _currentPage = 1; }
    private void Set30Dias() { _fechaDesde = DateTime.Today.AddDays(-30); _fechaHasta = DateTime.Today; _currentPage = 1; }
    private void LimpiarFechas() { _fechaDesde = null; _fechaHasta = null; _currentPage = 1; }

    private void AskStatusChange(string id, string newStatus)
    {
        _pendingEditId     = id;
        _pendingEditStatus = newStatus;
        _showEditConfirm   = true;
    }
    private void CancelEdit() { _showEditConfirm = false; _pendingEditId = null; _pendingEditStatus = null; }
    private async Task ConfirmEdit()
    {
        if (_pendingEditId == null || _pendingEditStatus == null) return;
        await SalesSvc.UpdateOrderStatusAsync(_pendingEditId, _pendingEditStatus);
        _showEditConfirm = false;
        _pendingEditId   = null;
        _pendingEditStatus = null;
        _showEditedToast = true;
        StateHasChanged();
        await Task.Delay(3000);
        _showEditedToast = false;
        StateHasChanged();
    }

    private string GetStatusClass(string status) => status.ToLower() switch
    {
        "atendido"   => "bg-success-subtle text-success",
        "en_proceso" => "bg-warning-subtle text-warning",
        "recibido"   => "bg-secondary text-muted-foreground",
        "rechazado"  => "bg-danger-subtle text-danger",
        "cancelado"  => "bg-danger-subtle text-danger",
        _ => "bg-light text-dark"
    };

    private string GetStatusLabel(string status) => status.ToLower() switch
    {
        "recibido"   => "Recibido",
        "en_proceso" => "En proceso",
        "atendido"   => "Atendido",
        "rechazado"  => "Rechazado",
        "cancelado"  => "Cancelado",
        _ => status
    };
}
