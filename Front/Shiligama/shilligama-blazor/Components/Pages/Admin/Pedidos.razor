@page "/admin/pedidos"
@layout AdminLayout
@inject SalesService SalesSvc

<PageTitle>Pedidos – Shiligama Admin</PageTitle>

<style>
    @@keyframes cartTrip {
        0%   { transform: translateX(-120px);                        opacity: 0; }
        12%  { transform: translateX(-30px)  translateY(0);         opacity: 1; }
        25%  { transform: translateX(20px)   translateY(-18px)   rotate(90deg); }
        40%  { transform: translateX(0)      translateY(-38px)   rotate(180deg); }
        55%  { transform: translateX(-20px)  translateY(-18px)   rotate(270deg); }
        68%  { transform: translateX(30px)   translateY(0)       rotate(360deg); }
        85%  { transform: translateX(120px);                        opacity: 0; }
        100% { transform: translateX(120px);                        opacity: 0; }
    }
</style>

<div class="d-flex flex-column gap-4">

@if (_loading)
{
    <div class="d-flex flex-column align-items-center justify-content-center py-5 w-100" style="min-height:400px;">
        <div style="font-size:4rem;color:#1A6B3C;animation:cartTrip 3.5s ease-in-out infinite;">
            <i class="fas fa-shopping-cart"></i>
        </div>
        <div class="mt-3" style="color:#1A6B3C;font-weight:600;font-size:1.1rem;">Cargando...</div>
    </div>
}
else
{
    <PedidosCardList @ref="_cardListRef" ActiveOnly="true" PageSize="6" OnOrderStatusChanged="RecargarPedidos" />

    <!-- Historial de pedidos -->
    <div class="mt-4">
        <h2 class="fw-bold text-foreground mb-0" style="font-family:'Outfit',sans-serif;font-size:1.9rem;letter-spacing:-0.01em;">Historial de pedidos</h2>
        <p class="text-muted-foreground small mb-0">Pedidos atendidos, rechazados y cancelados</p>
    </div>

    <!-- Filtros -->
    <div class="card p-4" style="border-radius:12px;">
        <div class="row g-3 align-items-end">

            <!-- Buscar -->
            <div class="col-md-4">
                <label class="form-label small fw-medium text-foreground mb-1">Buscar</label>
                <div class="position-relative">
                    <i class="fa-solid fa-magnifying-glass position-absolute top-50 translate-middle-y text-muted" style="left:14px;font-size:14px;"></i>
                    <input type="search" value="@_search"
                           @oninput="@(e => { _search = e.Value?.ToString() ?? ""; _currentPage = 1; })"
                           class="form-control text-foreground"
                           placeholder="Buscar por cliente o código de pedido..."
                           style="height:44px;padding-left:40px;" />
                </div>
            </div>

            <!-- Estado -->
            <div class="col-md-2">
                <label class="form-label small fw-medium text-foreground mb-1">Estado</label>
                <select value="@_statusFilter"
                        @onchange="@(e => { _statusFilter = e.Value?.ToString() ?? ""; _currentPage = 1; })"
                        class="form-select text-foreground" style="height:44px;">
                    <option value="">Todos los estados</option>
                    <option value="atendido">Aceptado</option>
                    <option value="rechazado">Rechazado</option>
                    <option value="cancelado">Cancelado</option>
                </select>
            </div>

            <!-- Desde -->
            <div class="col-md-2">
                <label class="form-label small fw-medium text-foreground mb-1">Desde</label>
                <input type="date" @bind="_fechaDesde" @bind:after="OnFechaChange"
                       class="form-control text-foreground" style="height:44px;" />
            </div>

            <!-- Hasta -->
            <div class="col-md-2">
                <label class="form-label small fw-medium text-foreground mb-1">Hasta</label>
                <input type="date" @bind="_fechaHasta" @bind:after="OnFechaChange"
                       class="form-control text-foreground" style="height:44px;" />
            </div>

            <!-- Botones rápidos -->
            <div class="col-md-2 d-flex gap-1 align-items-end">
                <button class="btn btn-outline-secondary btn-sm" style="height:44px;border-radius:8px;flex:1;font-size:0.78rem;padding:0;" @onclick="SetHoy">Hoy</button>
                <button class="btn btn-outline-secondary btn-sm" style="height:44px;border-radius:8px;flex:1;font-size:0.78rem;padding:0;" @onclick="Set7Dias">7d</button>
                <button class="btn btn-outline-secondary btn-sm" style="height:44px;border-radius:8px;flex:1;font-size:0.78rem;padding:0;" @onclick="Set30Dias">30d</button>
                @if (_fechaDesde.HasValue || _fechaHasta.HasValue)
                {
                    <button class="btn btn-ghost btn-sm text-muted-foreground d-flex align-items-center justify-content-center" style="height:44px;width:44px;flex-shrink:0;" @onclick="LimpiarFechas" title="Limpiar fechas">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                }
            </div>

        </div>
    </div>

    <!-- Resumen de filtros activos -->
    @if (TieneFiltrosaActivos)
    {
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="small text-muted-foreground">Filtros activos:</span>
            @if (!string.IsNullOrEmpty(_search))
            {
                <span class="badge bg-primary-subtle text-primary">
                    Búsqueda: "@_search"
                    <button class="btn-close btn-close-sm ms-1" style="font-size:.6rem;" @onclick="@(() => { _search = ""; _currentPage = 1; })"></button>
                </span>
            }
            @if (_fechaDesde.HasValue || _fechaHasta.HasValue)
            {
                <span class="badge bg-info-subtle text-info">
                    Fechas: @(_fechaDesde?.ToString("dd/MM/yy") ?? "…") → @(_fechaHasta?.ToString("dd/MM/yy") ?? "…")
                    <button class="btn-close btn-close-sm ms-1" style="font-size:.6rem;" @onclick="LimpiarFechas"></button>
                </span>
            }
            <span class="small text-muted-foreground ms-2">@Filtered.Count() resultado(s)</span>
        </div>
    }

    <!-- Tabla -->
    <div class="card" style="overflow:visible;">
        <div class="table-responsive" style="overflow:visible;">
            <table class="table table-borderless mb-0">
                <thead class="border-bottom border-color-default">
                    <tr>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Código</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Cliente</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase d-none d-md-table-cell" style="letter-spacing:.05em;">Fecha</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase d-none d-md-table-cell" style="letter-spacing:.05em;">Items</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Total</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Estado</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-end" style="letter-spacing:.05em;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in PagedOrders)
                    {
                        <tr class="border-bottom border-color-default align-middle">
                            <td class="px-4 py-3 fw-bold text-primary small">@order.Id</td>
                            <td class="px-4 py-3">
                                <span class="fw-medium text-foreground small d-block">@order.Customer</span>
                                <span class="text-xs text-muted-foreground">Vía @order.Channel</span>
                            </td>
                            <td class="px-4 py-3 text-muted-foreground small d-none d-md-table-cell">
                                @order.Date.ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td class="px-4 py-3 text-foreground small d-none d-md-table-cell">@order.Items items</td>
                            <td class="px-4 py-3 fw-semibold text-foreground small">S/. @order.Total.ToString("0.00")</td>
                            <td class="px-4 py-3">
                                <span class="badge @GetStatusClass(order.Status) py-1 px-2" style="border-radius:var(--radius);font-size:.8rem;">
                                    @GetStatusLabel(order.Status)
                                </span>
                                @if (!string.IsNullOrEmpty(order.Observaciones))
                                {
                                    <br/><span class="text-muted-foreground" style="font-size:0.65rem;line-height:1.2;display:inline-block;margin-top:2px;max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@order.Observaciones">
                                        <i class="fa-regular fa-comment me-1"></i>@order.Observaciones
                                    </span>
                                }
                            </td>
                            <td class="px-4 py-3 text-end">
                                <div class="d-flex align-items-center justify-content-end gap-1">
                                    <button class="btn btn-sm btn-outline-primary d-inline-flex align-items-center gap-1"
                                            @onclick="@(() => VerDetalle(order))"
                                            style="border-radius:var(--radius);font-size:0.8rem;">
                                        <i class="fa-solid fa-eye"></i> Ver detalles
                                    </button>
                                    <button class="btn btn-sm p-1 text-muted-foreground"
                                            @onclick="@(() => AskCambiarEstado(order))"
                                            title="Modificar estado del pedido"
                                            style="border:none;background:transparent;box-shadow:none;">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!PagedOrders.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted-foreground">No se encontraron pedidos con los filtros seleccionados</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Paginación -->
    @if (TotalPages > 1)
    {
        <div class="d-flex justify-content-center align-items-center gap-2 py-2">
            <button class="btn btn-sm rounded-circle pag-btn" @onclick="@(() => GoToPage(_currentPage - 1))" disabled="@(_currentPage == 1)" style="width:36px;height:36px;">
                <i class="fa-solid fa-chevron-left" style="font-size:.75rem;"></i>
            </button>
            @for (int p = 1; p <= TotalPages; p++)
            {
                var pg = p;
                <button class="btn btn-sm rounded-circle pag-btn @(pg == _currentPage ? "pag-active" : "")"
                        @onclick="@(() => GoToPage(pg))"
                        style="width:36px;height:36px;font-size:.85rem;font-weight:600;">
                    @pg
                </button>
            }
            <button class="btn btn-sm rounded-circle pag-btn" @onclick="@(() => GoToPage(_currentPage + 1))" disabled="@(_currentPage == TotalPages)" style="width:36px;height:36px;">
                <i class="fa-solid fa-chevron-right" style="font-size:.75rem;"></i>
            </button>
        </div>
    }
}
</div>

<!-- Modal Detalle de Pedido -->
@if (_showDetailModal && _detailOrder != null)
{
    <div class="detail-modal-overlay" @onclick="CerrarDetalle">
        <div class="detail-modal-container" @onclick:stopPropagation>

            <div class="detail-modal-header">
                <div class="d-flex flex-column gap-1">
                    <div class="d-flex align-items-center gap-2">
                        <span class="fw-bold text-foreground" style="font-size:1.1rem;font-family:'Outfit',sans-serif;">@_detailOrder.Id</span>
                        <span class="badge" style="@GetStatusBadgeStyle(_detailOrder.Status) font-size:0.73rem;border-radius:9999px;padding:4px 11px;">@GetStatusLabel(_detailOrder.Status)</span>
                    </div>
                    <span class="text-muted-foreground" style="font-size:0.78rem;">
                        <i class="far fa-calendar-alt me-1"></i>@_detailOrder.Date.ToString("dd/MM/yyyy")&nbsp;·&nbsp;
                        <i class="far fa-clock me-1"></i>@_detailOrder.Date.ToString("HH:mm")
                    </span>
                </div>
                <button class="detail-modal-close" @onclick="CerrarDetalle"><i class="fas fa-times"></i></button>
            </div>

            <div class="detail-modal-body">

                <!-- Datos del cliente -->
                <div class="detail-section">
                    <div class="detail-section-title"><i class="fas fa-user me-2"></i>Datos del Cliente</div>
                    <div class="detail-info-grid">
                        <div class="detail-info-row">
                            <span class="detail-label">Nombre</span>
                            <span class="detail-value fw-semibold">@_detailOrder.Customer</span>
                        </div>
                        <div class="detail-info-row">
                            <span class="detail-label">Canal</span>
                            <span class="detail-value">
                                <i class="fas @(_detailOrder.Channel=="Online"?"fa-globe":"fa-store") me-1 text-primary"></i>@_detailOrder.Channel
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Tipo de envío -->
                <div class="detail-section">
                    <div class="detail-section-title">
                        @if (_detailOrder.DeliveryMethod?.ToLower() == "delivery")
                        { <i class="fas fa-truck me-2" style="color:#1A6B3C;"></i> }
                        else
                        { <i class="fas fa-store me-2" style="color:#198754;"></i> }
                        Tipo de Envío
                    </div>
                    <div class="detail-info-grid">
                        <div class="detail-info-row">
                            <span class="detail-label">Método</span>
                            @if (_detailOrder.DeliveryMethod?.ToLower() == "delivery")
                            {
                                <span class="badge" style="background:#dcf0e8;color:#1A6B3C;font-size:0.73rem;font-weight:600;border-radius:9999px;padding:4px 11px;"><i class="fas fa-truck me-1"></i>Delivery</span>
                            }
                            else
                            {
                                <span class="badge" style="background:#e8f5e9;color:#198754;font-size:0.73rem;font-weight:600;border-radius:9999px;padding:4px 11px;"><i class="fas fa-store me-1"></i>Recojo en tienda</span>
                            }
                        </div>
                        @if (_detailOrder.DeliveryMethod?.ToLower() == "delivery" && !string.IsNullOrEmpty(_detailOrder.Address))
                        {
                            <div class="detail-info-row">
                                <span class="detail-label">Dirección</span>
                                <span class="detail-value"><i class="fas fa-map-marker-alt me-1" style="color:#dc3545;"></i>@_detailOrder.Address</span>
                            </div>
                        }
                    </div>
                </div>

                <!-- Productos -->
                <div class="detail-section">
                    <div class="detail-section-title"><i class="fas fa-shopping-basket me-2"></i>Productos del Pedido</div>
                    @if (_detailOrder.Products != null && _detailOrder.Products.Any())
                    {
                        <div class="detail-products-list">
                            @foreach (var product in _detailOrder.Products)
                            {
                                <div class="detail-product-row">
                                    <div class="detail-product-qty">x@product.Quantity</div>
                                    <div class="detail-product-name">@product.Name</div>
                                    <div class="detail-product-price">S/. @((product.Price * product.Quantity).ToString("0.00"))</div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted-foreground small m-0">Sin detalle de productos disponible.</p>
                    }
                </div>

                <!-- Resumen de pago -->
                <div class="detail-section">
                    <div class="detail-section-title"><i class="fas fa-receipt me-2"></i>Resumen de Pago</div>
                    <div class="detail-totals-block">
                        <div class="detail-totals-row">
                            <span class="detail-label">Subtotal</span>
                            <span class="detail-value">S/. @_detailOrder.Subtotal.ToString("0.00")</span>
                        </div>
                        <div class="detail-totals-row">
                            <span class="detail-label">Costo de envío</span>
                            @if (_detailOrder.DeliveryFee == 0)
                            { <span class="detail-value" style="color:#198754;font-weight:600;">Gratis</span> }
                            else
                            { <span class="detail-value">S/. @_detailOrder.DeliveryFee.ToString("0.00")</span> }
                        </div>
                        <div class="detail-totals-divider"></div>
                        <div class="detail-totals-row total-final">
                            <span>Total</span>
                            <span class="text-primary fw-bold" style="font-size:1.15rem;">S/. @_detailOrder.Total.ToString("0.00")</span>
                        </div>
                        <div class="detail-payment-method mt-2">
                            <span class="detail-label">Método de pago</span>
                            <div class="d-flex gap-2 mt-1">
                                @switch (_detailOrder.PaymentMethod?.ToLower())
                                {
                                    case "yape":
                                        <span class="badge text-white" style="background:#6f42c1;font-size:0.75rem;padding:5px 12px;font-weight:600;border-radius:8px;"><i class="fas fa-mobile-alt me-1"></i>Yape</span>
                                        <span class="badge" style="background:#e8f5e9;color:#198754;font-size:0.75rem;padding:5px 12px;font-weight:600;border-radius:8px;"><i class="fas fa-check-circle me-1"></i>Pagado</span>
                                        break;
                                    case "plin":
                                        <span class="badge text-white" style="background:#0dcaf0;font-size:0.75rem;padding:5px 12px;font-weight:600;border-radius:8px;"><i class="fas fa-mobile-alt me-1"></i>Plin</span>
                                        <span class="badge" style="background:#e8f5e9;color:#198754;font-size:0.75rem;padding:5px 12px;font-weight:600;border-radius:8px;"><i class="fas fa-check-circle me-1"></i>Pagado</span>
                                        break;
                                    case "tarjeta":
                                        <span class="badge text-white" style="background:#1A6B3C;font-size:0.75rem;padding:5px 12px;font-weight:600;border-radius:8px;"><i class="fas fa-credit-card me-1"></i>Tarjeta</span>
                                        <span class="badge" style="background:#e8f5e9;color:#198754;font-size:0.75rem;padding:5px 12px;font-weight:600;border-radius:8px;"><i class="fas fa-check-circle me-1"></i>Pagado</span>
                                        break;
                                    default:
                                        <span class="badge text-white" style="background:#198754;font-size:0.75rem;padding:5px 12px;font-weight:600;border-radius:8px;"><i class="fas fa-money-bill-wave me-1"></i>Efectivo</span>
                                        <span class="badge" style="background:#fff3e0;color:#b25e00;font-size:0.75rem;padding:5px 12px;font-weight:600;border-radius:8px;"><i class="fas fa-clock me-1"></i>Pago al recibir</span>
                                        break;
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Timeline -->
                <div class="detail-section">
                    <div class="detail-section-title"><i class="fas fa-history me-2"></i>Historial del Pedido</div>
                    <div class="detail-timeline">
                        @if (_detailOrder.TimelinePedidoRecibido.HasValue)
                        {
                            <div class="timeline-step done">
                                <div class="timeline-dot"></div>
                                <div class="timeline-content">
                                    <span class="timeline-label">Pedido recibido</span>
                                    <span class="timeline-time">@_detailOrder.TimelinePedidoRecibido.Value.ToString("dd/MM HH:mm")</span>
                                </div>
                            </div>
                        }
                        @if (_detailOrder.TimelineEnPreparacion.HasValue)
                        {
                            <div class="timeline-step done">
                                <div class="timeline-dot"></div>
                                <div class="timeline-content">
                                    <span class="timeline-label">En preparación</span>
                                    <span class="timeline-time">@_detailOrder.TimelineEnPreparacion.Value.ToString("dd/MM HH:mm")</span>
                                </div>
                            </div>
                        }
                        @if (_detailOrder.TimelineListo.HasValue)
                        {
                            <div class="timeline-step done">
                                <div class="timeline-dot"></div>
                                <div class="timeline-content">
                                    <span class="timeline-label">Listo para entrega</span>
                                    <span class="timeline-time">@_detailOrder.TimelineListo.Value.ToString("dd/MM HH:mm")</span>
                                </div>
                            </div>
                        }
                        @if (_detailOrder.TimelineEnCamino.HasValue)
                        {
                            <div class="timeline-step done">
                                <div class="timeline-dot"></div>
                                <div class="timeline-content">
                                    <span class="timeline-label">En camino</span>
                                    <span class="timeline-time">@_detailOrder.TimelineEnCamino.Value.ToString("dd/MM HH:mm")</span>
                                </div>
                            </div>
                        }
                        @if (_detailOrder.TimelineEntregado.HasValue)
                        {
                            <div class="timeline-step done success">
                                <div class="timeline-dot"></div>
                                <div class="timeline-content">
                                    <span class="timeline-label">Entregado</span>
                                    <span class="timeline-time">@_detailOrder.TimelineEntregado.Value.ToString("dd/MM HH:mm")</span>
                                </div>
                            </div>
                        }
                        @if (_detailOrder.TimelineCancelado.HasValue)
                        {
                            <div class="timeline-step cancelled">
                                <div class="timeline-dot"></div>
                                <div class="timeline-content">
                                    <span class="timeline-label">Cancelado</span>
                                    <span class="timeline-time">@_detailOrder.TimelineCancelado.Value.ToString("dd/MM HH:mm")</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Observaciones -->
                @if (!string.IsNullOrEmpty(_detailOrder.Observaciones))
                {
                    <div class="detail-section">
                        <div class="detail-section-title"><i class="fas fa-comment me-2"></i>Observaciones</div>
                        <p class="small text-foreground mb-0" style="white-space:pre-wrap;background:#f8f9fa;border-radius:0.85rem;padding:0.75rem 1rem;border:1px solid #f0f0f0;">@_detailOrder.Observaciones</p>
                    </div>
                }

            </div>

            <div class="detail-modal-footer">
                <button class="btn btn-outline-secondary fw-medium" @onclick="CerrarDetalle" style="border-radius:var(--radius);min-width:90px;">
                    <i class="fas fa-times me-1"></i>Cerrar
                </button>
            </div>

        </div>
    </div>
}

<!-- Modal Modificar Estado (desde Historial) -->
@if (_showCambiarEstadoModal && _cambiarEstadoOrder != null)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45);z-index:1070;" @onclick="CancelCambiarEstado">
        <div class="modal-dialog modal-dialog-centered" style="max-width:420px;" @onclick:stopPropagation>
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4">

                    @if (!_pedirConfirmacionFinal)
                    {
                        <h5 class="fw-bold text-foreground mb-1"><i class="fa-solid fa-rotate me-2"></i>Modificar estado</h5>
                        <p class="text-muted-foreground small mb-3">
                            Pedido <strong>@_cambiarEstadoOrder.Id</strong> · Estado actual:
                            <span class="badge" style="@GetStatusBadgeStyle(_cambiarEstadoOrder.Status) font-size:0.73rem;border-radius:9999px;padding:3px 9px;">@GetStatusLabel(_cambiarEstadoOrder.Status)</span>
                        </p>
                        <label class="form-label small fw-medium text-foreground mb-1">Nuevo estado</label>
                        <select class="form-select text-foreground mb-3" @bind="_nuevoEstadoSeleccionado">
                            <option value="recibido">Recibido</option>
                            <option value="en_proceso">En proceso</option>
                            <option value="atendido">Atendido</option>
                            <option value="rechazado">Rechazado</option>
                            <option value="cancelado">Cancelado</option>
                        </select>

                        @if (!string.IsNullOrEmpty(_cambiarEstadoError))
                        {
                            <div class="alert alert-danger py-2 small mb-3">@_cambiarEstadoError</div>
                        }

                        <div class="d-flex gap-2 justify-content-end">
                            <button class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="CancelCambiarEstado">Cancelar</button>
                            <button class="btn btn-primary"
                                    style="border-radius:var(--radius);"
                                    disabled="@(_nuevoEstadoSeleccionado == _cambiarEstadoOrder.Status)"
                                    @onclick="@(() => _pedirConfirmacionFinal = true)">
                                Continuar
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="text-center">
                            <div class="mb-3" style="font-size:2.5rem;">⚠️</div>
                            <h5 class="fw-bold text-foreground mb-1">¿Estás segura?</h5>
                            <p class="text-muted-foreground small mb-4">
                                El pedido <strong>@_cambiarEstadoOrder.Id</strong> pasará de
                                <strong>@GetStatusLabel(_cambiarEstadoOrder.Status)</strong> a
                                <strong>@GetStatusLabel(_nuevoEstadoSeleccionado)</strong>.
                            </p>

                            @if (!string.IsNullOrEmpty(_cambiarEstadoError))
                            {
                                <div class="alert alert-danger py-2 small mb-3 text-start">@_cambiarEstadoError</div>
                            }

                            <div class="d-flex gap-2 justify-content-center">
                                <button class="btn btn-secondary" disabled="@_cambiandoEstado" style="border-radius:var(--radius);" @onclick="@(() => _pedirConfirmacionFinal = false)">Volver</button>
                                <button class="btn text-white" disabled="@_cambiandoEstado"
                                        style="background:var(--primary);border-color:var(--primary);border-radius:var(--radius);min-width:160px;"
                                        @onclick="ConfirmCambiarEstado">
                                    @if (_cambiandoEstado)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                        <span>Actualizando...</span>
                                    }
                                    else
                                    {
                                        <span>Sí, confirmar</span>
                                    }
                                </button>
                            </div>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
}

<!-- Toast -->
@if (_showToast)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
        <div class="toast show align-items-center text-white border-0" style="background:@(_toastError ? "#dc3545" : "#1A6B3C");border-radius:var(--radius);min-width:300px;">
            <div class="d-flex align-items-center gap-2 px-3 py-2">
                <i class="fa-solid @(_toastError ? "fa-circle-exclamation" : "fa-circle-check")"></i>
                <span class="small">@_toastMsg</span>
                <button class="btn-close btn-close-white ms-auto" style="font-size:.7rem;" @onclick="@(() => _showToast = false)"></button>
            </div>
        </div>
    </div>
}

