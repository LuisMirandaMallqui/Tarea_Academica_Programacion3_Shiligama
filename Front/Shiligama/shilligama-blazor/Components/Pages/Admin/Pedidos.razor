@code {
    private bool _loading = true;
    private List<Order> _orders = new();
    private string _search          = "";
    private string _statusFilter    = "";
    private DateTime? _fechaDesde   = null;
    private DateTime? _fechaHasta   = null;

    // Referencia al componente hijo (Listado de pedidos) para poder refrescarlo
    // sin recargar la página cuando un pedido cambia de estado desde el Historial.
    private PedidosCardList? _cardListRef;

    // Paginación
    private int _pageSize    = 8;
    private int _currentPage = 1;

    // Modal detalle
    private bool _showDetailModal = false;
    private Order? _detailOrder;

    // Modificar estado (desde Historial) — flujo en 2 pasos: elegir estado → confirmar
    private bool _showCambiarEstadoModal = false;
    private bool _pedirConfirmacionFinal = false;
    private Order? _cambiarEstadoOrder;
    private string _nuevoEstadoSeleccionado = "";
    private bool _cambiandoEstado = false;
    private string _cambiarEstadoError = "";

    // Toast feedback
    private bool _showToast = false;
    private string _toastMsg = "";
    private bool _toastError = false;

    protected override async Task OnInitializedAsync()
    {
        await SalesSvc.EnsureLoadedAsync(recargar: true);
        _orders = SalesSvc.GetRecentOrders();
        _loading = false;
    }

    private async Task RecargarPedidos()
    {
        await SalesSvc.EnsureLoadedAsync(recargar: true);
        _orders = SalesSvc.GetRecentOrders();
        StateHasChanged();
    }

    private static readonly Dictionary<string,int> StatusOrder = new(StringComparer.OrdinalIgnoreCase)
    {
        {"recibido",0}, {"en_proceso",1}, {"atendido",2}, {"rechazado",3}, {"cancelado",4}
    };

    private IEnumerable<Order> Filtered => _orders.Where(o =>
        o.Channel != "Presencial" &&
        (o.Status is "atendido" or "rechazado" or "cancelado") &&
        (string.IsNullOrEmpty(_search) ||
         o.Customer.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
         o.Id.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_statusFilter) ||
         o.Status.Equals(_statusFilter, StringComparison.OrdinalIgnoreCase)) &&
        (!_fechaDesde.HasValue || o.Date.Date >= _fechaDesde.Value.Date) &&
        (!_fechaHasta.HasValue || o.Date.Date <= _fechaHasta.Value.Date)
    )
    .OrderBy(o => StatusOrder.TryGetValue(o.Status, out var r) ? r : 99)
    .ThenByDescending(o => o.Date)
    .GroupBy(o => o.Id).Select(g => g.First());

    private bool TieneFiltrosaActivos =>
        !string.IsNullOrEmpty(_search) || _fechaDesde.HasValue || _fechaHasta.HasValue;

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(Filtered.Count() / (double)_pageSize));

    private IEnumerable<Order> PagedOrders => Filtered
        .Skip((_currentPage - 1) * _pageSize)
        .Take(_pageSize);

    private void GoToPage(int page) { if (page >= 1 && page <= TotalPages) _currentPage = page; }

    private void OnFechaChange()  { _currentPage = 1; }

    private void SetHoy()    { _fechaDesde = DateTime.Today; _fechaHasta = DateTime.Today; _currentPage = 1; }
    private void Set7Dias()  { _fechaDesde = DateTime.Today.AddDays(-7); _fechaHasta = DateTime.Today; _currentPage = 1; }
    private void Set30Dias() { _fechaDesde = DateTime.Today.AddDays(-30); _fechaHasta = DateTime.Today; _currentPage = 1; }
    private void LimpiarFechas() { _fechaDesde = null; _fechaHasta = null; _currentPage = 1; }

    private void VerDetalle(Order order)
    {
        _detailOrder = order;
        _showDetailModal = true;
    }

    private void CerrarDetalle()
    {
        _showDetailModal = false;
        _detailOrder = null;
    }

    private string GetStatusClass(string status) => status.ToLower() switch
    {
        "atendido"   => "bg-success-subtle text-success",
        "en_proceso" => "bg-warning-subtle text-warning",
        "recibido"   => "bg-secondary text-muted-foreground",
        "rechazado"  => "bg-danger-subtle text-danger",
        "cancelado"  => "bg-danger-subtle text-danger",
        _ => "bg-light text-dark"
    };

    private string GetStatusLabel(string status) => status.ToLower() switch
    {
        "recibido"   => "Recibido",
        "en_proceso" => "En proceso",
        "atendido"   => "Atendido",
        "rechazado"  => "Rechazado",
        "cancelado"  => "Cancelado",
        _ => status
    };

    private string GetStatusBadgeStyle(string s) => s.ToLower() switch
    {
        "recibido"   => "background:#fff3e0;color:#b25e00;font-weight:600;",
        "en_proceso" => "background:#dcf0e8;color:#1A6B3C;font-weight:600;",
        "atendido"   => "background:#e8f5e9;color:#198754;font-weight:600;",
        "rechazado"  => "background:#ffebee;color:#c62828;font-weight:600;",
        "cancelado"  => "background:#ffebee;color:#c62828;font-weight:600;",
        _            => "background:#f5f5f5;color:#555;font-weight:600;"
    };

    // ── Modificar estado (Historial) ─────────────────────────────────────

    private void AskCambiarEstado(Order order)
    {
        _cambiarEstadoOrder = order;
        _nuevoEstadoSeleccionado = order.Status;
        _pedirConfirmacionFinal = false;
        _cambiarEstadoError = "";
        _showCambiarEstadoModal = true;
    }

    private void CancelCambiarEstado()
    {
        _showCambiarEstadoModal = false;
        _pedirConfirmacionFinal = false;
        _cambiarEstadoOrder = null;
        _nuevoEstadoSeleccionado = "";
        _cambiarEstadoError = "";
    }

    private async Task ConfirmCambiarEstado()
    {
        if (_cambiarEstadoOrder == null) return;
        _cambiandoEstado = true;
        _cambiarEstadoError = "";
        StateHasChanged();

        var (ok, error) = await SalesSvc.UpdateOrderStatusAsync(_cambiarEstadoOrder.Id, _nuevoEstadoSeleccionado);

        _cambiandoEstado = false;

        if (ok)
        {
            // Recargamos desde el backend para reflejar el estado real persistido.
            await SalesSvc.EnsureLoadedAsync(recargar: true);
            _orders = SalesSvc.GetRecentOrders();

            // Avisamos también al "Listado de pedidos" (PedidosCardList) para que
            // se actualice al instante: si un pedido pasó de un estado terminal
            // (atendido/rechazado/cancelado) a recibido/en_proceso, debe aparecer
            // ahí sin que la persona tenga que recargar la página.
            if (_cardListRef != null)
                await _cardListRef.RefreshAsync();

            _showCambiarEstadoModal = false;
            _pedirConfirmacionFinal = false;
            _cambiarEstadoOrder = null;
            ShowToast("Estado del pedido actualizado correctamente.", false);
        }
        else
        {
            // No mentimos en la UI: si el backend rechazó el cambio
            // (p.ej. el pedido ya está en un estado terminal y no puede revertirse),
            // mostramos el motivo real en vez de cerrar el modal como si hubiera funcionado.
            _cambiarEstadoError = error;
        }
        StateHasChanged();
    }

    private async void ShowToast(string message, bool isError)
    {
        _toastMsg = message;
        _toastError = isError;
        _showToast = true;
        StateHasChanged();
        await Task.Delay(3500);
        _showToast = false;
        StateHasChanged();
    }
}
