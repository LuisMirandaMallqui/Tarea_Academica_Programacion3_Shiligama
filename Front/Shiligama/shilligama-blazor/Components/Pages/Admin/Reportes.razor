@page "/admin/reportes"
@layout AdminLayout
@inject SalesService SalesSvc
@inject ProductService ProductSvc
@inject ReporteService ReporteSvc
@inject IJSRuntime JS
@inject DetalleVentaService DetalleVentaSvc

<PageTitle>Reportes & Estadísticas – Shiligama Admin</PageTitle>

<div class="d-flex flex-column gap-4">
    <!-- Header -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <p class="text-muted-foreground small mt-0 mb-0">Analítica de rendimiento comercial y canales de distribución</p>
        </div>
        <button type="button" class="btn btn-primary d-flex align-items-center gap-2 fw-semibold"
                onclick="window.print();" style="border-radius: var(--radius);">
            <i class="fas fa-print"></i> Imprimir Reporte
        </button>
    </div>

    <!-- Filtros -->
    <div class="card p-4" style="border-radius:12px;">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-medium text-foreground mb-1">Desde</label>
                <input type="date"
                       @bind="_fechaDesde"
                       @bind:after="OnDateRangeChanged"
                       class="form-control text-foreground" style="height:44px;border-radius:10px;" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-medium text-foreground mb-1">Hasta</label>
                <input type="date"
                       @bind="_fechaHasta"
                       @bind:after="OnDateRangeChanged"
                       class="form-control text-foreground" style="height:44px;border-radius:10px;" />
            </div>
            <div class="col-md-auto">
                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-secondary btn-sm" @onclick="SetRangeHoy"
                            style="border-radius:var(--radius);">Hoy</button>
                    <button class="btn btn-secondary btn-sm" @onclick="SetRange7Days"
                            style="border-radius:var(--radius);">7 días</button>
                    <button class="btn btn-secondary btn-sm" @onclick="SetRange30Days"
                            style="border-radius:var(--radius);">30 días</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Exportar Reportes (PDF) -->
    <div class="card p-4" style="border-radius:12px;">
        <h2 class="fs-5 fw-bold text-foreground mb-3">
            <i class="fas fa-file-pdf me-2 text-reporte"></i> Generar Reportes PDF
        </h2>
        <div class="d-flex gap-3 flex-wrap">
            <button class="btn btn-reporte fw-semibold" @onclick="AbrirModalDevoluciones">
                <i class="fas fa-download me-2"></i> Reporte Devoluciones
            </button>
            <button class="btn btn-reporte fw-semibold" @onclick="AbrirModalVentas">
                <i class="fas fa-download me-2"></i> Reporte Ventas Agrupadas
            </button>
            <button class="btn btn-reporte fw-semibold" @onclick="AbrirModalTopProductos">
                <i class="fas fa-download me-2"></i> Reporte Top Productos
            </button>
        </div>
    </div>

    <!-- Quick Stats Row -->
    <div class="row g-3">
        <div class="col-6 col-md-4">
            <div class="metric-card-kpi">
                <div>
                    <div class="metric-kpi-label mb-1">Ingresos Consolidados</div>
                    <div class="metric-kpi-value text-primary" style="font-size:1.5rem;">
                        S/. @FilteredSales.Sum(s => s.Total).ToString("0.00")
                    </div>
                    <span class="text-muted-foreground small">en el período seleccionado</span>
                </div>
                <div class="metric-kpi-icon"
                     style="background:color-mix(in srgb,var(--primary) 15%,transparent);color:var(--primary);">
                    <i class="fas fa-dollar-sign"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4">
            <div class="metric-card-kpi">
                <div>
                    <div class="metric-kpi-label mb-1">Transacciones Exitosas</div>
                    <div class="metric-kpi-value text-foreground">
                        @FilteredSales.Count(s => s.Estado == "completado")
                    </div>
                    <span class="text-muted-foreground small">de @FilteredSales.Count total</span>
                </div>
                <div class="metric-kpi-icon"
                     style="background:color-mix(in srgb,#2e7d32 15%,transparent);color:#2e7d32;">
                    <i class="fas fa-check-double"></i>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="metric-card-kpi">
                <div>
                    <div class="metric-kpi-label mb-1">Valor de Transacción</div>
                    <div class="metric-kpi-value text-foreground">
                        S/. @(FilteredSales.Any() ? FilteredSales.Average(s => s.Total).ToString("0.00") : "0.00")
                    </div>
                    <span class="text-muted-foreground small">promedio por venta</span>
                </div>
                <div class="metric-kpi-icon"
                     style="background:color-mix(in srgb,#7C3AED 15%,transparent);color:#7C3AED;">
                    <i class="fas fa-receipt"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card p-4">
                <h2 class="fs-5 fw-bold text-foreground mb-3">
                    <i class="fas fa-chart-bar me-2" style="color:#2563EB;"></i>Distribución de Canales (Físico vs Online)
                </h2>
                <div style="height:280px; position:relative;">
                    <canvas id="channelsComparisonChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Category share -->
        <div class="col-lg-4">
            <div class="card p-4 h-100 d-flex flex-column gap-3">
                <div>
                    <h2 class="fs-5 fw-bold text-foreground mb-1">
                        <i class="fas fa-tags me-2 text-primary"></i>Participación por Categoría
                    </h2>
                    <p class="text-muted-foreground small mb-0">Rendimiento estimado del inventario este mes</p>
                </div>

                <div class="d-flex flex-column gap-3 mt-2">
                    @foreach (var (cat, pct, color) in new (string, int, string)[]{
                        ("Abarrotes",          42, "#1A6B3C"),
                        ("Lácteos",            28, "#2e7d32"),
                        ("Bebidas",            18, "#2563EB"),
                        ("Snacks & Golosinas", 12, "#f59e0b"),
                    })
                    {
                        <div>
                            <div class="d-flex justify-content-between text-foreground small fw-medium mb-1">
                                <span>@cat</span>
                                <span>@pct%</span>
                            </div>
                            <div class="progress" style="height:8px;border-radius:var(--radius);">
                                <div class="progress-bar" role="progressbar"
                                     style="width:@(pct)%;background:@color;border-radius:var(--radius);"
                                     aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    
    <!-- Top Products Table -->
    <div class="card overflow-hidden">
        <div class="p-4 border-bottom border-color-default">
            <h2 class="fs-5 fw-bold text-foreground mb-0">
                <i class="fas fa-trophy me-2" style="color:#f59e0b;"></i>Top Productos Más Vendidos
            </h2>
            
            <p class="text-muted-foreground small m-0">Basado en unidades vendidas en el período seleccionado</p>
        </div>
        <div class="table-responsive">
            <table class="table table-borderless mb-0 align-middle">
                <thead class="border-bottom border-color-default">
                    <tr>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">#</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Producto</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-center" style="letter-spacing:.05em;">Unidades</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-end" style="letter-spacing:.05em;">Ingresos</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        string[] medals = { "🥇", "🥈", "🥉", "4°", "5°" };
                    }
                    @if (!TopProductosFiltrados.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted-foreground small">
                                Sin datos de ventas completadas aún.
                            </td>
                        </tr>
                    }
                    @for (int i = 0; i < TopProductosFiltrados.Count; i++)
                    {
                        var item = TopProductosFiltrados[i];
                        var rank = medals[i];
                        <tr class="border-bottom border-color-default">
                            <td class="px-4 py-3 fw-bold text-center" style="font-size:1.1rem;">@rank</td>
                            <td class="px-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@(item.ImagenUrl ?? "")" class="rounded-2 object-fit-cover flex-shrink-0"
                                         style="width:36px;height:36px;"
                                         onerror="this.src='https://placehold.co/36/e8f5e9/1A6B3C?text=P'" />
                                    <span class="fw-semibold text-foreground small">@item.Nombre</span>
                                </div>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="badge bg-primary-subtle text-primary" style="border-radius:var(--radius);">
                                    @item.TotalUnidades ud.
                                </span>
                            </td>
                            <td class="px-4 py-3 text-end fw-bold text-foreground small">
                                S/. @item.TotalIngresos.ToString("0.00")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modal Reporte Devoluciones -->
    @if (_showModalDevoluciones)
    {
        <div class="modal show d-block fade-in" tabindex="-1" style="background:rgba(0,0,0,.5);z-index:1060;">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content bg-card border-border" style="border-radius:1.2rem;overflow:hidden;">
                    <div class="modal-header border-border p-4">
                        <h5 class="modal-title text-foreground fw-bold">Reporte de Devoluciones</h5>
                        @if (!_generandoReporte)
                        {
                            <button type="button" class="btn-close" @onclick="CerrarModalDevoluciones"></button>
                        }
                    </div>
                    @if (_generandoReporte)
                    {
                        <div class="modal-body bg-light text-center py-5">
                            <LoadingIndicator Text="Se está generando el reporte...." MinHeight="200px" />
                        </div>
                    }
                    else
                    {
                        <div class="modal-body p-4 bg-light">
                            <div class="mb-3">
                                <label class="form-label small fw-medium text-foreground">Fecha Inicio</label>
                                <input type="date" @bind="_repDevDesde" class="form-control" style="border-radius:10px;" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-medium text-foreground">Fecha Fin</label>
                                <input type="date" @bind="_repDevHasta" class="form-control" style="border-radius:10px;" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-medium text-foreground">Estado</label>
                                <select @bind="_repDevEstado" class="form-select" style="border-radius:10px;">
                                    <option value="TODOS">Todos</option>
                                    <option value="PENDIENTE">Pendiente</option>
                                    <option value="APROBADO">Aprobado</option>
                                    <option value="RECHAZADO">Rechazado</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-medium text-foreground">Días Alerta</label>
                                <input type="number" @bind="_repDevDiasAlerta" min="1" class="form-control" style="border-radius:10px;" />
                            </div>
                        </div>
                        <div class="modal-footer border-0 p-4 bg-light justify-content-end">
                            <button class="btn btn-secondary" style="border-radius:0.6rem;" @onclick="CerrarModalDevoluciones">Cancelar</button>
                            <button class="btn btn-danger fw-bold" style="border-radius:0.6rem;" @onclick="GenerarDevoluciones">
                                <i class="fas fa-file-pdf me-2"></i>Generar PDF
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Modal Reporte Ventas Agrupadas -->
    @if (_showModalVentas)
    {
        <div class="modal show d-block fade-in" tabindex="-1" style="background:rgba(0,0,0,.5);z-index:1060;">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content bg-card border-border" style="border-radius:1.2rem;overflow:hidden;">
                    <div class="modal-header border-border p-4">
                        <h5 class="modal-title text-foreground fw-bold">Reporte de Ventas Agrupadas</h5>
                        @if (!_generandoReporte)
                        {
                            <button type="button" class="btn-close" @onclick="CerrarModalVentas"></button>
                        }
                    </div>
                    @if (_generandoReporte)
                    {
                        <div class="modal-body bg-light text-center py-5">
                            <LoadingIndicator Text="Se está generando el reporte...." MinHeight="200px" />
                        </div>
                    }
                    else
                    {
                        <div class="modal-body p-4 bg-light">
                            <div class="mb-3">
                                <label class="form-label small fw-medium text-foreground">Fecha Inicio</label>
                                <input type="date" @bind="_repVenDesde" class="form-control" style="border-radius:10px;" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-medium text-foreground">Fecha Fin</label>
                                <input type="date" @bind="_repVenHasta" class="form-control" style="border-radius:10px;" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-medium text-foreground">Agrupación</label>
                                <select @bind="_repVenAgrupacion" class="form-select" style="border-radius:10px;">
                                    <option value="DIA">Día</option>
                                    <option value="MES">Mes</option>
                                    <option value="ANIO">Año</option>
                                </select>
                            </div>
                        </div>
                        <div class="modal-footer border-0 p-4 bg-light justify-content-end">
                            <button class="btn btn-secondary" style="border-radius:0.6rem;" @onclick="CerrarModalVentas">Cancelar</button>
                            <button class="btn btn-danger fw-bold" style="border-radius:0.6rem;" @onclick="GenerarVentas">
                                <i class="fas fa-file-pdf me-2"></i>Generar PDF
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Modal Reporte Top Productos -->
    @if (_showModalTop)
    {
        <div class="modal show d-block fade-in" tabindex="-1" style="background:rgba(0,0,0,.5);z-index:1060;">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content bg-card border-border" style="border-radius:1.2rem;overflow:hidden;">
                    <div class="modal-header border-border p-4">
                        <h5 class="modal-title text-foreground fw-bold">Reporte Top Productos</h5>
                        @if (!_generandoReporte)
                        {
                            <button type="button" class="btn-close" @onclick="CerrarModalTopProductos"></button>
                        }
                    </div>
                    @if (_generandoReporte)
                    {
                        <div class="modal-body bg-light text-center py-5">
                            <LoadingIndicator Text="Se está generando el reporte...." MinHeight="200px" />
                        </div>
                    }
                    else
                    {
                        <div class="modal-body p-4 bg-light">
                            <div class="mb-3">
                                <label class="form-label small fw-medium text-foreground">Fecha Inicio</label>
                                <input type="date" @bind="_repTopDesde" class="form-control" style="border-radius:10px;" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-medium text-foreground">Fecha Fin</label>
                                <input type="date" @bind="_repTopHasta" class="form-control" style="border-radius:10px;" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-medium text-foreground">Límite</label>
                                <input type="number" @bind="_repTopLimite" min="1" max="100" class="form-control" style="border-radius:10px;" />
                            </div>
                        </div>
                        <div class="modal-footer border-0 p-4 bg-light justify-content-end">
                            <button class="btn btn-secondary" style="border-radius:0.6rem;" @onclick="CerrarModalTopProductos">Cancelar</button>
                            <button class="btn btn-danger fw-bold" style="border-radius:0.6rem;" @onclick="GenerarTopProductos">
                                <i class="fas fa-file-pdf me-2"></i>Generar PDF
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    // Estado de Modales Reportes PDF
    private bool _showModalDevoluciones = false;
    private bool _showModalVentas = false;
    private bool _showModalTop = false;
    private bool _generandoReporte = false;

    private DateTime _repDevDesde = DateTime.Today.AddDays(-30);
    private DateTime _repDevHasta = DateTime.Today;
    private string _repDevEstado = "TODOS";
    private int _repDevDiasAlerta = 30;

    private DateTime _repVenDesde = DateTime.Today.AddDays(-30);
    private DateTime _repVenHasta = DateTime.Today;
    private string _repVenAgrupacion = "DIA";

    private DateTime _repTopDesde = DateTime.Today.AddDays(-30);
    private DateTime _repTopHasta = DateTime.Today;
    private int _repTopLimite = 10;

    private void AbrirModalDevoluciones() => _showModalDevoluciones = true;
    private void CerrarModalDevoluciones() => _showModalDevoluciones = false;
    private async Task GenerarDevoluciones()
    {
        _generandoReporte = true;
        StateHasChanged();
        await Task.Delay(500); // Darle tiempo a Blazor de renderizar el indicador de carga
        try
        {
            var url = $"/api/reportes/descargar/devoluciones?fechaInicio={_repDevDesde.ToString("yyyy-MM-dd")}&fechaFin={_repDevHasta.ToString("yyyy-MM-dd")}&estado={_repDevEstado}&diasAlerta={_repDevDiasAlerta}";
            await JS.InvokeVoidAsync("chartHelper.downloadPdfFromUrl", url);
            await Task.Delay(2000); // Mantener spinner brevemente para mejorar experiencia de usuario antes de cerrar
            CerrarModalDevoluciones();
        }
        catch { }
        finally
        {
            _generandoReporte = false;
            StateHasChanged();
        }
    }

    private void AbrirModalVentas() => _showModalVentas = true;
    private void CerrarModalVentas() => _showModalVentas = false;
    private async Task GenerarVentas()
    {
        _generandoReporte = true;
        StateHasChanged();
        await Task.Delay(500); // Darle tiempo a Blazor de renderizar el indicador de carga
        try
        {
            var url = $"/api/reportes/descargar/ventas-agrupadas?fechaInicio={_repVenDesde.ToString("yyyy-MM-dd")}&fechaFin={_repVenHasta.ToString("yyyy-MM-dd")}&agrupacion={_repVenAgrupacion}";
            await JS.InvokeVoidAsync("chartHelper.downloadPdfFromUrl", url);
            await Task.Delay(2000); // Mantener spinner brevemente para mejorar experiencia de usuario antes de cerrar
            CerrarModalVentas();
        }
        catch { }
        finally
        {
            _generandoReporte = false;
            StateHasChanged();
        }
    }

    private void AbrirModalTopProductos() => _showModalTop = true;
    private void CerrarModalTopProductos() => _showModalTop = false;
    private async Task GenerarTopProductos()
    {
        _generandoReporte = true;
        StateHasChanged();
        await Task.Delay(500); // Darle tiempo a Blazor de renderizar el indicador de carga
        try
        {
            var url = $"/api/reportes/descargar/top-productos?fechaInicio={_repTopDesde.ToString("yyyy-MM-dd")}&fechaFin={_repTopHasta.ToString("yyyy-MM-dd")}&limite={_repTopLimite}";
            await JS.InvokeVoidAsync("chartHelper.downloadPdfFromUrl", url);
            await Task.Delay(2000); // Mantener spinner brevemente para mejorar experiencia de usuario antes de cerrar
            CerrarModalTopProductos();
        }
        catch { }
        finally
        {
            _generandoReporte = false;
            StateHasChanged();
        }
    }

    private List<DetalleVenta> _detallesVenta = new();
    private class CategoriaStats
    {
        public string Nombre { get; set; } = "";
        public int Porcentaje { get; set; }
        public string Color { get; set; } = "";
    }

    private List<CategoriaStats> CategoriasFiltradas
    {
        get
        {
            var colores = new[]
            {
            "#1A6B3C",
            "#2e7d32",
            "#2563EB",
            "#f59e0b",
            "#7C3AED",
            "#DC2626"
        };

            var productosVendidos = FilteredSales
                .Where(s => s.Estado == "completado")
                .SelectMany(s => s.Productos);

            var totalUnidades = productosVendidos.Sum(p => p.Quantity);

            if (totalUnidades == 0)
                return new();

            return productosVendidos
                .GroupBy(p =>
                {
                    var producto = ProductSvc.GetProducts()
                    .FirstOrDefault(x => x.Id == p.Id);

                    return producto?.Categoria?.Name ?? "Sin categoría";
                })
                .Select((g, index) => new CategoriaStats
                {
                    Nombre = g.Key,
                    Porcentaje = (int)Math.Round(
                        (double)g.Sum(x => x.Quantity) * 100 / totalUnidades
                    ),
                    Color = colores[index % colores.Length]
                })
                .OrderByDescending(x => x.Porcentaje)
                .ToList();
        }
    }

    private DateTime _fechaDesde = DateTime.Today.AddDays(-30);
    private DateTime _fechaHasta = DateTime.Today;

    private List<Sale> FilteredSales => SalesSvc.GetSales()
        .Where(s => s.Fecha.Date >= _fechaDesde.Date && s.Fecha.Date <= _fechaHasta.Date)
        .ToList();
        

    // Reemplaza la propiedad TopProductosFiltrados existente
    private List<TopProductoItem> TopProductosFiltrados
    {
        get
        {
            // IDs numéricos de las ventas en el rango actual
            var ventaIdsEnRango = FilteredSales
                .Select(s => s.Id.Replace("VTA-", "").TrimStart('0'))
                .ToHashSet();

            return _detallesVenta
                .Where(d => ventaIdsEnRango.Contains(d.idPadreVenta.ToString()))
                .GroupBy(d => d.producto.IdProducto)
                .Select(g => new TopProductoItem
                {
                    Nombre = g.First().producto.Nombre,
                    ImagenUrl = g.First().producto.ImagenUrl,
                    TotalUnidades = g.Sum(d => d.cantidad),
                    TotalIngresos = g.Sum(d => d.subtotal)
                })
                .OrderByDescending(x => x.TotalUnidades)
                .Take(5)
                .ToList();
        }
    }


    private async Task CargarDetallesFiltradosAsync()
    {
        // No recarga si ya están en memoria
        if (_detallesVenta.Count == 0)
        {
            _detallesVenta = await DetalleVentaSvc.GetAllDetallesVentaAsync();
        }
        StateHasChanged();
    }

    // Top productos — cargados desde el API, no hardcodeados
    //private List<TopProductoItem> _topProductos = new();
    private async Task OnDateRangeChanged()
    {
        await CargarDetallesFiltradosAsync();
        await RenderCharts();
    }
    private async Task SetRangeHoy()
    {
        _fechaDesde = DateTime.Today;
        _fechaHasta = DateTime.Today;
        await CargarDetallesFiltradosAsync();
        await RenderCharts();
    }
    private async Task SetRange7Days()
    {
        _fechaDesde = DateTime.Today.AddDays(-7);
        _fechaHasta = DateTime.Today;
        await CargarDetallesFiltradosAsync();
        await RenderCharts();
    }

    // Reemplaza SetRange30Days
    private async Task SetRange30Days()
    {
        _fechaDesde = DateTime.Today.AddDays(-30);
        _fechaHasta = DateTime.Today;
        await CargarDetallesFiltradosAsync();
        await RenderCharts();
    }

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            ProductSvc.EnsureLoadedAsync(),
            SalesSvc.EnsureLoadedAsync(cargarDetalles: false) // ← sin detalles
        );
        await CargarDetallesFiltradosAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        StateHasChanged();
        await RenderCharts();
    }

    private async Task RenderCharts()
    {
        var labels = Enumerable.Range(0, 7)
            .Select(i => DateTime.Today.AddDays(-6 + i).ToString("dd/MM"))
            .ToArray();

        var presencialData = new int[7];
        var onlineData = new int[7];

        for (int i = 0; i < 7; i++)
        {
            var fecha = DateTime.Today.AddDays(-6 + i).Date;

            presencialData[i] = FilteredSales.Count(s =>
                s.Fecha.Date == fecha &&
                s.Canal == "presencial");

            onlineData[i] = FilteredSales.Count(s =>
                s.Fecha.Date == fecha &&
                (s.Canal == "web" || s.Canal == "whatsapp"));
        }

        await JS.InvokeVoidAsync(
            "chartHelper.renderOrdersComparisonChart",
            "channelsComparisonChart",
            labels,
            presencialData,
            onlineData);
    }
}

