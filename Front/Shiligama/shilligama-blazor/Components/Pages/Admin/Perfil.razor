@page "/admin/perfil"
@layout AdminLayout
@inject AuthService Auth
@inject HttpClient Http

<PageTitle>Mi Perfil – Shiligama Admin</PageTitle>

<div class="container-fluid p-0 mx-auto" style="max-width: 900px;">
    <!-- Header -->
    <div>
        <h1 class="fs-4 fw-bold text-foreground mb-0">Mi Perfil de Administrador</h1>
        <p class="text-muted-foreground small mt-1 mb-0">Administra tus datos de contacto y credenciales de acceso</p>
    </div>

    <div class="row g-4">
        <!-- Main profile details -->
        <div class="col-lg-8">
            <div class="d-flex flex-column gap-4">
                <div class="card p-4 d-flex flex-column gap-3 rounded-4">
                    <h2 class="fs-5 fw-bold text-foreground mb-0">Información Personal</h2>

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <label class="form-label small fw-medium text-foreground">Nombres</label>
                            <input type="text" @bind="_nombres" @bind:event="oninput" @bind:after="ValidateNombres"
                                   maxlength="100" class="form-control text-foreground"
                                   placeholder="Ej. Juan Carlos"
                                   style="@(_nombresError != null ? "border-color:#dc3545;" : "")" />
                            @if (_nombresError != null)
                            {
                                <div class="text-danger small mt-1"><i class="fas fa-exclamation-triangle me-1"></i>@_nombresError</div>
                            }
                        </div>
                        <div class="col-sm-6">
                            <label class="form-label small fw-medium text-foreground">Apellidos</label>
                            <input type="text" @bind="_apellidos" @bind:event="oninput"
                                   maxlength="100" class="form-control text-foreground"
                                   placeholder="Ej. García López" />
                        </div>
                    </div>

                    <div>
                        <label class="form-label small fw-medium text-foreground">Correo electrónico corporativo</label>
                        <input type="email" @bind="_email" @bind:event="oninput" class="form-control text-foreground" />
                    </div>

                    <div>
                        <label class="form-label small fw-medium text-foreground">Teléfono móvil</label>
                        <input type="tel" @bind="_phone" @bind:event="oninput" class="form-control text-foreground" />
                    </div>

                    @if (!string.IsNullOrEmpty(_profileError))
                    {
                        <div class="text-danger small"><i class="fas fa-exclamation-triangle me-1"></i> @_profileError</div>
                    }
                </div>

                <div class="card p-4 d-flex flex-column gap-3 rounded-4">
                    <h2 class="fs-5 fw-bold text-foreground mb-0">Actualizar Contraseña</h2>
                    <p class="text-muted-foreground small mb-0">Deja los campos vacíos si no deseas cambiar tu contraseña.</p>

                    <div>
                        <label class="form-label small fw-medium text-foreground">Contraseña actual</label>
                        <input type="password" @bind="_currentPassword" @bind:event="oninput"
                               class="form-control text-foreground"
                               placeholder="Ingresa tu contraseña actual" style="height:44px;border-radius:10px;" />
                    </div>
                    <div>
                        <label class="form-label small fw-medium text-foreground">Nueva Contraseña</label>
                        <input type="password" @bind="_newPassword" @bind:event="oninput"
                               class="form-control text-foreground"
                               placeholder="Mínimo 8 caracteres" style="height:44px;border-radius:10px;" />
                    </div>
                    <div>
                        <label class="form-label small fw-medium text-foreground">Confirmar Contraseña</label>
                        <input type="password" @bind="_confirmPassword" @bind:event="oninput"
                               class="form-control text-foreground"
                               placeholder="Repite tu nueva contraseña" style="height:44px;border-radius:10px;" />
                    </div>
                    @if (!string.IsNullOrEmpty(_passwordError))
                    {
                        <div class="text-danger small"><i class="fas fa-exclamation-triangle me-1"></i> @_passwordError</div>
                    }
                </div>

                <div class="d-flex justify-content-end">
                    <button type="button" @onclick="SaveProfile" class="btn btn-primary px-4 fw-semibold" style="border-radius: var(--radius);">
                        Guardar Perfil
                    </button>
                </div>
            </div>
        </div>

        <!-- Sidebar visual Card -->
        <div class="col-lg-4">
            <div class="card p-4 text-center rounded-4 bg-muted border-0 d-flex flex-column gap-3">
                <div class="d-flex align-items-center justify-content-center rounded-circle bg-primary text-white mx-auto" style="width: 72px; height: 72px; font-size: 1.8rem;">
                    @(DisplayName.Length > 0 ? DisplayName[0].ToString().ToUpper() : "A")
                </div>
                <div>
                    <h3 class="fs-5 fw-bold text-foreground mb-1">@DisplayName</h3>
                    <span class="badge bg-primary px-2.5 py-1.5 text-uppercase tracking-wider small fw-semibold" style="border-radius: var(--radius);">Administrador</span>
                </div>
                <hr class="border-color-default my-1" />
                <p class="text-xs text-muted-foreground m-0">Correo: @_email</p>
            </div>
        </div>
    </div>
</div>

@* ─── Modal Confirmación ────────────────────────────────────────────── *@
@if (_showConfirm)
{
    <div class="modal show d-block fade-in" tabindex="-1" style="background:rgba(0,0,0,.55);backdrop-filter:blur(3px);" @onclick="@(() => _showConfirm = false)">
        <div class="modal-dialog modal-dialog-centered" style="max-width:420px;" @onclick:stopPropagation>
            <div class="modal-content bg-card border-border" style="border-radius:1.25rem;overflow:hidden;">
                <div class="modal-body p-4 text-center d-flex flex-column align-items-center gap-3">
                    <div style="width:56px;height:56px;border-radius:50%;background:color-mix(in srgb,var(--primary) 15%,transparent);display:flex;align-items:center;justify-content:center;">
                        <i class="fas fa-question" style="font-size:1.4rem;color:var(--primary);"></i>
                    </div>
                    <h5 class="fw-bold text-foreground mb-0">¿Guardar cambios?</h5>
                    <p class="text-muted-foreground small mb-0">Se actualizarán tus datos de perfil.</p>
                </div>
                <div class="modal-footer border-top border-color-default p-3 d-flex justify-content-center gap-2">
                    <button class="btn btn-outline-secondary fw-semibold" style="border-radius:8px;min-width:90px;" @onclick="@(() => _showConfirm = false)" disabled="@_saving">Cancelar</button>
                    <button class="btn btn-primary fw-semibold" style="border-radius:8px;min-width:110px;" @onclick="ConfirmSave" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Sí, guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ─── Toast Emergente ────────────────────────────────────────────── *@
@if (_showToast)
{
    <div class="position-fixed d-flex align-items-center gap-2 p-3 shadow-lg"
         style="bottom:24px;right:24px;z-index:9999;background:#e8f5e9;border:1px solid #c8e6c9;border-radius:var(--radius);animation:slideIn 0.3s ease;">
        <i class="fas fa-check-circle" style="color:#2e7d32;font-size:1.2rem;"></i>
        <span class="text-foreground fw-semibold small">@_toastMessage</span>
        <button class="btn btn-sm p-0 ms-2" @onclick="@(() => _showToast = false)">
            <i class="fas fa-times text-muted" style="font-size:0.8rem;"></i>
        </button>
    </div>
}

<style>
    @@keyframes slideIn {
        from { transform: translateY(20px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
</style>

@code {
    private string _nombres         = "";
    private string _apellidos       = "";
    private string _email           = "";
    private string _phone           = "";
    private string _currentPassword = "";
    private string _newPassword     = "";
    private string _confirmPassword = "";
    private string? _nombresError;
    private string? _profileError;
    private string? _passwordError;
    private bool _showConfirm    = false;
    private bool _showToast      = false;
    private bool _saving         = false;
    private string _toastMessage = "Cambios guardados exitosamente";

    // Flags internos para saber qué guardar en este ciclo
    private bool _cambiarPassword = false;

    // Nombre para mostrar en sidebar
    private string DisplayName => $"{_nombres} {_apellidos}".Trim();

    protected override void OnInitialized()
    {
        _nombres   = Auth.CurrentUser?.Nombres  ?? "";
        _apellidos = Auth.CurrentUser?.Apellidos ?? "";
        _email     = Auth.CurrentUser?.Email     ?? "";
        _phone     = Auth.CurrentUser?.Telefono  ?? "";
    }

    private void ValidateNombres()
    {
        _nombresError = null;
        if (string.IsNullOrWhiteSpace(_nombres))
            _nombresError = "El nombre es obligatorio.";
        else if (_nombres.Length > 100)
            _nombresError = "Máximo 100 caracteres.";
        else if (_nombres.Any(char.IsDigit))
            _nombresError = "El nombre no debe contener números.";
    }

    private void SaveProfile()
    {
        _nombresError  = null;
        _profileError  = null;
        _passwordError = null;
        _cambiarPassword = false;

        ValidateNombres();
        if (_nombresError != null) return;

        // Validar contraseña solo si el usuario llenó alguno de los campos
        bool quiereCambiarPassword =
            !string.IsNullOrEmpty(_currentPassword) ||
            !string.IsNullOrEmpty(_newPassword)     ||
            !string.IsNullOrEmpty(_confirmPassword);

        if (quiereCambiarPassword)
        {
            if (string.IsNullOrWhiteSpace(_currentPassword))
            { _passwordError = "Ingresa tu contraseña actual."; return; }

            if (string.IsNullOrWhiteSpace(_newPassword) || _newPassword.Length < 8)
            { _passwordError = "La nueva contraseña debe tener al menos 8 caracteres."; return; }

            if (_newPassword != _confirmPassword)
            { _passwordError = "Las contraseñas nuevas no coinciden."; return; }

            _cambiarPassword = true;
        }

        _showConfirm = true;
    }

    private async Task ConfirmSave()
    {
        _showConfirm = false;
        _saving = true;
        StateHasChanged();

        try
        {
            // ── 1. Actualizar datos personales ───────────────────────────────
            var perfilDto = new
            {
                idUsuario  = Auth.CurrentUser!.Id,
                nombres    = _nombres.Trim(),
                apellidos  = _apellidos.Trim(),
                correo     = _email.Trim(),
                telefono   = _phone.Trim(),
                dni        = Auth.CurrentUser!.Dni ?? ""
            };
            var perfilResp = await Http.PutAsJsonAsync("administradores", perfilDto);
            if (!perfilResp.IsSuccessStatusCode)
            {
                var msg = await perfilResp.Content.ReadAsStringAsync();
                _profileError = !string.IsNullOrEmpty(msg)
                    ? msg : "No se pudo actualizar el perfil.";
                return;
            }

            // Sincronizar CurrentUser en memoria para que el layout refleje el cambio
            Auth.CurrentUser!.Nombres   = _nombres.Trim();
            Auth.CurrentUser!.Apellidos = _apellidos.Trim();
            Auth.CurrentUser!.Correo    = _email.Trim();
            Auth.CurrentUser!.Telefono  = _phone.Trim();
            await Auth.SyncSessionAsync();

            // ── 2. Cambiar contraseña si el usuario lo solicitó ─────────────
            if (_cambiarPassword)
            {
                var pwdDto = new { contrasenaActual = _currentPassword, nuevaContrasena = _newPassword };
                var pwdResp = await Http.PutAsJsonAsync(
                    $"administradores/{Auth.CurrentUser!.Id}/contrasena", pwdDto);

                if (!pwdResp.IsSuccessStatusCode)
                {
                    var msg = await pwdResp.Content.ReadAsStringAsync();
                    _passwordError = !string.IsNullOrEmpty(msg)
                        ? msg : "No se pudo actualizar la contraseña.";
                    return;
                }
            }

            // Limpiar campos de contraseña tras éxito
            _currentPassword = "";
            _newPassword     = "";
            _confirmPassword = "";
            _passwordError   = null;
            _cambiarPassword = false;

            _toastMessage = "Cambios guardados exitosamente";
            _showToast = true;
            StateHasChanged();
            await Task.Delay(3000);
            _showToast = false;
        }
        catch (Exception ex)
        {
            _profileError = $"Error de conexión: {ex.Message}";
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }
}
