@page "/admin/ventas"
@layout AdminLayout
@using shilligama_blazor.Models
@inject SalesService SalesSvc
@inject IJSRuntime JS

<PageTitle>Historial de Ventas – Shiligama Admin</PageTitle>


<div class="d-flex flex-column gap-4">
    <!-- Header -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h1 class="fs-4 fw-bold text-foreground mb-0">Historial de Ventas</h1>
            <p class="text-muted-foreground small mt-1 mb-0">Reportes de ingresos consolidados físicos y virtuales</p>
        </div>
    </div>


    <!-- Stats summary -->
    <div class="row g-3">
        <div class="col-md-4">
            <div class="card p-3 d-flex flex-column gap-1">
                <span class="small text-muted-foreground fw-medium">Ingresos Totales</span>
                <span class="fs-3 fw-bold text-primary">S/. @TotalRevenue.ToString("0.00")</span>
                <span class="text-xs text-muted-foreground mt-1">Con filtros aplicados</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 d-flex flex-column gap-1">
                <span class="small text-muted-foreground fw-medium">Ticket Promedio</span>
                <span class="fs-3 fw-bold text-foreground">S/. @AvgTicket.ToString("0.00")</span>
                <span class="text-xs text-muted-foreground mt-1">Valor promedio por ticket</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 d-flex flex-column gap-1">
                <span class="small text-muted-foreground fw-medium">Transacciones</span>
                <span class="fs-3 fw-bold text-foreground">@TotalTransactions</span>
                <span class="text-xs text-muted-foreground mt-1">Ventas registradas</span>
            </div>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card p-4" style="border-radius:12px;">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-medium text-foreground mb-1">Buscar</label>
                <div class="position-relative">
                    <i class="fa-solid fa-magnifying-glass position-absolute top-50 translate-middle-y text-muted" style="left:16px;font-size:14px;"></i>
                    <input type="search" @bind="_search" @bind:event="oninput" @bind:after="OnFilterChange"
                           class="form-control text-foreground" placeholder="Buscar por cliente o comprobante..."
                           style="height:44px;border-radius:10px;padding-left:42px;" />
                </div>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-medium text-foreground mb-1">Canal</label>
                <select @bind="_channelFilter" @bind:after="OnFilterChange" class="form-select text-foreground" style="height:44px;border-radius:10px;">
                    <option value="">Todos</option>
                    <option value="web">Web</option>
                    <option value="presencial">Tienda</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-medium text-foreground mb-1">Pago</label>
                <select @bind="_payFilter" @bind:after="OnFilterChange" class="form-select text-foreground" style="height:44px;border-radius:10px;">
                    <option value="">Todos</option>
                    <option value="efectivo">Efectivo</option>
                    <option value="tarjeta">Tarjeta</option>
                    <option value="yape">Yape</option>
                    <option value="plin">Plin</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-medium text-foreground mb-1">Desde</label>
                <input type="date" @bind="_fechaDesde" @bind:after="OnFilterChange"
                       class="form-control text-foreground" style="height:44px;" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-medium text-foreground mb-1">Hasta</label>
                <input type="date" @bind="_fechaHasta" @bind:after="OnFilterChange"
                       class="form-control text-foreground" style="height:44px;" />
            </div>
        </div>
    </div>

    <!-- Filtros activos -->
    @if (TieneFiltrosActivos)
    {
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="small text-muted-foreground">Filtros activos:</span>
            @if (!string.IsNullOrEmpty(_search))
            {
                <span class="badge bg-primary-subtle text-primary">
                    Búsqueda: "@_search"
                    <button class="btn-close btn-close-sm ms-1" style="font-size:.6rem;" @onclick="@(() => { _search = ""; _currentPage = 1; })"></button>
                </span>
            }
            @if (_fechaDesde.HasValue || _fechaHasta.HasValue)
            {
                <span class="badge bg-info-subtle text-info">
                    @(_fechaDesde?.ToString("dd/MM/yy") ?? "…") → @(_fechaHasta?.ToString("dd/MM/yy") ?? "…")
                    <button class="btn-close btn-close-sm ms-1" style="font-size:.6rem;" @onclick="LimpiarFechas"></button>
                </span>
            }
            @if (!string.IsNullOrEmpty(_channelFilter))
            {
                <span class="badge bg-warning-subtle text-warning">
                    Canal: @_channelFilter
                    <button class="btn-close btn-close-sm ms-1" style="font-size:.6rem;" @onclick="@(() => { _channelFilter = ""; _currentPage = 1; })"></button>
                </span>
            }
            @if (!string.IsNullOrEmpty(_payFilter))
            {
                <span class="badge bg-secondary-subtle text-secondary">
                    Pago: @_payFilter
                    <button class="btn-close btn-close-sm ms-1" style="font-size:.6rem;" @onclick="@(() => { _payFilter = ""; _currentPage = 1; })"></button>
                </span>
            }
        </div>
    }

    <!-- Tabla -->
    <!-- Tabla -->
    <div class="card overflow-hidden">

        @if (_loading)
        {
            <LoadingIndicator Text="Cargando ventas..." MinHeight="350px" />
        }
        else
        {
            <div class="table-responsive">
                <!-- PEGA AQUÍ TODO EL CÓDIGO DE TU TABLA -->
                    
                <div class="card overflow-hidden">
                    <div class="table-responsive">
                        <table class="table table-borderless mb-0">
                            <thead class="border-bottom border-color-default">
                                <tr>
                                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Venta ID</th>
                                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Cliente</th>
                                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Fecha</th>
                                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Canal</th>
                                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Método Pago</th>
                                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Total</th>
                                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-center" style="letter-spacing:.05em;">Comprobante</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sale in Paged)
                                {
                                    <tr class="border-bottom border-color-default align-middle">
                                        <td class="px-4 py-3 fw-bold text-primary small">@sale.Id</td>
                                        <td class="px-4 py-3 small">
                                            <span class="fw-medium text-foreground d-block">@sale.Cliente</span>
                                            <span class="text-xs text-muted-foreground text-capitalize">Doc: @sale.Comprobante</span>
                                        </td>
                                        <td class="px-4 py-3 text-muted-foreground small">@sale.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="px-4 py-3 small">
                                            <span class="badge @GetChannelClass(sale.Canal) text-capitalize px-2 py-1" style="border-radius:var(--radius);">@sale.Canal</span>
                                        </td>
                                        <td class="px-4 py-3 text-foreground small">@((MarkupString)GetPayIcon(sale.MetodoPago))</td>
                                        <td class="px-4 py-3 fw-semibold text-foreground small">S/. @sale.Total.ToString("0.00")</td>
                                        <td class="px-4 py-3 text-center">
                                            <button class="btn btn-sm d-inline-flex align-items-center gap-1"
                                                    style="border-radius:0.4rem;font-size:0.78rem;font-weight:600;background-color:#e8f5e9;color:#064420;border:1px solid #c8e6d0;"
                                                    @onclick="@(() => VerBoleta(sale.Id))"
                                                    disabled="@_loadingBoleta">
                                                <i class="fas fa-file-invoice"></i> Ver Comprobante
                                            </button>
                                        </td>
                                    </tr>
                                }
                                @if (!Filtered.Any())
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-5 text-muted-foreground">No se encontraron registros de ventas</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

    </div>

    <!-- Paginación -->
    @if (TotalPages > 1)
    {
        <div class="d-flex justify-content-center align-items-center gap-2 py-2">
            <button class="btn btn-sm rounded-circle pag-btn" @onclick="@(() => GoToPage(_currentPage - 1))" disabled="@(_currentPage == 1)" style="width:36px;height:36px;">
                <i class="fa-solid fa-chevron-left" style="font-size:.75rem;"></i>
            </button>
            @for (int p = 1; p <= TotalPages; p++)
            {
                var pg = p;
                <button class="btn btn-sm rounded-circle pag-btn @(pg == _currentPage ? "pag-active" : "")"
                        @onclick="@(() => GoToPage(pg))"
                        style="width:36px;height:36px;font-size:.85rem;font-weight:600;">
                    @pg
                </button>
            }
            <button class="btn btn-sm rounded-circle pag-btn" @onclick="@(() => GoToPage(_currentPage + 1))" disabled="@(_currentPage == TotalPages)" style="width:36px;height:36px;">
                <i class="fa-solid fa-chevron-right" style="font-size:.75rem;"></i>
            </button>
        </div>
    }
</div>

<!-- Modal Ver Comprobante -->
@if (_showBoletaModal && _boletaSeleccionada != null)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.6);z-index:1070;backdrop-filter:blur(4px);">
        <div class="modal-dialog modal-dialog-centered" style="max-width:520px;">
            <div class="modal-content border-0 shadow-lg" style="border-radius:1.2rem;overflow:hidden;">

                <div class="p-4 text-center text-white" style="background: linear-gradient(135deg, #064420 0%, #157347 100%);">
                    <div class="d-inline-flex align-items-center justify-content-center bg-white rounded-circle mb-3 shadow-sm" style="width:60px;height:60px;color:#064420;">
                        <i class="fas fa-file-invoice" style="font-size:1.5rem;"></i>
                    </div>
                    <h4 class="fw-bold mb-1">Comprobante de Pago</h4>
                    <p class="mb-0 opacity-75 small">@_boletaSeleccionada.Serie - @_boletaSeleccionada.Numero.ToString("D8")</p>
                </div>

                <div class="modal-body p-4 bg-light">
                    <div class="card p-3 border-0 shadow-sm mb-3" style="border-radius:0.8rem;background-color:#ffffff;">
                        <div class="d-flex justify-content-between mb-2 pb-2 border-bottom" style="border-color:#f1f3f5!important;">
                            <span class="text-muted small">Cliente:</span>
                            <span class="fw-medium text-dark text-truncate" style="max-width:280px;">@_boletaSeleccionada.ClienteDenominacion</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 pb-2 border-bottom" style="border-color:#f1f3f5!important;">
                            <span class="text-muted small">Fecha de Emisión:</span>
                            <span class="fw-medium text-dark">@(_boletaSeleccionada.FechaEmision?.ToString("dd/MM/yyyy") ?? "-")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 pb-2 border-bottom" style="border-color:#f1f3f5!important;">
                            <span class="text-muted small">Monto Total:</span>
                            <span class="fw-bold text-success">S/ @_boletaSeleccionada.Total.ToString("0.00")</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted small">SUNAT:</span>
                            @if (_boletaSeleccionada.AceptadaPorSunat)
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle px-2.5 py-1" style="font-size:0.75rem;">
                                    <i class="fas fa-check-circle me-1"></i> ACEPTADA
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2.5 py-1" style="font-size:0.75rem;">
                                    <i class="fas fa-times-circle me-1"></i> RECHAZADA
                                </span>
                            }
                        </div>
                    </div>

                    <div class="d-flex flex-column gap-2 mb-3">
                        @if (!string.IsNullOrEmpty(_boletaSeleccionada.NubefactEnlacePdf))
                        {
                            <a href="@_boletaSeleccionada.NubefactEnlacePdf" target="_blank" class="btn btn-primary d-flex align-items-center justify-content-center gap-2 py-2.5" style="border-radius:0.6rem;font-weight:600;background-color:#064420;border:none;">
                                <i class="far fa-file-pdf fs-5"></i> Ver PDF del Comprobante
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(_boletaSeleccionada.NubefactEnlaceXml))
                        {
                            <a href="@_boletaSeleccionada.NubefactEnlaceXml" target="_blank" class="btn btn-outline-secondary d-flex align-items-center justify-content-center gap-2 py-2.5" style="border-radius:0.6rem;font-weight:600;">
                                <i class="far fa-file-code fs-5"></i> Ver XML (FacturaE)
                            </a>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(_boletaSeleccionada.NubefactCodigoHash))
                    {
                        <div class="text-center p-3 rounded" style="background-color:#f8f9fa;border:1px dashed #dee2e6;">
                            <span class="text-muted small d-block mb-1">Código Hash SUNAT:</span>
                            <code class="small text-break text-muted">@_boletaSeleccionada.NubefactCodigoHash</code>
                        </div>
                    }
                </div>

                <div class="modal-footer border-0 p-4 bg-light justify-content-center">
                    <button class="btn btn-dark w-100 py-2.5 fw-bold" style="border-radius:0.6rem;" @onclick="@(() => _showBoletaModal = false)">
                        Cerrar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showNoBoletaToast)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
        <div class="toast show text-white border-0 px-3 py-2" style="background:#6c757d;border-radius:var(--radius);min-width:260px;">
            <i class="fa-solid fa-info-circle me-2"></i>
            <span class="small">@_toastMsg</span>
        </div>
    </div>
}

@code {
    private List<Sale> _sales = new();
    private string _search        = "";
    private string _channelFilter = "";
    private string _payFilter     = "";
    private int _pageSize    = 10;
    private int _currentPage = 1;
    private bool _loading = true;

    private DateTime? _fechaDesde   = null;
    private DateTime? _fechaHasta   = null;

    private bool _loadingBoleta = false;
    private BoletaResponse? _boletaSeleccionada = null;
    private bool _showBoletaModal = false;
    private bool _showNoBoletaToast = false;
    private string _toastMsg = "";

    protected override async Task OnInitializedAsync()
    {
        _loading = true;

        await SalesSvc.EnsureLoadedAsync();
        _sales = SalesSvc.GetSales();

        _loading = false;
    }

    private void OnFilterChange() => _currentPage = 1;
    private void GoToPage(int p) { if (p >= 1 && p <= TotalPages) _currentPage = p; }
    private void LimpiarFechas() { _fechaDesde = null; _fechaHasta = null; OnFilterChange(); }

    private async Task VerBoleta(string saleId)
    {
        if (!int.TryParse(saleId.Replace("VTA-", ""), out int ventaId) || ventaId <= 0) return;

        _loadingBoleta = true;
        _showNoBoletaToast = false;
        _showBoletaModal = false;
        _boletaSeleccionada = null;
        StateHasChanged();

        try
        {
            var boleta = await SalesSvc.GetBoletaByVentaIdAsync(ventaId);
            if (boleta != null)
            {
                _boletaSeleccionada = boleta;
                _showBoletaModal = true;
            }
            else
            {
                _toastMsg = "Esta venta no tiene un comprobante de pago asociado.";
                _showNoBoletaToast = true;
                StateHasChanged();
                _ = Task.Run(async () => { await Task.Delay(3000); _showNoBoletaToast = false; await InvokeAsync(StateHasChanged); });
            }
        }
        catch
        {
            _toastMsg = "Error al consultar el comprobante.";
            _showNoBoletaToast = true;
            StateHasChanged();
            _ = Task.Run(async () => { await Task.Delay(3000); _showNoBoletaToast = false; await InvokeAsync(StateHasChanged); });
        }
        finally
        {
            _loadingBoleta = false;
        }
    }

    private bool TieneFiltrosActivos =>
        !string.IsNullOrEmpty(_search) ||
        _fechaDesde.HasValue || _fechaHasta.HasValue ||
        !string.IsNullOrEmpty(_channelFilter) ||
        !string.IsNullOrEmpty(_payFilter);
    private IEnumerable<Sale> Filtered => _sales.Where(s =>
        (string.IsNullOrEmpty(_search) ||
         s.Cliente.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
         s.Id.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_channelFilter) || s.Canal.Equals(_channelFilter, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_payFilter) || s.MetodoPago.Equals(_payFilter, StringComparison.OrdinalIgnoreCase)) &&
        (!_fechaDesde.HasValue || s.Fecha.Date >= _fechaDesde.Value.Date) &&
        (!_fechaHasta.HasValue || s.Fecha.Date <= _fechaHasta.Value.Date)
    ).OrderByDescending(s => s.Fecha);

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(Filtered.Count() / (double)_pageSize));
    private IEnumerable<Sale> Paged => Filtered.Skip((_currentPage - 1) * _pageSize).Take(_pageSize);

    private decimal TotalRevenue    => Filtered.Sum(s => s.Total);
    private decimal AvgTicket       => Filtered.Any() ? Filtered.Average(s => s.Total) : 0;
    private int     TotalTransactions => Filtered.Count();

    private string GetChannelClass(string ch) => ch.ToLower() switch
    {
        "web"       => "bg-primary-subtle text-primary",
        "presencial"=> "bg-success-subtle text-success",
        _ => "bg-light text-dark"
    };

    private string GetPayIcon(string method) => method.ToLower() switch
    {
        "yape"     => "<i class=\"fas fa-mobile-alt me-1 text-muted-foreground\"></i> Yape",
        "plin"     => "<i class=\"fas fa-mobile-alt me-1 text-muted-foreground\"></i> Plin",
        "tarjeta"  => "<i class=\"fas fa-credit-card me-1 text-muted-foreground\"></i> Tarjeta",
        "efectivo" => "<i class=\"fas fa-money-bill-wave me-1 text-muted-foreground\"></i> Efectivo",
        _ => method
    };
}
