@page "/admin/notificaciones"
@layout AdminLayout
@inject NotificacionService NotifSvc

@code {
    private List<NotificacionItem> _notifications = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _notifications = await NotifSvc.GetAllAsync();
        _loading = false;
    }

    private async Task MarkAsRead(int id)
    {
        await NotifSvc.MarcarLeidaAsync(id);
        var item = _notifications.FirstOrDefault(n => n.IdNotificacion == id);
        if (item != null) { item.Leida = true; StateHasChanged(); }
    }

    private async Task Delete(int id)
    {
        await NotifSvc.EliminarAsync(id);
        _notifications.RemoveAll(n => n.IdNotificacion == id);
        StateHasChanged();
    }

    private async Task ClearAll()
    {
        foreach (var n in _notifications.ToList())
            await NotifSvc.EliminarAsync(n.IdNotificacion);
        _notifications.Clear();
        StateHasChanged();
    }

    private string GetIcon(string? tipo) => tipo?.ToUpper() switch
    {
        "STOCK_BAJO"           => "fa-triangle-exclamation",
        "DEVOLUCION_PENDIENTE" => "fa-rotate-left",
        "NUEVO_PEDIDO"         => "fa-cart-shopping",
        "PEDIDO_LISTO"         => "fa-box-open",
        "VENTA_REGISTRADA"     => "fa-receipt",
        _                      => "fa-bell"
    };
}

<PageTitle>Notificaciones – Shiligama Admin</PageTitle>

<div class="d-flex flex-column gap-4 mx-auto" style="max-width: 900px; width: 100%;">
    <!-- Header -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h1 class="fs-4 fw-bold text-foreground mb-0">Centro de Notificaciones</h1>
            <p class="text-muted-foreground small mt-1 mb-0">Mantente al tanto del inventario y las ventas en tiempo real</p>
        </div>
        @if (_notifications.Any())
        {
            <button @onclick="ClearAll" class="btn btn-secondary btn-sm" style="border-radius: var(--radius);">
                Limpiar todas
            </button>
        }
    </div>

    @if (_loading)
    {
        <div class="text-center py-5 text-muted-foreground">
            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
            Cargando notificaciones...
        </div>
    }
    else if (!_notifications.Any())
    {
        <div class="card p-5 text-center bg-card rounded-4 border">
            <div class="fs-1 mb-3">🔔</div>
            <h3 class="text-foreground fw-semibold fs-5">No tienes notificaciones</h3>
            <p class="text-muted-foreground small m-0">¡Buen trabajo! Todo está bajo control en tu minimarket.</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var n in _notifications)
            {
                <div class="card p-3 d-flex flex-row align-items-start gap-3 rounded-4 border-color-default @(n.Leida ? "opacity-75 bg-muted bg-opacity-25" : "")">
                    <!-- Icono según tipo -->
                    <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                         style="width: 44px; height: 44px; background-color: @(n.TipoVisual == "warning" ? "rgba(245,158,11,0.15)" : n.TipoVisual == "danger" ? "rgba(239,68,68,0.15)" : "rgba(34,197,94,0.15)");">
                        <i class="fa-solid @GetIcon(n.Tipo)"
                           style="font-size: 20px; color: @(n.TipoVisual == "warning" ? "#f59e0b" : n.TipoVisual == "danger" ? "#ef4444" : "#22c55e");"></i>
                    </div>

                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center justify-content-between gap-3">
                            <h2 class="fs-6 fw-bold text-foreground mb-1">@n.Titulo</h2>
                            <span class="text-xs text-muted-foreground small">
                                @(n.FechaCreacion?.ToString("dd/MM/yyyy HH:mm") ?? "")
                            </span>
                        </div>
                        <p class="small text-muted-foreground mb-2">@n.Mensaje</p>

                        <div class="d-flex align-items-center gap-2">
                            @if (!n.Leida)
                            {
                                <button @onclick="@(() => MarkAsRead(n.IdNotificacion))"
                                        class="btn btn-ghost btn-sm text-primary px-2 py-1"
                                        style="border-radius: var(--radius); font-size: 0.75rem;">
                                    Marcar como leída
                                </button>
                            }
                            <button @onclick="@(() => Delete(n.IdNotificacion))"
                                    class="btn btn-ghost btn-sm text-danger px-2 py-1"
                                    style="border-radius: var(--radius); font-size: 0.75rem;">
                                Eliminar
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
