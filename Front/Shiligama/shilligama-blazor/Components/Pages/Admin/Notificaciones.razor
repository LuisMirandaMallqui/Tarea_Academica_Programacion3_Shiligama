@page "/admin/notificaciones"
@layout AdminLayout

@code {
    private List<NotificationItem> _notifications = new()
    {
        new("AL-001", "Alerta de Stock Crítico", "El producto 'Inca Kola 1.5L' se encuentra sin existencias.", "warning", DateTime.Now.AddHours(-1), false),
        new("AL-002", "Nueva Venta Registrada", "El cliente 'María García' ha completado el pedido ORD-001 por S/. 125.50.", "info", DateTime.Now.AddHours(-4), false),
        new("AL-003", "Solicitud de Devolución", "El empleado 'Jorge Trabajador' registró una devolución de 2 unidades de 'Pechuga de Pollo'.", "danger", DateTime.Now.AddDays(-1), true),
        new("AL-004", "Alerta de Almacén", "El producto 'Aceite Primor 1L' se encuentra con stock bajo (5 unidades).", "warning", DateTime.Now.AddDays(-2), true)
    };

    private void MarkAsRead(string id)
    {
        var item = _notifications.FirstOrDefault(n => n.Id == id);
        if (item != null) item.IsRead = true;
    }

    private void Delete(string id) => _notifications.RemoveAll(n => n.Id == id);

    private void ClearAll() => _notifications.Clear();

    private record NotificationItem(string Id, string Title, string Description, string Type, DateTime Time, bool IsRead)
    {
        public bool IsRead { get; set; } = IsRead;
    }
}

<PageTitle>Notificaciones – Shiligama Admin</PageTitle>

<div class="d-flex flex-column gap-4 mx-auto" style="max-width: 900px; width: 100%;">
    <!-- Header -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h1 class="fs-4 fw-bold text-foreground mb-0">Centro de Notificaciones</h1>
            <p class="text-muted-foreground small mt-1 mb-0">Mantente al tanto del inventario y las ventas en tiempo real</p>
        </div>
        @if (_notifications.Any())
        {
            <button @onclick="ClearAll" class="btn btn-secondary btn-sm" style="border-radius: var(--radius);">
                Limpiar todas
            </button>
        }
    </div>

    @if (!_notifications.Any())
    {
        <div class="card p-5 text-center bg-card rounded-4 border">
            <div class="fs-1 mb-3">🔔</div>
            <h3 class="text-foreground fw-semibold fs-5">No tienes notificaciones</h3>
            <p class="text-muted-foreground small m-0">¡Buen trabajo! Todo está bajo control en tu minimarket.</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var n in _notifications)
            {
                <div class="card p-3 d-flex flex-row align-items-start gap-3 rounded-4 border-color-default transition-all @(n.IsRead ? "opacity-75 bg-muted bg-opacity-25" : "")">
                    <!-- Icon based on type -->
                    <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 44px; height: 44px; background-color: @(n.Type == "warning" ? "rgba(245, 158, 11, 0.15)" : n.Type == "danger" ? "rgba(239, 68, 68, 0.15)" : "rgba(34, 197, 94, 0.15)");">
                        @if (n.Type == "warning")
                        {
                            <i class="fa-solid fa-triangle-exclamation" style="font-size: 22px; color: #f59e0b;"></i>
                        }
                        else if (n.Type == "danger")
                        {
                            <i class="fa-solid fa-trash-can" style="font-size: 22px; color: #ef4544;"></i>
                        }
                        else
                        {
                            <i class="fa-solid fa-cart-shopping" style="font-size: 22px; color: #22c55e;"></i>
                        }
                    </div>

                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center justify-content-between gap-3">
                            <h2 class="fs-6 fw-bold text-foreground mb-1">@n.Title</h2>
                            <span class="text-xs text-muted-foreground">@n.Time.ToString("g")</span>
                        </div>
                        <p class="small text-muted-foreground mb-2">@n.Description</p>
                
                        <div class="d-flex align-items-center gap-2">
                            @if (!n.IsRead)
                            {
                                <button @onclick="@(() => MarkAsRead(n.Id))" class="btn btn-ghost btn-sm text-primary px-2 py-1 small" style="border-radius: var(--radius); font-size: 0.75rem;">
                                    Marcar como leída
                                </button>
                            }
                            <button @onclick="@(() => Delete(n.Id))" class="btn btn-ghost btn-sm text-danger px-2 py-1 small" style="border-radius: var(--radius); font-size: 0.75rem;">
                                Eliminar
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
