@page "/admin/notificaciones"
@layout AdminLayout
@inject NotificacionService NotifSvc
@inject NavigationManager Navigation

<PageTitle>Notificaciones – Shiligama Admin</PageTitle>

<div class="d-flex flex-column gap-4 mx-auto" style="max-width: 900px; width: 100%;">
    <!-- Header -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <p class="text-muted-foreground small mt-0 mb-0">Todo lo relevante para el equipo: inventario, pedidos, devoluciones y promociones</p>
        </div>
        <div class="d-flex align-items-center gap-2">
            <button @onclick="RevisarPromociones" disabled="@_revisando" class="btn btn-outline-primary btn-sm" style="border-radius: var(--radius);" title="Revisa ahora promociones por vencer o vencidas, sin esperar el job automático">
                @if (_revisando)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                else
                {
                    <i class="fa-solid fa-rotate me-1"></i>
                }
                Revisar promociones
            </button>
            @if (_notifications.Any())
            {
                <button @onclick="ClearAll" class="btn btn-secondary btn-sm" style="border-radius: var(--radius);">
                    Limpiar todas
                </button>
            }
        </div>
    </div>

    @if (_loading)
    {
        <LoadingIndicator Text="Cargando notificaciones..." />
    }
    else if (!_notifications.Any())
    {
        <div class="card p-5 text-center bg-card rounded-4 border">
            <div class="fs-1 mb-3"><i class="fa-regular fa-bell-slash"></i></div>
            <h3 class="text-foreground fw-semibold fs-5">No tienes notificaciones</h3>
            <p class="text-muted-foreground small m-0">¡Buen trabajo! Todo está bajo control en tu minimarket.</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var n in _notifications)
            {
                <div class="card p-3 d-flex flex-row align-items-start gap-3 rounded-4 border-color-default @(n.Leida ? "opacity-75 bg-muted bg-opacity-25" : "")">
                    <!-- Icono según tipo -->
                    <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                         style="width: 44px; height: 44px; background-color: @(n.TipoVisual == "warning" ? "rgba(245,158,11,0.15)" : n.TipoVisual == "danger" ? "rgba(239,68,68,0.15)" : n.TipoVisual == "success" ? "rgba(34,197,94,0.15)" : "rgba(34,197,94,0.15)");">
                        <i class="fa-solid @n.Icono"
                           style="font-size: 20px; color: @(n.TipoVisual == "warning" ? "#f59e0b" : n.TipoVisual == "danger" ? "#ef4444" : n.TipoVisual == "success" ? "#22c55e" : "#22c55e");"></i>
                    </div>

                    <div class="flex-grow-1">
                        <div class="d-flex align-items-center justify-content-between gap-3">
                            <h2 class="fs-6 fw-bold text-foreground mb-1 notif-title-link"
                                @onclick="@(() => Ver(n))">
                                @n.Titulo
                            </h2>
                            <span class="text-xs text-muted-foreground small flex-shrink-0">
                                @(n.FechaCreacion?.ToString("dd/MM/yyyy HH:mm") ?? "")
                            </span>
                        </div>
                        <div class="d-flex align-items-center justify-content-between gap-3">
                            <p class="small text-muted-foreground mb-0">@n.Mensaje</p>
                            <div class="d-flex align-items-center gap-1 flex-shrink-0">
                                @if (!n.Leida)
                                {
                                    <button @onclick="@(() => MarkAsRead(n.IdNotificacion))"
                                            class="btn btn-ghost btn-sm text-primary d-flex align-items-center justify-content-center p-2"
                                            style="border-radius: var(--radius); width: 32px; height: 32px;"
                                            title="Marcar como revisado" aria-label="Marcar como revisado">
                                        <i class="fa-solid fa-check-circle" style="font-size: 0.85rem;"></i>
                                    </button>
                                }
                                <button @onclick="@(() => Delete(n.IdNotificacion))"
                                        class="btn btn-ghost btn-sm text-danger d-flex align-items-center justify-content-center p-2"
                                        style="border-radius: var(--radius); width: 32px; height: 32px;"
                                        title="Eliminar" aria-label="Eliminar">
                                    <i class="fa-solid fa-trash" style="font-size: 0.85rem;"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<NotificacionItem> _notifications = new();
    private bool _loading = true;
    private bool _revisando = false;

    protected override async Task OnInitializedAsync()
    {
        // Admin ve todo menos lo dirigido específicamente a un CLIENTE.
        _notifications = await NotifSvc.GetParaAdminAsync();
        _loading = false;
    }

    // Dispara la revisión de promociones (por vencer/vencidas) al instante
    // y recarga la lista para mostrar las notificaciones nuevas sin esperar
    // el job automático de 24h ni reiniciar el servidor.
    private async Task RevisarPromociones()
    {
        _revisando = true;
        StateHasChanged();
        await NotifSvc.RevisarPromocionesAsync();
        _notifications = await NotifSvc.GetParaAdminAsync();
        _revisando = false;
    }

    private async Task MarkAsRead(int id)
    {
        await NotifSvc.MarcarLeidaAsync(id);
        var item = _notifications.FirstOrDefault(n => n.IdNotificacion == id);
        if (item != null) { item.Leida = true; StateHasChanged(); }
    }

    private async Task Delete(int id)
    {
        await NotifSvc.EliminarAsync(id);
        _notifications.RemoveAll(n => n.IdNotificacion == id);
        StateHasChanged();
    }

    private async Task ClearAll()
    {
        foreach (var n in _notifications.ToList())
            await NotifSvc.EliminarAsync(n.IdNotificacion);
        _notifications.Clear();
        StateHasChanged();
    }

    // "Ver": navega al pedido/producto/devolución/promoción referenciado.
    // La página destino marca la notificación como leída via el parámetro &notif=.
    private void Ver(NotificacionItem n)
    {
        var ruta = n.RutaVerPara("admin");
        if (!string.IsNullOrEmpty(ruta))
        {
            Navigation.NavigateTo(ruta);
        }
    }
}
