@page "/admin/configuracion"
@layout AdminLayout
@inject AuthService Auth
@inject ConfiguracionService ConfigSvc

<PageTitle>Configuración del Sistema – Shiligama Admin</PageTitle>

<div class="container-fluid p-0 mx-auto" style="max-width: 900px;">
    <!-- Header -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h1 class="fs-4 fw-bold text-foreground mb-0">Configuración General del Sistema</h1>
            <p class="text-muted-foreground small mt-1 mb-0">Establece los parámetros globales de la tienda y del panel</p>
        </div>
    </div>

    @if (_error != null)
    {
        <div class="alert alert-danger alert-dismissible fade show p-3 d-flex align-items-center gap-2"
             style="border-radius: var(--radius);" role="alert">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <div>@_error</div>
            <button type="button" class="btn-close" @onclick="@(() => _error = null)"></button>
        </div>
    }

    @if (_success)
    {
        <div class="alert alert-success alert-dismissible fade show p-3 d-flex align-items-center gap-2"
             style="border-radius: var(--radius);" role="alert">
            <Icons Name="Check" Class="w-5 h-5 text-success" />
            <div>Las configuraciones globales han sido aplicadas correctamente.</div>
            <button type="button" class="btn-close" @onclick="@(() => _success = false)"></button>
        </div>
    }

    @if (_loading)
    {
        <div class="text-center py-5 text-muted-foreground">
            <div class="spinner-border spinner-border-sm me-2"></div> Cargando configuración...
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Forms column -->
            <div class="col-lg-8">
                <EditForm Model="_cfg" OnValidSubmit="SaveSettings" class="d-flex flex-column gap-4">
                    <!-- Shop Details -->
                    <div class="card p-4 d-flex flex-column gap-3 rounded-4">
                        <h2 class="fs-5 fw-bold text-foreground mb-0">Detalles del Minimarket</h2>
                        <div>
                            <label class="form-label small fw-medium text-foreground">Nombre Comercial</label>
                            <input type="text" @bind="_cfg.NombreTienda" required class="form-control text-foreground" />
                        </div>
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label small fw-medium text-foreground">Moneda Base</label>
                                <select @bind="_cfg.Moneda" class="form-select text-foreground">
                                    <option value="PEN (S/.)">Soles Peruanos (S/.)</option>
                                    <option value="USD ($)">Dólares Americanos ($)</option>
                                </select>
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-medium text-foreground">Impuesto IGV (%)</label>
                                <input type="number" step="0.1" min="0" @bind="_cfg.Igv" required class="form-control text-foreground" />
                            </div>
                        </div>
                    </div>

                    <!-- Delivery Settings -->
                    <div class="card p-4 d-flex flex-column gap-3 rounded-4">
                        <h2 class="fs-5 fw-bold text-foreground mb-0">Tarifa de Envío</h2>
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label small fw-medium text-foreground">Costo de Delivery (S/.)</label>
                                <input type="number" step="0.50" min="0" @bind="_cfg.TarifaEnvio" required
                                       class="form-control text-foreground" />
                                <div class="form-text text-muted-foreground">Tarifa base cuando no aplica envío gratis.</div>
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-medium text-foreground">Mínimo para Envío Gratis (S/.)</label>
                                <input type="number" step="1" min="0" @bind="_cfg.MinimoEnvioGratis" required
                                       class="form-control text-foreground" />
                                <div class="form-text text-muted-foreground">Subtotal desde el cual el envío es gratuito.</div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary px-4 py-2 fw-semibold"
                                style="border-radius: var(--radius);" disabled="@_saving">
                            @if (_saving)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            Guardar Configuración
                        </button>
                    </div>
                </EditForm>
            </div>

            <!-- Right helper column -->
            <div class="col-lg-4">
                <div class="card p-4 rounded-4 bg-muted border-0 text-center d-flex flex-column gap-3">
                    <div class="d-flex align-items-center justify-content-center bg-primary text-white rounded-3 mx-auto"
                         style="width: 48px; height: 48px;">
                        <Icons Name="Settings" Class="w-6 h-6" />
                    </div>
                    <div>
                        <h3 class="fs-6 fw-bold text-foreground mb-1">Información de Sistema</h3>
                        <p class="text-xs text-muted-foreground m-0">Shiligama Blazor v1.0.0-preview</p>
                    </div>
                    <p class="small text-muted-foreground m-0 leading-relaxed">
                        Corriendo en el entorno interactivo de alto rendimiento de .NET 10.
                    </p>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private ConfiguracionDto _cfg = new();
    private bool _loading = true;
    private bool _saving  = false;
    private bool _success = false;
    private string? _error = null;

    protected override async Task OnInitializedAsync()
    {
        await ConfigSvc.EnsureLoadedAsync();
        _cfg     = ConfigSvc.GetCopy();
        _loading = false;
    }

    private async Task SaveSettings()
    {
        _saving = true;
        _error  = null;
        _success = false;
        try
        {
            await ConfigSvc.GuardarAsync(_cfg);
            _success = true;
        }
        catch (Exception ex)
        {
            _error = $"No se pudo guardar la configuración: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }
}
