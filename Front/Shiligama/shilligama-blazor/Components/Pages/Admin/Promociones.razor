@page "/admin/promociones"
@layout AdminLayout
@using shilligama_blazor.Models
@using shilligama_blazor.Services
@inject ProductService ProductSvc
@inject PromocionService PromoSvc

<PageTitle>Promociones – Shiligama Admin</PageTitle>

<div class="d-flex flex-column gap-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h1 class="fs-4 fw-bold text-foreground mb-0">Gestión de Promociones</h1>
            <p class="text-muted-foreground small mt-1 mb-0">Crea y administra descuentos vinculados a productos del catálogo</p>
        </div>
        <button @onclick="OpenCreate" class="btn btn-primary d-flex align-items-center gap-2 fw-semibold" style="border-radius:var(--radius);">
            <i class="fa-solid fa-plus"></i> Nueva Promoción
        </button>
    </div>

    <!-- KPI -->
    <div class="row g-3">
        <div class="col-6 col-md-3">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value text-foreground">@_promos.Count</div><div class="metric-kpi-label">Total</div></div>
                <div class="metric-kpi-icon kpi-icon-primary"><i class="fas fa-tags"></i></div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value text-success">@_promos.Count(p => IsActive(p))</div><div class="metric-kpi-label">Vigentes</div></div>
                <div class="metric-kpi-icon kpi-icon-success"><i class="fas fa-check-circle"></i></div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value text-warning">@_promos.Count(p => p.TipoDescuento == "PORCENTAJE")</div><div class="metric-kpi-label">Por %</div></div>
                <div class="metric-kpi-icon kpi-icon-warning"><i class="fas fa-percent"></i></div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value text-primary">@_promos.Count(p => p.TipoDescuento == "MONTO_FIJO")</div><div class="metric-kpi-label">Monto Fijo</div></div>
                <div class="metric-kpi-icon kpi-icon-info"><i class="fas fa-dollar-sign"></i></div>
            </div>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card p-4" style="border-radius:12px;">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-medium text-foreground mb-1">Buscar</label>
                <div class="position-relative">
                    <i class="fa-solid fa-magnifying-glass position-absolute top-50 translate-middle-y text-muted" style="left:16px;font-size:14px;"></i>
                    <input type="search" @bind="_search" @bind:event="oninput" @bind:after="OnFilterChange"
                           class="form-control text-foreground" placeholder="Buscar por nombre o descripción..."
                           style="height:44px;border-radius:10px;padding-left:42px;" />
                </div>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-medium text-foreground mb-1">Tipo</label>
                <select @bind="_tipoFilter" @bind:after="OnFilterChange" class="form-select text-foreground" style="height:44px;border-radius:10px;">
                    <option value="">Todos</option>
                    <option value="PORCENTAJE">Porcentaje</option>
                    <option value="MONTO_FIJO">Monto Fijo</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-medium text-foreground mb-1">Estado</label>
                <select @bind="_estadoFilter" @bind:after="OnFilterChange" class="form-select text-foreground" style="height:44px;border-radius:10px;">
                    <option value="">Todos</option>
                    <option value="activo">Activas</option>
                    <option value="inactivo">Inactivas</option>
                </select>
            </div>

            <!-- Rango de fechas -->
            <div class="col-12">
                <div class="card border rounded-3 p-3" style="background:var(--secondary);">
                    <div class="row g-3 align-items-end">
                        <div class="col-auto d-flex align-items-center gap-2"
                             style="margin-bottom:8px;">
                            <i class="fa-regular fa-calendar text-primary" style="font-size:1.1rem;"></i>
                            <span class="small fw-semibold text-foreground">Rango de fechas</span>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small text-muted-foreground mb-1">Desde</label>
                            <input type="date" @bind="_fechaDesde" @bind:after="OnFilterChange"
                                   class="form-control text-foreground" style="height:40px;" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small text-muted-foreground mb-1">Hasta</label>
                            <input type="date" @bind="_fechaHasta" @bind:after="OnFilterChange"
                                   class="form-control text-foreground" style="height:40px;" />
                        </div>
                        <div class="col-auto d-flex gap-2 align-items-end">
                            <button class="btn btn-outline-secondary btn-sm" style="height:40px;border-radius:8px;" @onclick="SetHoy">Hoy</button>
                            <button class="btn btn-outline-secondary btn-sm" style="height:40px;border-radius:8px;" @onclick="Set7Dias">7 días</button>
                            <button class="btn btn-outline-secondary btn-sm" style="height:40px;border-radius:8px;" @onclick="Set30Dias">30 días</button>
                            @if (_fechaDesde.HasValue || _fechaHasta.HasValue)
                            {
                                <button class="btn btn-ghost btn-sm text-muted-foreground" style="height:40px;" @onclick="LimpiarFechas" title="Limpiar fechas">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla mejorada -->
    <div class="card" style="overflow:visible;">
        <div class="table-responsive" style="overflow:visible;">
            <table class="table table-borderless mb-0 align-middle">
                <thead class="border-bottom border-color-default">
                    <tr>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Promoción</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Descuento</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase d-none d-md-table-cell" style="letter-spacing:.05em;">Vigencia</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase d-none d-lg-table-cell" style="letter-spacing:.05em;">Productos</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Estado</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-end" style="letter-spacing:.05em;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var promo in Paged)
                    {
                        var isVigente = IsActive(promo);
                        <tr class="border-bottom border-color-default" style="transition:background .15s;">
                            <td class="px-4 py-3">
                                <div class="d-flex align-items-start gap-3">
                                    <!-- Ícono de tipo -->
                                    <div class="rounded-3 d-flex align-items-center justify-content-center flex-shrink-0"
                                         style="width:40px;height:40px;background:color-mix(in srgb,@(promo.TipoDescuento == "PORCENTAJE" ? "#f59e0b" : "#2563EB") 15%,transparent);">
                                        <i class="fas @(promo.TipoDescuento == "PORCENTAJE" ? "fa-percent" : "fa-dollar-sign")"
                                           style="color:@(promo.TipoDescuento == "PORCENTAJE" ? "#f59e0b" : "#2563EB");font-size:.9rem;"></i>
                                    </div>
                                    <div>
                                        <p class="fw-semibold text-foreground mb-0 small">@promo.Nombre</p>
                                        @if (!string.IsNullOrEmpty(promo.Descripcion))
                                        {
                                            <p class="text-xs text-muted-foreground mb-0">@promo.Descripcion</p>
                                        }
                                        @if (!string.IsNullOrEmpty(promo.Condiciones))
                                        {
                                            <p class="text-xs text-muted-foreground mb-0"><i class="fa-solid fa-circle-info me-1"></i>@promo.Condiciones</p>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-3 small">
                                <span class="badge fs-6 px-3 py-2 @(promo.TipoDescuento == "PORCENTAJE" ? "bg-warning-subtle text-warning" : "bg-info-subtle text-info")" style="border-radius:var(--radius);">
                                    @(promo.TipoDescuento == "PORCENTAJE" ? $"{promo.ValorDescuento}%" : $"S/. {promo.ValorDescuento:0.00}")
                                </span>
                            </td>
                            <td class="px-4 py-3 small text-muted-foreground d-none d-md-table-cell">
                                <div>
                                    <span class="badge bg-secondary-subtle text-secondary me-1" style="font-size:.7rem;">Inicio</span>
                                    @promo.FechaInicio.ToString("dd/MM/yy")
                                </div>
                                <div class="mt-1">
                                    <span class="badge bg-secondary-subtle text-secondary me-1" style="font-size:.7rem;">Fin</span>
                                    @promo.FechaFin.ToString("dd/MM/yy")
                                </div>
                            </td>
                            <td class="px-4 py-3 small text-muted-foreground d-none d-lg-table-cell">
                                @if (promo.ProductoIds.Count == 0)
                                {
                                    <span class="text-muted-foreground fst-italic">Ninguno asignado</span>
                                }
                                else
                                {
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var pid in promo.ProductoIds.Take(3))
                                        {
                                            var pNombre = _allProducts.FirstOrDefault(p => p.Id == pid)?.Name ?? $"ID {pid}";
                                            <span class="badge bg-secondary" style="font-size:.7rem;border-radius:6px;">@pNombre</span>
                                        }
                                        @if (promo.ProductoIds.Count > 3)
                                        {
                                            <span class="badge bg-secondary-subtle text-secondary" style="font-size:.7rem;border-radius:6px;">+@(promo.ProductoIds.Count - 3) más</span>
                                        }
                                    </div>
                                }
                            </td>
                            <td class="px-4 py-3">
                                <span class="badge px-2 py-1 @(isVigente ? "bg-success" : promo.Activo && promo.FechaInicio > DateTime.Today ? "bg-primary-subtle text-primary" : "bg-secondary")" style="border-radius:var(--radius);font-size:.75rem;">
                                    @(isVigente ? "✓ Vigente" : promo.Activo && promo.FechaInicio > DateTime.Today ? "⏳ Próxima" : "Inactiva")
                                </span>
                            </td>
                            <td class="px-4 py-3 text-end">
                                <div class="d-flex align-items-center justify-content-end gap-1">
                                    <button @onclick="@(() => OpenEdit(promo))"
                                            class="btn btn-ghost btn-sm text-muted-foreground"
                                            style="border-radius:var(--radius);" title="Editar">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </button>
                                    <button @onclick="@(() => AskToggle(promo.Id))"
                                            class="btn btn-ghost btn-sm @(promo.Activo ? "text-warning" : "text-success")"
                                            style="border-radius:var(--radius);" title="@(promo.Activo ? "Desactivar" : "Activar")">
                                        <i class="fa-solid @(promo.Activo ? "fa-eye-slash" : "fa-eye")"></i>
                                    </button>
                                    <!-- Sin eliminar según requerimiento -->
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Paged.Any())
                    {
                        <tr><td colspan="6" class="text-center py-5 text-muted-foreground">No se encontraron promociones</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Paginación -->
    @if (TotalPages > 1)
    {
        <div class="d-flex justify-content-center align-items-center gap-2 py-2">
            <button class="btn btn-sm rounded-circle pag-btn" @onclick="@(() => GoToPage(_currentPage - 1))" disabled="@(_currentPage == 1)" style="width:36px;height:36px;"><i class="fa-solid fa-chevron-left" style="font-size:.75rem;"></i></button>
            @for (int p = 1; p <= TotalPages; p++) { var pg = p;
                <button class="btn btn-sm rounded-circle pag-btn @(pg == _currentPage ? "pag-active" : "")" @onclick="@(() => GoToPage(pg))" style="width:36px;height:36px;font-size:.85rem;font-weight:600;">@pg</button>
            }
            <button class="btn btn-sm rounded-circle pag-btn" @onclick="@(() => GoToPage(_currentPage + 1))" disabled="@(_currentPage == TotalPages)" style="width:36px;height:36px;"><i class="fa-solid fa-chevron-right" style="font-size:.75rem;"></i></button>
        </div>
    }
</div>

<!-- Modal Crear/Editar -->
@if (_showModal)
{
    <div class="modal show d-block fade-in" tabindex="-1" style="background:rgba(0,0,0,.5);" @onclick="TryCloseModal">
        <div class="modal-dialog modal-lg modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content bg-card border-border">
                <div class="modal-header border-border">
                    <h5 class="modal-title text-foreground fw-bold">@(_isEditing ? "Editar Promoción" : "Nueva Promoción")</h5>
                    <button type="button" class="btn-close" @onclick="TryCloseModal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-medium text-foreground">Nombre *</label>
                            <input type="text" @bind="_form.Nombre" @bind:event="oninput" @bind:after="MarkDirty"
                                   class="form-control text-foreground @(string.IsNullOrWhiteSpace(_form.Nombre) && _submitted ? "is-invalid" : "")"
                                   placeholder="Descuento Verano" />
                            @if (string.IsNullOrWhiteSpace(_form.Nombre) && _submitted)
                            {
                                <div class="invalid-feedback">El nombre es obligatorio.</div>
                            }
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-medium text-foreground">Descripción</label>
                            <input type="text" @bind="_form.Descripcion" @bind:event="oninput" @bind:after="MarkDirty"
                                   class="form-control text-foreground" placeholder="Breve descripción" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium text-foreground">Tipo de descuento *</label>
                            <select @bind="_form.TipoDescuento" class="form-select text-foreground">
                                <option value="PORCENTAJE">Porcentaje (%)</option>
                                <option value="MONTO_FIJO">Monto Fijo (S/.)</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium text-foreground">
                                Valor * @(_form.TipoDescuento == "PORCENTAJE" ? "(0–100%)" : "(S/.)")
                            </label>
                            <input type="number" step=".01" min="0" @bind="_form.ValorDescuento" @bind:after="MarkDirty"
                                   class="form-control text-foreground @(_valorError != null ? "is-invalid" : "")" />
                            @if (_valorError != null)
                            {
                                <div class="invalid-feedback d-block" style="font-size:.8rem;">@_valorError</div>
                                @if (_invalidProducts.Count > 0)
                                {
                                    <div class="mt-1 px-2 py-2 rounded" style="background:color-mix(in srgb,#c62828 8%,transparent);border-left:3px solid #c62828;">
                                        <p class="small text-danger fw-semibold mb-1" style="font-size:.8rem;">Productos con precio insuficiente:</p>
                                        <ul class="mb-0 ps-3" style="font-size:.78rem;">
                                            @foreach (var name in _invalidProducts) { <li class="text-danger">@name</li> }
                                        </ul>
                                    </div>
                                }
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium text-foreground">Fecha Inicio *</label>
                            <input type="date" @bind="_form.FechaInicio" @bind:after="MarkDirty"
                                   class="form-control text-foreground @(_dateError != null ? "is-invalid" : "")" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium text-foreground">Fecha Fin *</label>
                            <input type="date" @bind="_form.FechaFin" @bind:after="MarkDirty"
                                   class="form-control text-foreground @(_dateError != null ? "is-invalid" : "")" />
                            @if (_dateError != null) { <div class="invalid-feedback d-block" style="font-size:.8rem;">@_dateError</div> }
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-medium text-foreground">Condiciones (opcional)</label>
                            <input type="text" @bind="_form.Condiciones" class="form-control text-foreground" placeholder="Ej: Solo fines de semana" />
                        </div>
                        <div class="col-md-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="promoActivo" @bind="_form.Activo" />
                                <label class="form-check-label small text-foreground" for="promoActivo">Promoción activa</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-medium text-foreground">
                                Productos vinculados
                                <span class="text-muted-foreground fw-normal">(@_form.ProductoIds.Count seleccionados)</span>
                            </label>
                            <div class="border rounded-3 p-3" style="max-height:180px;overflow-y:auto;background:var(--secondary);">
                                <div class="row g-1">
                                    @foreach (var prod in _allProducts.OrderBy(p => p.Name))
                                    {
                                        var pid = prod.Id;
                                        <div class="col-6">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="prod_@pid"
                                                       checked="@_form.ProductoIds.Contains(pid)"
                                                       @onchange="@(() => { ToggleProduct(pid); MarkDirty(); })" />
                                                <label class="form-check-label small text-foreground" for="prod_@pid">
                                                    @prod.Name
                                                    <span class="text-muted-foreground" style="font-size:.75rem;">(S/. @prod.Price.ToString("0.00"))</span>
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" @onclick="TryCloseModal" class="btn btn-secondary" style="border-radius:var(--radius);">Cancelar</button>
                        <button type="button" @onclick="TrySubmit" class="btn btn-primary fw-medium" style="border-radius:var(--radius);">
                            @(_isEditing ? "Guardar cambios" : "Crear promoción")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal Confirmar Salir sin Guardar -->
@if (_showUnsavedConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45);z-index:1070;">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">⚠️</div>
                    <h5 class="fw-bold text-foreground mb-1">¿Salir sin guardar?</h5>
                    <p class="text-muted-foreground small mb-4">Tienes cambios sin guardar. Si sales ahora se perderán.</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="@(() => _showUnsavedConfirm = false)">Continuar editando</button>
                        <button class="btn btn-danger" style="border-radius:var(--radius);" @onclick="ForceCloseModal">Salir sin guardar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal Confirmar Guardar -->
@if (_showSaveConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.55);z-index:1060;">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">💾</div>
                    <h5 class="fw-bold text-foreground mb-1">¿Guardar promoción?</h5>
                    <p class="text-muted-foreground small mb-4">
                        Se @(_isEditing ? "actualizará" : "creará") la promoción <strong>@_form.Nombre</strong>.
                        Los @_form.ProductoIds.Count producto(s) vinculados se marcarán en oferta.
                    </p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="CancelSave">Cancelar</button>
                        <button class="btn btn-primary" style="border-radius:var(--radius);" disabled="@_saving" @onclick="ConfirmSave">
                            @(_saving ? "Guardando…" : "Guardar")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal Confirmar Toggle -->
@if (_showToggleConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45);">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">⚙️</div>
                    <h5 class="fw-bold text-foreground mb-1">¿Cambiar estado?</h5>
                    <p class="text-muted-foreground small mb-4">Se cambiará el estado de la promoción. Los productos vinculados se actualizarán.</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="CancelToggle">Cancelar</button>
                        <button class="btn btn-primary" style="border-radius:var(--radius);" @onclick="ConfirmToggle">Confirmar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Toasts -->
@if (_showSavedToast)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
        <div class="toast show text-white border-0 px-3 py-2" style="background:#1A6B3C;border-radius:var(--radius);min-width:260px;">
            <i class="fa-solid fa-circle-check me-2"></i>
            <span class="small">Promoción @(_isEditing ? "actualizada" : "creada") correctamente</span>
        </div>
    </div>
}
@if (_showToggledToast)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
        <div class="toast show text-white border-0 px-3 py-2" style="background:#1A6B3C;border-radius:var(--radius);min-width:260px;">
            <i class="fa-solid fa-circle-check me-2"></i>
            <span class="small">Estado de promoción actualizado</span>
        </div>
    </div>
}

<style>
    .pag-btn { background:var(--card); border:1px solid var(--border); color:var(--foreground); transition:all .15s; }
    .pag-btn:hover:not(:disabled) { background:var(--secondary); }
    .pag-btn:disabled { opacity:.4; }
    .pag-active { background:#1A6B3C !important; color:#fff !important; border-color:#1A6B3C !important; }
</style>

@code {
    private List<Promocion> _promos      = new();
    private List<Product>   _allProducts = new();

    private string    _search       = "";
    private string    _tipoFilter   = "";
    private string    _estadoFilter = "";
    private DateTime? _fechaDesde   = null;
    private DateTime? _fechaHasta   = null;
    private int _pageSize    = 6;
    private int _currentPage = 1;

    // Modal
    private bool     _showModal    = false;
    private bool     _isEditing    = false;
    private bool     _formDirty    = false;
    private bool     _submitted    = false;
    private bool     _saving       = false;
    private Promocion _form        = new();
    private string?  _dateError;
    private string?  _valorError;
    private List<string> _invalidProducts = new();

    // Confirmaciones / toasts
    private bool _showSaveConfirm    = false;
    private bool _showToggleConfirm  = false;
    private bool _showSavedToast     = false;
    private bool _showToggledToast   = false;
    private bool _showUnsavedConfirm = false;
    private int  _pendingToggleId;

    protected override async Task OnInitializedAsync()
    {
        await ProductSvc.EnsureLoadedAsync();
        _allProducts = ProductSvc.GetProducts();

        // FIX: recargar siempre para que los cambios persistan entre visitas
        await PromoSvc.EnsureLoadedAsync(recargar: true);
        _promos = new List<Promocion>(PromoSvc.GetPromociones());

        foreach (var promo in _promos)
            promo.ProductoIds = await PromoSvc.GetProductosDePromocionAsync(promo.Id);

        SyncProductBadges();
    }

    private IEnumerable<Promocion> Filtered => _promos.Where(p =>
        (string.IsNullOrEmpty(_search) ||
            p.Nombre.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            (p.Descripcion ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_tipoFilter) || p.TipoDescuento == _tipoFilter) &&
        (_estadoFilter switch { "activo" => p.Activo, "inactivo" => !p.Activo, _ => true }) &&
        (!_fechaDesde.HasValue || p.FechaFin  >= _fechaDesde.Value) &&
        (!_fechaHasta.HasValue || p.FechaInicio <= _fechaHasta.Value)
    ).OrderByDescending(p => p.FechaInicio);

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(Filtered.Count() / (double)_pageSize));
    private IEnumerable<Promocion> Paged => Filtered.Skip((_currentPage - 1) * _pageSize).Take(_pageSize);
    private void OnFilterChange() { _currentPage = 1; }
    private void GoToPage(int p)  { if (p >= 1 && p <= TotalPages) _currentPage = p; }

    private void SetHoy()    { _fechaDesde = DateTime.Today; _fechaHasta = DateTime.Today; OnFilterChange(); }
    private void Set7Dias()  { _fechaDesde = DateTime.Today.AddDays(-7); _fechaHasta = DateTime.Today; OnFilterChange(); }
    private void Set30Dias() { _fechaDesde = DateTime.Today.AddDays(-30); _fechaHasta = DateTime.Today; OnFilterChange(); }
    private void LimpiarFechas() { _fechaDesde = null; _fechaHasta = null; OnFilterChange(); }

    private bool IsActive(Promocion p) => p.Activo && p.FechaFin >= DateTime.Today;

    private void SyncProductBadges()
    {
        foreach (var prod in _allProducts)
            prod.IsPromo = _promos.Any(pr => pr.Activo && pr.FechaFin >= DateTime.Today && pr.ProductoIds.Contains(prod.Id));
    }

    private void ToggleProduct(int id)
    {
        if (_form.ProductoIds.Contains(id)) _form.ProductoIds.Remove(id);
        else _form.ProductoIds.Add(id);
    }

    private void MarkDirty() => _formDirty = true;

    private void OpenCreate()
    {
        _form      = new Promocion { FechaInicio = DateTime.Today, FechaFin = DateTime.Today.AddDays(7) };
        _isEditing = false; _formDirty = false; _submitted = false;
        _dateError = null; _valorError = null; _invalidProducts.Clear(); _showModal = true;
    }
    private void OpenEdit(Promocion p)
    {
        _form = new Promocion
        {
            Id = p.Id, Nombre = p.Nombre, Descripcion = p.Descripcion,
            TipoDescuento = p.TipoDescuento, ValorDescuento = p.ValorDescuento,
            FechaInicio = p.FechaInicio, FechaFin = p.FechaFin,
            Condiciones = p.Condiciones, Activo = p.Activo, ProductoIds = new(p.ProductoIds)
        };
        _isEditing = true; _formDirty = false; _submitted = false;
        _dateError = null; _valorError = null; _invalidProducts.Clear(); _showModal = true;
    }

    private void TryCloseModal()
    {
        if (_formDirty) _showUnsavedConfirm = true;
        else            ForceCloseModal();
    }
    private void ForceCloseModal() { _showUnsavedConfirm = false; _showModal = false; }

    private void TrySubmit()
    {
        _submitted = true;
        _dateError = null; _valorError = null; _invalidProducts.Clear();

        if (string.IsNullOrWhiteSpace(_form.Nombre)) { _valorError = "El nombre es obligatorio."; return; }
        if (_form.FechaFin < _form.FechaInicio) { _dateError = "La fecha de fin no puede ser anterior al inicio."; return; }
        if (_form.ValorDescuento <= 0) { _valorError = "El valor de descuento debe ser mayor a 0."; return; }
        if (_form.TipoDescuento == "PORCENTAJE" && _form.ValorDescuento > 100) { _valorError = "El porcentaje no puede superar 100%."; return; }
        if (_form.TipoDescuento == "MONTO_FIJO" && _form.ProductoIds.Count > 0)
        {
            foreach (var id in _form.ProductoIds)
            {
                var prod = _allProducts.FirstOrDefault(p => p.Id == id);
                if (prod != null && _form.ValorDescuento >= (double)prod.Price)
                    _invalidProducts.Add($"{prod.Name} (S/. {prod.Price:0.00})");
            }
            if (_invalidProducts.Count > 0) { _valorError = $"El monto S/. {_form.ValorDescuento:0.00} supera el precio de {_invalidProducts.Count} producto(s)."; return; }
        }

        _showSaveConfirm = true;
    }

    private async Task ConfirmSave()
    {
        _saving = true;
        try
        {
            if (_isEditing)
            {
                var idx        = _promos.FindIndex(p => p.Id == _form.Id);
                var idsAntiguos = idx >= 0 ? new List<int>(_promos[idx].ProductoIds) : new List<int>();

                // FIX: Guardar en el backend primero, luego sincronizar productos
                await PromoSvc.UpdatePromocionAsync(_form);
                await SincronizarProductosAsync(_form.Id, idsAntiguos, _form.ProductoIds);

                // Actualizar lista local con los nuevos datos
                if (idx >= 0)
                {
                    _promos[idx] = new Promocion
                    {
                        Id = _form.Id, Nombre = _form.Nombre, Descripcion = _form.Descripcion,
                        TipoDescuento = _form.TipoDescuento, ValorDescuento = _form.ValorDescuento,
                        FechaInicio = _form.FechaInicio, FechaFin = _form.FechaFin,
                        Condiciones = _form.Condiciones, Activo = _form.Activo,
                        ProductoIds = new List<int>(_form.ProductoIds)
                    };
                }
            }
            else
            {
                await PromoSvc.AddPromocionAsync(_form);
                await SincronizarProductosAsync(_form.Id, new List<int>(), _form.ProductoIds);
                _promos.Insert(0, new Promocion
                {
                    Id = _form.Id, Nombre = _form.Nombre, Descripcion = _form.Descripcion,
                    TipoDescuento = _form.TipoDescuento, ValorDescuento = _form.ValorDescuento,
                    FechaInicio = _form.FechaInicio, FechaFin = _form.FechaFin,
                    Condiciones = _form.Condiciones, Activo = _form.Activo,
                    ProductoIds = new List<int>(_form.ProductoIds)
                });
            }

            SyncProductBadges();
            _showModal = false; _showSaveConfirm = false; _formDirty = false;
            _showSavedToast = true; StateHasChanged();
            await Task.Delay(3000); _showSavedToast = false; StateHasChanged();
        }
        finally { _saving = false; }
    }
    private void CancelSave() => _showSaveConfirm = false;

    private async Task SincronizarProductosAsync(int idPromo, List<int> antiguos, List<int> nuevos)
    {
        foreach (var pid in nuevos.Where(x => !antiguos.Contains(x)))
            await PromoSvc.AsociarProductoAsync(idPromo, pid);
        foreach (var pid in antiguos.Where(x => !nuevos.Contains(x)))
            await PromoSvc.DesasociarProductoAsync(idPromo, pid);
    }

    private void AskToggle(int id) { _pendingToggleId = id; _showToggleConfirm = true; }
    private void CancelToggle()    { _showToggleConfirm = false; }
    private async Task ConfirmToggle()
    {
        var p = _promos.FirstOrDefault(x => x.Id == _pendingToggleId);
        if (p != null)
        {
            p.Activo = !p.Activo;
            await PromoSvc.UpdatePromocionAsync(p);
            SyncProductBadges();
        }
        _showToggleConfirm = false;
        _showToggledToast  = true; StateHasChanged();
        await Task.Delay(3000); _showToggledToast = false; StateHasChanged();
    }
}
