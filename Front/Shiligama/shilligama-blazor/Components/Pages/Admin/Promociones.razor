@page "/admin/promociones"
@layout AdminLayout
@using shilligama_blazor.Models
@using shilligama_blazor.Services
@inject ProductService ProductSvc
@inject PromocionService PromoSvc

@code {
    // ── Estado ──────────────────────────────────────────────────────
    // Diseño portado del front del equipo, conectado a PromocionService
    // (carga real desde /api/promociones y persistencia de CRUD + vínculos).
    private List<Promocion> _promos = new();
    private List<Product> _allProducts = new();

    private string _search = "";
    private string _tipoFilter = "";
    private string _estadoFilter = "";
    private int _pageSize = 5;
    private int _currentPage = 1;

    // Modal
    private bool _showModal = false;
    private bool _isEditing = false;
    private Promocion _form = new();
    private string? _dateError;
    private string? _valorError;
    private List<string> _invalidProducts = new();

    // Confirmaciones / toasts
    private bool _showSaveConfirm   = false;
    private bool _showDeleteConfirm = false;
    private bool _showToggleConfirm = false;
    private bool _showSavedToast    = false;
    private bool _showToggledToast  = false;
    private bool _showDeletedToast  = false;
    private int  _pendingDeleteId;
    private int  _pendingToggleId;
    private System.Threading.CancellationTokenSource? _undoCts;
    private bool _undoAvailable = false;
    private Promocion? _deletedBackup;

    protected override async Task OnInitializedAsync()
    {
        await ProductSvc.EnsureLoadedAsync();
        _allProducts = ProductSvc.GetProducts();

        await PromoSvc.EnsureLoadedAsync();
        _promos = new List<Promocion>(PromoSvc.GetPromociones());

        // Cargar los productos vinculados de cada promoción (promocion_producto).
        foreach (var promo in _promos)
        {
            promo.ProductoIds = await PromoSvc.GetProductosDePromocionAsync(promo.Id);
        }
        SyncProductBadges();
    }

    private IEnumerable<Promocion> Filtered => _promos.Where(p =>
        (string.IsNullOrEmpty(_search)
            || p.Nombre.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || (p.Descripcion ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_tipoFilter) || p.TipoDescuento == _tipoFilter) &&
        (_estadoFilter switch { "activo" => p.Activo, "inactivo" => !p.Activo, _ => true })
    );

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(Filtered.Count() / (double)_pageSize));
    private IEnumerable<Promocion> Paged => Filtered.Skip((_currentPage - 1) * _pageSize).Take(_pageSize);
    private void OnFilterChange() { _currentPage = 1; }
    private void GoToPage(int p)  { if (p >= 1 && p <= TotalPages) _currentPage = p; }

    private string GetProductNames(List<int> ids) =>
        ids.Count == 0 ? "Ninguno asignado"
        : string.Join(", ", ids.Select(id => _allProducts.FirstOrDefault(p => p.Id == id)?.Name ?? $"ID {id}").Take(3)) + (ids.Count > 3 ? $" +{ids.Count - 3}" : "");

    private bool IsActive(Promocion p) => p.Activo && p.FechaFin >= DateTime.Today;

    private void SyncProductBadges()
    {
        foreach (var prod in _allProducts)
            prod.IsPromo = _promos.Any(pr => pr.Activo && pr.ProductoIds.Contains(prod.Id));
    }

    private void ToggleProduct(int id)
    {
        if (_form.ProductoIds.Contains(id)) _form.ProductoIds.Remove(id);
        else _form.ProductoIds.Add(id);
    }

    private void OpenCreate()
    {
        _form = new Promocion { FechaInicio = DateTime.Today, FechaFin = DateTime.Today.AddDays(7) };
        _isEditing = false; _dateError = null; _valorError = null; _invalidProducts.Clear(); _showModal = true;
    }
    private void OpenEdit(Promocion p)
    {
        _form = new Promocion
        {
            Id = p.Id, Nombre = p.Nombre, Descripcion = p.Descripcion, TipoDescuento = p.TipoDescuento,
            ValorDescuento = p.ValorDescuento, FechaInicio = p.FechaInicio, FechaFin = p.FechaFin,
            Condiciones = p.Condiciones, Activo = p.Activo, ProductoIds = new(p.ProductoIds)
        };
        _isEditing = true; _dateError = null; _valorError = null; _invalidProducts.Clear(); _showModal = true;
    }

    private void TrySubmit()
    {
        _dateError = null; _valorError = null; _invalidProducts.Clear();

        if (string.IsNullOrWhiteSpace(_form.Nombre))
            _valorError = "El nombre es obligatorio.";

        if (_form.FechaFin < _form.FechaInicio)
            _dateError = "La fecha de fin no puede ser anterior a la fecha de inicio.";

        if (_form.ValorDescuento <= 0)
            _valorError = "El valor de descuento debe ser mayor a 0.";
        else if (_form.TipoDescuento == "PORCENTAJE" && _form.ValorDescuento > 100)
            _valorError = "El porcentaje no puede superar 100%.";
        else if (_form.TipoDescuento == "MONTO_FIJO" && _form.ProductoIds.Count > 0)
        {
            foreach (var id in _form.ProductoIds)
            {
                var prod = _allProducts.FirstOrDefault(p => p.Id == id);
                if (prod != null && _form.ValorDescuento >= (double)prod.Price)
                    _invalidProducts.Add($"{prod.Name} (S/. {prod.Price:0.00})");
            }
            if (_invalidProducts.Count > 0)
                _valorError = $"El monto S/. {_form.ValorDescuento:0.00} es mayor o igual al precio de {_invalidProducts.Count} producto(s). Todos deben ser válidos para guardar.";
        }

        if (_dateError != null || _valorError != null) return;
        _showSaveConfirm = true;
    }

    private async Task ConfirmSave()
    {
        if (_isEditing)
        {
            var idx = _promos.FindIndex(p => p.Id == _form.Id);
            var idsAntiguos = idx >= 0 ? new List<int>(_promos[idx].ProductoIds) : new List<int>();

            await PromoSvc.UpdatePromocionAsync(_form);
            await SincronizarProductosAsync(_form.Id, idsAntiguos, _form.ProductoIds);

            if (idx >= 0) _promos[idx] = _form;
        }
        else
        {
            await PromoSvc.AddPromocionAsync(_form); // asigna _form.Id desde el backend
            await SincronizarProductosAsync(_form.Id, new List<int>(), _form.ProductoIds);
            _promos.Insert(0, _form);
        }
        SyncProductBadges();
        _showModal = false; _showSaveConfirm = false;
        _showSavedToast = true; StateHasChanged();
        await Task.Delay(3000); _showSavedToast = false; StateHasChanged();
    }
    private void CancelSave() => _showSaveConfirm = false;

    // Asocia/desasocia los productos vinculados según la diferencia.
    private async Task SincronizarProductosAsync(int idPromo, List<int> antiguos, List<int> nuevos)
    {
        foreach (var pid in nuevos.Where(x => !antiguos.Contains(x)))
            await PromoSvc.AsociarProductoAsync(idPromo, pid);
        foreach (var pid in antiguos.Where(x => !nuevos.Contains(x)))
            await PromoSvc.DesasociarProductoAsync(idPromo, pid);
    }

    // Toggle activo
    private void AskToggle(int id) { _pendingToggleId = id; _showToggleConfirm = true; }
    private void CancelToggle()    { _showToggleConfirm = false; }
    private async Task ConfirmToggle()
    {
        var p = _promos.FirstOrDefault(x => x.Id == _pendingToggleId);
        if (p != null)
        {
            p.Activo = !p.Activo;
            await PromoSvc.UpdatePromocionAsync(p);
            SyncProductBadges();
        }
        _showToggleConfirm = false;
        _showToggledToast = true; StateHasChanged();
        await Task.Delay(3000); _showToggledToast = false; StateHasChanged();
    }

    // Eliminar
    private void AskDelete(int id) { _pendingDeleteId = id; _showDeleteConfirm = true; }
    private void CancelDelete()    { _showDeleteConfirm = false; }
    private async Task ConfirmDelete()
    {
        _deletedBackup = _promos.FirstOrDefault(p => p.Id == _pendingDeleteId);
        await PromoSvc.DeletePromocionAsync(_pendingDeleteId);
        _promos.RemoveAll(p => p.Id == _pendingDeleteId);
        SyncProductBadges();
        _showDeleteConfirm = false;
        _showDeletedToast = true; _undoAvailable = true; StateHasChanged();
        _undoCts?.Cancel(); _undoCts = new();
        try { await Task.Delay(5000, _undoCts.Token); _showDeletedToast = false; _undoAvailable = false; StateHasChanged(); }
        catch (TaskCanceledException) { }
    }
    private async Task UndoDelete()
    {
        if (_deletedBackup != null)
        {
            var backup = _deletedBackup;
            await PromoSvc.AddPromocionAsync(backup); // se re-crea en el backend
            await SincronizarProductosAsync(backup.Id, new List<int>(), backup.ProductoIds);
            _promos.Insert(0, backup);
            _deletedBackup = null;
            SyncProductBadges();
        }
        _undoCts?.Cancel(); _showDeletedToast = false; _undoAvailable = false; StateHasChanged();
    }
}

<PageTitle>Promociones – Shiligama Admin</PageTitle>

<div class="d-flex flex-column gap-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h1 class="page-title mb-0"><i class="fas fa-tags me-2 text-primary"></i>Gestión de Promociones</h1>
            <p class="page-subtitle">Crea y administra descuentos vinculados a productos del catálogo</p>
        </div>
        <button @onclick="OpenCreate" class="btn btn-primary d-flex align-items-center gap-2 fw-semibold" style="border-radius:var(--radius);">
            <i class="fa-solid fa-plus"></i> Nueva Promoción
        </button>
    </div>

    <!-- KPI mini -->
    <div class="row g-3">
        <div class="col-6 col-md-3">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value text-foreground">@_promos.Count</div><div class="metric-kpi-label">Total</div></div>
                <div class="metric-kpi-icon kpi-icon-primary"><i class="fas fa-tags"></i></div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value text-success">@_promos.Count(p => IsActive(p))</div><div class="metric-kpi-label">Activas</div></div>
                <div class="metric-kpi-icon kpi-icon-success"><i class="fas fa-check-circle"></i></div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value text-warning">@_promos.Count(p => p.TipoDescuento == "PORCENTAJE")</div><div class="metric-kpi-label">Por %</div></div>
                <div class="metric-kpi-icon kpi-icon-warning"><i class="fas fa-percent"></i></div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="metric-card-kpi">
                <div><div class="metric-kpi-value text-primary">@_promos.Count(p => p.TipoDescuento == "MONTO_FIJO")</div><div class="metric-kpi-label">Monto Fijo</div></div>
                <div class="metric-kpi-icon kpi-icon-info"><i class="fas fa-dollar-sign"></i></div>
            </div>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card p-4" style="border-radius:12px;">
        <div class="row g-2 align-items-center">
            <div class="col-md-5">
                <div class="position-relative">
                    <i class="fa-solid fa-magnifying-glass position-absolute top-50 translate-middle-y text-muted" style="left:16px;font-size:14px;"></i>
                    <input type="search" @bind="_search" @bind:event="oninput" @bind:after="OnFilterChange"
                           class="form-control text-foreground" placeholder="Buscar por nombre o descripción..."
                           style="height:56px;border-radius:10px;padding-left:42px;" />
                </div>
            </div>
            <div class="col-md-4">
                <select @bind="_tipoFilter" @bind:after="OnFilterChange" class="form-select text-foreground" style="height:56px;border-radius:10px;">
                    <option value="">Todos los tipos</option>
                    <option value="PORCENTAJE">Porcentaje (%)</option>
                    <option value="MONTO_FIJO">Monto Fijo (S/.)</option>
                </select>
            </div>
            <div class="col-md-3">
                <select @bind="_estadoFilter" @bind:after="OnFilterChange" class="form-select text-foreground" style="height:56px;border-radius:10px;">
                    <option value="">Todos los estados</option>
                    <option value="activo">Activas</option>
                    <option value="inactivo">Inactivas</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Tabla -->
    <div class="card" style="overflow:visible;">
        <div class="table-responsive" style="overflow:visible;">
            <table class="table table-borderless mb-0 align-middle">
                <thead class="border-bottom border-color-default">
                    <tr>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Promoción</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Descuento</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase d-none d-md-table-cell" style="letter-spacing:.05em;">Vigencia</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase d-none d-lg-table-cell" style="letter-spacing:.05em;">Productos</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Estado</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-end" style="letter-spacing:.05em;">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var promo in Paged)
                    {
                        var isVigente = IsActive(promo);
                        <tr class="border-bottom border-color-default">
                            <td class="px-4 py-3">
                                <p class="fw-semibold text-foreground mb-0 small">@promo.Nombre</p>
                                <p class="text-xs text-muted-foreground mb-0">@promo.Descripcion</p>
                                @if (!string.IsNullOrEmpty(promo.Condiciones))
                                {
                                    <p class="text-xs text-muted-foreground mb-0"><i class="fa-solid fa-circle-info me-1"></i>@promo.Condiciones</p>
                                }
                            </td>
                            <td class="px-4 py-3 small">
                                <span class="badge @(promo.TipoDescuento == "PORCENTAJE" ? "bg-warning-subtle text-warning" : "bg-info-subtle text-info")" style="border-radius:var(--radius);font-size:.8rem;">
                                    @(promo.TipoDescuento == "PORCENTAJE" ? $"{promo.ValorDescuento}%" : $"S/. {promo.ValorDescuento:0.00}")
                                </span>
                            </td>
                            <td class="px-4 py-3 small text-muted-foreground d-none d-md-table-cell">
                                @promo.FechaInicio.ToString("dd/MM/yy") → @promo.FechaFin.ToString("dd/MM/yy")
                            </td>
                            <td class="px-4 py-3 small text-muted-foreground d-none d-lg-table-cell">
                                @GetProductNames(promo.ProductoIds)
                            </td>
                            <td class="px-4 py-3">
                                <span class="badge @(isVigente ? "bg-success" : promo.Activo && promo.FechaInicio > DateTime.Today ? "bg-primary-subtle text-primary" : "bg-secondary") px-2 py-1" style="border-radius:var(--radius);font-size:.75rem;">
                                    @(isVigente ? "Activa" : promo.Activo && promo.FechaInicio > DateTime.Today ? "Próxima" : "Inactiva")
                                </span>
                            </td>
                            <td class="px-4 py-3 text-end">
                                <div class="d-flex align-items-center justify-content-end gap-1">
                                    <button @onclick="@(() => OpenEdit(promo))" class="btn btn-ghost btn-sm text-muted-foreground" style="border-radius:var(--radius);" title="Editar">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </button>
                                    <button @onclick="@(() => AskToggle(promo.Id))"
                                            class="btn btn-ghost btn-sm @(promo.Activo ? "text-warning" : "text-success")"
                                            style="border-radius:var(--radius);" title="@(promo.Activo ? "Desactivar" : "Activar")">
                                        <i class="fa-solid @(promo.Activo ? "fa-eye-slash" : "fa-eye")"></i>
                                    </button>
                                    <button @onclick="@(() => AskDelete(promo.Id))" class="btn btn-ghost btn-sm text-danger" style="border-radius:var(--radius);" title="Eliminar">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Paged.Any()) { <tr><td colspan="6" class="text-center py-5 text-muted-foreground">No se encontraron promociones</td></tr> }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Paginación -->
    @if (TotalPages > 1)
    {
        <div class="d-flex justify-content-center align-items-center gap-2 py-2">
            <button class="btn btn-sm rounded-circle pag-btn" @onclick="@(() => GoToPage(_currentPage - 1))" disabled="@(_currentPage == 1)" style="width:36px;height:36px;"><i class="fa-solid fa-chevron-left" style="font-size:.75rem;"></i></button>
            @for (int p = 1; p <= TotalPages; p++) { var pg = p;
                <button class="btn btn-sm rounded-circle pag-btn @(pg == _currentPage ? "pag-active" : "")" @onclick="@(() => GoToPage(pg))" style="width:36px;height:36px;font-size:.85rem;font-weight:600;">@pg</button>
            }
            <button class="btn btn-sm rounded-circle pag-btn" @onclick="@(() => GoToPage(_currentPage + 1))" disabled="@(_currentPage == TotalPages)" style="width:36px;height:36px;"><i class="fa-solid fa-chevron-right" style="font-size:.75rem;"></i></button>
        </div>
    }
</div>

<!-- Modal Crear/Editar -->
@if (_showModal)
{
    <div class="modal show d-block fade-in" tabindex="-1" style="background:rgba(0,0,0,.5);" @onclick="@(() => _showModal = false)">
        <div class="modal-dialog modal-lg modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content bg-card border-border">
                <div class="modal-header border-border">
                    <h5 class="modal-title text-foreground fw-bold">@(_isEditing ? "Editar Promoción" : "Nueva Promoción")</h5>
                    <button type="button" class="btn-close" @onclick="@(() => _showModal = false)"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-medium text-foreground">Nombre *</label>
                            <input type="text" @bind="_form.Nombre" class="form-control text-foreground" placeholder="Descuento Verano" />
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-medium text-foreground">Descripción</label>
                            <input type="text" @bind="_form.Descripcion" class="form-control text-foreground" placeholder="Breve descripción de la promo" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium text-foreground">Tipo de descuento *</label>
                            <select @bind="_form.TipoDescuento" class="form-select text-foreground">
                                <option value="PORCENTAJE">Porcentaje (%)</option>
                                <option value="MONTO_FIJO">Monto Fijo (S/.)</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium text-foreground">
                                Valor *
                                @(_form.TipoDescuento == "PORCENTAJE" ? "(0–100%)" : "(S/.)")
                            </label>
                            <input type="number" step=".01" min="0" @bind="_form.ValorDescuento"
                                   class="form-control text-foreground @(_valorError != null ? "is-invalid" : "")" />
                            @if (_valorError != null)
                            {
                                <div class="invalid-feedback d-block" style="font-size:.8rem;">@_valorError</div>
                                @if (_invalidProducts.Count > 0)
                                {
                                    <div class="mt-1 px-2 py-2 rounded" style="background:color-mix(in srgb,#c62828 8%,transparent);border-left:3px solid #c62828;">
                                        <p class="small text-danger fw-semibold mb-1" style="font-size:.8rem;">Productos con precio insuficiente:</p>
                                        <ul class="mb-0 ps-3" style="font-size:.78rem;">
                                            @foreach (var name in _invalidProducts)
                                            {
                                                <li class="text-danger">@name</li>
                                            }
                                        </ul>
                                    </div>
                                }
                            }
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium text-foreground">Fecha Inicio *</label>
                            <input type="date" @bind="_form.FechaInicio" class="form-control text-foreground @(_dateError != null ? "is-invalid" : "")" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-medium text-foreground">Fecha Fin *</label>
                            <input type="date" @bind="_form.FechaFin" class="form-control text-foreground @(_dateError != null ? "is-invalid" : "")" />
                            @if (_dateError != null) { <div class="invalid-feedback d-block" style="font-size:.8rem;">@_dateError</div> }
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-medium text-foreground">Condiciones (opcional)</label>
                            <input type="text" @bind="_form.Condiciones" class="form-control text-foreground" placeholder="Ej: Solo fines de semana" />
                        </div>
                        <div class="col-md-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="promoActivo" @bind="_form.Activo" />
                                <label class="form-check-label small text-foreground" for="promoActivo">Promoción activa</label>
                            </div>
                        </div>
                        <!-- Vincular productos -->
                        <div class="col-12">
                            <label class="form-label small fw-medium text-foreground">Productos vinculados (promocion_producto)</label>
                            <div class="row g-1 mt-1" style="max-height:160px;overflow-y:auto;">
                                @foreach (var prod in _allProducts)
                                {
                                    var pid = prod.Id;
                                    <div class="col-6">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="prod_@pid"
                                                   checked="@_form.ProductoIds.Contains(pid)"
                                                   @onchange="@(() => ToggleProduct(pid))" />
                                            <label class="form-check-label small text-foreground" for="prod_@pid">@prod.Name</label>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" @onclick="@(() => _showModal = false)" class="btn btn-secondary" style="border-radius:var(--radius);">Cancelar</button>
                        <button type="button" @onclick="TrySubmit" class="btn btn-primary fw-medium" style="border-radius:var(--radius);">
                            @(_isEditing ? "Guardar cambios" : "Crear promoción")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal Confirmar Guardar -->
@if (_showSaveConfirm) {
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.55);z-index:1060;">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">💾</div>
                    <h5 class="fw-bold text-foreground mb-1">¿Guardar promoción?</h5>
                    <p class="text-muted-foreground small mb-4">Se @(_isEditing ? "actualizará" : "creará") la promoción <strong>@_form.Nombre</strong>. Los productos vinculados se marcarán como "en promoción".</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="CancelSave">Cancelar</button>
                        <button class="btn btn-primary" style="border-radius:var(--radius);" @onclick="ConfirmSave">Guardar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal Confirmar Toggle -->
@if (_showToggleConfirm) {
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45);">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">⚙️</div>
                    <h5 class="fw-bold text-foreground mb-1">¿Cambiar estado?</h5>
                    <p class="text-muted-foreground small mb-4">Se cambiará el estado de la promoción. Los productos vinculados se actualizarán.</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="CancelToggle">Cancelar</button>
                        <button class="btn btn-primary" style="border-radius:var(--radius);" @onclick="ConfirmToggle">Confirmar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal Confirmar Eliminar -->
@if (_showDeleteConfirm) {
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45);">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">🗑️</div>
                    <h5 class="fw-bold text-foreground mb-1">¿Eliminar promoción?</h5>
                    <p class="text-muted-foreground small mb-4">Se eliminará la promoción y se quitará el badge "Promo" de los productos vinculados. Podrás deshacer por 5 seg.</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary" style="border-radius:var(--radius);" @onclick="CancelDelete">Cancelar</button>
                        <button class="btn btn-danger" style="border-radius:var(--radius);" @onclick="ConfirmDelete">Eliminar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Toasts -->
@if (_showSavedToast) {
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
        <div class="toast show text-white border-0 px-3 py-2" style="background:#1A6B3C;border-radius:var(--radius);min-width:260px;">
            <i class="fa-solid fa-circle-check me-2"></i><span class="small">Promoción @(_isEditing ? "actualizada" : "creada") correctamente</span>
        </div>
    </div>
}
@if (_showToggledToast) {
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
        <div class="toast show text-white border-0 px-3 py-2" style="background:#1A6B3C;border-radius:var(--radius);min-width:260px;">
            <i class="fa-solid fa-circle-check me-2"></i><span class="small">Estado de promoción actualizado</span>
        </div>
    </div>
}
@if (_showDeletedToast) {
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
        <div class="toast show text-white border-0 d-flex align-items-center gap-2 px-3 py-2" style="background:#1A6B3C;border-radius:var(--radius);min-width:280px;">
            <i class="fa-solid fa-circle-check"></i>
            <span class="small flex-grow-1">Promoción eliminada</span>
            @if (_undoAvailable) { <button class="btn btn-sm btn-link text-white p-0" @onclick="UndoDelete">Deshacer</button> }
        </div>
    </div>
}

<style>
    .pag-btn { background:var(--card); border:1px solid var(--border); color:var(--foreground); transition:all .15s; }
    .pag-btn:hover:not(:disabled) { background:var(--secondary); }
    .pag-btn:disabled { opacity:.4; }
    .pag-active { background:#1A6B3C !important; color:#fff !important; border-color:#1A6B3C !important; }
</style>
