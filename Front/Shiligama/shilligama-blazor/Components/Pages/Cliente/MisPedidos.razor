@page "/mis-pedidos"
@layout MainLayout
@inject SalesService SalesSvc
@inject AuthService Auth
@inject NavigationManager Navigation
@inject CartService Cart
@inject ProductService ProductSvc
@inject IJSRuntime JS

<PageTitle>Mis Pedidos – Shiligama</PageTitle>

<style>
/* ── Pagination ──────────────────────────────────────────────────────────── */
.pagination-nav-btn {
    width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;
    border:1.5px solid var(--border);background:var(--background);color:var(--foreground);
    cursor:pointer;transition:background .15s,border-color .15s;font-size:.8rem;
}
.pagination-nav-btn:disabled { opacity:.4;cursor:not-allowed; }
.pagination-nav-btn:not(:disabled):hover { background:var(--secondary); }
.pagination-num-btn {
    width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;
    border:1.5px solid var(--border);background:var(--background);color:var(--foreground);
    cursor:pointer;transition:background .15s,border-color .15s;font-size:.8rem;
}
.pagination-num-btn.active-page {
    background:var(--primary);border-color:var(--primary);color:#fff;font-weight:600;
}
.pagination-num-btn:not(.active-page):hover { background:var(--secondary); }
/* ── Cancel toast ────────────────────────────────────────────────────────── */
@@keyframes toastSlideIn  { from{transform:translateY(40px);opacity:0} to{transform:translateY(0);opacity:1} }
@@keyframes toastSlideOut { from{opacity:1} to{opacity:0} }
.cancelled-toast {
    position:fixed;bottom:1.5rem;right:1.5rem;z-index:1090;
    display:flex;align-items:center;gap:.6rem;
    background:#1d4ed8;color:#fff;border-radius:var(--radius);
    padding:.65rem 1rem;font-size:.84rem;font-weight:500;
    box-shadow:0 4px 18px rgba(0,0,0,.25);
    animation:toastSlideIn .3s ease-out forwards;
    max-width:320px;
}
/* ── Repeat modal qty input ──────────────────────────────────────────────── */
.qty-input-sm {
    width:54px;text-align:center;border:1.5px solid var(--border);
    border-radius:6px;padding:.2rem .3rem;font-size:.8rem;
    background:var(--background);color:var(--foreground);
}
.qty-input-sm::-webkit-inner-spin-button,
.qty-input-sm::-webkit-outer-spin-button { -webkit-appearance:none;margin:0; }
.qty-input-sm[type=number] { -moz-appearance:textfield; }
</style>

@if (_loading)
{
    <LoadingIndicator Text="Cargando tus pedidos..." />
}
else
{
<div class="container-xl px-3 px-sm-4 py-4" style="max-width:960px;">

    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="d-flex align-items-center justify-content-center bg-primary-subtle text-primary rounded-3 flex-shrink-0"
             style="width:48px;height:48px;">
            <Icons Name="Package" style="width:24px;height:24px;" />
        </div>
        <div>
            <h1 class="fs-4 fw-bold text-foreground mb-0">Mis Pedidos</h1>
            <p class="text-muted-foreground small mb-0">
                Revisa el historial de tus compras y repite tus pedidos favoritos
            </p>
        </div>
    </div>

    <div class="card border border-border rounded-4 p-3 mb-4">
        <div class="d-flex flex-column flex-md-row align-items-md-center gap-2">
            <select class="form-select form-select-sm" style="min-width:170px;max-width:220px;"
                    @onchange="OnStatusChanged">
                <option value="todos">Todos los estados</option>
                <option value="recibido">Recibido</option>
                <option value="en_proceso">En proceso</option>
                <option value="atendido">Atendido</option>
                <option value="rechazado">Rechazado</option>
                <option value="cancelado">Cancelado</option>
            </select>

            <div class="input-group input-group-sm" style="max-width:190px;">
                <span class="input-group-text"
                      style="border:1.5px solid var(--border);border-right:none;
                    background:var(--secondary);color:var(--foreground);">
                    <Icons Name="Calendar" style="width:13px;height:13px;" />
                </span>
                <input type="date" class="form-control form-control-sm"
                       style="border:1.5px solid var(--border);border-left:none;"
                       value="@(_dateFrom?.ToString("yyyy-MM-dd") ?? "")"
                       @onchange="OnDateFromChanged" />
            </div>

            <div class="input-group input-group-sm" style="max-width:190px;">
                <span class="input-group-text"
                      style="border:1.5px solid var(--border);border-right:none;
                    background:var(--secondary);color:var(--foreground);">
                    <Icons Name="Calendar" style="width:13px;height:13px;" />
                </span>
                <input type="date" class="form-control form-control-sm"
                       style="border:1.5px solid var(--border);border-left:none;"
                       value="@(_dateTo?.ToString("yyyy-MM-dd") ?? "")"
                       @onchange="OnDateToChanged" />
            </div>

            @if (_statusFilter != "todos" || _dateFrom.HasValue || _dateTo.HasValue)
            {
                <button class="btn btn-outline-secondary btn-sm d-flex align-items-center gap-1 flex-shrink-0"
                        @onclick="ClearFilters">
                    <Icons Name="X" style="width:13px;height:13px;" /> Limpiar
                </button>
            }
        </div>
    </div>

    @if (!_filtered.Any())
    {
        <div class="card p-5 text-center rounded-4 border border-border">
            <div class="fs-1 mb-3">📦</div>
            <h3 class="text-foreground fw-semibold fs-5">No se encontraron pedidos</h3>
            <p class="text-muted-foreground small">
                @(_statusFilter != "todos" || _dateFrom.HasValue || _dateTo.HasValue
                    ? "Prueba ajustando los filtros"
                    : "Aún no has realizado ningún pedido")
            </p>
            <a href="/catalogo" class="btn btn-primary mt-3 px-4" style="border-radius:var(--radius);">
                Explorar catálogo
            </a>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var order in PagedOrders)
            {
                <div class="card border border-border rounded-4 overflow-hidden">
                    <div class="d-flex flex-column flex-lg-row">

                        <div class="flex-grow-1 p-3 p-sm-4">
                            <div class="d-flex flex-wrap align-items-start justify-content-between gap-2 mb-3">
                                <div>
                                    <div class="d-flex align-items-center gap-2 flex-wrap">
                                        <span class="fw-bold text-foreground">@order.Id</span>
                                        <span class="badge rounded-pill @(StatusBadgeClass(order.Status))">
                                            @StatusLabel(order.Status)
                                        </span>
                                    </div>
                                    <p class="text-muted-foreground small mt-1 mb-0">
                                        @order.Date.ToString("dd MMM yyyy, hh:mm tt")
                                    </p>
                                </div>
                                <span class="badge border d-flex align-items-center gap-1
                                    @(order.DeliveryMethod == "delivery"
                                                                              ? "border-primary text-primary bg-primary-subtle"
                                                                              : "border-success text-success bg-success-subtle")">
                                    <Icons Name="@(order.DeliveryMethod == "delivery" ? "Truck" : "Store")"
                                           style="width:12px;height:12px;" />
                                    @DeliveryLabel(order.DeliveryMethod)
                                </span>
                            </div>

                            <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
                                <div class="d-flex flex-shrink-0">
                                    @for (int i = 0; i < Math.Min(order.Products.Count, 4); i++)
                                    {
                                        int idx = i;
                                        <div class="rounded-2 bg-secondary-subtle d-flex align-items-center justify-content-center"
                                             style="width:32px;height:32px;
                                            margin-left:@(idx > 0 ? "-6px" : "0");
                                            z-index:@(4 - idx);
                                            border:2px solid var(--bs-body-bg);">
                                            <Icons Name="Package" style="width:14px;height:14px;" Class="text-muted-foreground" />
                                        </div>
                                    }
                                    @if (order.Products.Count > 4)
                                    {
                                        <div class="rounded-2 bg-primary-subtle d-flex align-items-center justify-content-center"
                                             style="width:32px;height:32px;margin-left:-6px;
                                            border:2px solid var(--bs-body-bg);">
                                            <span class="small text-primary fw-bold" style="font-size:.65rem;">
                                                +@(order.Products.Count - 4)
                                            </span>
                                        </div>
                                    }
                                </div>
                                <div class="small">
                                    <span class="fw-medium">@order.Products.Count productos</span>
                                    <span class="text-muted-foreground"> – </span>
                                    <span class="text-muted-foreground">
                                        @string.Join(", ", order.Products.Take(2).Select(p => p.Name))
                                        @(order.Products.Count > 2 ? "..." : "")
                                    </span>
                                </div>
                            </div>

                            <div class="d-flex align-items-center gap-1 small">
                                <Icons Name="@PaymentIconName(order.PaymentMethod)"
                                       style="width:14px;height:14px;"
                                       Class="text-muted-foreground" />
                                <span class="text-muted-foreground">@PaymentLabel(order.PaymentMethod)</span>
                            </div>
                        </div>

                        <div class="d-flex flex-row flex-lg-column align-items-center
                            justify-content-between justify-content-lg-center
                            gap-3 p-3 p-sm-4
                            border-top border-lg-top-0 border-lg-start border-border"
                             style="min-width:0;">
                            <div class="text-center">
                                <p class="text-muted-foreground mb-0"
                                   style="font-size:.65rem;text-transform:uppercase;letter-spacing:.05em;">Total</p>
                                <p class="fw-bold text-primary mb-0 fs-5">
                                    S/. @order.Total.ToString("0.00")
                                </p>
                            </div>
                            <div class="d-flex flex-row flex-lg-column gap-2">
                                <button class="btn btn-outline-secondary btn-sm d-flex align-items-center gap-1"
                                        @onclick="() => OpenDetail(order)">
                                    <Icons Name="Eye" style="width:13px;height:13px;" />
                                    <span>Ver detalle</span>
                                </button>
                                @if (order.Status != "cancelado")
                                {
                                    <button class="btn btn-primary btn-sm d-flex align-items-center gap-1"
                                            @onclick="() => OpenRepeatModal(order)">
                                        <Icons Name="RotateCcw" style="width:13px;height:13px;" />
                                        <span>Repetir</span>
                                    </button>
                                }
                                @if (CanCancel(order))
                                {
                                    <button class="btn btn-outline-danger btn-sm d-flex align-items-center gap-1"
                                            @onclick="() => AskCancel(order)">
                                        <Icons Name="X" style="width:13px;height:13px;" />
                                        <span>Cancelar</span>
                                    </button>
                                }
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>

        @if (TotalPages > 1)
        {
            <nav class="d-flex align-items-center justify-content-center gap-2 mt-4 flex-wrap">
                <button class="pagination-nav-btn" disabled="@(_currentPage == 1)"
                        @onclick="() => GoToPage(_currentPage - 1)">
                    <Icons Name="ChevronLeft" style="width:14px;height:14px;" />
                </button>
                @for (int pg = 1; pg <= TotalPages; pg++)
                {
                    int p = pg;
                    <button class="pagination-num-btn @(_currentPage == p ? "active-page" : "")"
                            @onclick="() => GoToPage(p)">@p</button>
                }
                <button class="pagination-nav-btn" disabled="@(_currentPage == TotalPages)"
                        @onclick="() => GoToPage(_currentPage + 1)">
                    <Icons Name="ChevronRight" style="width:14px;height:14px;" />
                </button>
            </nav>
        }

        <p class="text-center small text-muted-foreground mt-3">
            Mostrando @PagedOrders.Count de @_filtered.Count pedidos
            @if (TotalPages > 1) { <text> (página @_currentPage de @TotalPages)</text> }
        </p>
    }
</div>

@* ===== Toast cancelación ===== *@
@if (_showCancelledToast)
{
    <div class="cancelled-toast">
        <Icons Name="CheckCircle" style="width:18px;height:18px;flex-shrink:0;" />
        <span>Pedido cancelado correctamente</span>
    </div>
}

@* ===== Modal repetir pedido ===== *@
@if (_showRepeatModal && _orderToRepeat != null)
{
    <div class="modal fade show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.55);backdrop-filter:blur(3px);"
         @onclick="CloseRepeatModal">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable"
             style="max-width:500px;"
             @onclick:stopPropagation="true">
            <div class="modal-content rounded-4 border-0"
                 style="background:var(--card);color:var(--foreground);">
                <div class="modal-header border-bottom border-border py-3">
                    <h5 class="modal-title fw-bold d-flex align-items-center gap-2">
                        <Icons Name="RotateCcw" Class="text-primary" style="width:18px;height:18px;" />
                        Repetir pedido @_orderToRepeat.Id
                    </h5>
                    <button class="btn-close ms-auto" @onclick="CloseRepeatModal"></button>
                </div>
                <div class="modal-body py-3">
                    <p class="text-muted-foreground small mb-3">
                        Selecciona los productos y ajusta las cantidades a tu gusto.
                    </p>
                    <div class="d-flex flex-column gap-2">
                        @foreach (var item in _orderToRepeat.Products)
                        {
                            bool isSelected = _selectedProductsToRepeat.Contains(item.Id);
                            <div class="d-flex align-items-center gap-3 p-2 rounded-3
                                        @(isSelected ? "" : "opacity-50")"
                                 style="border:1.5px solid var(--border);transition:opacity .15s;">
                                <input type="checkbox" class="form-check-input flex-shrink-0"
                                       checked="@isSelected"
                                       @onchange="() => ToggleProductSelection(item.Id)" />
                                <div class="flex-grow-1 min-w-0">
                                    <p class="fw-medium small mb-0 text-truncate">@item.Name</p>
                                    <p class="text-muted-foreground mb-0" style="font-size:.72rem;">
                                        S/. @item.Price.ToString("0.00") c/u
                                    </p>
                                </div>
                                <input type="number"
                                       class="qty-input-sm"
                                       min="1"
                                       value="@(_quantitiesToRepeat.GetValueOrDefault(item.Id, item.Quantity))"
                                       disabled="@(!isSelected)"
                                       @onchange="@(e => HandleRepeatQuantityChange(item.Id,
                                                   int.TryParse(e.Value?.ToString(), out var q) ? q : 1))" />
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer border-top border-border py-3 d-flex gap-2">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="CloseRepeatModal">
                        Cancelar
                    </button>
                    <button class="btn btn-primary btn-sm fw-semibold d-flex align-items-center gap-2"
                            @onclick="ConfirmRepeatOrder"
                            disabled="@(!_selectedProductsToRepeat.Any())">
                        <Icons Name="ShoppingCart" style="width:13px;height:13px;" />
                        Agregar al carrito
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ===== Modal confirmación de cancelación ===== *@
@if (_showCancelConfirm && _orderToCancel != null)
{
    <div class="modal fade show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.55);backdrop-filter:blur(3px);">
        <div class="modal-dialog modal-dialog-centered" style="max-width:400px;">
            <div class="modal-content rounded-4 border-0" style="background:var(--card);">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.4rem;">⚠️</div>
                    <h5 class="fw-bold mb-1">¿Cancelar pedido @_orderToCancel.Id?</h5>
                    <p class="text-muted-foreground small mb-4">
                        Puedes cancelar mientras el pedido esté en estado <strong>Recibido</strong> o <strong>En proceso</strong>.
                        Una vez atendido no es posible cancelar.
                    </p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-outline-secondary px-3"
                                @onclick="@(() => { _showCancelConfirm = false; _orderToCancel = null; })"
                                disabled="@_cancelling">
                            Volver
                        </button>
                        <button class="btn btn-danger px-3 fw-semibold d-flex align-items-center gap-2"
                                @onclick="ConfirmCancel"
                                disabled="@_cancelling">
                            @if (_cancelling)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            Sí, cancelar pedido
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* ===== Modal alertas de stock al repetir pedido ===== *@
@if (_showStockAlerts)
{
    <div class="modal fade show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.55);backdrop-filter:blur(3px);">
        <div class="modal-dialog modal-dialog-centered" style="max-width:460px;">
            <div class="modal-content rounded-4 border-0"
                 style="background:var(--card);color:var(--foreground);">
                <div class="modal-header border-bottom border-border py-3">
                    <h5 class="modal-title fw-bold d-flex align-items-center gap-2">
                        <Icons Name="AlertTriangle" Class="text-warning" style="width:20px;height:20px;" />
                        Stock insuficiente
                    </h5>
                    <button class="btn-close ms-auto" @onclick="@(() => _stockAlerts.Clear())"></button>
                </div>
                <div class="modal-body py-3">
                    <p class="text-muted-foreground small mb-3">
                        Se ajustaron las cantidades de algunos productos al repetir el pedido:
                    </p>
                    <ul class="list-unstyled d-flex flex-column gap-2">
                        @foreach (var msg in _stockAlerts)
                        {
                            <li class="d-flex align-items-start gap-2 p-2 rounded-3"
                                style="background:color-mix(in srgb,#f59e0b 10%,transparent);
                                       border:1px solid color-mix(in srgb,#f59e0b 30%,transparent);">
                                <Icons Name="Info" Class="text-warning flex-shrink-0"
                                       style="width:14px;height:14px;margin-top:2px;" />
                                <span class="small">@msg</span>
                            </li>
                        }
                    </ul>
                </div>
                <div class="modal-footer border-top border-border py-3 d-flex gap-2">
                    <button class="btn btn-outline-secondary btn-sm"
                            @onclick="@(() => _stockAlerts.Clear())">
                        Cancelar
                    </button>
                    <button class="btn btn-primary btn-sm"
                            @onclick="@(() => { _stockAlerts.Clear(); Navigation.NavigateTo("/carrito"); })">
                        Ir al carrito de todos modos
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showModal && _selectedOrder != null)
{
    <div class="modal fade show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.65);backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);"
         @onclick="CloseModal">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-fullscreen-sm-down"
             @onclick:stopPropagation="true">
            <div class="modal-content rounded-4 border-0"
                 style="background-color:var(--card);color:var(--foreground);">

                <div class="modal-header border-bottom border-border py-3">
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <h5 class="modal-title fw-bold text-foreground mb-0">
                            @_selectedOrder.Id
                        </h5>
                        <span class="badge rounded-pill @(StatusBadgeClass(_selectedOrder.Status))">
                            @StatusLabel(_selectedOrder.Status)
                        </span>
                    </div>
                    <button class="btn-close ms-auto" @onclick="CloseModal"></button>
                </div>

                <div class="modal-body d-flex flex-column gap-4 py-4">

                    <div class="d-flex align-items-center gap-2 small text-muted-foreground">
                        <Icons Name="Clock" style="width:14px;height:14px;" />
                        <span>
                            @_selectedOrder.Date.ToString("dddd, dd 'de' MMMM 'de' yyyy, hh:mm tt",
                                new System.Globalization.CultureInfo("es-PE"))
                        </span>
                    </div>

                    <div class="p-3 rounded-3" style="background:var(--secondary);">
                        <h6 class="fw-semibold small mb-3">Seguimiento del pedido</h6>
                        @{
                            var steps = GetTimeline(_selectedOrder);
                            int totalSteps = steps.Count;
                        }
                        @for (int i = 0; i < totalSteps; i++)
                        {
                            var step = steps[i];
                            bool isLast = i == totalSteps - 1;

                            string circleBg = step.Cancelled ? "#fee2e2"
                                                : step.Done ? "var(--bs-primary)"
                                                                 : "var(--bs-secondary-bg)";
                            string circleBorder = step.Cancelled ? "#ef4444"
                                                : step.Done ? "var(--bs-primary)"
                                                                 : "var(--bs-border-color)";
                            string iconName = step.Cancelled ? "X"
                                                : step.Done ? "Check"
                                                                 : "Circle";
                            string iconClass = step.Cancelled ? "text-danger"
                                                : step.Done ? "text-white"
                                                                 : "text-muted-foreground";

                            <div class="d-flex gap-3 position-relative @(!isLast ? "pb-4" : "")">
                                @if (!isLast)
                                {
                                    <div class="position-absolute"
                                         style="left:15px;top:30px;width:2px;height:calc(100% - 10px);
                                        background:@(step.Done ? "var(--bs-primary)" : "var(--bs-border-color)");">
                                    </div>
                                }
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                                     style="width:32px;height:32px;z-index:1;position:relative;
                                    background:@circleBg;border:2px solid @circleBorder;">
                                    <Icons Name="@iconName" Class="@iconClass"
                                           style="width:14px;height:14px;" />
                                </div>
                                <div class="pt-1">
                                    <p class="fw-medium small mb-0
                                        @(step.Cancelled ? "text-danger"
                                                                                 : step.Done ? "text-foreground"
                                                                                                : "text-muted-foreground")">
                                        @step.Label
                                    </p>
                                    @if (step.Time.HasValue)
                                    {
                                        <p class="mb-0 text-muted-foreground" style="font-size:.72rem;">
                                            @step.Time.Value.ToString("dd MMM")
                                            – @step.Time.Value.ToString("hh:mm tt")
                                        </p>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <div class="d-flex align-items-center gap-3 p-3 border border-border rounded-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:40px;height:40px;
                            background:@(_selectedOrder.DeliveryMethod == "delivery"
                                                             ? "color-mix(in srgb,#3b82f6 15%,transparent)"
                                                             : "color-mix(in srgb,#22c55e 15%,transparent)");">
                            <Icons Name="@(_selectedOrder.DeliveryMethod == "delivery" ? "Truck" : "Store")"
                                   Class="@(_selectedOrder.DeliveryMethod == "delivery" ? "text-primary" : "text-success")"
                                   style="width:18px;height:18px;" />
                        </div>
                        <div>
                            <p class="fw-medium small mb-0">
                                @(_selectedOrder.DeliveryMethod == "delivery"
                                    ? "Delivery a domicilio" : "Recojo en tienda")
                            </p>
                            @if (!string.IsNullOrEmpty(_selectedOrder.Address))
                            {
                                <p class="text-muted-foreground mb-0" style="font-size:.72rem;">
                                    <Icons Name="MapPin" style="width:11px;height:11px;" />
                                    @_selectedOrder.Address
                                </p>
                            }
                        </div>
                    </div>

                    <div>
                        <h6 class="fw-semibold small mb-3 d-flex align-items-center gap-1">
                            <Icons Name="Package" Class="text-primary" style="width:14px;height:14px;" />
                            Productos (@_selectedOrder.Products.Count)
                        </h6>
                        <div class="d-flex flex-column">
                            @foreach (var item in _selectedOrder.Products)
                            {
                                <div class="d-flex align-items-center justify-content-between py-2 border-bottom border-border">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded-2 bg-secondary-subtle d-flex align-items-center justify-content-center flex-shrink-0"
                                             style="width:36px;height:36px;">
                                            <Icons Name="Package" style="width:14px;height:14px;"
                                                   Class="text-muted-foreground" />
                                        </div>
                                        <div>
                                            <p class="fw-medium small mb-0">@item.Name</p>
                                            <p class="text-muted-foreground mb-0" style="font-size:.72rem;">
                                                S/. @item.Price.ToString("0.00") × @item.Quantity
                                            </p>
                                        </div>
                                    </div>
                                    <span class="fw-medium small flex-shrink-0 ms-2">
                                        S/. @((item.Price * item.Quantity).ToString("0.00"))
                                    </span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="d-flex flex-column gap-1">
                        <div class="d-flex justify-content-between small text-muted-foreground">
                            <span>Subtotal</span>
                            <span>S/. @_selectedOrder.Subtotal.ToString("0.00")</span>
                        </div>
                        <div class="d-flex justify-content-between small text-muted-foreground">
                            <span>Envío</span>
                            <span>
                                @(_selectedOrder.DeliveryFee > 0
                                    ? $"S/. {_selectedOrder.DeliveryFee:0.00}" : "Gratis")
                            </span>
                        </div>
                        <div class="d-flex justify-content-between fw-bold pt-2 border-top border-border">
                            <span class="text-foreground">Total</span>
                            <span class="text-primary fs-5">
                                S/. @_selectedOrder.Total.ToString("0.00")
                            </span>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-3 p-3 border border-border rounded-3">
                        <div class="rounded-circle bg-secondary-subtle d-flex align-items-center justify-content-center flex-shrink-0"
                             style="width:40px;height:40px;">
                            <Icons Name="@PaymentIconName(_selectedOrder.PaymentMethod)"
                                   style="width:18px;height:18px;"
                                   Class="text-muted-foreground" />
                        </div>
                        <div>
                            <p class="fw-medium small mb-0">
                                @PaymentLabel(_selectedOrder.PaymentMethod)
                            </p>
                            <p class="text-muted-foreground mb-0" style="font-size:.72rem;">
                                Método de pago
                            </p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
}

}

@code {
    private List<Order> _allOrders = new();
    private List<Order> _filtered  = new();
    private bool _loading = true;

    private string    _statusFilter = "todos";
    private DateTime? _dateFrom;
    private DateTime? _dateTo;

    private Order? _selectedOrder;
    private bool   _showModal;

    // ── Pagination ───────────────────────────────────────────────────────────
    private int _currentPage = 1;
    private const int PageSize = 10;
    private int TotalPages => (int)Math.Ceiling(_filtered.Count / (double)PageSize);
    private List<Order> PagedOrders => _filtered
        .Skip((_currentPage - 1) * PageSize).Take(PageSize).ToList();

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > TotalPages) return;
        _currentPage = page;
        await JS.InvokeVoidAsync("window.scrollTo", 0, 0);
    }

    // ── Repeat-order modal ───────────────────────────────────────────────────
    private bool   _showRepeatModal = false;
    private Order? _orderToRepeat;
    private HashSet<int>     _selectedProductsToRepeat = new();
    private Dictionary<int, int> _quantitiesToRepeat   = new();

    private void OpenRepeatModal(Order o)
    {
        _orderToRepeat = o;
        _selectedProductsToRepeat = o.Products.Select(p => p.Id).ToHashSet();
        _quantitiesToRepeat = o.Products.ToDictionary(p => p.Id, p => p.Quantity);
        _showRepeatModal = true;
    }

    private void CloseRepeatModal()
    {
        _showRepeatModal = false;
        _orderToRepeat   = null;
    }

    private void ToggleProductSelection(int productId)
    {
        if (_selectedProductsToRepeat.Contains(productId))
            _selectedProductsToRepeat.Remove(productId);
        else
            _selectedProductsToRepeat.Add(productId);
    }

    private void HandleRepeatQuantityChange(int productId, int qty)
    {
        _quantitiesToRepeat[productId] = Math.Max(1, qty);
    }

    private async Task ConfirmRepeatOrder()
    {
        if (_orderToRepeat == null) return;
        _stockAlerts.Clear();
        await ProductSvc.EnsureLoadedAsync();

        bool anyAdded = false;
        foreach (var item in _orderToRepeat.Products)
        {
            if (!_selectedProductsToRepeat.Contains(item.Id)) continue;

            int quantityToAdd = _quantitiesToRepeat.GetValueOrDefault(item.Id, item.Quantity);
            var currentProduct = ProductSvc.GetProductById(item.Id);

            if (currentProduct != null)
            {
                if (currentProduct.Stock == 0)
                {
                    _stockAlerts.Add($"'{item.Name}' ya no está disponible (sin stock).");
                    continue;
                }
                if (currentProduct.Stock < quantityToAdd)
                {
                    _stockAlerts.Add(
                        $"Pediste {quantityToAdd} de '{item.Name}', " +
                        $"pero solo hay {currentProduct.Stock} disponible(s). " +
                        $"Se agregó la cantidad disponible.");
                    quantityToAdd = currentProduct.Stock;
                }
            }

            var p = new Product
            {
                Id    = item.Id,
                Name  = item.Name,
                Price = item.Price,
                Image = item.Image
            };
            for (int i = 0; i < quantityToAdd; i++)
                await Cart.AddToCartAsync(p);
            anyAdded = true;
        }

        CloseRepeatModal();

        if (_showStockAlerts)
            StateHasChanged();
        else if (anyAdded)
            Navigation.NavigateTo("/carrito?repeated=true");
    }

    // ── Cancel toast ─────────────────────────────────────────────────────────
    private bool _showCancelledToast = false;

    // ── Alertas de stock al repetir pedido ───────────────────────────────────
    private List<string> _stockAlerts = new();
    private bool _showStockAlerts => _stockAlerts.Any();

    // ── Cancelación de pedido ─────────────────────────────────────────────────
    private Order? _orderToCancel;
    private bool   _showCancelConfirm = false;
    private bool   _cancelling = false;

    // Cancelable mientras no haya sido atendido, rechazado ni cancelado ya
    private bool CanCancel(Order o) =>
        o.Status == "recibido" || o.Status == "en_proceso";

    private void AskCancel(Order o)
    {
        _orderToCancel = o;
        _showCancelConfirm = true;
    }

    private async Task ConfirmCancel()
    {
        if (_orderToCancel == null) return;
        _cancelling = true;

        // Extraer ID numérico de "PED-0012"
        int idPedido = 0;
        if (_orderToCancel.Id.StartsWith("PED-"))
            int.TryParse(_orderToCancel.Id[4..], out idPedido);

        await SalesSvc.CancelOrderAsync(idPedido);

        // Refrescar lista y mostrar toast
        _orderToCancel.Status = "cancelado";
        _showCancelConfirm = false;
        _orderToCancel = null;
        _cancelling = false;
        ApplyFilters();

        // Toast temporal
        _showCancelledToast = true;
        StateHasChanged();
        await Task.Delay(3000);
        _showCancelledToast = false;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn()) { Navigation.NavigateTo("/"); return; }
        var idCliente = Auth.CurrentUser?.IdUsuario ?? 0;
        _allOrders = await SalesSvc.GetClientOrdersAsync(idCliente);
        ApplyFilters();
        _loading = false;
    }

    private void ApplyFilters()
    {
        _filtered = _allOrders.Where(o =>
        {
            if (_statusFilter != "todos" && o.Status != _statusFilter) return false;
            if (_dateFrom.HasValue && o.Date.Date < _dateFrom.Value.Date) return false;
            if (_dateTo.HasValue && o.Date.Date > _dateTo.Value.Date) return false;
            return true;
        })
        .OrderByDescending(o => o.Date)
        .ToList();
        _currentPage = 1;
    }

    private void OnStatusChanged(ChangeEventArgs e)
    { _statusFilter = e.Value?.ToString() ?? "todos"; ApplyFilters(); }

    private void OnDateFromChanged(ChangeEventArgs e)
    {
        _dateFrom = string.IsNullOrEmpty(e.Value?.ToString())
            ? null : DateTime.Parse(e.Value.ToString()!);
        ApplyFilters();
    }

    private void OnDateToChanged(ChangeEventArgs e)
    {
        _dateTo = string.IsNullOrEmpty(e.Value?.ToString())
            ? null : DateTime.Parse(e.Value.ToString()!);
        ApplyFilters();
    }

    private void ClearFilters()
    { _statusFilter = "todos"; _dateFrom = null; _dateTo = null; ApplyFilters(); }

    private void OpenDetail(Order o) { _selectedOrder = o; _showModal = true; }
    private void CloseModal() { _showModal = false; _selectedOrder = null; }

    private string StatusBadgeClass(string s) => s.ToLower() switch
    {
        "atendido"   => "badge-entregado",
        "en_proceso" => "badge-preparando",
        "recibido"   => "badge-pendiente",
        "rechazado"  => "badge-cancelado",
        "cancelado"  => "badge-cancelado",
        _ => "badge-pendiente"
    };
    private string StatusLabel(string s) => s.ToLower() switch
    {
        "atendido"   => "Atendido",
        "en_proceso" => "En proceso",
        "recibido"   => "Recibido",
        "rechazado"  => "Rechazado",
        "cancelado"  => "Cancelado",
        _ => s
    };
    private string PaymentLabel(string p) => p.ToLower() switch
    {
        "yape"     => "Yape",
        "plin"     => "Plin",
        "tarjeta"  => "Tarjeta",
        "efectivo" => "Efectivo",
        "izipay"   => "Izipay",
        ""         => "Por confirmar",
        _          => p
    };
    private string PaymentIconName(string p) => p.ToLower() switch
    {
        "yape" or "plin"      => "Smartphone",
        "tarjeta" or "izipay" => "CreditCard",
        _                     => "Banknote"
    };
    private string DeliveryLabel(string d) =>
        d == "delivery" ? "Delivery" : "Recojo en tienda";

    private List<(string Label, DateTime? Time, bool Done, bool Cancelled)> GetTimeline(Order o)
    {
        var steps = new List<(string, DateTime?, bool, bool)>();
        bool cancelled = o.Status == "cancelado";

        steps.Add(("Pedido recibido", o.TimelinePedidoRecibido, true, false));

        if (cancelled)
        {
            steps.Add(("Cancelado", o.TimelineCancelado, true, true));
            return steps;
        }

        steps.Add(("En preparación", o.TimelineEnPreparacion,
            o.TimelineEnPreparacion.HasValue, false));
        steps.Add(("Listo para envío", o.TimelineListo,
            o.TimelineListo.HasValue, false));

        if (o.DeliveryMethod == "delivery")
            steps.Add(("En camino", o.TimelineEnCamino,
                o.TimelineEnCamino.HasValue, false));

        string lastLabel = o.DeliveryMethod == "delivery" ? "Entregado" : "Recogido";
        steps.Add((lastLabel, o.TimelineEntregado,
            o.TimelineEntregado.HasValue, false));

        return steps;
    }
}
