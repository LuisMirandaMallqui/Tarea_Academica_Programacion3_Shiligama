@page "/configuracion"
@layout MainLayout
@inject AuthService Auth
@inject AddressService AddressSvc
@inject NavigationManager Navigation
@inject HttpClient Http
@implements IDisposable

<PageTitle>Configuración – Shiligama</PageTitle>

<div class="container-xl px-3 px-sm-4 py-4" style="max-width: 680px;">
    <!-- Back Button -->
    <nav class="mb-3">
        <a href="/catalogo" class="text-muted-foreground text-decoration-none small d-inline-flex align-items-center gap-2" style="font-weight: 500;">
            <i class="fa-solid fa-chevron-left" style="font-size: 0.85rem;"></i> Volver al catálogo
        </a>
    </nav>

    <h1 class="fs-2 fw-bold text-foreground mb-1">Configuración</h1>
    <p class="text-muted-foreground small mt-1 mb-4">Administra tu información personal y preferencias de entrega</p>

    @if (_success)
    {
        <div class="alert alert-success p-3 d-flex align-items-center gap-2 mb-4" style="border-radius: var(--radius);" role="alert">
            <i class="fa-solid fa-check text-success"></i>
            <div>¡Tus cambios han sido guardados con éxito!</div>
        </div>
    }
    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger p-3 mb-4" style="border-radius: var(--radius);">@_error</div>
    }

    <EditForm Model="this" OnValidSubmit="PedirConfirmacion" class="d-flex flex-column gap-4">

        <!-- Información Personal -->
        <div class="card p-4 d-flex flex-column gap-3 shadow-sm" style="border-radius: 12px; border: 1px solid rgba(0,0,0,0.08);">
            <div class="d-flex align-items-center gap-3">
                <div class="d-flex align-items-center justify-content-center rounded-circle"
                     style="width:40px;height:40px;background:#E8F5E9;flex-shrink:0;">
                    <i class="fa-regular fa-user" style="color:#1A6B3C;font-size:1.1rem;"></i>
                </div>
                <div>
                    <h3 class="fw-bold text-foreground mb-0" style="font-size:1.05rem;">Información Personal</h3>
                    <p class="text-muted-foreground small mb-0">Tu nombre y documento de identidad</p>
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-md-6">
                    <label class="form-label small fw-medium text-foreground">Nombres</label>
                    <input type="text" @bind="_nombres" required class="form-control text-foreground"
                           style="height:44px;border-radius:8px;" />
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-medium text-foreground">Apellidos</label>
                    <input type="text" @bind="_apellidos" required class="form-control text-foreground"
                           style="height:44px;border-radius:8px;" />
                </div>
                <div class="col-md-5">
                    <label class="form-label small fw-medium text-foreground">DNI</label>
                    <div class="position-relative">
                        <i class="fa-regular fa-id-card text-muted-foreground position-absolute"
                           style="left:14px;top:50%;transform:translateY(-50%);"></i>
                        <input type="text" value="@_dni"
                               readonly disabled
                               class="form-control text-muted-foreground"
                               style="height:44px;padding-left:42px;border-radius:8px;cursor:not-allowed;" />
                    </div>
                    <div class="form-text small text-muted-foreground">El DNI no puede modificarse.</div>
                </div>
                <div class="col-md-7">
                    <label class="form-label small fw-medium text-foreground">Correo</label>
                    <input type="email" value="@Auth.CurrentUser?.Correo" disabled
                           class="form-control text-muted-foreground" style="height:44px;border-radius:8px;" />
                    <div class="form-text small text-muted-foreground">El correo no se puede cambiar desde aquí.</div>
                </div>
            </div>
        </div>

        <!-- Contacto -->
        <div class="card p-4 d-flex flex-column gap-3 shadow-sm"
             style="border-radius:12px;border:1px solid rgba(0,0,0,0.08);">
            <div class="d-flex align-items-center gap-3">
                <div class="d-flex align-items-center justify-content-center rounded-circle"
                     style="width:40px;height:40px;background:#E8F5E9;flex-shrink:0;">
                    <i class="fa-solid fa-phone" style="color:#1A6B3C;font-size:1.1rem;"></i>
                </div>
                <div>
                    <h3 class="fw-bold text-foreground mb-0" style="font-size:1.05rem;">Contacto</h3>
                    <p class="text-muted-foreground small mb-0">Tu número de teléfono para coordinar entregas</p>
                </div>
            </div>
            <div>
                <label class="form-label small fw-medium text-foreground">Teléfono</label>
                <div class="position-relative">
                    <i class="fa-solid fa-phone text-muted-foreground position-absolute"
                       style="left:14px;top:50%;transform:translateY(-50%);"></i>
                    <input type="tel" value="@_phone" @oninput="OnPhoneInput" maxlength="9" inputmode="numeric" class="form-control text-foreground"
                           style="height:44px;padding-left:42px;border-radius:8px;" placeholder="987654321" />
                </div>
                <div class="form-text text-muted-foreground mt-1" style="font-size:0.75rem;">
                    Usaremos este número para contactarte sobre tus pedidos.
                </div>
            </div>
        </div>

        <!-- Dirección de Entrega -->
        <div class="card p-4 d-flex flex-column gap-3 shadow-sm"
             style="border-radius:12px;border:1px solid rgba(0,0,0,0.08);">
            <div class="d-flex align-items-center gap-3">
                <div class="d-flex align-items-center justify-content-center rounded-circle"
                     style="width:40px;height:40px;background:#E8F5E9;flex-shrink:0;">
                    <i class="fa-solid fa-location-dot" style="color:#1A6B3C;font-size:1.1rem;"></i>
                </div>
                <div>
                    <h3 class="fw-bold text-foreground mb-0" style="font-size:1.05rem;">Direcciones de Entrega</h3>
                    <p class="text-muted-foreground small mb-0">Tus direcciones guardadas para entrega</p>
                </div>
            </div>
            <div class="mt-1">
                @* Lista de direcciones guardadas en localStorage *@
                @if (_savedAddresses.Count > 0)
                {
                    <div class="d-flex flex-column gap-2 mb-3">
                        @foreach (var addr in _savedAddresses)
                        {
                            <div class="d-flex align-items-start gap-2 p-3"
                                 style="background:#f0fdf4;border-radius:10px;border:1px solid #bbf7d0;">
                                <i class="fa-solid fa-location-dot mt-1 flex-shrink-0" style="color:#1A6B3C;"></i>
                                <span class="flex-grow-1" style="font-size:0.88rem;color:#374151;word-break:break-word;">@addr</span>
                                <button type="button" class="btn btn-link p-0 text-danger flex-shrink-0"
                                        style="font-size:.75rem;"
                                        @onclick="() => DeleteSavedAddress(addr)">
                                    <i class="fa-solid fa-xmark"></i>
                                </button>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column align-items-center justify-content-center py-4 px-3 mb-3"
                         style="border-radius:10px;border:1px dashed #d1d5db;background:#f9fafb;">
                        <i class="fa-solid fa-map-location-dot mb-2" style="font-size:2rem;color:#c4c9d1;"></i>
                        <span style="font-size:0.9rem;color:#6b7280;font-weight:500;">No hay direcciones guardadas</span>
                        <span style="font-size:0.8rem;color:#9ca3af;">Agrega una dirección desde el mapa</span>
                    </div>
                }

                @* Botón para abrir el mapa y agregar dirección *@
                <button type="button" @onclick="OpenMapModal"
                        class="btn d-flex align-items-center gap-2 px-3 py-2"
                        style="border:2px dashed #1A6B3C;border-radius:10px;background:transparent;
                               color:#1A6B3C;font-weight:600;font-size:0.9rem;transition:all 0.2s;"
                        onmouseover="this.style.backgroundColor='#f0fdf4';"
                        onmouseout="this.style.backgroundColor='transparent';">
                    <i class="fa-solid fa-plus"></i>
                    Agregar dirección en mapa
                </button>

                <div class="form-text text-muted-foreground mt-2" style="font-size:0.75rem;">
                    Las direcciones guardadas aparecerán en el checkout para seleccionar rápidamente.
                </div>
            </div>
        </div>

        <!-- Save Bar -->
        <div class="d-flex flex-column flex-sm-row align-items-start align-items-sm-center justify-content-between gap-3 mt-2 mb-4">
            <span class="text-muted-foreground small">Los cambios se guardarán automáticamente en tu perfil.</span>
            <button type="submit" disabled="@_saving"
                    class="btn text-white px-4 py-2 fw-semibold d-flex align-items-center gap-2"
                    style="background-color:#1A6B3C;border-radius:8px;border:none;">
                @if (_saving)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span><span>Guardando…</span>
                }
                else
                {
                    <i class="fa-solid fa-floppy-disk"></i><span> Guardar cambios</span>
                }
            </button>
        </div>
    </EditForm>
</div>

@* ===== Modal del Mapa — componente reutilizable ===== *@
<MapAddressPicker @ref="_mapPicker" OnAddressSelected="OnMapAddressSelected" />

@* ===== Modal de confirmación al modificar datos ===== *@
@if (_showConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);z-index:1060;">
        <div class="modal-dialog modal-dialog-centered" style="max-width:400px;">
            <div class="modal-content" style="border-radius:14px;">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.4rem;">✏️</div>
                    <h5 class="fw-bold mb-1" style="color:#111827;">¿Estás seguro?</h5>
                    <p class="text-muted-foreground small mb-4">
                        Se actualizará tu información personal con los datos ingresados.
                    </p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="button" class="btn btn-outline-secondary px-3"
                                style="border-radius:8px;" @onclick="@(() => _showConfirm = false)">
                            Cancelar
                        </button>
                        <button type="button" class="btn text-white px-3 fw-semibold"
                                style="background-color:#1A6B3C;border-radius:8px;border:none;"
                                @onclick="SaveChanges">
                            Sí, guardar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string _nombres   = "";
    private string _apellidos = "";
    private string _dni       = "";
    private string _phone     = "";
    private string _address   = "";
    private bool   _success   = false;
    private bool   _saving    = false;
    private string _error     = "";
    private bool   _showConfirm = false;

    // ── Saved addresses (localStorage via AddressService) ────────────────────
    private List<string> _savedAddresses = new();

    // Permite solo dígitos en el DNI (máx. 8), bloqueando letras.
    private void OnDniInput(ChangeEventArgs e)
    {
        var soloDigitos = new string((e.Value?.ToString() ?? "")
            .Where(char.IsDigit).Take(8).ToArray());
        _dni = soloDigitos;
    }

    // Permite solo dígitos en el Teléfono (máx. 9 dígitos peruanos).
    private void OnPhoneInput(ChangeEventArgs e)
        => _phone = new string((e.Value?.ToString() ?? "").Where(char.IsDigit).Take(9).ToArray());

    // Valida y pide confirmación antes de guardar.
    private void PedirConfirmacion()
    {
        _error = "";
        if (string.IsNullOrWhiteSpace(_nombres) || string.IsNullOrWhiteSpace(_apellidos))
        {
            _error = "Nombres y apellidos son obligatorios.";
            return;
        }
        if (_dni.Length != 8)
        {
            _error = "El DNI debe tener exactamente 8 dígitos.";
            return;
        }
        _showConfirm = true;
    }

    // ── Mapa Leaflet ──────────────────────────────────────────────────────────
    private MapAddressPicker? _mapPicker;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn())
        {
            Navigation.NavigateTo("/");
            return;
        }

        var u = Auth.CurrentUser!;
        _nombres   = u.Nombres;
        _apellidos = u.Apellidos;
        _dni       = u.Dni ?? "";
        _phone     = u.Telefono ?? "";
        _address   = u.DireccionEntrega ?? "";

        // Load saved addresses from localStorage
        await AddressSvc.InitializeAsync();
        AddressSvc.OnChange += OnSavedAddressesChanged;
        _savedAddresses = AddressSvc.GetAddresses();
    }

    private void OnSavedAddressesChanged()
    {
        _savedAddresses = AddressSvc.GetAddresses();
        InvokeAsync(StateHasChanged);
    }

    public void Dispose() => AddressSvc.OnChange -= OnSavedAddressesChanged;

    private async Task SaveChanges()
    {
        _showConfirm = false;
        _saving  = true;
        _error   = "";
        _success = false;

        var u = Auth.CurrentUser!;
        var dto = new
        {
            idUsuario        = u.Id,
            correo           = u.Correo,
            contrasena       = "*",          // SP MODIFICAR_USUARIO no lo toca
            nombres          = _nombres.Trim(),
            apellidos        = _apellidos.Trim(),
            dni              = _dni.Trim(),
            telefono         = _phone.Trim(),
            direccionEntrega = _address.Trim()
        };

        try
        {
            var resp = await Http.PutAsJsonAsync("clientes", dto);
            if (resp.IsSuccessStatusCode)
            {
                u.Nombres          = _nombres.Trim();
                u.Apellidos        = _apellidos.Trim();
                u.Dni              = _dni.Trim();
                u.Telefono         = _phone.Trim();
                u.DireccionEntrega = _address.Trim();
                // Persistir en localStorage para que Checkout (y cualquier otra página)
                // encuentre la dirección actualizada aunque el usuario haga refresh.
                await Auth.SyncSessionAsync();
                _success = true;
            }
            else
            {
                var msg = await resp.Content.ReadAsStringAsync();
                _error = $"No se pudo guardar: {msg}";
            }
        }
        catch (Exception ex)
        {
            _error = $"Error de conexión: {ex.Message}";
        }
        finally
        {
            _saving = false;
            if (_success)
            {
                await Task.Delay(3000);
                _success = false;
                StateHasChanged();
            }
        }
    }

    // ── Mapa ──────────────────────────────────────────────────────────────────

    private async Task OpenMapModal()
    {
        if (_mapPicker != null)
            await _mapPicker.OpenAsync();
    }

    private async void OnMapAddressSelected(string address)
    {
        _address = address;
        await AddressSvc.AddAddressAsync(address);
        _savedAddresses = AddressSvc.GetAddresses();
        StateHasChanged();
    }

    private async Task DeleteSavedAddress(string addr)
    {
        await AddressSvc.RemoveAddressAsync(addr);
        _savedAddresses = AddressSvc.GetAddresses();
    }
}
