@page "/recuperar-password"
@layout EmptyLayout
@inject RecuperacionService RecuperacionSvc

<PageTitle>Recuperar contraseña – Shiligama</PageTitle>

<div class="d-flex align-items-center justify-content-center min-vh-100 p-3" style="background:var(--secondary);">
    <div class="card border border-border rounded-3 p-4 w-100" style="max-width:420px;">
        <div class="text-center mb-4">
            <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3"
                 style="width:56px;height:56px;background:color-mix(in srgb,var(--primary) 15%,transparent);">
                <Icons Name="Lock" Class="text-primary" style="width:26px;height:26px;" />
            </div>
            <h1 class="fs-4 fw-bold text-foreground mb-1">Recuperar contraseña</h1>
            <p class="text-muted-foreground small mb-0">
                Ingresa tu correo y te enviaremos un enlace para crear una nueva contraseña.
            </p>
        </div>

        @if (_enviado)
        {
            <div class="alert alert-success small d-flex gap-2 align-items-start mb-3">
                <Icons Name="Check" style="width:16px;height:16px;margin-top:2px;" />
                <span>
                    Si el correo está registrado, te enviamos las instrucciones de recuperación.
                    Revisa tu bandeja de entrada (y la carpeta de spam).
                </span>
            </div>
            <a href="/" class="btn btn-primary w-100" style="border-radius:var(--radius);">Volver al inicio de sesión</a>
        }
        else
        {
            <EditForm Model="this" OnValidSubmit="Solicitar" class="d-flex flex-column gap-3">
                <div>
                    <label class="form-label small fw-medium text-foreground">Correo electrónico</label>
                    <div class="input-group">
                        <span class="input-group-text"><Icons Name="Mail" style="width:16px;height:16px;" /></span>
                        <input type="email" @bind="_correo" required
                               class="form-control text-foreground" placeholder="tucorreo@ejemplo.com" />
                    </div>
                </div>
                <button type="submit" disabled="@_isLoading"
                        class="btn btn-primary w-100 fw-semibold d-flex align-items-center justify-content-center gap-2"
                        style="height:46px;border-radius:var(--radius);">
                    @if (_isLoading)
                    {
                        <span class="spinner-border spinner-border-sm"></span>
                        <span>Enviando...</span>
                    }
                    else
                    {
                        <span>Enviar instrucciones</span>
                    }
                </button>
                <a href="/" class="text-center small fw-medium text-primary text-decoration-none">Volver al inicio de sesión</a>
            </EditForm>
        }
    </div>
</div>

@code {
    private string _correo = "";
    private bool _isLoading = false;
    private bool _enviado = false;

    private async Task Solicitar()
    {
        if (string.IsNullOrWhiteSpace(_correo)) return;
        _isLoading = true;
        // El backend responde igual exista o no el correo (no se revela).
        await RecuperacionSvc.SolicitarAsync(_correo.Trim());
        _enviado = true;
        _isLoading = false;
    }
}
