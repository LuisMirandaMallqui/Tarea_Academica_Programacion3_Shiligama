@page "/carrito"
@layout MainLayout
@inject CartService Cart
@inject PromocionService PromoSvc
@inject ProductService ProductSvc
@inject AuthService Auth
@inject NavigationManager Navigation

<PageTitle>Mi Carrito – Shiligama</PageTitle>

<style>
.delete-btn-hover:hover { transform: scale(1.15); }

.delivery-option {
    border: 1px solid var(--border) !important;
    background-color: var(--card) !important;
    color: var(--muted-foreground) !important;
}
.delivery-option i { color: var(--muted-foreground) !important; }
.delivery-option:hover { border-color: var(--primary) !important; color: var(--primary) !important; }
.delivery-option:hover i { color: var(--primary) !important; }
.delivery-option.active {
    border: 1px solid var(--primary) !important;
    background-color: color-mix(in srgb, var(--primary) 10%, transparent) !important;
    color: var(--primary) !important;
}
.delivery-option.active i { color: var(--primary) !important; }

.qty-control {
    display: flex;
    align-items: center;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    background-color: var(--card);
    height: 32px;
}
.qty-control button {
    background: transparent;
    border: none;
    color: var(--foreground);
    padding: 0 8px;
    height: 100%;
    font-size: 1rem;
    cursor: pointer;
    transition: background-color 0.2s;
}
.qty-control button:hover { background-color: var(--secondary); }
.qty-control input {
    color: var(--foreground);
    font-size: 0.9rem;
    font-weight: 500;
    width: 36px;
    text-align: center;
    border: none;
    background: transparent;
    outline: none;
    -moz-appearance: textfield;
}
.qty-control input::-webkit-outer-spin-button,
.qty-control input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
@@keyframes toastSlideIn {
    from { transform: translateX(120%); opacity: 0; }
    to   { transform: translateX(0);   opacity: 1; }
}
.cart-action-toast {
    position: fixed; bottom: 28px; right: 28px; z-index: 99999;
    display: flex; align-items: flex-start; gap: 14px;
    background: #ffffff; color: #111827;
    border: 1.5px solid #d1fae5; border-radius: 16px;
    padding: 16px 18px; min-width: 300px; max-width: 360px;
    box-shadow: 0 8px 32px rgba(0,0,0,.18);
    animation: toastSlideIn 0.35s cubic-bezier(.21,1.02,.73,1) forwards;
}
</style>

<div class="container-xl px-3 px-sm-4 py-4">
    <nav class="mb-4">
        <a href="/catalogo" class="text-muted-foreground text-decoration-none small d-inline-flex align-items-center gap-2"
           style="transition: color 0.2s; font-weight: 500;">
            <i class="fa-solid fa-chevron-left" style="font-size: 0.85rem;"></i> Volver al catálogo
        </a>
    </nav>

    <h1 class="fs-3 fw-bold text-foreground mb-4">Mi Carrito</h1>

    @if (!Cart.GetCartItems().Any())
    {
        <div class="text-center py-5">
            <div class="fs-1 mb-3">🛒</div>
            <h3 class="text-foreground fw-medium">Tu carrito está vacío</h3>
            <p class="text-muted-foreground">Agrega algunos productos para comenzar</p>
            <a href="/catalogo" class="btn btn-primary mt-2" style="border-radius:var(--radius);">
                Ver catálogo
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card d-flex flex-column gap-0">
                    @foreach (var item in Cart.GetCartItems())
                    {
                        <div class="d-flex flex-column flex-sm-row gap-3 p-3 border-bottom border-color-default align-items-start align-items-sm-center position-relative">
                            <div class="d-flex gap-3 align-items-center flex-grow-1 w-100">
                                <img src="@item.Image" alt="@item.Name"
                                     class="rounded-3 object-fit-cover flex-shrink-0"
                                     style="width:80px;height:80px;"
                                     onerror="this.src='https://placehold.co/80x80/e8f5e9/1A6B3C?text=🛒'" />
                                <div class="flex-grow-1">
                                    <p class="fw-semibold text-foreground mb-1"
                                       style="font-family:'Outfit',sans-serif;font-size:1rem;">
                                        @item.Name
                                    </p>
                                    @{
                                        var _itemPromo = GetPromo(item.Id);
                                        bool _itemHasPromo = _itemPromo != null && _itemPromo.EsVigente;
                                        decimal _itemPrecioEfectivo = PromocionHelper.PrecioEfectivo(item.Price, 1, _itemPromo);
                                    }
                                    <p class="fw-bold mb-0 text-primary"
                                       style="font-size:1.1rem;font-family:'Outfit',sans-serif;">
                                        S/. @_itemPrecioEfectivo.ToString("0.00")
                                        @if (_itemHasPromo && _itemPrecioEfectivo < item.Price)
                                        {
                                            <span class="text-decoration-line-through text-muted-foreground ms-1"
                                                  style="font-size:.8rem;font-weight:400;">
                                                S/. @item.Price.ToString("0.00")
                                            </span>
                                            <span class="badge ms-1"
                                                  style="background:#7c3aed;font-size:.6rem;vertical-align:middle;">
                                                @_itemPromo!.DescuentoLabel
                                            </span>
                                        }
                                    </p>
                                </div>
                            </div>

                            <div class="d-flex align-items-center justify-content-between justify-content-sm-end gap-4 w-100 w-sm-auto mt-2 mt-sm-0 pe-sm-4">
                                <div class="d-flex flex-column align-items-start gap-1">
                                    <span class="text-muted-foreground fw-medium text-uppercase"
                                          style="font-size:0.725rem;">Cantidad</span>
                                    <div class="qty-control">
                                        <button @onclick="@(() => UpdateQty(item.Id, item.Quantity - 1))">−</button>
                                        <input type="number" min="1" max="@StockOf(item.Id)"
                                               @bind:get="item.Quantity"
                                               @bind:set="@(async (qty) => await HandleQuantityInput(item.Id, qty))" />
                                        <button @onclick="@(() => UpdateQty(item.Id, item.Quantity + 1))">+</button>
                                    </div>
                                </div>

                                <div class="d-flex flex-column align-items-start gap-1" style="min-width:80px;">
                                    <span class="text-muted-foreground fw-medium text-uppercase"
                                          style="font-size:0.725rem;">Total</span>
                                    <span class="fw-bold text-foreground"
                                          style="font-family:'Outfit',sans-serif;font-size:1.1rem;
                                                 height:32px;display:flex;align-items:center;">
                                        S/. @LineTotal(item).ToString("0.00")
                                    </span>
                                </div>

                                <button class="btn btn-link btn-sm text-danger p-0 border-0 delete-btn-hover align-self-end align-self-sm-center"
                                        style="font-size:1.15rem;transition:transform 0.15s ease;margin-bottom:5px;"
                                        @onclick="@(() => AskRemove(item.Id, item.Name))"
                                        title="Eliminar del carrito">
                                    <i class="fa-regular fa-trash-can"></i>
                                </button>
                            </div>
                        </div>
                    }
                    <div class="p-3 d-flex justify-content-end">
                        <button @onclick="AskClearCart"
                                class="btn btn-link text-muted-foreground text-decoration-none small d-flex align-items-center gap-1">
                            <i class="fa-regular fa-trash-can" style="font-size:0.95rem;"></i>Vaciar carrito
                        </button>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 d-flex flex-column gap-3">
                <div class="card p-4 d-flex flex-column gap-3">
                    <h2 class="fw-semibold text-foreground fs-5 mb-0"
                        style="font-family:'Outfit',sans-serif;">Método de entrega</h2>
                    <div class="d-flex gap-3">
                        <div class="flex-grow-1 p-3 border text-center delivery-option @(_deliveryMethod == DeliveryMethod.Delivery ? "active" : "")"
                             @onclick="@(() => SetDeliveryMethod(DeliveryMethod.Delivery))"
                             style="cursor:pointer;transition:all 0.2s;border-radius:var(--radius);flex-basis:50%;">
                            <i class="fa-solid fa-truck mb-2" style="font-size:1.5rem;"></i>
                            <div class="fw-medium small">Delivery</div>
                            <div class="text-muted-foreground text-xs mt-1">
                                @(Subtotal > Cart.MinimoEnvioGratis ? "Gratis" : $"S/. {Cart.TarifaEnvioBase:0.00}")
                            </div>
                        </div>
                        <div class="flex-grow-1 p-3 border text-center delivery-option @(_deliveryMethod == DeliveryMethod.Pickup ? "active" : "")"
                             @onclick="@(() => SetDeliveryMethod(DeliveryMethod.Pickup))"
                             style="cursor:pointer;transition:all 0.2s;border-radius:var(--radius);flex-basis:50%;">
                            <i class="fa-solid fa-store mb-2" style="font-size:1.5rem;"></i>
                            <div class="fw-medium small">Recojo en tienda</div>
                            <div class="text-muted-foreground text-xs mt-1">Gratis</div>
                        </div>
                    </div>
                </div>

                <div class="card p-4 d-flex flex-column gap-3">
                    <h2 class="fw-semibold text-foreground fs-5 mb-0">Resumen del pedido</h2>
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between text-foreground small">
                            <span>Subtotal (@Cart.GetCartCount() items)</span>
                            <span>S/. @Subtotal.ToString("0.00")</span>
                        </div>
                        @if (_deliveryMethod == DeliveryMethod.Delivery)
                        {
                            <div class="d-flex justify-content-between text-foreground small">
                                <span>Envío</span>
                                <span>@(Envio == 0 ? "Gratis 🎉" : $"S/. {Envio:0.00}")</span>
                            </div>
                            @if (Subtotal < Cart.MinimoEnvioGratis)
                            {
                                <p class="small text-muted-foreground bg-muted rounded-3 p-2 mb-0">
                                    Agrega S/. @((Cart.MinimoEnvioGratis - Subtotal).ToString("0.00")) más para envío gratis
                                </p>
                            }
                        }
                        <hr class="border-color-default my-1" />
                        <div class="d-flex justify-content-between fw-bold text-foreground">
                            <span>Total</span>
                            <span>S/. @Total.ToString("0.00")</span>
                        </div>
                    </div>
                    <button type="button"
                            class="btn btn-primary w-100 fw-medium d-flex align-items-center justify-content-center gap-2"
                            style="border-radius:var(--radius);"
                            @onclick="TryProceedToCheckout">
                        <Icons Name="ShoppingCart" Class="w-4 h-4" />
                        Proceder al Checkout
                    </button>
                    <a href="/catalogo"
                       class="btn btn-secondary w-100 small text-decoration-none text-center"
                       style="border-radius:var(--radius);">
                        Continuar comprando
                    </a>
                </div>
            </div>
        </div>
    }
</div>

<LoginRequiredModal @bind-IsOpen="_showLoginRequired"
                    ReturnUrl="@CheckoutReturnUrl" />

@* ===== Toast: pedido repetido ===== *@
@if (_showRepeatedToast)
{
    <div class="cart-action-toast">
        <div style="width:42px;height:42px;border-radius:50%;background:#16a34a;
                    display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <Icons Name="CheckCircle" style="width:20px;height:20px;color:#fff;" />
        </div>
        <div style="flex:1;min-width:0;">
            <p style="margin:0 0 4px;font-weight:700;font-size:.95rem;">¡Pedido repetido!</p>
            <p style="margin:0;font-size:.78rem;color:#6b7280;">Los productos se agregaron a tu carrito.</p>
        </div>
        <button type="button" style="background:none;border:none;cursor:pointer;color:#9ca3af;font-size:1.1rem;"
                @onclick="() => _showRepeatedToast = false">✕</button>
    </div>
}

@* ===== Toast: producto eliminado ===== *@
@if (_showRemovedToast)
{
    <div class="cart-action-toast">
        <div style="width:42px;height:42px;border-radius:50%;background:#16a34a;
                    display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <Icons Name="Check" style="width:20px;height:20px;color:#fff;" />
        </div>
        <div style="flex:1;min-width:0;">
            <p style="margin:0 0 4px;font-weight:700;font-size:.95rem;">¡Producto eliminado!</p>
            <p style="margin:0;font-size:.78rem;color:#6b7280;">@_removedProductName se eliminó del carrito.</p>
        </div>
        <button type="button" style="background:none;border:none;cursor:pointer;color:#9ca3af;font-size:1.1rem;"
                @onclick="() => _showRemovedToast = false">✕</button>
    </div>
}

@* ===== Toast: carrito vaciado ===== *@
@if (_showClearedToast)
{
    <div class="cart-action-toast">
        <div style="width:42px;height:42px;border-radius:50%;background:#16a34a;
                    display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <Icons Name="Check" style="width:20px;height:20px;color:#fff;" />
        </div>
        <div style="flex:1;min-width:0;">
            <p style="margin:0 0 4px;font-weight:700;font-size:.95rem;">¡Carrito vaciado!</p>
            <p style="margin:0;font-size:.78rem;color:#6b7280;">Se eliminaron todos los productos.</p>
        </div>
        <button type="button" style="background:none;border:none;cursor:pointer;color:#9ca3af;font-size:1.1rem;"
                @onclick="() => _showClearedToast = false">✕</button>
    </div>
}

@* ===== Modal: confirmar eliminar item ===== *@
@if (_showRemoveConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45);">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">🗑️</div>
                    <h5 class="fw-bold text-foreground mb-1">¿Eliminar este producto?</h5>
                    <p class="text-muted-foreground small mb-4">
                        Se eliminará <strong>@_pendingRemoveName</strong> de tu carrito.
                    </p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="button" class="btn btn-secondary" style="border-radius:var(--radius);"
                                @onclick="CancelRemove">Cancelar</button>
                        <button type="button" class="btn btn-danger" style="border-radius:var(--radius);"
                                @onclick="ConfirmRemove">Eliminar</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* ===== Modal: confirmar vaciar carrito ===== *@
@if (_showClearConfirm)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45);">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">🗑️</div>
                    <h5 class="fw-bold text-foreground mb-1">¿Vaciar el carrito?</h5>
                    <p class="text-muted-foreground small mb-4">Se eliminarán todos los productos.</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="button" class="btn btn-secondary" style="border-radius:var(--radius);"
                                @onclick="CancelClear">Cancelar</button>
                        <button type="button" class="btn btn-danger" style="border-radius:var(--radius);"
                                @onclick="ConfirmClear">Vaciar carrito</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* ===== Modal: stock insuficiente ===== *@
@if (_showStockWarning)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45);">
        <div class="modal-dialog modal-dialog-centered" style="max-width:440px;">
            <div class="modal-content bg-card border-border">
                <div class="modal-body p-4">
                    <div class="text-center mb-3" style="font-size:2.5rem;">⚠️</div>
                    <h5 class="fw-bold text-foreground mb-2 text-center">Stock insuficiente</h5>
                    <p class="text-muted-foreground small mb-3 text-center">
                        Algunos productos tienen menos unidades disponibles que las que tienes en el carrito:
                    </p>
                    <ul class="list-unstyled mb-4">
                        @foreach (var (name, available) in _stockErrors)
                        {
                            <li class="d-flex align-items-center gap-2 py-2 border-bottom border-color-default">
                                <i class="fa-solid fa-triangle-exclamation text-warning"></i>
                                <span class="small flex-grow-1">
                                    <strong>@name</strong>
                                    <span class="text-muted-foreground"> — solo <strong>@available</strong> disponible(s)</span>
                                </span>
                            </li>
                        }
                    </ul>
                    <p class="text-muted-foreground small text-center mb-3">
                        Puedes ajustar las cantidades automáticamente y continuar, o revisar el carrito manualmente.
                    </p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="button" class="btn btn-primary" style="border-radius:var(--radius);"
                                @onclick="AdjustAndProceed">
                            <i class="fa-solid fa-check me-1"></i>Ajustar y continuar
                        </button>
                        <button type="button" class="btn btn-secondary" style="border-radius:var(--radius);"
                                @onclick="() => _showStockWarning = false">
                            Revisar carrito
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@implements IDisposable

@code {
    [SupplyParameterFromQuery(Name = "repeated")]
    public bool Repeated { get; set; }

    private enum DeliveryMethod { Delivery, Pickup }
    private DeliveryMethod _deliveryMethod = DeliveryMethod.Delivery;

    private bool   _showLoginRequired  = false;
    private bool   _showRepeatedToast  = false;
    private bool   _showClearConfirm   = false;
    private bool   _showClearedToast   = false;
    private bool   _showRemoveConfirm  = false;
    private bool   _showRemovedToast   = false;
    private int?   _pendingRemoveId;
    private string _pendingRemoveName  = "";
    private string _removedProductName = "";
    private bool   _showStockWarning   = false;
    private List<(string Name, int Available)> _stockErrors = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Cart.InitializeAsync();
            await Auth.InitializeAsync();
            await PromoSvc.EnsureLoadedAsync();
            await ProductSvc.EnsureLoadedAsync();
            Cart.OnChange += StateHasChanged;
            Auth.OnChange += StateHasChanged;

            _showRepeatedToast = Repeated;
            StateHasChanged();

            if (_showRepeatedToast)
            {
                _ = Task.Run(async () =>
                {
                    await Task.Delay(4500);
                    _showRepeatedToast = false;
                    await InvokeAsync(StateHasChanged);
                });
            }
        }
    }

    public void Dispose()
    {
        Cart.OnChange -= StateHasChanged;
        Auth.OnChange -= StateHasChanged;
    }

    // ── Remove with confirm ──────────────────────────────────────────────────
    private void AskRemove(int id, string name)
    {
        _pendingRemoveId   = id;
        _pendingRemoveName = name;
        _showRemoveConfirm = true;
    }

    private void CancelRemove()
    {
        _showRemoveConfirm = false;
        _pendingRemoveId   = null;
        _pendingRemoveName = "";
    }

    private async Task ConfirmRemove()
    {
        if (!_pendingRemoveId.HasValue) return;
        var name = _pendingRemoveName;
        await Cart.RemoveFromCartAsync(_pendingRemoveId.Value);
        _showRemoveConfirm  = false;
        _pendingRemoveId    = null;
        _pendingRemoveName  = "";
        _removedProductName = name;
        _showRemovedToast   = true;
        StateHasChanged();
        _ = Task.Run(async () =>
        {
            await Task.Delay(2500);
            _showRemovedToast = false;
            await InvokeAsync(StateHasChanged);
        });
    }

    // ── Clear with confirm ───────────────────────────────────────────────────
    private void AskClearCart() => _showClearConfirm = true;
    private void CancelClear()  => _showClearConfirm = false;

    private async Task ConfirmClear()
    {
        await Cart.ClearCartAsync();
        _showClearConfirm = false;
        _showClearedToast = true;
        StateHasChanged();
        _ = Task.Run(async () =>
        {
            await Task.Delay(2500);
            _showClearedToast = false;
            await InvokeAsync(StateHasChanged);
        });
    }

    // ── Qty input with snap-back ─────────────────────────────────────────────
    private int StockOf(int id) => ProductSvc.GetProductById(id)?.Stock ?? int.MaxValue;

    private async Task UpdateQty(int id, int qty)
    {
        int clamped = Math.Clamp(qty, 1, StockOf(id));
        await Cart.UpdateQuantityAsync(id, clamped);
    }

    private async Task HandleQuantityInput(int id, int qty)
    {
        int clamped = Math.Clamp(qty, 1, StockOf(id));
        // Snap-back: yield primero para que Blazor acepte el valor del input,
        // luego actualiza al valor válido y re-renderiza.
        await Task.Yield();
        await Cart.UpdateQuantityAsync(id, clamped);
    }

    // ── Checkout guard ───────────────────────────────────────────────────────
    private string CheckoutReturnUrl =>
        $"/checkout?delivery={(_deliveryMethod == DeliveryMethod.Delivery ? "delivery" : "pickup")}";

    private async Task TryProceedToCheckout()
    {
        if (!Auth.IsCliente()) { _showLoginRequired = true; return; }

        // Validar que ningún item supera el stock disponible
        _stockErrors = new();
        foreach (var item in Cart.GetCartItems())
        {
            int avail = StockOf(item.Id);
            if (avail != int.MaxValue && item.Quantity > avail)
                _stockErrors.Add((item.Name, avail));
        }
        if (_stockErrors.Any()) { _showStockWarning = true; return; }

        Navigation.NavigateTo(CheckoutReturnUrl);
    }

    // Ajusta automáticamente las cantidades al stock disponible y procede al checkout.
    private async Task AdjustAndProceed()
    {
        foreach (var (name, avail) in _stockErrors)
        {
            var item = Cart.GetCartItems().FirstOrDefault(i => i.Name == name);
            if (item != null) await Cart.UpdateQuantityAsync(item.Id, avail);
        }
        _showStockWarning = false;
        Navigation.NavigateTo(CheckoutReturnUrl);
    }

    private void SetDeliveryMethod(DeliveryMethod method) => _deliveryMethod = method;

    // ── Promo-aware pricing ──────────────────────────────────────────────────
    private Promocion? GetPromo(int productId) =>
        PromoSvc.GetVigentes().FirstOrDefault(p => p.ProductoIds.Contains(productId));

    private decimal LineTotal(CartItem item)
    {
        var promo = GetPromo(item.Id);
        return PromocionHelper.PrecioEfectivo(item.Price, item.Quantity, promo);
    }

    private decimal Subtotal => Cart.GetCartItems().Sum(i => LineTotal(i));
    private decimal Envio    => Cart.GetDeliveryFee(_deliveryMethod == DeliveryMethod.Delivery);
    private decimal Total    => Subtotal + Envio;
}
