@page "/restablecer-password"
@layout EmptyLayout
@inject RecuperacionService RecuperacionSvc

<PageTitle>Restablecer contraseña – Shiligama</PageTitle>

<div class="d-flex align-items-center justify-content-center min-vh-100 p-3" style="background:var(--secondary);">
    <div class="card border border-border rounded-3 p-4 w-100" style="max-width:420px;">

        @if (_exito)
        {
            <div class="text-center">
                <div class="d-flex align-items-center justify-content-center rounded-circle bg-success mx-auto mb-3"
                     style="width:64px;height:64px;">
                    <Icons Name="Check" Class="text-white" style="width:32px;height:32px;" />
                </div>
                <h1 class="fs-4 fw-bold text-foreground mb-1">¡Contraseña actualizada!</h1>
                <p class="text-muted-foreground small mb-4">Ya puedes iniciar sesión con tu nueva contraseña.</p>
                <a href="/" class="btn btn-primary w-100" style="border-radius:var(--radius);">Ir a iniciar sesión</a>
            </div>
        }
        else
        {
            <div class="text-center mb-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3"
                     style="width:56px;height:56px;background:color-mix(in srgb,var(--primary) 15%,transparent);">
                    <Icons Name="Lock" Class="text-primary" style="width:26px;height:26px;" />
                </div>
                <h1 class="fs-4 fw-bold text-foreground mb-1">Crear nueva contraseña</h1>
                <p class="text-muted-foreground small mb-0">Ingresa y confirma tu nueva contraseña.</p>
            </div>

            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger small d-flex gap-2 align-items-start mb-3">
                    <Icons Name="AlertCircle" style="width:16px;height:16px;margin-top:2px;" />
                    <span>@_error</span>
                </div>
            }

            <EditForm Model="this" OnValidSubmit="Restablecer" class="d-flex flex-column gap-3">
                <div>
                    <label class="form-label small fw-medium text-foreground">Nueva contraseña</label>
                    <div class="input-group">
                        <span class="input-group-text"><Icons Name="Lock" style="width:16px;height:16px;" /></span>
                        <input type="password" @bind="_nueva" required minlength="6"
                               class="form-control text-foreground" placeholder="Mínimo 6 caracteres" />
                    </div>
                </div>
                <div>
                    <label class="form-label small fw-medium text-foreground">Confirmar contraseña</label>
                    <div class="input-group">
                        <span class="input-group-text"><Icons Name="Lock" style="width:16px;height:16px;" /></span>
                        <input type="password" @bind="_confirmar" required
                               class="form-control text-foreground" placeholder="Repite la contraseña" />
                    </div>
                </div>
                <button type="submit" disabled="@_isLoading"
                        class="btn btn-primary w-100 fw-semibold d-flex align-items-center justify-content-center gap-2"
                        style="height:46px;border-radius:var(--radius);">
                    @if (_isLoading)
                    {
                        <span class="spinner-border spinner-border-sm"></span>
                        <span>Guardando...</span>
                    }
                    else
                    {
                        <span>Restablecer contraseña</span>
                    }
                </button>
                <a href="/" class="text-center small fw-medium text-primary text-decoration-none">Volver al inicio de sesión</a>
            </EditForm>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private string _nueva = "";
    private string _confirmar = "";
    private bool _isLoading = false;
    private bool _exito = false;
    private string? _error;

    private async Task Restablecer()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(Token))
        {
            _error = "El enlace de recuperación no es válido o está incompleto.";
            return;
        }
        if (_nueva.Length < 6)
        {
            _error = "La contraseña debe tener al menos 6 caracteres.";
            return;
        }
        if (_nueva != _confirmar)
        {
            _error = "Las contraseñas no coinciden.";
            return;
        }

        _isLoading = true;
        var (ok, mensaje) = await RecuperacionSvc.RestablecerAsync(Token!, _nueva);
        _isLoading = false;

        if (ok) _exito = true;
        else _error = string.IsNullOrWhiteSpace(mensaje)
            ? "No se pudo restablecer la contraseña. El enlace pudo expirar."
            : mensaje;
    }
}
