@code {
    private List<Order> _allOrders = new();
    private string _searchTerm = "";
    private string _selectedFilter = "todos";
    private Order? _detailOrder = null;
    private bool _showDetailModal = false;

    private int _currentPage = 1;
    private int _pageSize = 6;

    // ── Nuestra integración: carga los pedidos desde el API antes de mostrar ──
    protected override async Task OnInitializedAsync()
    {
        await SalesSvc.EnsureLoadedAsync();
        RefreshList();
    }

    private void RefreshList()
    {
        _allOrders = SalesSvc.GetRecentOrders();
    }

    private IEnumerable<Order> FilteredOrders => _allOrders.Where(o =>
    {
        bool matchSearch = string.IsNullOrEmpty(_searchTerm) ||
            o.Id.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
            o.Customer.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase);

        bool matchFilter = _selectedFilter switch
        {
            "recibido"   => o.Status == "recibido",
            "en_proceso" => o.Status == "en_proceso",
            "atendido"   => o.Status == "atendido",
            "rechazado"  => o.Status == "rechazado",
            "cancelado"  => o.Status == "cancelado",
            _            => true
        };
        return matchSearch && matchFilter;
    });

    private int CountByStatus(string s) => _allOrders.Count(o => o.Status == s);

    private void SetFilter(string f) { _selectedFilter = f; _currentPage = 1; }

    private async Task UpdateStatus(string id, string newStatus)
    {
        await SalesSvc.UpdateOrderStatusAsync(id, newStatus);
        RefreshList();
        if (_detailOrder?.Id == id)
            _detailOrder = _allOrders.FirstOrDefault(o => o.Id == id);
    }

    private void VerDetalle(Order o) { _detailOrder = o; _showDetailModal = true; }
    private void CloseModal()        => _showDetailModal = false;
    private void ClearSearch()       { _searchTerm = ""; _currentPage = 1; }

    private async Task SiguienteAccion(Order o)
    {
        // Flujo lineal según estados del backend: RECIBIDO → EN_PROCESO → ATENDIDO
        var next = o.Status switch
        {
            "recibido"   => "en_proceso",
            "en_proceso" => "atendido",
            _            => ""
        };
        if (!string.IsNullOrEmpty(next)) await UpdateStatus(o.Id, next);
    }

    private async Task CancelarOrder(Order o) => await UpdateStatus(o.Id, "cancelado");

    private string GetStatusLabel(string s) => s switch
    {
        "recibido"   => "Recibido",
        "en_proceso" => "En proceso",
        "atendido"   => "Atendido",
        "rechazado"  => "Rechazado",
        "cancelado"  => "Cancelado",
        _            => s
    };

    private string GetStatusBadgeStyle(string s) => s switch
    {
        "recibido"   => "background:#fff3e0;color:#b25e00;font-weight:600;",
        "en_proceso" => "background:#e3f2fd;color:#0d6efd;font-weight:600;",
        "atendido"   => "background:#e8f5e9;color:#198754;font-weight:600;",
        "rechazado"  => "background:#ffebee;color:#c62828;font-weight:600;",
        "cancelado"  => "background:#ffebee;color:#c62828;font-weight:600;",
        _            => "background:#f5f5f5;color:#555;font-weight:600;"
    };

    private string GetLeftBorderClass(string s) => s switch
    {
        "recibido"   => "border-left-pendiente",
        "en_proceso" => "border-left-preparando",
        "atendido"   => "border-left-entregado",
        "rechazado"  => "border-left-cancelado",
        "cancelado"  => "border-left-cancelado",
        _            => ""
    };

    private string GetElapsedTime(DateTime date)
    {
        var diff = DateTime.Now - date;
        if (diff.TotalMinutes < 1)  return "Hace unos segundos";
        if (diff.TotalMinutes < 60) return $"Hace {Math.Floor(diff.TotalMinutes)} min";
        if (diff.TotalHours < 24)   return $"Hace {Math.Floor(diff.TotalHours)} h";
        return $"Hace {Math.Floor(diff.TotalDays)} días";
    }

    private string GetNextActionLabel(string s) => s switch
    {
        "recibido"   => "Iniciar proceso",
        "en_proceso" => "Marcar atendido",
        _            => ""
    };

    private int TotalPages(int totalCount) => (int)Math.Ceiling((double)totalCount / _pageSize);
    private void SetPage(int p) => _currentPage = p;
    private void NextPage(int totalCount) { if (_currentPage < TotalPages(totalCount)) _currentPage++; }
    private void PrevPage()               { if (_currentPage > 1) _currentPage--; }

    private IEnumerable<Order> PaginatedOrders(IEnumerable<Order> filtered)
    {
        int total    = filtered.Count();
        int maxPages = TotalPages(total);
        if (_currentPage > maxPages && maxPages > 0) _currentPage = maxPages;
        else if (maxPages == 0) _currentPage = 1;
        return filtered.Skip((_currentPage - 1) * _pageSize).Take(_pageSize);
    }
}
