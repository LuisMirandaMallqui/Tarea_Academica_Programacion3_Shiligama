@page "/trabajador/productos"
@layout TrabajadorLayout
@inject ProductService ProductSvc

<PageTitle>Consulta de Productos – Shiligama</PageTitle>

<div class="d-flex flex-column gap-4">
    <!-- Header -->
    <div>
        <h1 class="fs-4 fw-bold text-foreground mb-0">
            <i class="fas fa-box me-2 text-primary"></i>Catálogo de Productos
        </h1>
        <p class="text-muted-foreground small mt-1 mb-0">Consulta el inventario y disponibilidad de productos</p>
    </div>

    <!-- KPI Cards -->
    <div class="row g-3">
        <div class="col-6 col-xl-3">
            <div class="worker-kpi-card kpi-blue">
                <div>
                    <div class="metric-kpi-value text-foreground" style="font-size:1.6rem;font-weight:700;">@_products.Count</div>
                    <div class="metric-kpi-label" style="font-size:0.8rem;color:var(--muted-foreground);">Total Productos</div>
                </div>
                <div class="metric-kpi-icon-custom" style="background:#dcf0e8;color:#1A6B3C;">
                    <i class="fas fa-boxes"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="worker-kpi-card kpi-green">
                <div>
                    <div class="metric-kpi-value text-foreground" style="font-size:1.6rem;font-weight:700;">@_products.Count(p => p.Stock > 10)</div>
                    <div class="metric-kpi-label" style="font-size:0.8rem;color:var(--muted-foreground);">Stock Disponible</div>
                </div>
                <div class="metric-kpi-icon-custom" style="background:#e8f5e9;color:#198754;">
                    <i class="fas fa-check-circle"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="worker-kpi-card kpi-yellow">
                <div>
                    <div class="metric-kpi-value text-foreground" style="font-size:1.6rem;font-weight:700;">@_products.Count(p => p.Stock > 0 && p.Stock <= 10)</div>
                    <div class="metric-kpi-label" style="font-size:0.8rem;color:var(--muted-foreground);">Stock Bajo</div>
                </div>
                <div class="metric-kpi-icon-custom" style="background:#fff8e1;color:#ffc107;">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="worker-kpi-card kpi-red">
                <div>
                    <div class="metric-kpi-value text-foreground" style="font-size:1.6rem;font-weight:700;">@_products.Count(p => p.Stock == 0)</div>
                    <div class="metric-kpi-label" style="font-size:0.8rem;color:var(--muted-foreground);">Agotados</div>
                </div>
                <div class="metric-kpi-icon-custom" style="background:#ffebee;color:#dc3545;">
                    <i class="fas fa-times-circle"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card border rounded-4 d-flex align-items-center justify-content-center" style="min-height: 72px; padding: 14px 18px;">
        <div class="row g-3 align-items-center justify-content-center w-100 m-0">
            <div class="col-md-8 p-0 pe-md-2">
                <div class="position-relative w-100 d-flex align-items-center">
                    <i class="fas fa-search position-absolute text-muted-foreground" style="left:16px;font-size:14px;pointer-events:none;z-index:3;"></i>
                    <input type="search" @bind="_search" @bind:event="oninput"
                           class="form-control text-foreground"
                           placeholder="Buscar por nombre..."
                           style="height: 44px; padding-left: 44px; width:100%; border-radius:8px;" />
                </div>
            </div>
            <div class="col-md-4 p-0 ps-md-2">
                <select @bind="_categoryFilter" class="form-select text-foreground w-100" style="height: 44px; border-radius:8px;">
                    <option value="">Categorías (todas)</option>
                    @foreach (var cat in ProductSvc.GetCategories())
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>
            </div>
        </div>
    </div>

    <style>
        .worker-kpi-card {
            background: var(--card);
            border-radius: var(--radius);
            padding: 1.5rem 1.25rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            height: 105px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
        }
        .worker-kpi-card:hover {
            transform: translateY(-6px) scale(1.02);
            z-index: 10;
        }
        
        .kpi-blue {
            border: 2px solid #1A6B3C;
            box-shadow: 0 4px 12px rgba(26, 107, 60, 0.08);
        }
        .kpi-blue:hover {
            border-color: #155230;
            box-shadow: 0 12px 24px rgba(26, 107, 60, 0.2);
        }
        
        .kpi-green {
            border: 2px solid #198754;
            box-shadow: 0 4px 12px rgba(25, 135, 84, 0.08);
        }
        .kpi-green:hover {
            border-color: #157347;
            box-shadow: 0 12px 24px rgba(25, 135, 84, 0.2);
        }
        
        .kpi-yellow {
            border: 2px solid #ffc107;
            box-shadow: 0 4px 12px rgba(255, 193, 7, 0.08);
        }
        .kpi-yellow:hover {
            border-color: #ffca2c;
            box-shadow: 0 12px 24px rgba(255, 193, 7, 0.2);
        }
        
        .kpi-red {
            border: 2px solid #dc3545;
            box-shadow: 0 4px 12px rgba(220, 53, 69, 0.08);
        }
        .kpi-red:hover {
            border-color: #bb2d3b;
            box-shadow: 0 12px 24px rgba(220, 53, 69, 0.2);
        }

        .worker-kpi-card .metric-kpi-icon-custom {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
            flex-shrink: 0;
        }
    </style>

    <!-- Inventory Table Grid -->
    <div class="card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-borderless mb-0 align-middle">
                <thead class="border-bottom border-color-default">
                    <tr>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Código</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Producto</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Categoría</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Precio Unitario</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-center" style="letter-spacing:.05em;">Stock Disponible</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in PaginatedProducts)
                    {
                        <tr class="border-bottom border-color-default">
                            <td class="px-4 py-3 fw-medium text-muted-foreground small">PROD-@product.Id.ToString("D3")</td>
                            <td class="px-4 py-3 d-flex align-items-center gap-3">
                                <img src="@product.Image" alt="@product.Name" class="rounded-3 flex-shrink-0 object-fit-cover" style="width:40px;height:40px;" onerror="this.src='https://placehold.co/40x40/e8f5e9/1A6B3C?text=🛒'" />
                                <span class="fw-medium text-foreground small">@product.Name</span>
                            </td>
                            <td class="px-4 py-3 text-muted-foreground small">
                                @ProductSvc.GetCategoryName(product.Category)
                            </td>
                            <td class="px-4 py-3 text-foreground small fw-semibold">
                                S/. @product.Price.ToString("0.00")
                            </td>
                            <td class="px-4 py-3 text-center">
                                <span class="badge @(product.Stock == 0 ? "bg-danger" : product.Stock < 10 ? "bg-warning text-dark" : "bg-success") py-1 px-3" style="border-radius:var(--radius); font-size:.8rem;">
                                    @product.Stock unidades
                                </span>
                            </td>
                        </tr>
                    }
                    @if (!Filtered.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted-foreground">
                                No se encontraron productos coincidentes.
                                @if (!string.IsNullOrEmpty(_search) || !string.IsNullOrEmpty(_categoryFilter))
                                {
                                    <button class="btn btn-link btn-sm p-0 ms-1" @onclick="ClearFilters">Limpiar filtros</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Paginación -->
        @if (TotalPages > 1)
        {
            var totalPaginas = TotalPages;
            var totalItems = Filtered.Count();
            var desde = (_currentPage - 1) * PAGE_SIZE + 1;
            var hasta = Math.Min(_currentPage * PAGE_SIZE, totalItems);

            <div class="d-flex align-items-center justify-content-between px-4 py-3 border-top border-color-default">
                <span class="small text-muted-foreground">
                    Mostrando @desde–@hasta de @totalItems productos
                </span>
                <nav>
                    <ul class="pagination pagination-sm mb-0 gap-1">
                        <li class="page-item @(_currentPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="PrevPage" style="border-radius:var(--radius);">
                                <i class="fa-solid fa-chevron-left"></i>
                            </button>
                        </li>

                        @for (int i = 1; i <= totalPaginas; i++)
                        {
                            var p = i;
                            <li class="page-item @(_currentPage == p ? "active" : "")">
                                <button class="page-link" @onclick="@(() => SetPage(p))" style="border-radius:var(--radius);">@p</button>
                            </li>
                        }

                        <li class="page-item @(_currentPage == totalPaginas ? "disabled" : "")">
                            <button class="page-link" @onclick="NextPage" style="border-radius:var(--radius);">
                                <i class="fa-solid fa-chevron-right"></i>
                            </button>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

@code {
    private List<Product> _products = new();
    private string _search = "";
    private string _categoryFilter = "";

    // ── Paginación ────────────────────────────────────────────────────────────
    private int _currentPage = 1;
    private const int PAGE_SIZE = 20;

    protected override async Task OnInitializedAsync()
    {
        await ProductSvc.EnsureLoadedAsync();   // productos + categorías del API
        _products = ProductSvc.GetProducts();
    }

    private IEnumerable<Product> Filtered => _products.Where(p =>
        (string.IsNullOrEmpty(_search) || p.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_categoryFilter) || p.Category.Equals(_categoryFilter, StringComparison.OrdinalIgnoreCase))
    );

    private int TotalPages => (int)Math.Ceiling(Filtered.Count() / (double)PAGE_SIZE);

    private IEnumerable<Product> PaginatedProducts
    {
        get
        {
            int max = TotalPages;
            if (_currentPage > max && max > 0) _currentPage = max;
            if (max == 0) _currentPage = 1;
            return Filtered.Skip((_currentPage - 1) * PAGE_SIZE).Take(PAGE_SIZE);
        }
    }

    private void SetPage(int p) => _currentPage = p;
    private void PrevPage() { if (_currentPage > 1) _currentPage--; }
    private void NextPage() { if (_currentPage < TotalPages) _currentPage++; }
    private void ClearFilters() { _search = ""; _categoryFilter = ""; _currentPage = 1; }
}
