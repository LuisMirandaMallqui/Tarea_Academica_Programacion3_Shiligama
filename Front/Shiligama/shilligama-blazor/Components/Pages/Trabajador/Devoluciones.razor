@page "/trabajador/devoluciones"
@layout TrabajadorLayout
@inject ReturnsService ReturnsSvc
@inject ProductService ProductSvc
@inject AuthService Auth

@code {
    private List<Return> _returns = new();
    private string _search = "";
    private string _motivoFilter = "";
    private bool _showModal = false;
    private Return _form = new();

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            ProductSvc.EnsureLoadedAsync(),
            ReturnsSvc.EnsureLoadedAsync()
        );
        _returns = ReturnsSvc.GetReturns();
    }

    private IEnumerable<Return> Filtered => _returns.Where(r =>
        (string.IsNullOrEmpty(_search) ||
        r.Product.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
        r.Id.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_motivoFilter) || r.Reason.Equals(_motivoFilter, StringComparison.OrdinalIgnoreCase))
    );

    private void OpenCreate()
    {
        _form = new Return
        {
            Quantity = 1,
            RegisteredBy = Auth.CurrentUser?.Name ?? "Jorge Trabajador"
        };
        _showModal = true;
    }

    private void Save()
    {
        var prod = ProductSvc.GetProducts().FirstOrDefault(p => p.Name.Equals(_form.Product, StringComparison.OrdinalIgnoreCase));
        if (prod != null)
        {
            _form.ProductCode = $"PROD-{prod.Id:D3}";
            _form.Amount = prod.Price * _form.Quantity;
        }
        else
        {
            _form.ProductCode = "PROD-GEN";
            _form.Amount = _form.Amount == 0 ? 10.00m * _form.Quantity : _form.Amount;
        }

        ReturnsSvc.AddReturn(_form);
        _showModal = false;
        _returns = ReturnsSvc.GetReturns(); // refresh
    }
}

<PageTitle>Registro de Devoluciones – Shiligama</PageTitle>

<div class="d-flex flex-column gap-4">
    <!-- Header -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h1 class="fs-4 fw-bold text-foreground mb-0">
                <i class="fas fa-undo-alt me-2 text-primary"></i>Registro de Devoluciones
            </h1>
            <p class="text-muted-foreground small mt-1 mb-0">Registra y atiende reclamos físicos de clientes por productos dañados o vencidos</p>
        </div>
        <button @onclick="OpenCreate" class="btn btn-primary d-flex align-items-center gap-2 fw-semibold" style="border-radius: var(--radius);">
            <i class="fas fa-plus"></i> Registrar Devolución
        </button>
    </div>

    <!-- KPI Cards -->
    <div class="row g-3">
        <div class="col-md-4">
            <div class="metric-card-kpi">
                <div>
                    <div class="metric-kpi-value text-foreground">@_returns.Count</div>
                    <div class="metric-kpi-label">Devoluciones este mes</div>
                </div>
                <div class="metric-kpi-icon" style="background:color-mix(in srgb,var(--primary) 15%,transparent);color:var(--primary);">
                    <i class="fas fa-sync-alt"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-card-kpi">
                <div>
                    <div class="metric-kpi-value" style="color:#c62828;font-size:1.4rem;">S/. @_returns.Sum(r => r.Amount).ToString("0.00")</div>
                    <div class="metric-kpi-label">Pérdida acumulada</div>
                </div>
                <div class="metric-kpi-icon" style="background:color-mix(in srgb,#c62828 15%,transparent);color:#c62828;">
                    <i class="fas fa-arrow-down"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-card-kpi">
                <div>
                    <div class="metric-kpi-value text-foreground" style="font-size:1.1rem;">@(_returns.OrderByDescending(r => r.Quantity).FirstOrDefault()?.Product ?? "N/A")</div>
                    <div class="metric-kpi-label">Producto más devuelto</div>
                </div>
                <div class="metric-kpi-icon" style="background:color-mix(in srgb,#f59e0b 15%,transparent);color:#f59e0b;">
                    <i class="fas fa-box"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="row g-2">
        <div class="col-md-8">
            <div class="position-relative">
                <i class="fas fa-search position-absolute top-50 translate-middle-y text-muted-foreground" style="left:14px;font-size:0.85rem;"></i>
                <input type="search" @bind="_search" @bind:event="oninput" class="form-control text-foreground" placeholder="Buscar por código o producto..." style="padding-left:40px;" />
            </div>
        </div>
        <div class="col-md-4">
            <select @bind="_motivoFilter" class="form-select text-foreground">
                <option value="">Todos los motivos</option>
                <option value="Vencido">Vencido</option>
                <option value="Dañado">Dañado / Roto</option>
                <option value="Error de pedido">Error de pedido</option>
            </select>
        </div>
    </div>

    <!-- Table -->
    <div class="card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-borderless mb-0 align-middle">
                <thead class="border-bottom border-color-default">
                    <tr>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Código</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Fecha</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Producto</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-center" style="letter-spacing:.05em;">Cantidad</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Motivo</th>
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Importe Devuelto</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dev in Filtered)
                    {
                        <tr class="border-bottom border-color-default">
                            <td class="px-4 py-3 fw-bold text-primary small">@dev.Id</td>
                            <td class="px-4 py-3 text-muted-foreground small">@dev.Date.ToString("dd/MM/yyyy")</td>
                            <td class="px-4 py-3 small">
                                <span class="fw-semibold text-foreground d-block">@dev.Product</span>
                                <span class="text-xs text-muted-foreground">@dev.ProductCode</span>
                            </td>
                            <td class="px-4 py-3 text-center small">@dev.Quantity ud.</td>
                            <td class="px-4 py-3 small">
                                <span class="badge bg-warning-subtle text-warning" style="border-radius: var(--radius);">
                                    @dev.Reason
                                </span>
                            </td>
                            <td class="px-4 py-3 fw-semibold text-danger small">S/. @dev.Amount.ToString("0.00")</td>
                        </tr>
                        @if (!string.IsNullOrEmpty(dev.Observations))
                        {
                            <tr class="border-bottom border-color-default bg-muted bg-opacity-30">
                                <td colspan="6" class="px-5 py-2.5 small text-muted-foreground italic" style="font-size: 0.8rem;">
                                    <strong>Observación:</strong> @dev.Observations
                                </td>
                            </tr>
                        }
                    }
                    @if (!Filtered.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted-foreground">
                                No se encontraron registros de devoluciones
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Form -->
@if (_showModal)
{
    <div class="modal show d-block fade-in" tabindex="-1" style="background:rgba(0,0,0,.5);" @onclick="@(() => _showModal = false)">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content bg-card border-border">
                <div class="modal-header border-border">
                    <h5 class="modal-title text-foreground fw-bold">Registrar Devolución</h5>
                    <button type="button" class="btn-close" @onclick="@(() => _showModal = false)"></button>
                </div>
                <div class="modal-body p-4">
                    <EditForm Model="_form" OnValidSubmit="Save" class="d-flex flex-column gap-3">
                        <div>
                            <label class="form-label small fw-medium text-foreground">Nombre del Producto</label>
                            <input type="text" @bind="_form.Product" required class="form-control text-foreground" placeholder="Pechuga de Pollo" />
                        </div>
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label small fw-medium text-foreground">Cantidad</label>
                                <input type="number" @bind="_form.Quantity" required class="form-control text-foreground" min="1" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-medium text-foreground">Motivo</label>
                                <select @bind="_form.Reason" class="form-select text-foreground" required>
                                    <option value="">Seleccionar motivo</option>
                                    <option value="Vencido">Vencido</option>
                                    <option value="Dañado">Dañado / Roto</option>
                                    <option value="Error de pedido">Error de pedido</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="form-label small fw-medium text-foreground">Observaciones detalladas</label>
                            <textarea @bind="_form.Observations" class="form-control text-foreground" rows="3" placeholder="Detalle adicional del estado..."></textarea>
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <button type="button" @onclick="@(() => _showModal = false)" class="btn btn-secondary" style="border-radius: var(--radius);">Cancelar</button>
                            <button type="submit" class="btn btn-primary fw-semibold" style="border-radius: var(--radius);">
                                Registrar
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}
