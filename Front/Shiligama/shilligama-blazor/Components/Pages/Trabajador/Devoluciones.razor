@page "/trabajador/devoluciones"
@layout TrabajadorLayout

<PageTitle>Devoluciones – Shiligama Trabajador</PageTitle>

<div class="d-flex flex-column gap-5">

    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h1 class="fs-4 fw-bold text-foreground mb-0">Devoluciones</h1>
            <p class="text-muted-foreground small mt-1 mb-0">
                Gestiona solicitudes online y revisa el historial completo de devoluciones.
            </p>
        </div>

        <button @onclick="AbrirRegistroPresencial"
                class="btn btn-primary d-flex align-items-center gap-2 fw-semibold"
                style="border-radius: var(--radius);">
            <i class="fas fa-plus"></i>
            Registrar devolución presencial
        </button>
    </div>

    <!-- TABLA 1: SOLICITUDES ONLINE -->
    <section class="d-flex flex-column gap-3">
        <div>
            <h2 class="fs-5 fw-bold text-foreground mb-1">Solicitudes online</h2>
            <p class="text-muted-foreground small mb-0">
                Solicitudes registradas por clientes desde sus pedidos online. Estas pueden aprobarse o rechazarse.
            </p>
        </div>

        <DevolucionesPanel Rol="trabajador"
                           TipoVista="online"
                           MostrarCanal="true"
                           MostrarEditar="false"
                           MostrarKpis="true"
                           PermitirEvaluar="true"
                           EmptyMessage="No hay solicitudes online registradas"
                           LoadingText="Cargando solicitudes online..." />
    </section>

    <!-- TABLA 2: HISTORIAL COMPLETO -->
    <section class="d-flex flex-column gap-3 mt-4">
        <div>
            <h2 class="fs-5 fw-bold text-foreground mb-1">Historial de devoluciones</h2>
            <p class="text-muted-foreground small mb-0">
                Historial completo de devoluciones online y presenciales. Esta tabla es solo informativa.
            </p>
        </div>

        <DevolucionesPanel Rol="trabajador"
                           TipoVista="todas"
                           MostrarCanal="true"
                           MostrarEditar="false"
                           MostrarKpis="true"
                           PermitirEvaluar="false"
                           EmptyMessage="No se encontraron devoluciones registradas"
                           LoadingText="Cargando historial de devoluciones..."
                           @ref="_panelHistorial" />
    </section>

</div>

@code {
    private DevolucionesPanel? _panelHistorial;

    private void AbrirRegistroPresencial()
    {
        _panelHistorial?.OpenCreate();
    }
}