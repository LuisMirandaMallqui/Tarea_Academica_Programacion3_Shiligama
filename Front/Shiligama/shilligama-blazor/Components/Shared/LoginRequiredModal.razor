@inject AuthService Auth
@inject NavigationManager Navigation

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public string? ReturnUrl { get; set; }

    private string SafeReturnUrl
    {
        get
        {
            if (string.IsNullOrWhiteSpace(ReturnUrl)) return "/carrito";
            if (!ReturnUrl.StartsWith('/') || ReturnUrl.StartsWith("//")) return "/carrito";
            return ReturnUrl;
        }
    }

    private string LoginUrl    => BuildAuthUrl(register: false);
    private string RegisterUrl => BuildAuthUrl(register: true);

    private string BuildAuthUrl(bool register)
    {
        var encoded = Uri.EscapeDataString(SafeReturnUrl);
        return register
            ? $"/?register=true&returnUrl={encoded}"
            : $"/?returnUrl={encoded}";
    }

    private async Task CloseAsync()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
    }

    private async Task ContinueAsGuestAsync()
    {
        Auth.LoginAsGuest();
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
        Navigation.NavigateTo(SafeReturnUrl);
    }
}

@if (IsOpen)
{
    <style>
        .hover-text-primary:hover { color: var(--primary) !important; }
        .btn-green-primary {
            background-color: var(--primary) !important;
            border-color: var(--primary) !important;
            color: #ffffff !important;
            transition: all 0.2s ease;
        }
        .btn-green-primary:hover {
            background-color: color-mix(in srgb, var(--primary) 85%, black) !important;
        }
    </style>

    <div class="modal fade show d-block fade-in" tabindex="-1"
         style="background:rgba(0,0,0,.45);backdrop-filter:blur(3px);z-index:1050;" role="dialog">
        <div class="modal-dialog modal-dialog-centered" style="max-width:780px;" role="document">
            <div class="modal-content border-0 shadow-lg" style="border-radius:1.5rem;overflow:hidden;background:var(--card);">

                <!-- Cabecera -->
                <div class="p-3 text-center border-bottom border-border"
                     style="background:color-mix(in srgb,var(--primary) 6%,var(--card));">
                    <p class="mb-0 fw-semibold text-foreground d-flex align-items-center justify-content-center gap-2"
                       style="font-size:0.95rem;font-family:'Outfit',sans-serif;">
                        <i class="fa-solid fa-circle-exclamation text-primary" style="font-size:1.1rem;"></i>
                        Para proceder con el checkout debes iniciar sesión o crear una cuenta.
                    </p>
                </div>

                <!-- Dos columnas -->
                <div class="position-relative row g-0">
                    <button type="button" class="btn-close position-absolute" @onclick="CloseAsync"
                            style="top:1.25rem;right:1.25rem;z-index:10;opacity:0.6;"></button>

                    <!-- Columna: Crear Cuenta -->
                    <div class="col-md-6 p-4 p-lg-5" style="background:var(--card);">
                        <div class="d-flex flex-column justify-content-between h-100" style="min-height:260px;">
                            <div>
                                <div class="d-flex align-items-center gap-2 mb-3">
                                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle"
                                         style="width:40px;height:40px;background:#FFF3E0;color:#E65100;">
                                        <i class="fa-solid fa-bag-shopping" style="font-size:1.15rem;"></i>
                                    </div>
                                    <span class="text-muted-foreground fw-semibold small">Crea tu cuenta</span>
                                </div>
                                <h2 class="fw-bold text-foreground mb-2"
                                    style="font-family:'Outfit',sans-serif;font-size:1.85rem;letter-spacing:-0.02em;">
                                    Crea tu cuenta
                                </h2>
                                <p class="text-muted-foreground mb-0" style="font-size:0.95rem;">Para beneficios exclusivos.</p>
                            </div>
                            <div class="mt-4">
                                <a href="@RegisterUrl" class="btn btn-green-primary w-100 py-2 fw-semibold"
                                   style="border-radius:var(--radius);font-family:'Outfit',sans-serif;">
                                    Crear Cuenta
                                </a>
                                <div class="text-center mt-2">
                                    <button type="button" class="btn btn-link text-decoration-none text-muted-foreground p-0 fw-semibold"
                                            @onclick="ContinueAsGuestAsync" style="font-size:0.85rem;">
                                        Saltar y continuar como invitado
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Columna: Iniciar Sesión -->
                    <div class="col-md-6 p-4 p-lg-5 border-top border-md-top-0 border-border"
                         style="background:color-mix(in srgb,var(--primary) 3%,var(--card));">
                        <div class="d-flex flex-column justify-content-between h-100" style="min-height:260px;">
                            <div>
                                <div class="d-flex align-items-center gap-2 mb-3">
                                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle"
                                         style="width:40px;height:40px;background:#E8F5E9;color:var(--primary);">
                                        <i class="fa-solid fa-lock" style="font-size:1rem;"></i>
                                    </div>
                                    <span class="text-muted-foreground fw-semibold small">Inicia sesión</span>
                                </div>
                                <h2 class="fw-bold text-foreground mb-2"
                                    style="font-family:'Outfit',sans-serif;font-size:1.85rem;letter-spacing:-0.02em;">
                                    Inicia sesión
                                </h2>
                                <p class="text-muted-foreground mb-0" style="font-size:0.95rem;">Vuelve a comprar rápidamente.</p>
                            </div>
                            <div class="mt-4">
                                <a href="@LoginUrl" class="btn btn-green-primary w-100 py-2 fw-semibold"
                                   style="border-radius:var(--radius);font-family:'Outfit',sans-serif;">
                                    Iniciar Sesión
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
}
