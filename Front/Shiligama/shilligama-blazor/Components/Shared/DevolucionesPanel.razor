@* DevolucionesPanel.razor — componente compartido para Admin y Trabajador *@
@using shilligama_blazor.Models
@using shilligama_blazor.Services
@inject ReturnsService ReturnsSvc
@inject ProductService ProductSvc
@inject AuthService Auth
@inject SalesService SalesSvc


@* ─── KPIs ──────────────────────────────────────────────────────────────────── *@
@if (Rol == "trabajador")
{
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="worker-kpi-card kpi-green-custom">
                <div>
                    <div class="metric-kpi-value text-foreground" style="font-size:1.6rem;font-weight:700;">@MesActualCount</div>
                    <div class="metric-kpi-label" style="font-size:0.8rem;color:var(--muted-foreground);">Devoluciones este mes</div>
                </div>
                <div class="metric-kpi-icon-custom" style="background:#e8f5e9;color:#198754;">
                    <i class="fas fa-sync-alt"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="worker-kpi-card kpi-red-custom">
                <div>
                    <div class="metric-kpi-value text-foreground" style="font-size:1.6rem;font-weight:700;">S/. @MesActualTotal.ToString("0.00")</div>
                    <div class="metric-kpi-label" style="font-size:0.8rem;color:var(--muted-foreground);">Total Mermas (pérdida)</div>
                </div>
                <div class="metric-kpi-icon-custom" style="background:#ffebee;color:#dc3545;">
                    <i class="fas fa-arrow-down"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="worker-kpi-card kpi-yellow-custom">
                <div>
                    <div class="metric-kpi-value text-foreground" style="font-size:1.1rem;font-weight:700;">@GetTopReturnedOrderText()</div>
                    <div class="metric-kpi-label" style="font-size:0.8rem;color:var(--muted-foreground);">Pedido con más devoluciones</div>
                </div>
                <div class="metric-kpi-icon-custom" style="background:#fff8e1;color:#ffc107;">
                    <i class="fas fa-box"></i>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card p-3 d-flex flex-column gap-1">
                <span class="small text-muted-foreground fw-medium">Devoluciones este mes</span>
                <span class="fs-3 fw-bold text-primary">@MesActualCount</span>
                <span class="text-xs text-muted-foreground mt-1">@DateTime.Now.ToString("MMMM yyyy")</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 d-flex flex-column gap-1">
                <span class="small text-muted-foreground fw-medium">Valor Devuelto (mes)</span>
                <span class="fs-3 fw-bold text-danger">S/. @MesActualTotal.ToString("0.00")</span>
                <span class="text-xs text-muted-foreground mt-1">Pérdida del mes</span>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 d-flex flex-column gap-1">
                <span class="small text-muted-foreground fw-medium">Ticket Promedio</span>
                <span class="fs-3 fw-bold text-foreground">S/. @MesAvgTicket.ToString("0.00")</span>
                <span class="text-xs text-muted-foreground mt-1">Monto promedio por devolución</span>
            </div>
        </div>
    </div>
}

@* ─── Filtros ────────────────────────────────────────────────────────────────── *@
<div class="card p-4" style="border-radius:12px;">
    <div class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label small fw-medium text-foreground mb-1">Buscar</label>
            <div class="position-relative">
                <i class="fa-solid fa-magnifying-glass position-absolute top-50 translate-middle-y text-muted"
                   style="left:16px;font-size:14px;"></i>
                <input type="search" @bind="_search" @bind:event="oninput"
                       class="form-control text-foreground"
                       placeholder="Buscar por ID, producto o responsable..."
                       style="height:44px;border-radius:10px;padding-left:42px;" />
            </div>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-medium text-foreground mb-1">Motivo</label>
            <select @bind="_motivoFilter" class="form-select text-foreground" style="height:44px;border-radius:10px;">
                <option value="">Todos</option>
                <option value="Vencido">Vencido</option>
                <option value="Dañado">Dañado</option>
                <option value="Error de pedido">Error de pedido</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-medium text-foreground mb-1">Desde</label>
            <input type="date" @bind="_fechaDesde" @bind:after="OnFilterChange"
                   class="form-control text-foreground" style="height:44px;border-radius:10px;" />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-medium text-foreground mb-1">Hasta</label>
            <input type="date" @bind="_fechaHasta" @bind:after="OnFilterChange"
                   class="form-control text-foreground" style="height:44px;border-radius:10px;" />
        </div>
    </div>
</div>

<style>
    @@keyframes cartTrip {
        0%   { transform: translateX(-120px);                        opacity: 0; }
        12%  { transform: translateX(-30px)  translateY(0);         opacity: 1; }
        25%  { transform: translateX(20px)   translateY(-18px)   rotate(90deg); }
        40%  { transform: translateX(0)      translateY(-38px)   rotate(180deg); }
        55%  { transform: translateX(-20px)  translateY(-18px)   rotate(270deg); }
        68%  { transform: translateX(30px)   translateY(0)       rotate(360deg); }
        85%  { transform: translateX(120px);                        opacity: 0; }
        100% { transform: translateX(120px);                        opacity: 0; }
    }
</style>

@* ─── Tabla ──────────────────────────────────────────────────────────────────── *@

<!-- Tabla -->
    <div class="card overflow-hidden">

        @if (_loading)
        {
            <div class="d-flex flex-column align-items-center justify-content-center py-5"
                 style="min-height:350px;">

                <div style="font-size:4rem;
                    color:#1A6B3C;
                    animation:cartTrip 3.5s ease-in-out infinite;">
                    <i class="fas fa-shopping-cart"></i>
                </div>

                <div class="mt-3"
                     style="color:#1A6B3C;font-weight:600;">
                    Cargando devoluciones...
                </div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <!-- PEGA AQUÍ TODO EL CÓDIGO DE TU TABLA -->
                <div class="card overflow-hidden">
                    <div class="table-responsive">
                        <table class="table table-borderless mb-0 align-middle return-table">
                            <thead class="border-bottom border-color-default">
                                <tr>
                                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Fecha</th>
                                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">ID Pedido</th>
                                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Motivo</th>
                                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Registrado Por</th>
                                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Estado</th>
                                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Monto Total</th>
                                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-end" style="letter-spacing:.05em;">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{var devList = Filtered.ToList();}
                                    @for (int i = 0; i < devList.Count; i++)
                                    {
                                        var dev = devList[i];

                                        @if (i > 0)
                                        {
                                            <tr style="height:16px;">
                                                <td colspan="6" style="padding:0; border:none; background:transparent;"></td>
                                            </tr>
                                        }

                                        <tr class="return-group-start return-row">
                                            <td class="px-4 py-3 text-muted-foreground small">@dev.Date.ToString("dd MMM yyyy")</td>
                                            <td class="px-4 py-3 small">
                                                <span class="fw-bold text-success d-block">@(dev.IdPedido.HasValue && dev.IdPedido.Value > 0 ? $"SHI-2024-{dev.IdPedido.Value:D4}" : "SHI-2024-GEN")</span>
                                                <span class="text-xs text-muted-foreground">@GetCustomerNameForReturn(dev)</span>
                                            </td>
                                            <td class="px-4 py-3 small">
                                                @switch (dev.Reason?.ToLower())
                                                {
                                                    case "vencido":
                                                        <span class="badge text-white" style="background:#dc3545;font-size:0.75rem;padding:4px 11px;font-weight:600;border-radius:8px;"><i class="fas fa-hourglass-end me-1"></i>Vencido</span>
                                                        break;
                                                    case "dañado":
                                                    case "dañado / roto":
                                                        <span class="badge text-white" style="background:#fd7e14;font-size:0.75rem;padding:4px 11px;font-weight:600;border-radius:8px;"><i class="fas fa-exclamation-triangle me-1"></i>Dañado</span>
                                                        break;
                                                    default:
                                                        <span class="badge text-white" style="background:#6c757d;font-size:0.75rem;padding:4px 11px;font-weight:600;border-radius:8px;"><i class="fas fa-tag me-1"></i>Motivo personalizado</span>
                                                        break;
                                                }
                                            </td>
                                            <td class="px-4 py-3 text-muted-foreground small">@dev.RegisteredBy</td>
                                            <td class="px-4 py-3 small">
                                                @{
                                                    var estado = dev.Estado?.ToLower() ?? "pendiente";
                                                }

                                                @if (estado == "pendiente")
                                                {
                                                    <span class="badge badge-pendiente">⏳ Pendiente</span>
                                                }
                                                else if (estado == "aprobado")
                                                {
                                                    <span class="badge badge-entregado">✅ Aprobado</span>
                                                }
                                                else if (estado == "rechazado")
                                                {
                                                    <span class="badge badge-cancelado">❌ Rechazado</span>
                                                }
                                            </td>
                                            <td class="px-4 py-3 fw-bold text-danger small">-S/. @dev.Amount.ToString("0.00")</td>
                                            <td class="px-4 py-3 text-end">
                                                <div class="d-flex gap-1 justify-content-end">
                                                    <button class="btn btn-sm" @onclick="@(() => VerDetalle(dev))" title="Ver detalle"
                                                            style="width:32px;height:32px;border-radius:8px;">
                                                        <i class="fas fa-eye text-success" style="font-size:0.82rem;"></i>
                                                    </button>
                                                    <button class="btn btn-sm" @onclick="@(() => OpenEdit(dev))" title="Editar"
                                                            style="width:32px;height:32px;border-radius:8px;">
                                                        <i class="fas fa-edit text-warning" style="font-size:0.82rem;"></i>
                                                        
                                                    </button>
                                                    @if ((dev.Estado?.ToLower() ?? "pendiente") == "pendiente")
                                                        {
                                                            <button class="btn btn-sm" title="Evaluar devolución"
                                                                    @onclick="@(() => AbrirEvaluacion(dev))"
                                                                    style="width:32px;height:32px;border-radius:8px;">
                                                                <i class="fas fa-exchange-alt text-primary" style="font-size:0.82rem;"></i>
                                                            </button>
                                                        }
                                                </div>
                                            </td>
                                        </tr>
                                        @if (!string.IsNullOrEmpty(dev.Observations))
                                        {
                                            <tr class="return-observation bg-muted bg-opacity-30">
                                                <td colspan="6" class="px-5 py-2.5 small text-muted-foreground italic" style="font-size:0.8rem;">
                                                    <strong>Observación:</strong> @dev.Observations
                                                </td>
                                            </tr>
                                        }
                                    }
                                @if (!Filtered.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-5 text-muted-foreground">
                                            No se encontraron registros de devoluciones
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                </div>
        }

    </div>

@* ─── Modal Registrar / Editar Devolución ─────────────────────────────────────────────── *@
@if (_showModal)
{
<div class="modal show d-block fade-in" tabindex="-1" style="background:rgba(0,0,0,.55); backdrop-filter:blur(3px);" @onclick="TryCloseModal">        
    <div class="modal-dialog modal-dialog-centered" style="max-width:540px;" @onclick:stopPropagation>
            <div class="modal-content bg-card border-border" style="border-radius: 1.25rem; overflow: hidden; box-shadow: 0 15px 35px rgba(0,0,0,0.2);">
                <div class="modal-header border-border bg-muted bg-opacity-10 px-4 py-3 d-flex align-items-center justify-content-between">
                    <div>
                        <h5 class="modal-title text-foreground fw-bold" style="font-family:'Outfit',sans-serif;">@(_isEditing ? "Modificar Devolución" : "Registrar Devolución")</h5>
                        <p class="text-muted-foreground text-xs m-0">Selecciona el pedido y los productos a devolver</p>
                    </div>
                    <button type="button" class="btn-close" @onclick="@(() => _showModal = false)"></button>
                </div>
                <div class="modal-body p-4" style="max-height: 75vh; overflow-y: auto;">
                    <EditForm Model="_form" OnValidSubmit="Save" class="d-flex flex-column gap-3">
                        
                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <div class="alert alert-danger py-2 small mb-0" role="alert">
                                <i class="fas fa-exclamation-triangle me-1"></i> @_errorMessage
                            </div>
                        }

                        <!-- Buscar Pedido -->
                        <div>
                            <label class="form-label small fw-bold text-foreground">Pedido entregado <span class="text-danger">*</span></label>
                            <div class="position-relative w-100">
                                <i class="fas fa-search position-absolute text-muted-foreground top-50 translate-middle-y" style="left:14px;pointer-events:none;"></i>
                                <input type="text" class="form-control text-foreground" 
                                       placeholder="Buscar por # pedido o cliente..." 
                                       @bind="_orderSearchTerm" @oninput="OnSearchOrderInput"
                                       disabled="@_isEditing"
                                       style="height: 46px; padding-left: 40px; border-radius: 8px; @(_isEditing ? "background-color: #f5f5f5;" : "")" required />
                            </div>
                            
                            @if (_orderMatches.Any())
                            {
                                <div class="list-group shadow-lg border rounded-3 mt-1 position-absolute w-100 bg-card" style="z-index: 1100; max-height: 180px; overflow-y: auto; right: 0; left: 0; padding: 0 1.5rem;">
                                    @foreach (var order in _orderMatches)
                                    {
                                        <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2 px-3 border-color-default"
                                                @onclick="@(() => SelectOrder(order))">
                                            <div>
                                                <span class="fw-bold text-success">@order.Id.Replace("PED-", "SHI-2024-")</span>
                                                <span class="text-muted-foreground ms-2 small">@order.Customer</span>
                                            </div>
                                            <span class="badge bg-light text-muted-foreground border small">@order.Date.ToString("dd/MM/yy")</span>
                                        </button>
                                    }
                                </div>
                            }
                        </div>

                        <!-- Lista de productos del pedido seleccionado -->
                        @if (_selectedOrder != null)
                        {
                            <div class="mt-2">
                                <label class="form-label small fw-bold text-foreground"><i class="fas fa-shopping-basket me-1 text-success"></i> Productos del pedido (@_selectedOrder.Id.Replace("PED-", "SHI-2024-"))</label>
                                <div class="d-flex flex-column gap-2" style="max-height: 220px; overflow-y: auto; padding-right: 4px;">
                                    @foreach (var item in _selectedOrder.Products)
                                    {
                                        <div class="d-flex align-items-center justify-content-between border rounded-3 p-3 bg-muted bg-opacity-10 border-color-default"
                                             style="border-radius: 8px; cursor: pointer;"
                                             @onclick="@(() => OnProductCheckedChange(item.Id, !GetProductChecked(item.Id)))">
                                            <div class="d-flex align-items-center gap-2">
                                                <input type="checkbox" class="form-check-input" 
                                                       checked="@GetProductChecked(item.Id)" 
                                                       @onchange="@((e) => OnProductCheckedChange(item.Id, (bool)e.Value))"
                                                       style="width: 18px; height: 18px; border-radius: 4px;" />
                                                <div>
                                                    <span class="fw-semibold text-foreground small d-block">@item.Name</span>
                                                    <span class="text-muted-foreground text-xs">Comprado: @item.Quantity uds. · S/. @item.Price.ToString("0.00")</span>
                                                </div>
                                            </div>
                                            <div class="d-flex align-items-center gap-1">
                                                <span class="text-muted-foreground text-xs me-1">Cant.:</span>
                                                <input type="number" class="form-control text-center text-foreground font-semibold" 
                                                       value="@GetProductReturnQty(item.Id)"
                                                       @onchange="@((e) => OnProductReturnQtyChange(item.Id, int.Parse(e.Value.ToString())))"
                                                       @onclick:stopPropagation
                                                       min="1" max="@item.Quantity" 
                                                       disabled="@(!GetProductChecked(item.Id))"
                                                       style="width: 60px; height: 36px; padding: 4px; border-radius:6px;" />
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <!-- Motivo -->
                        <div>
                            <label class="form-label small fw-bold text-foreground">Motivo <span class="text-danger">*</span></label>
                            <select @bind="_selectedMotivo" @bind:after="@(() => _formDirty = true)" class="form-select text-foreground" style="height: 46px; border-radius: 8px;" required>
                                <option value="Vencido">Vencido</option>
                                <option value="Dañado">Dañado</option>
                                <option value="Otro">Otro</option>
                            </select>
                        </div>

                        @if (_selectedMotivo == "Otro")
                        {
                            <div>
                                <label class="form-label small fw-bold text-foreground">Especificar Motivo <span class="text-danger">*</span></label>
                                <input type="text" @bind="_customMotivo" class="form-control text-foreground" 
                                       placeholder="Especifica el motivo personalizado..." 
                                       style="height: 46px; border-radius: 8px;" required />
                            </div>
                        }

                        <!-- Observaciones -->
                        <div>
                            <label class="form-label small fw-bold text-foreground">Observaciones</label>
                            <textarea @bind="_form.Observations" @bind:after="@(() => _formDirty = true)" class="form-control text-foreground" rows="3" 
                                      placeholder="El empaque presentaba fecha vencida de hace 2 días, etc..." 
                                      style="border-radius: 8px; font-size:0.85rem;"></textarea>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-3 pt-3 border-top border-color-default">
                                    <button type="button" @onclick="TryCloseModal" class="btn btn-outline-secondary fw-semibold" style="border-radius:8px; height:44px; min-width:90px;">Cancelar</button>                            
                                    <button type="submit" class="btn btn-success fw-semibold" 
                                    disabled="@(_selectedOrder == null || !_productSelected.Values.Any(v => v) || (_selectedMotivo == "Otro" ? string.IsNullOrWhiteSpace(_customMotivo) : string.IsNullOrEmpty(_selectedMotivo)))"
                                    style="border-radius:8px; height:44px; min-width:140px; background:#196c3e; border-color:#196c3e;">
                                @(_isEditing ? "Guardar Cambios" : "Registrar Devolución")
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@* ─── Modal Ver Detalle Devolución ─────────────────────────────────────────────── *@
@if (_showDetailModal && _selectedDetailReturn != null)
{
    <div class="modal show d-block fade-in" tabindex="-1" style="background:rgba(0,0,0,.55); backdrop-filter:blur(3px);" @onclick="@(() => _showDetailModal = false)">
        <div class="modal-dialog modal-dialog-centered" style="max-width:500px;" @onclick:stopPropagation>
            <div class="modal-content bg-card border-border" style="border-radius: 1.25rem; overflow: hidden; box-shadow: 0 15px 35px rgba(0,0,0,0.2);">
                <div class="modal-header border-bottom border-color-default px-4 py-3 d-flex align-items-center justify-content-between">
                    <div>
                        <h5 class="modal-title text-foreground fw-bold" style="font-family:'Outfit',sans-serif;">Detalle de Devolución</h5>
                        <span class="text-success fw-bold text-sm">@_selectedDetailReturn.Id</span>
                    </div>
                    <button type="button" class="btn-close" @onclick="@(() => _showDetailModal = false)"></button>
                </div>
                <div class="modal-body p-4 d-flex flex-column gap-3">
                    <div class="d-flex justify-content-between">
                        <span class="text-muted-foreground small">Fecha:</span>
                        <span class="text-foreground small fw-medium">@_selectedDetailReturn.Date.ToString("dd MMM yyyy - HH:mm")</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted-foreground small">Pedido de origen:</span>
                        <span class="text-success small fw-bold">@(_selectedDetailReturn.IdPedido.HasValue ? $"SHI-2024-{_selectedDetailReturn.IdPedido.Value:D4}" : "N/A")</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted-foreground small">Registrado por:</span>
                        <span class="text-foreground small fw-medium">@_selectedDetailReturn.RegisteredBy</span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <span class="text-muted-foreground small">Motivo:</span>
                        <span class="text-foreground small fw-semibold">@_selectedDetailReturn.Reason</span>
                    </div>
                    <div class="d-flex justify-content-between border-bottom border-color-default pb-2">
                        <span class="text-muted-foreground small">Estado:</span>
                        <span class="badge @GetEstadoBadge(_selectedDetailReturn)">
                            @_selectedDetailReturn.Estado
                        </span>
                    </div>

                    @if (!string.IsNullOrEmpty(_selectedDetailReturn.Observations))
                    {
                        <div>
                            <span class="text-muted-foreground small fw-bold d-block mb-1"><i class="fas fa-sticky-note me-1 text-warning"></i> Observaciones:</span>
                            <span class="text-foreground small" style="white-space:pre-wrap;">@_selectedDetailReturn.Observations</span>
                        </div>
                    }

                    <div>
                        <span class="text-muted-foreground small fw-bold d-block mb-2"><i class="fas fa-undo-alt me-1 text-danger"></i> Productos Devueltos</span>
                        <div class="d-flex flex-column gap-2" style="max-height: 180px; overflow-y: auto;">
                            @if (_selectedDetailReturn.Detalles != null && _selectedDetailReturn.Detalles.Any())
                            {
                                @foreach (var det in _selectedDetailReturn.Detalles)
                                {
                                    <div class="d-flex justify-content-between align-items-center p-2 rounded-2 bg-muted bg-opacity-10 border-color-default" style="border: 1px solid #f0f0f0;">
                                        <div class="small">
                                            <span class="fw-semibold text-foreground d-block">@det.NombreProducto</span>
                                            <span class="text-muted-foreground text-xs">Código: @($"PROD-{det.IdProducto:D3}") · S/. @det.PrecioUnitario.ToString("0.00")</span>
                                        </div>
                                        <span class="badge bg-danger text-white">x@(det.Cantidad) uds.</span>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="d-flex justify-content-between align-items-center p-2 rounded-2 bg-muted bg-opacity-10" style="border: 1px solid #f0f0f0;">
                                    <div class="small">
                                        <span class="fw-semibold text-foreground d-block">@_selectedDetailReturn.Product</span>
                                        <span class="text-muted-foreground text-xs">Código: @_selectedDetailReturn.ProductCode</span>
                                    </div>
                                    <span class="badge bg-danger text-white">x@(_selectedDetailReturn.Quantity) uds.</span>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="d-flex justify-content-between border-top border-color-default pt-3 mt-1">
                        <span class="text-foreground fw-bold">Importe Ajuste Pérdida:</span>
                        <span class="text-danger fw-bold fs-5">-S/. @_selectedDetailReturn.Amount.ToString("0.00")</span>
                    </div>
                </div>
                <div class="modal-footer bg-muted bg-opacity-10 border-color-default p-3 justify-content-end">
                    <button type="button" class="btn btn-outline-secondary fw-semibold" @onclick="@(() => _showDetailModal = false)" style="border-radius:8px;">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

