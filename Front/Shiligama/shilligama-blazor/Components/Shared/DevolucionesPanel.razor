@* DevolucionesPanel.razor — componente compartido para Admin y Trabajador *@
@using shilligama_blazor.Models
@using shilligama_blazor.Services
@inject ReturnsService ReturnsSvc
@inject ProductService ProductSvc
@inject AuthService Auth
@inject SalesService SalesSvc
@inject IJSRuntime JS
@inject NavigationManager Nav


@* ─── KPIs ──────────────────────────────────────────────────────────────────── *@
@if (MostrarKpis)
{
    @if (Rol == "trabajador")
    {
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="worker-kpi-card kpi-green-custom">
                    <div>
                        <div class="metric-kpi-value text-foreground" style="font-size:1.6rem;font-weight:700;">@MesActualCount</div>
                        <div class="metric-kpi-label" style="font-size:0.8rem;color:var(--muted-foreground);">Devoluciones este mes</div>
                    </div>
                    <div class="metric-kpi-icon-custom" style="background:#e8f5e9;color:#198754;">
                        <i class="fas fa-sync-alt"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="worker-kpi-card kpi-red-custom">
                    <div>
                        <div class="metric-kpi-value text-foreground" style="font-size:1.6rem;font-weight:700;">S/. @MesActualTotal.ToString("0.00")</div>
                        <div class="metric-kpi-label" style="font-size:0.8rem;color:var(--muted-foreground);">Total Mermas (pérdida)</div>
                    </div>
                    <div class="metric-kpi-icon-custom" style="background:#ffebee;color:#dc3545;">
                        <i class="fas fa-arrow-down"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="worker-kpi-card kpi-yellow-custom">
                    <div>
                        <div class="metric-kpi-value text-foreground" style="font-size:1.1rem;font-weight:700;">@GetTopReturnedOrderText()</div>
                        <div class="metric-kpi-label" style="font-size:0.8rem;color:var(--muted-foreground);">Pedido con más devoluciones</div>
                    </div>
                    <div class="metric-kpi-icon-custom" style="background:#fff8e1;color:#ffc107;">
                        <i class="fas fa-box"></i>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="card p-3 d-flex flex-column gap-1">
                    <span class="small text-muted-foreground fw-medium">Devoluciones este mes</span>
                    <span class="fs-3 fw-bold text-primary">@MesActualCount</span>
                    <span class="text-xs text-muted-foreground mt-1">@DateTime.Now.ToString("MMMM yyyy")</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-3 d-flex flex-column gap-1">
                    <span class="small text-muted-foreground fw-medium">Valor Devuelto (mes)</span>
                    <span class="fs-3 fw-bold text-danger">S/. @MesActualTotal.ToString("0.00")</span>
                    <span class="text-xs text-muted-foreground mt-1">Pérdida del mes</span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card p-3 d-flex flex-column gap-1">
                    <span class="small text-muted-foreground fw-medium">Ticket Promedio</span>
                    <span class="fs-3 fw-bold text-foreground">S/. @MesAvgTicket.ToString("0.00")</span>
                    <span class="text-xs text-muted-foreground mt-1">Monto promedio por devolución</span>
                </div>
            </div>
        </div>
    }
}

@* ─── Filtros ────────────────────────────────────────────────────────────────── *@
<div class="card p-4" style="border-radius:12px;">
    <div class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label small fw-medium text-foreground mb-1">Buscar</label>
            <div class="position-relative">
                <i class="fa-solid fa-magnifying-glass position-absolute top-50 translate-middle-y text-muted"
                   style="left:16px;font-size:14px;"></i>
                <input type="search" @bind="_search" @bind:event="oninput"
                       class="form-control text-foreground"
                       placeholder="Buscar por ID, producto o responsable..."
                       style="height:44px;border-radius:10px;padding-left:42px;" />
            </div>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-medium text-foreground mb-1">Motivo</label>
            <select @bind="_motivoFilter" class="form-select text-foreground" style="height:44px;border-radius:10px;">
                <option value="">Todos</option>
                <option value="VENCIDO">Vencido</option>
                <option value="DAÑADO">Dañado</option>
                <option value="ERROR_PEDIDO">Error de pedido</option>
                <option value="OTRO">Otro</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-medium text-foreground mb-1">Desde</label>
            <input type="date" @bind="_fechaDesde" @bind:after="OnFilterChange"
                   class="form-control text-foreground" style="height:44px;border-radius:10px;" />
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-medium text-foreground mb-1">Hasta</label>
            <input type="date" @bind="_fechaHasta" @bind:after="OnFilterChange"
                   class="form-control text-foreground" style="height:44px;border-radius:10px;" />
        </div>
    </div>
</div>


@* ─── Tabla ──────────────────────────────────────────────────────────────────── *@

<!-- Tabla -->
    <div class="card overflow-hidden">

        @if (_loading)
        {
            <LoadingIndicator Text="@LoadingText" MinHeight="350px" />
        }
        else
        {
            @if (TipoVista == "todas")
            {
                @* ─── Vista agrupada por venta (historial) ─── *@
                <div class="p-3">
                    @{ var grupos = GroupedByVenta.ToList(); }
                    @if (!grupos.Any())
                    {
                        <div class="text-center py-5 text-muted-foreground">
                            @EmptyMessage
                        </div>
                    }
                    else
                    {
                        @foreach (var grupo in grupos)
                        {
                            var primeraDev = grupo.First();
                            var totalGrupo = grupo.Sum(r => r.Amount);
                            var estadoGrupo = grupo.All(r => r.Estado == primeraDev.Estado) ? primeraDev.Estado : "mixto";
                            var isOnline = IsOnlineReturn(primeraDev);

                            <div class="card mb-3" style="border-radius:14px; border:1px solid #e5e7eb; overflow:hidden;" id="row-dev-@primeraDev.Id">
                                @* ── Header ── *@
                                <div class="d-flex align-items-center justify-content-between px-4 py-3" style="background:var(--muted); border-bottom:1px solid #e5e7eb;">
                                    <div class="d-flex align-items-center gap-3">
                                        <span class="fw-bold text-success" style="font-size:0.95rem;">@GetOrigenText(primeraDev)</span>
                                        <span class="text-muted-foreground small">@GetCustomerNameForReturn(primeraDev)</span>
                                        @if (MostrarCanal)
                                        {
                                            <span class="badge @(isOnline ? "bg-primary" : "bg-success") text-white"
                                                  style="font-size:0.7rem;padding:3px 9px;font-weight:600;border-radius:8px;">
                                                @(isOnline ? "Online" : "Presencial")
                                            </span>
                                        }
                                    </div>
                                    <span class="text-muted-foreground small">@primeraDev.Date.ToString("dd MMM yyyy")</span>
                                </div>

                                @* ── Body: Productos ── *@
                                <div class="px-4 py-3">
                                    @foreach (var dev in grupo)
                                    {
                                        <div class="d-flex align-items-center justify-content-between py-2 @(dev != grupo.Last() ? "border-bottom" : "")" style="border-color:#f0f0f0 !important;">
                                            <div class="d-flex align-items-center gap-3 flex-grow-1">
                                                <i class="fas fa-circle text-muted-foreground" style="font-size:5px;"></i>
                                                <div>
                                                    <span class="fw-semibold text-foreground small d-block">@dev.Product</span>
                                                    <span class="text-muted-foreground" style="font-size:0.75rem;">
                                                        @dev.Quantity uds. · @GetReasonText(dev.Reason, dev.MotivoDetalle)
                                                    </span>
                                                </div>
                                            </div>
                                            <div class="d-flex align-items-center gap-2">
                                                @if (string.IsNullOrEmpty(dev.Observations))
                                                {
                                                    <span class="text-muted-foreground small" style="font-size:0.75rem;">@dev.RegisteredBy</span>
                                                }
                                                <span class="fw-bold text-danger small">-S/. @dev.Amount.ToString("0.00")</span>
                                                <div class="d-flex gap-1">
                                                    <button class="btn btn-sm" @onclick="@(() => VerDetalle(dev))" title="Ver detalle"
                                                            style="width:28px;height:28px;border-radius:6px;">
                                                        <i class="fas fa-eye text-success" style="font-size:0.75rem;"></i>
                                                    </button>
                                                    @if (MostrarEditar)
                                                    {
                                                        <button class="btn btn-sm" @onclick="async () => await OpenEdit(dev)" title="Editar"
                                                                style="width:28px;height:28px;border-radius:6px;">
                                                            <i class="fas fa-edit text-warning" style="font-size:0.75rem;"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(dev.Observations))
                                        {
                                            <div class="ms-4 mb-2 small text-muted-foreground" style="font-size:0.78rem; font-style:italic;">
                                                <i class="fas fa-sticky-note me-1 text-warning"></i>@dev.Observations
                                            </div>
                                        }
                                    }
                                </div>

                                @* ── Footer ── *@
                                <div class="d-flex align-items-center justify-content-between px-4 py-2.5" style="background:var(--muted); border-top:1px solid #e5e7eb;">
                                    <span class="text-muted-foreground small">
                                        @grupo.Count() devolucione@(grupo.Count() > 1 ? "s" : "") · @primeraDev.RegisteredBy
                                    </span>
                                    <span class="fw-bold text-danger" style="font-size:0.95rem;">-S/. @totalGrupo.ToString("0.00")</span>
                                </div>
                            </div>
                        }
                    }
                </div>
            }
            else
            {
                @* ─── Vista tabla (online / presencial) ─── *@
                <div class="table-responsive">
                    <div class="card overflow-hidden">
                        <div class="table-responsive">
                            <table class="table table-borderless mb-0 align-middle return-table">
                                <thead class="border-bottom border-color-default">
                                    <tr>
                                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Fecha</th>
                                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Origen</th>
                                        @if (MostrarCanal)
                                        {
                                            <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Canal</th>
                                        }
                                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Motivo</th>
                                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Registrado Por</th>
                                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Estado</th>
                                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Monto Total</th>
                                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-end" style="letter-spacing:.05em;">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{var devList = Filtered.ToList();}
                                    @for (int i = 0; i < devList.Count; i++)
                                    {
                                        var dev = devList[i];

                                        @if (i > 0)
                                        {
                                            <tr style="height:16px;">
                                                <td colspan="@TableColumnCount" style="padding:0; border:none; background:transparent;"></td>
                                            </tr>
                                        }

                                        <tr class="return-group-start return-row" id="row-dev-@dev.Id">
                                            <td class="px-4 py-3 text-muted-foreground small">@dev.Date.ToString("dd MMM yyyy")</td>
                                            <td class="px-4 py-3 small">
                                                <span class="fw-bold text-success d-block">@GetOrigenText(dev)</span>
                                                <span class="text-xs text-muted-foreground">@GetCustomerNameForReturn(dev)</span>
                                            </td>

                                            @if (MostrarCanal)
                                            {
                                                <td class="px-4 py-3 small">
                                                    <span class="badge @(IsOnlineReturn(dev) ? "bg-primary" : "bg-success") text-white"
                                                          style="font-size:0.75rem;padding:4px 11px;font-weight:600;border-radius:8px;">
                                                        @(IsOnlineReturn(dev) ? "Online" : "Presencial")
                                                    </span>
                                                </td>
                                            }
                                            <td class="px-4 py-3 small">
                                                @switch (dev.Reason)
                                                {
                                                    case "VENCIDO":
                                                        <span class="badge text-white" style="background:#dc3545;font-size:0.75rem;padding:4px 11px;font-weight:600;border-radius:8px;"><i class="fas fa-hourglass-end me-1"></i>Vencido</span>
                                                        break;
                                                    case "DAÑADO":
                                                        <span class="badge text-white" style="background:#fd7e14;font-size:0.75rem;padding:4px 11px;font-weight:600;border-radius:8px;"><i class="fas fa-exclamation-triangle me-1"></i>Dañado</span>
                                                        break;
                                                    case "ERROR_PEDIDO":
                                                        <span class="badge text-white" style="background:#0d6efd;font-size:0.75rem;padding:4px 11px;font-weight:600;border-radius:8px;"><i class="fas fa-shopping-cart me-1"></i>Error de pedido</span>
                                                        break;
                                                    case "OTRO":
                                                        <span class="badge text-white" style="background:#6c757d;font-size:0.75rem;padding:4px 11px;font-weight:600;border-radius:8px;"><i class="fas fa-tag me-1"></i>Otro</span>
                                                        break;
                                                    default:
                                                        <span class="badge text-white" style="background:#6c757d;font-size:0.75rem;padding:4px 11px;font-weight:600;border-radius:8px;"><i class="fas fa-tag me-1"></i>Motivo personalizado</span>
                                                        break;
                                                }
                                            </td>
                                            <td class="px-4 py-3 text-muted-foreground small">@dev.RegisteredBy</td>
                                            <td class="px-4 py-3 small">
                                                @{
                                                    var estado = dev.Estado?.ToLower() ?? "pendiente";
                                                }

                                                @if (estado == "pendiente")
                                                {
                                                    <span class="badge badge-pendiente">Pendiente</span>
                                                }
                                                else if (estado == "aprobado")
                                                {
                                                    <span class="badge badge-entregado">Aprobado</span>
                                                }
                                                else if (estado == "rechazado")
                                                {
                                                    <span class="badge badge-cancelado">Rechazado</span>
                                                }
                                            </td>
                                            <td class="px-4 py-3 fw-bold text-danger small">-S/. @dev.Amount.ToString("0.00")</td>
                                            <td class="px-4 py-3 text-end">
                                                <div class="d-flex gap-1 justify-content-end">
                                                    <button class="btn btn-sm" @onclick="@(() => VerDetalle(dev))" title="Ver detalle"
                                                            style="width:32px;height:32px;border-radius:8px;">
                                                        <i class="fas fa-eye text-success" style="font-size:0.82rem;"></i>
                                                    </button>
                                                    @if (MostrarEditar)
                                                    {
                                                        <button class="btn btn-sm" @onclick="async () => await OpenEdit(dev)" title="Editar"
                                                                style="width:32px;height:32px;border-radius:8px;">
                                                            <i class="fas fa-edit text-warning" style="font-size:0.82rem;"></i>
                                                        </button>
                                                    }
                                                    @if (PermitirEvaluar
                                                        && IsOnlineReturn(dev)
                                                        && (dev.Estado?.ToLower() ?? "pendiente") == "pendiente")
                                                    {
                                                        <button class="btn btn-sm" title="Evaluar devolución"
                                                                @onclick="@(() => AbrirEvaluacion(dev))"
                                                                style="width:32px;height:32px;border-radius:8px;">
                                                            <i class="fas fa-exchange-alt text-primary" style="font-size:0.82rem;"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                        @if (!string.IsNullOrEmpty(dev.Observations))
                                        {
                                            <tr class="return-observation bg-muted bg-opacity-30">
                                                <td colspan="@TableColumnCount" class="px-5 py-2.5 small text-muted-foreground italic" style="font-size:0.8rem;">
                                                    <strong>Observación:</strong> @dev.Observations
                                                </td>
                                            </tr>
                                        }
                                    }
                                    @if (!Filtered.Any())
                                    {
                                        <tr>
                                            <td colspan="@TableColumnCount" class="text-center py-5 text-muted-foreground">
                                                @EmptyMessage
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        }

    </div>

@* ─── Modal Registrar / Editar Devolución ─────────────────────────────────────────────── *@
@if (_showModal)
{
<div class="modal show d-block fade-in" tabindex="-1" style="background:rgba(0,0,0,.55); backdrop-filter:blur(3px);" @onclick="TryCloseModal">        
    <div class="modal-dialog modal-dialog-centered" style="max-width:540px;" @onclick:stopPropagation>
            <div class="modal-content bg-card border-border" style="border-radius: 1.25rem; overflow: hidden; box-shadow: 0 15px 35px rgba(0,0,0,0.2);">
                <div class="modal-header border-border bg-muted bg-opacity-10 px-4 py-3 d-flex align-items-center justify-content-between">
                    <div>
                        <h5 class="modal-title text-foreground fw-bold">@(_isEditing ? "Modificar Devolución" : "Registrar Devolución")</h5>
                        <p class="text-muted-foreground text-xs m-0">Selecciona la venta presencial y los productos a devolver</p>
                    </div>
                    <button type="button" class="btn-close" @onclick="@(() => _showModal = false)"></button>
                </div>
                <div class="modal-body p-4" style="max-height: 75vh; overflow-y: auto;">
                    <EditForm Model="_form" OnValidSubmit="Save" class="d-flex flex-column gap-3">
                        
                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <div class="alert alert-danger py-2 small mb-0" role="alert">
                                <i class="fas fa-exclamation-triangle me-1"></i> @_errorMessage
                            </div>
                        }

                        <!-- Buscar Venta Presencial -->
                        <div>
                            <label class="form-label small fw-bold text-foreground">
                                Venta presencial <span class="text-danger">*</span>
                            </label>

                            <div class="position-relative w-100">
                                <i class="fas fa-search position-absolute text-muted-foreground top-50 translate-middle-y"
                                   style="left:14px;pointer-events:none;"></i>

                                <input type="text"
                                       class="form-control text-foreground"
                                       placeholder="Buscar por # venta o cliente..."
                                       @bind="_saleSearchTerm"
                                       @oninput="OnSearchSaleInput"
                                       disabled="@_isEditing"
                                       style="height: 46px; padding-left: 40px; border-radius: 8px; @(_isEditing ? "background-color: #f5f5f5;" : "")"
                                       required />
                            </div>

                            @if (_saleMatches.Any())
                            {
                                <div class="list-group shadow-lg border rounded-3 mt-1 bg-card"
                                     style="z-index: 1100; max-height: 180px; overflow-y: auto;">
                                    @foreach (var sale in _saleMatches)
                                    {
                                        <button type="button"
                                                class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2 px-3 border-color-default"
                                                @onclick="@(() => SelectSaleAsync(sale))">
                                            <div>
                                                <span class="fw-bold text-success">@sale.Id</span>
                                                <span class="text-muted-foreground ms-2 small">@sale.Cliente</span>
                                            </div>
                                            <span class="badge bg-light text-muted-foreground border small">
                                                @sale.Fecha.ToString("dd/MM/yy") · S/. @sale.Total.ToString("0.00")
                                            </span>
                                        </button>
                                    }
                                </div>
                            }
                        </div>

                        @if (_selectedSale != null)
                        {
                            <div class="mt-2">
                                <label class="form-label small fw-bold text-foreground">
                                    <i class="fas fa-shopping-basket me-1 text-success"></i>
                                    Productos de la venta (@_selectedSale.Id)
                                </label>

                                <div class="d-flex flex-column gap-2" style="max-height: 220px; overflow-y: auto; padding-right: 4px;">
                                    @foreach (var item in _selectedSale.Productos)
                                    {
                                        <div class="d-flex align-items-center justify-content-between border rounded-3 p-3 bg-muted bg-opacity-10 border-color-default"
                                             style="border-radius: 8px; cursor: pointer;"
                                             @onclick="@(() => OnProductCheckedChange(item.Id, !GetProductChecked(item.Id)))">

                                            <div class="d-flex align-items-center gap-2">
                                                <input type="checkbox"
                                                       class="form-check-input"
                                                       checked="@GetProductChecked(item.Id)"
                                                       @onchange="@((e) => OnProductCheckedChange(item.Id, (bool)(e.Value ?? false)))"
                                                       style="width: 18px; height: 18px; border-radius: 4px;" />

                                                <div>
                                                    <span class="fw-semibold text-foreground small d-block">@item.Name</span>
                                                    <span class="text-muted-foreground text-xs">
                                                        Comprado: @item.Quantity uds. · S/. @item.Price.ToString("0.00")
                                                    </span>
                                                </div>
                                            </div>

                                            <div class="d-flex align-items-center gap-1">
                                                <span class="text-muted-foreground text-xs me-1">Cant.:</span>

                                                <input type="number"
                                                       class="form-control text-center text-foreground font-semibold"
                                                       value="@GetProductReturnQty(item.Id)"
                                                       @onchange="@((e) => OnProductReturnQtyChange(item.Id, int.Parse(e.Value?.ToString() ?? "1")))"
                                                       @onclick:stopPropagation
                                                       min="1"
                                                       max="@item.Quantity"
                                                       disabled="@(!GetProductChecked(item.Id))"
                                                       style="width: 60px; height: 36px; padding: 4px; border-radius:6px;" />
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <!-- Motivo -->
                        <div>
                            <label class="form-label small fw-bold text-foreground">Motivo <span class="text-danger">*</span></label>
                            <select @bind="_selectedMotivo" @bind:after="@(() => _formDirty = true)" class="form-select text-foreground" style="height: 46px; border-radius: 8px;" required>
                                <option value="VENCIDO">Vencido</option>
                                <option value="DAÑADO">Dañado</option>
                                <option value="ERROR_PEDIDO">Error de pedido</option>
                                <option value="OTRO">Otro</option>
                            </select>
                        </div>

                        @if (_selectedMotivo == "OTRO")
                        {
                            <div>
                                <label class="form-label small fw-bold text-foreground">Especificar Motivo <span class="text-danger">*</span></label>
                                <input type="text" @bind="_customMotivo" class="form-control text-foreground" 
                                       placeholder="Especifica el motivo personalizado..." 
                                       style="height: 46px; border-radius: 8px;" required />
                            </div>
                        }

                        <!-- Observaciones -->
                        <div>
