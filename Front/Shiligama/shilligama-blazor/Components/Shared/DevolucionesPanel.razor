@* DevolucionesPanel.razor — componente compartido para Admin y Trabajador *@
@using shilligama_blazor.Models
@using shilligama_blazor.Services
@inject ReturnsService ReturnsSvc
@inject ProductService ProductSvc
@inject AuthService Auth

@* ─── KPIs ──────────────────────────────────────────────────────────────────── *@
@if (Rol == "trabajador")
{
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="metric-card-kpi">
                <div>
                    <div class="metric-kpi-value text-foreground">@_returns.Count</div>
                    <div class="metric-kpi-label">Devoluciones este mes</div>
                </div>
                <div class="metric-kpi-icon" style="background:color-mix(in srgb,var(--primary) 15%,transparent);color:var(--primary);">
                    <i class="fas fa-sync-alt"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-card-kpi">
                <div>
                    <div class="metric-kpi-value" style="color:#c62828;font-size:1.4rem;">S/. @_returns.Sum(r => r.Amount).ToString("0.00")</div>
                    <div class="metric-kpi-label">Pérdida acumulada</div>
                </div>
                <div class="metric-kpi-icon" style="background:color-mix(in srgb,#c62828 15%,transparent);color:#c62828;">
                    <i class="fas fa-arrow-down"></i>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="metric-card-kpi">
                <div>
                    <div class="metric-kpi-value text-foreground" style="font-size:1.1rem;">@(_returns.OrderByDescending(r => r.Quantity).FirstOrDefault()?.Product ?? "N/A")</div>
                    <div class="metric-kpi-label">Producto más devuelto</div>
                </div>
                <div class="metric-kpi-icon" style="background:color-mix(in srgb,#f59e0b 15%,transparent);color:#f59e0b;">
                    <i class="fas fa-box"></i>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card p-4">
                <span class="small text-muted-foreground fw-medium">Valor Total Devuelto</span>
                <span class="fs-3 fw-bold text-danger mt-1">S/. @TotalRefunded.ToString("0.00")</span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card p-4">
                <span class="small text-muted-foreground fw-medium">Total de Registros</span>
                <span class="fs-3 fw-bold text-foreground mt-1">@Filtered.Count() devoluciones</span>
            </div>
        </div>
    </div>
}

@* ─── Filtros ────────────────────────────────────────────────────────────────── *@
<div class="row g-2 mb-4">
    <div class="@(Rol == "trabajador" ? "col-md-8" : "col-12")">
        <div class="card p-4" style="border-radius:12px;">
            <div class="position-relative">
                <i class="fa-solid fa-magnifying-glass position-absolute top-50 translate-middle-y text-muted" style="left:16px;font-size:14px;"></i>
                <input type="search" @bind="_search" @bind:event="oninput" class="form-control text-foreground"
                       placeholder="Buscar por código, producto o responsable..."
                       style="height:56px;border-radius:10px;padding-left:42px;" />
            </div>
        </div>
    </div>
    @if (Rol == "trabajador")
    {
        <div class="col-md-4">
            <div class="card p-4" style="border-radius:12px;">
                <select @bind="_motivoFilter" class="form-select text-foreground" style="height:40px;">
                    <option value="">Todos los motivos</option>
                    <option value="Vencido">Vencido</option>
                    <option value="Dañado">Dañado / Roto</option>
                    <option value="Error de pedido">Error de pedido</option>
                </select>
            </div>
        </div>
    }
</div>

@* ─── Tabla ──────────────────────────────────────────────────────────────────── *@
<div class="card overflow-hidden">
    <div class="table-responsive">
        <table class="table table-borderless mb-0 align-middle">
            <thead class="border-bottom border-color-default">
                <tr>
                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Código</th>
                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Fecha</th>
                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Producto</th>
                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Cantidad</th>
                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Motivo</th>
                    @if (Rol == "admin")
                    {
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase d-none d-md-table-cell" style="letter-spacing:.05em;">Responsable</th>
                    }
                    <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;">Importe</th>
                    @if (Rol == "admin")
                    {
                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-end" style="letter-spacing:.05em;">Acción</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var dev in Filtered)
                {
                    <tr class="border-bottom border-color-default">
                        <td class="px-4 py-3 fw-bold text-primary small">@dev.Id</td>
                        <td class="px-4 py-3 text-muted-foreground small">@dev.Date.ToString("dd/MM/yyyy")</td>
                        <td class="px-4 py-3 small">
                            <span class="fw-medium text-foreground d-block">@dev.Product</span>
                            <span class="text-xs text-muted-foreground">@dev.ProductCode</span>
                        </td>
                        <td class="px-4 py-3 text-foreground small">@dev.Quantity ud.</td>
                        <td class="px-4 py-3 small">
                            <span class="badge bg-warning-subtle text-warning" style="border-radius:var(--radius);">@dev.Reason</span>
                        </td>
                        @if (Rol == "admin")
                        {
                            <td class="px-4 py-3 text-muted-foreground small d-none d-md-table-cell">@dev.RegisteredBy</td>
                        }
                        <td class="px-4 py-3 fw-semibold text-danger small">S/. @dev.Amount.ToString("0.00")</td>
                        @if (Rol == "admin")
                        {
                            <td class="px-4 py-3 text-end">
                                <button @onclick="@(() => Delete(dev.Id))" class="btn btn-ghost btn-sm text-danger" style="border-radius:var(--radius);" title="Eliminar">
                                    <Icons Name="Trash2" Class="w-4 h-4" />
                                </button>
                            </td>
                        }
                    </tr>
                    @if (!string.IsNullOrEmpty(dev.Observations))
                    {
                        <tr class="border-bottom border-color-default bg-muted bg-opacity-30">
                            <td colspan="@(Rol == "admin" ? 8 : 6)" class="px-5 py-2.5 small text-muted-foreground italic" style="font-size:0.8rem;">
                                <strong>Observación:</strong> @dev.Observations
                            </td>
                        </tr>
                    }
                }
                @if (!Filtered.Any())
                {
                    <tr>
                        <td colspan="@(Rol == "admin" ? 8 : 6)" class="text-center py-5 text-muted-foreground">
                            No se encontraron registros de devoluciones
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* ─── Modal Registrar Devolución ─────────────────────────────────────────────── *@
@if (_showModal)
{
    <div class="modal show d-block fade-in" tabindex="-1" style="background:rgba(0,0,0,.5);" @onclick="@(() => _showModal = false)">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content bg-card border-border">
                <div class="modal-header border-border">
                    <h5 class="modal-title text-foreground fw-bold">Registrar Devolución</h5>
                    <button type="button" class="btn-close" @onclick="@(() => _showModal = false)"></button>
                </div>
                <div class="modal-body p-4">
                    <EditForm Model="_form" OnValidSubmit="Save" class="d-flex flex-column gap-3">
                        <div>
                            <label class="form-label small fw-medium text-foreground">Producto</label>
                            <select @bind="_selectedProductId" class="form-select text-foreground" required>
                                <option value="0">— Seleccionar producto —</option>
                                @foreach (var p in ProductSvc.GetProducts().OrderBy(p => p.Name))
                                {
                                    <option value="@p.Id">@p.Name</option>
                                }
                            </select>
                        </div>
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label small fw-medium text-foreground">Cantidad</label>
                                <input type="number" @bind="_form.Quantity" required class="form-control text-foreground" min="1" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-medium text-foreground">Motivo</label>
                                <select @bind="_form.Reason" class="form-select text-foreground" required>
                                    <option value="">— Seleccionar —</option>
                                    <option value="Vencido">Vencido</option>
                                    <option value="Dañado">Dañado / Roto</option>
                                    <option value="Error de pedido">Error de pedido</option>
                                    <option value="Merma">Merma / Pérdida</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="form-label small fw-medium text-foreground">Observación</label>
                            <textarea @bind="_form.Observations" class="form-control text-foreground" rows="2" placeholder="Detalle adicional..."></textarea>
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-2">
                            <button type="button" @onclick="@(() => _showModal = false)" class="btn btn-secondary" style="border-radius:var(--radius);">Cancelar</button>
                            <button type="submit" class="btn btn-primary fw-semibold" style="border-radius:var(--radius);"
                                    disabled="@(_selectedProductId == 0 || string.IsNullOrEmpty(_form.Reason))">
                                Registrar
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Rol { get; set; } = "admin"; // "admin" | "trabajador"

    private List<Return> _returns = new();
    private string _search = "";
    private string _motivoFilter = "";
    private bool _showModal = false;
    private Return _form = new();
    private int _selectedProductId = 0;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            ProductSvc.EnsureLoadedAsync(),
            ReturnsSvc.EnsureLoadedAsync()
        );
        _returns = ReturnsSvc.GetReturns();
    }

    private IEnumerable<Return> Filtered => _returns.Where(r =>
        (string.IsNullOrEmpty(_search) ||
         r.Product.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
         r.Id.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
         r.RegisteredBy.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_motivoFilter) || r.Reason.Equals(_motivoFilter, StringComparison.OrdinalIgnoreCase))
    );

    private decimal TotalRefunded => Filtered.Sum(r => r.Amount);

    public void OpenCreate()
    {
        _form = new Return
        {
            Quantity     = 1,
            RegisteredBy = Auth.CurrentUser?.Name ?? (Rol == "admin" ? "Admin" : "Trabajador")
        };
        _selectedProductId = 0;
        _showModal = true;
    }

    private async Task Save()
    {
        var prod = _selectedProductId > 0
            ? ProductSvc.GetProductById(_selectedProductId)
            : null;

        if (prod != null)
        {
            _form.Product     = prod.Name;
            _form.ProductCode = $"PROD-{prod.Id:D3}";
            _form.Amount      = prod.Price * _form.Quantity;
        }
        else
        {
            _form.ProductCode = "PROD-GEN";
            _form.Amount      = _form.Amount == 0 ? 10.00m * _form.Quantity : _form.Amount;
        }

        int idUsuario = Auth.CurrentUser?.IdUsuario ?? 0;
        await ReturnsSvc.AddReturnAsync(_form, _selectedProductId, idUsuario);
        _showModal = false;
        _returns = ReturnsSvc.GetReturns();
    }

    private void Delete(string id)
    {
        ReturnsSvc.DeleteReturn(id);
        _returns = ReturnsSvc.GetReturns();
    }
}
