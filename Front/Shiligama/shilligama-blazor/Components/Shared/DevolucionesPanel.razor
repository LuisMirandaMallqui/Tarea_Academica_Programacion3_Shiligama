                                "VENCIDO" => "Vencido",
                                "DAÑADO" => "Dañado",
                                "ERROR_PEDIDO" => "Error de pedido",
                                "OTRO" => string.IsNullOrEmpty(_devAEvaluar.MotivoDetalle) ? "Otro" : $"Otro: {_devAEvaluar.MotivoDetalle}",
                                _ => _devAEvaluar.Reason
                            })</span>
                            <span><strong>Monto:</strong> -S/. @_devAEvaluar.Amount.ToString("0.00")</span>
                            @if (!string.IsNullOrEmpty(_devAEvaluar.Observations))
                            {
                                <span><strong>Observación:</strong> @_devAEvaluar.Observations</span>
                            }
                        </div>
                        <div class="d-flex flex-row gap-2 mt-2 justify-content-center">
                            <button class="btn btn-danger fw-semibold flex-fill" style="border-radius:var(--radius);"
                                    @onclick="@(async () => await CambiarEstado(_devAEvaluar, "RECHAZADO"))">
                                <i class="fas fa-times me-2"></i>Rechazar
                            </button>
                            <button class="btn btn-success fw-semibold flex-fill" style="border-radius:var(--radius);background:#196c3e;border-color:#196c3e;"
                                    @onclick="@(async () => await CambiarEstado(_devAEvaluar, "APROBADO"))">
                                <i class="fas fa-check me-2"></i>Aceptar
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}


@code {
    [Parameter] public string Rol { get; set; } = "admin"; // "admin" | "trabajador"
    [Parameter] public bool MostrarAccionesGestion { get; set; } = true;
    [Parameter] public string TipoVista { get; set; } = "todas"; 
    // "todas" | "presencial" | "online"

    private bool _guardandoDevolucion = false;

    [Parameter] public bool MostrarCanal { get; set; } = false;

    [Parameter] public bool MostrarEditar { get; set; } = true;

    [Parameter] public string EmptyMessage { get; set; } = "No se encontraron registros de devoluciones";

    [Parameter] public string LoadingText { get; set; } = "Cargando devoluciones...";

    [Parameter] public bool MostrarKpis { get; set; } = true;
    [Parameter] public bool PermitirEvaluar { get; set; } = true;
    [Parameter] public string FiltrarEstados { get; set; } = ""; // "" = todos, "PENDIENTE", "APROBADO,RECHAZADO"

    private bool _loading = true;

    private int TableColumnCount => MostrarCanal ? 8 : 7;   

    private List<Return> _returns = new();
    private string _search = "";
    private string _motivoFilter = "";
    private DateTime? _fechaDesde;
    private DateTime? _fechaHasta;
    private bool _showModal = false;
    private Return _form = new();
    private bool _isEditing = false;
    private string _errorMessage = "";

    
    // Search de Ventas presenciales
    private string _saleSearchTerm = "";
    private List<Sale> _saleMatches = new();
    private Sale? _selectedSale = null;

    private Dictionary<int, bool> _productSelected = new();
    private Dictionary<int, int> _productReturnQty = new();

    // Detalle de Devolución
    private bool _showDetailModal = false;
    private Return? _selectedDetailReturn = null;

    // Motivo select values
    private string _selectedMotivo = "VENCIDO";
    private string _customMotivo = "";

    private bool _showUnsavedConfirm = false;
    
    private bool _formDirty = false;

    private bool _showEvaluarModal = false;
    private Return? _devAEvaluar = null;

    private bool _guardandoEstado = false;


    private void AbrirEvaluacion(Return dev)
    {
        _devAEvaluar = dev;
        _showEvaluarModal = true;
    }

    private async Task CambiarEstado(Return dev, string nuevoEstado)
    {
        _guardandoEstado = true;
        _errorMessage = "";
        StateHasChanged();

        try
        {
            int idUsuario = Auth.CurrentUser?.IdUsuario ?? 0;
            Console.WriteLine($"idDevolucion={dev.Id}, idUsuario={idUsuario}");

            bool ok = await ReturnsSvc.CambiarEstadoAsync(dev, nuevoEstado, idUsuario);

            if (!ok)
            {
                _errorMessage = "No se pudo actualizar el estado. Intente nuevamente.";
                return;
            }

            await ReturnsSvc.EnsureLoadedAsync(recargar: true);
            _returns = ReturnsSvc.GetReturns();
            _showEvaluarModal = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error CambiarEstado: {ex.Message}");
            _errorMessage = "Error inesperado al cambiar el estado.";
        }
        finally
        {
            _guardandoEstado = false;
            StateHasChanged();
        }
    }

    private string? _resaltarId;

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        _resaltarId = System.Web.HttpUtility.ParseQueryString(uri.Query)["resaltar"];
    }

    protected override async Task OnInitializedAsync()
    {
        _loading = true;

        try
        {
            await ProductSvc.EnsureLoadedAsync();
            await ReturnsSvc.EnsureLoadedAsync(recargar: true);
            await SalesSvc.EnsureLoadedAsync(cargarDetalles: true);

            _returns = ReturnsSvc.GetReturns();

            Console.WriteLine($"Devoluciones cargadas: {_returns.Count}");

            foreach (var r in _returns)
            {
                Console.WriteLine($"DEV={r.Id}, Pedido={r.IdPedido}, Venta={r.IdVenta}, Estado={r.Estado}, Motivo={r.Reason}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando devoluciones: {ex.Message}");
            _errorMessage = "Error cargando devoluciones. Revisa el backend.";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !string.IsNullOrEmpty(_resaltarId))
            await JS.InvokeVoidAsync("scrollToElement", $"row-dev-{_resaltarId}");
    }

    private static bool IsOnlineReturn(Return r) =>
    r.IdPedido.HasValue && r.IdPedido.Value > 0;

    private bool MatchesTipoVista(Return r)
    {
        return TipoVista.ToLowerInvariant() switch
        {
            "online" => IsOnlineReturn(r),
            "presencial" => !IsOnlineReturn(r),
            _ => true
        };
    }

    private IEnumerable<Return> BaseReturns => _returns.Where(MatchesTipoVista);

    private IEnumerable<Return> Filtered
    {
        get
        {
            var query = BaseReturns.Where(r =>
                (string.IsNullOrEmpty(_search) ||
                 r.Product.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                 r.Id.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                 r.RegisteredBy.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                 (r.IdPedido.HasValue && (
                     r.IdPedido.Value.ToString().Contains(_search) ||
                     $"SHI-2024-{r.IdPedido.Value:D4}".Contains(_search, StringComparison.OrdinalIgnoreCase))) ||
                 (r.IdVenta.HasValue && (
                     r.IdVenta.Value.ToString().Contains(_search) ||
                     $"VTA-{r.IdVenta.Value:D3}".Contains(_search, StringComparison.OrdinalIgnoreCase)))
                ) &&
                (string.IsNullOrEmpty(_motivoFilter) || r.Reason == _motivoFilter) &&
                (!_fechaDesde.HasValue || r.Date >= _fechaDesde.Value) &&
                (!_fechaHasta.HasValue || r.Date <= _fechaHasta.Value.AddDays(1))
            );

            if (!string.IsNullOrEmpty(FiltrarEstados))
            {
                var estados = FiltrarEstados.Split(',').Select(e => e.Trim().ToLower()).ToHashSet();
                query = query.Where(r => estados.Contains(r.Estado?.ToLower() ?? "pendiente"));
            }

            return query
                .OrderBy(r => (r.Estado?.ToLower() ?? "pendiente") == "pendiente" ? 0 : 1)
                .ThenByDescending(r => r.Date);
        }
    }

    private IEnumerable<IGrouping<int, Return>> GroupedByVenta =>
        Filtered.GroupBy(r => r.IdVenta ?? 0)
                .OrderByDescending(g => g.Max(r => r.Date));

    private static string GetReasonText(string reason, string motivoDetalle) => reason switch
    {
        "VENCIDO" => "Vencido",
        "DAÑADO" => "Dañado",
        "ERROR_PEDIDO" => "Error de pedido",
        "OTRO" => string.IsNullOrEmpty(motivoDetalle) ? "Otro" : motivoDetalle,
        _ => reason ?? "Otro"
    };

    private decimal TotalRefunded => Filtered.Sum(r => r.Amount);


    private IEnumerable<Return> KpiFiltered => Filtered;

    private int MesActualCount => KpiFiltered.Count();

    private decimal MesActualTotal => KpiFiltered.Sum(r => r.Amount);

    private decimal MesAvgTicket => MesActualCount > 0 
        ? MesActualTotal / MesActualCount 
        : 0;

    private void OnFilterChange() => StateHasChanged();

    private string GetTopReturnedOrderText()
    {
        if (TipoVista.Equals("presencial", StringComparison.OrdinalIgnoreCase))
        {
            var topSaleGroup = BaseReturns
                .Where(r => r.IdVenta.HasValue && r.IdVenta.Value > 0)
                .GroupBy(r => r.IdVenta!.Value)
                .OrderByDescending(g => g.Count())
                .FirstOrDefault();

            return topSaleGroup != null
                ? $"VTA-{topSaleGroup.Key:D3}"
                : "N/A";
        }

        var topOrderGroup = BaseReturns
            .Where(r => r.IdPedido.HasValue && r.IdPedido.Value > 0)
            .GroupBy(r => r.IdPedido!.Value)
            .OrderByDescending(g => g.Count())
            .FirstOrDefault();

        return topOrderGroup != null
            ? $"SHI-2024-{topOrderGroup.Key:D4}"
            : "N/A";
    }

    
    private string GetOrigenText(Return? r)
    {
        if (r == null)
            return "Sin origen";

        if (r.IdPedido.HasValue && r.IdPedido.Value > 0)
            return $"SHI-2024-{r.IdPedido.Value:D4}";

        if (r.IdVenta.HasValue && r.IdVenta.Value > 0)
            return $"VTA-{r.IdVenta.Value:D3}";

        return "Sin origen";
    }
    

    private string GetCustomerNameForReturn(Return r)
    {
        if (r.IdPedido.HasValue && r.IdPedido.Value > 0)
        {
            var order = SalesSvc.GetRecentOrders()
                .FirstOrDefault(o => o.Id == $"PED-{r.IdPedido.Value:D4}");

            if (order != null)
                return order.Customer;
        }

        if (r.IdVenta.HasValue && r.IdVenta.Value > 0)
        {
            var sale = SalesSvc.GetSales()
                .FirstOrDefault(s => s.Id == $"VTA-{r.IdVenta.Value:D3}");

            if (sale != null)
                return sale.Cliente;
        }

        return "Público General";
    }

    private void VerDetalle(Return dev)
    {
        _selectedDetailReturn = dev;
        _showDetailModal = true;
    }

    public void OpenCreate()
    {
        _isEditing = false;
        _errorMessage = "";

        _form = new Return
        {
            Quantity = 1,
            IdPedido = null,
            IdVenta = null,
            RegisteredBy = Auth.CurrentUser?.Name ?? (Rol == "admin" ? "Admin" : "Trabajador")
        };

        _saleSearchTerm = "";
        _saleMatches.Clear();
        _selectedSale = null;

        _productSelected.Clear();
        _productReturnQty.Clear();

        _selectedMotivo = "VENCIDO";
        _customMotivo = "";
        _formDirty = false;
        _showModal = true;

        StateHasChanged();
    }

    private async Task OpenEdit(Return dev)
    {
        _isEditing = true;
        _errorMessage = "";

        _form = new Return
        {
            Id = dev.Id,
            IdPedido = dev.IdPedido,
            IdVenta = dev.IdVenta,
            Reason = dev.Reason,
            Observations = dev.Observations,
            Quantity = dev.Quantity,
            Amount = dev.Amount,
            RegisteredBy = dev.RegisteredBy,
            Detalles = dev.Detalles != null ? dev.Detalles.Select(d => new DetalleDevolucionApi
            {
                IdProducto = d.IdProducto,
                NombreProducto = d.NombreProducto,
                PrecioUnitario = d.PrecioUnitario,
                Cantidad = d.Cantidad
            }).ToList() : new List<DetalleDevolucionApi>()
        };

        if (dev.Reason is "VENCIDO" or "DAÑADO" or "ERROR_PEDIDO")
        {
            _selectedMotivo = dev.Reason;
            _customMotivo = "";
        }
        else
        {
            _selectedMotivo = "OTRO";
            _customMotivo = dev.MotivoDetalle ?? dev.Reason ?? "";
        }

        _saleSearchTerm = "";
        _saleMatches.Clear();
        _selectedSale = null;
        _productSelected.Clear();
        _productReturnQty.Clear();

        if (dev.IdVenta.HasValue && dev.IdVenta.Value > 0)
        {
            _selectedSale = SalesSvc.GetSales()
                .FirstOrDefault(s => s.Id == $"VTA-{dev.IdVenta.Value:D3}");

            if (_selectedSale != null)
            {
                _saleSearchTerm = $"{_selectedSale.Id} - {_selectedSale.Cliente}";

                if (_selectedSale.Productos == null || !_selectedSale.Productos.Any())
                {
                    _selectedSale.Productos = await SalesSvc.GetProductosPorVentaAsync(dev.IdVenta.Value);
                }

                foreach (var item in _selectedSale.Productos)
                {
                    var existingDetail = _form.Detalles.FirstOrDefault(d => d.IdProducto == item.Id);
                    _productSelected[item.Id] = existingDetail != null;
                    _productReturnQty[item.Id] = existingDetail != null ? existingDetail.Cantidad : 1;
                }
            }
        }

        _formDirty = false;
        _showModal = true;
        StateHasChanged();
    }



    private bool GetProductChecked(int productId) => _productSelected.ContainsKey(productId) && _productSelected[productId];
    private void OnProductCheckedChange(int productId, bool val)
    {
        _productSelected[productId] = val;
        _formDirty = true; // ← agrega
    }
    private int GetProductReturnQty(int productId) => _productReturnQty.ContainsKey(productId) ? _productReturnQty[productId] : 1;
    private void OnProductReturnQtyChange(int productId, int val)
    {
        _productReturnQty[productId] = val;
        _formDirty = true; // ← agrega
    }

    private string GetEstadoBadge(Return r)
    {
        var estado = r.Estado?.ToLower();

        return estado switch
        {
            "aprobado" => "bg-success text-white",
            "rechazado" => "bg-danger text-white",
            _ => "bg-warning text-dark"
        };
    }

    private void OnSearchSaleInput(ChangeEventArgs e)
    {
        _saleSearchTerm = e.Value?.ToString() ?? "";

        if (string.IsNullOrWhiteSpace(_saleSearchTerm))
        {
            _saleMatches.Clear();
            return;
        }

        _saleMatches = SalesSvc.GetSales()
            .Where(s =>
                s.Canal.Equals("presencial", StringComparison.OrdinalIgnoreCase) &&
                s.Estado.Equals("completado", StringComparison.OrdinalIgnoreCase) &&
                (
                    s.Id.Contains(_saleSearchTerm, StringComparison.OrdinalIgnoreCase) ||
                    s.Cliente.Contains(_saleSearchTerm, StringComparison.OrdinalIgnoreCase)
                )
            )
            .Take(6)
            .ToList();
    }

    private async Task SelectSaleAsync(Sale sale)
    {
        Console.WriteLine($"VENTA SELECCIONADA: {sale.Id}");

        _selectedSale = sale;

        _form.IdPedido = null;

        int? idVenta = int.TryParse(sale.Id.Replace("VTA-", ""), out var parsedId)
            ? parsedId
            : null;

        _form.IdVenta = idVenta;

        if (idVenta.HasValue && (_selectedSale.Productos == null || !_selectedSale.Productos.Any()))
        {
            _selectedSale.Productos = await SalesSvc.GetProductosPorVentaAsync(idVenta.Value);
        }

        Console.WriteLine($"PRODUCTOS EN VENTA: {_selectedSale.Productos?.Count ?? 0}");

        foreach (var p in _selectedSale.Productos)
        {
            Console.WriteLine($"Producto: {p.Id} - {p.Name} - Cantidad: {p.Quantity}");
        }

        _productSelected.Clear();
        _productReturnQty.Clear();
        _saleMatches.Clear();

        _saleSearchTerm = $"{sale.Id} - {sale.Cliente}";

        foreach (var item in _selectedSale.Productos)
        {
            _productSelected[item.Id] = false;
            _productReturnQty[item.Id] = 1;
        }

        _formDirty = true;
        StateHasChanged();
    }

    private async Task Save()
    {
        if (_guardandoDevolucion)
            return;

        _guardandoDevolucion = true;
        _errorMessage = "";
        StateHasChanged();

        try
        {
            if (Auth.CurrentUser == null || Auth.CurrentUser.IdUsuario <= 0)
            {
                _errorMessage = "Debe iniciar sesión para registrar una devolución.";
                return;
            }

            _form.Reason = _selectedMotivo;
            _form.MotivoDetalle = _selectedMotivo == "OTRO" ? _customMotivo : "";

            _form.Detalles ??= new List<DetalleDevolucionApi>();
            _form.Detalles.Clear();

            if (!_isEditing && _selectedSale == null)
            {
                _errorMessage = "Debe seleccionar una venta presencial.";
                return;
            }

            if (_selectedSale != null)
            {
                _form.IdPedido = null;

                _form.IdVenta = int.TryParse(_selectedSale.Id.Replace("VTA-", ""), out var idVenta)
                    ? idVenta
                    : null;

                foreach (var item in _selectedSale.Productos)
                {
                    if (GetProductChecked(item.Id))
                    {
                        _form.Detalles.Add(new DetalleDevolucionApi
                        {
                            IdProducto = item.Id,
                            NombreProducto = item.Name,
                            PrecioUnitario = (double)item.Price,
                            Cantidad = GetProductReturnQty(item.Id)
                        });
                    }
                }
            }

            if (!_form.Detalles.Any())
            {
                _errorMessage = "Debe seleccionar al menos un producto para devolver.";
                return;
            }

            _form.Product = string.Join(", ", _form.Detalles.Select(d => d.NombreProducto));
            _form.ProductCode = string.Join(", ", _form.Detalles.Select(d => $"PROD-{d.IdProducto:D3}"));
            _form.Quantity = _form.Detalles.Sum(d => d.Cantidad);
            _form.Amount = (decimal)_form.Detalles.Sum(d => d.Cantidad * d.PrecioUnitario);

            if (!_isEditing)
            {
                _form.Estado = "aprobado";
            }

            int idUsuario = Auth.CurrentUser.IdUsuario;
            bool success;

            if (_isEditing)
            {
                success = await ReturnsSvc.UpdateReturnAsync(_form, idUsuario);
            }
            else
            {
                int idProductoPrincipal = _form.Detalles.First().IdProducto;

                success = await ReturnsSvc.AddReturnAsync(
                    _form,
                    idProductoPrincipal,
                    idUsuario);
            }

            if (!success)
            {
                _errorMessage = ReturnsSvc.UltimoErrorDevolucion
                    ?? "Error al guardar la devolución en el servidor. Verifique su conexión e intente nuevamente.";
                return;
            }

            _showModal = false;
            _formDirty = false;

            await ReturnsSvc.EnsureLoadedAsync(recargar: true);
            _returns = ReturnsSvc.GetReturns();
        }
        finally
        {
            _guardandoDevolucion = false;
            StateHasChanged();
        }
    }

 

    private void TryCloseModal()
    {
        if (_guardandoDevolucion)
            return;

        if (_formDirty)
            _showUnsavedConfirm = true;
        else
            CloseModal();
    }

    private void CloseModal()
    {
        _showUnsavedConfirm = false;
        _showModal = false;
    }
}
