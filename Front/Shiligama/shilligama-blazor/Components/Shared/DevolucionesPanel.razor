@* ─── Modal: Salir sin guardar ─────────────────────────── *@
@if (_showUnsavedConfirm)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.45);z-index:1070;"
         @onclick="@(() => _showUnsavedConfirm = false)">
        <div class="modal-dialog modal-dialog-centered" style="max-width:380px;" @onclick:stopPropagation>
            <div class="modal-content bg-card border-border" style="border-radius:1.25rem;">
                <div class="modal-body p-4 text-center">
                    <div class="mb-3" style="font-size:2.5rem;">⚠️</div>
                    <h5 class="fw-bold text-foreground mb-1">¿Salir sin guardar?</h5>
                    <p class="text-muted-foreground small mb-4">Los cambios se perderán.</p>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-secondary" style="border-radius:var(--radius);"
                                @onclick="@(() => _showUnsavedConfirm = false)">
                            Seguir editando
                        </button>
                        <button class="btn btn-danger" style="border-radius:var(--radius);"
                                @onclick="CloseModal">
                            Salir sin guardar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* ─── Modal: Evaluar Devolución ─────────────────────────── *@
@if (_showEvaluarModal && _devAEvaluar != null)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.45);z-index:1070;"
         @onclick="@(() => _showEvaluarModal = false)">     
        <div class="modal-dialog modal-dialog-centered" style="max-width:460px;" @onclick:stopPropagation>
            <div class="modal-content bg-card border-border" style="border-radius:1.25rem;">
                <div class="modal-header border-color-default px-4 py-3">
                    <div>
                        <h5 class="modal-title text-foreground fw-bold mb-0">Evaluar Devolución</h5>
                        <span class="text-muted-foreground small">@_devAEvaluar.Id</span>
                    </div>
                    <button type="button" class="btn-close" @onclick="@(() => _showEvaluarModal = false)"></button>
                </div>
                <div class="modal-body p-4 d-flex flex-column gap-3">
                    @if (_guardandoEstado)
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center py-4" style="min-height:160px;">
                            <div class="spinner-border text-success" role="status" style="width:3rem;height:3rem;">
                                <span class="visually-hidden">Cargando...</span>
                            </div>
                            <div class="mt-3 fw-semibold" style="color:#1A6B3C;">Procesando...</div>
                        </div>
                    }
                    else
                    {

                        <p class="text-muted-foreground small mb-0">
                            Revisa la devolución y decide si la <strong>aceptas</strong> o <strong>rechazas</strong>.
                        </p>
                        <div class="d-flex flex-column gap-1 p-3 rounded-3" style="background:var(--muted);font-size:0.85rem;">
                            <span><strong>Pedido:</strong> @(_devAEvaluar.IdPedido.HasValue ? $"SHI-2024-{_devAEvaluar.IdPedido.Value:D4}" : "N/A")</span>
                            <span><strong>Motivo:</strong> @(_devAEvaluar.Reason is "Vencido" or "Dañado" ? _devAEvaluar.Reason : "Motivo personalizado")</span>
                            <span><strong>Monto:</strong> -S/. @_devAEvaluar.Amount.ToString("0.00")</span>
                            @if (!string.IsNullOrEmpty(_devAEvaluar.Observations))
                            {
                                <span><strong>Observación:</strong> @_devAEvaluar.Observations</span>
                            }
                        </div>
                        <div class="d-flex flex-row gap-2 mt-2 justify-content-center">
                            <button class="btn btn-danger fw-semibold flex-fill" style="border-radius:var(--radius);"
                                    @onclick="@(async () => await CambiarEstado(_devAEvaluar, "RECHAZADO"))">
                                <i class="fas fa-times me-2"></i>Rechazar
                            </button>
                            <button class="btn btn-success fw-semibold flex-fill" style="border-radius:var(--radius);background:#196c3e;border-color:#196c3e;"
                                    @onclick="@(async () => await CambiarEstado(_devAEvaluar, "APROBADO"))">
                                <i class="fas fa-check me-2"></i>Aceptar
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Rol { get; set; } = "admin"; // "admin" | "trabajador"
    private bool _loading = true;

    private List<Return> _returns = new();
    private string _search = "";
    private string _motivoFilter = "";
    private DateTime? _fechaDesde;
    private DateTime? _fechaHasta;
    private bool _showModal = false;
    private Return _form = new();
    private bool _isEditing = false;
    private string _errorMessage = "";

    // Search de Pedidos
    private string _orderSearchTerm = "";
    private List<Order> _orderMatches = new();
    private Order? _selectedOrder = null;
    private Dictionary<int, bool> _productSelected = new();
    private Dictionary<int, int> _productReturnQty = new();

    // Detalle de Devolución
    private bool _showDetailModal = false;
    private Return? _selectedDetailReturn = null;

    // Motivo select values
    private string _selectedMotivo = "Vencido";
    private string _customMotivo = "";

    private bool _showUnsavedConfirm = false;
    
    private bool _formDirty = false;

    private bool _showEvaluarModal = false;
    private Return? _devAEvaluar = null;

    private bool _guardandoEstado = false;


    private void AbrirEvaluacion(Return dev)
    {
        _devAEvaluar = dev;
        _showEvaluarModal = true;
    }

    private async Task CambiarEstado(Return dev, string nuevoEstado)
    {
        _guardandoEstado = true;
        _errorMessage = "";
        StateHasChanged();

        try
        {
            int idUsuario = Auth.CurrentUser?.IdUsuario ?? 0;
            Console.WriteLine($"idDevolucion={dev.Id}, idUsuario={idUsuario}");

            bool ok = await ReturnsSvc.CambiarEstadoAsync(dev, nuevoEstado, idUsuario);

            if (!ok)
            {
                _errorMessage = "No se pudo actualizar el estado. Intente nuevamente.";
                return;
            }

            await ReturnsSvc.EnsureLoadedAsync(recargar: true);
            _returns = ReturnsSvc.GetReturns();
            _showEvaluarModal = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error CambiarEstado: {ex.Message}");
            _errorMessage = "Error inesperado al cambiar el estado.";
        }
        finally
        {
            _guardandoEstado = false;
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        await Task.WhenAll(
            ProductSvc.EnsureLoadedAsync(),
            ReturnsSvc.EnsureLoadedAsync(),
            SalesSvc.EnsureLoadedAsync(cargarDetalles: true) // ← con detalles (necesita productos del pedido)
        );
        _returns = ReturnsSvc.GetReturns();
        _loading = false;
    }

    private IEnumerable<Return> Filtered => _returns.Where(r =>
        (string.IsNullOrEmpty(_search) ||
         r.Product.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
         r.Id.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
         r.RegisteredBy.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
         (r.IdPedido.HasValue && (
             r.IdPedido.Value.ToString().Contains(_search) ||
              $"SHI-2024-{r.IdPedido.Value:D4}".Contains(_search, StringComparison.OrdinalIgnoreCase)))) &&
        (string.IsNullOrEmpty(_motivoFilter) || r.Reason.Equals(_motivoFilter, StringComparison.OrdinalIgnoreCase)) &&
        (!_fechaDesde.HasValue || r.Date >= _fechaDesde.Value) &&
        (!_fechaHasta.HasValue || r.Date <= _fechaHasta.Value.AddDays(1))
    )
    .OrderBy(r => (r.Estado?.ToLower() ?? "pendiente") == "pendiente" ? 0 : 1);

    private decimal TotalRefunded => Filtered.Sum(r => r.Amount);


    private IEnumerable<Return> MonthFilter => _returns.Where(r =>
        r.Date.Month == DateTime.Now.Month && r.Date.Year == DateTime.Now.Year);

    private int MesActualCount => MonthFilter.Count();
    private decimal MesActualTotal => MonthFilter.Sum(r => r.Amount);
    private decimal MesAvgTicket => MesActualCount > 0 ? MesActualTotal / MesActualCount : 0;

    private void OnFilterChange() => StateHasChanged();

    private string GetTopReturnedOrderText()
    {
        var topOrderGroup = _returns.Where(r => r.IdPedido.HasValue && r.IdPedido.Value > 0)
                                    .GroupBy(r => r.IdPedido.Value)
                                    .OrderByDescending(g => g.Count())
                                    .FirstOrDefault();
        return topOrderGroup != null 
            ? $"SHI-2024-{topOrderGroup.Key:D4}"
            : "N/A";
    }

    

    

    private string GetCustomerNameForReturn(Return r)
    {
        if (r.IdPedido.HasValue)
        {
            var order = SalesSvc.GetRecentOrders().FirstOrDefault(o => o.Id == $"PED-{r.IdPedido.Value:D4}");
            if (order != null) return order.Customer;
        }
        return "Público General";
    }

    private void VerDetalle(Return dev)
    {
        _selectedDetailReturn = dev;
        _showDetailModal = true;
    }

    public void OpenCreate()
    {
        _isEditing = false;
        _errorMessage = "";
        _form = new Return
        {
            Quantity     = 1,
            RegisteredBy = Auth.CurrentUser?.Name ?? (Rol == "admin" ? "Admin" : "Trabajador")
        };
        _orderSearchTerm = "";
        _orderMatches.Clear();
        _selectedOrder = null;
        _productSelected.Clear();
        _productReturnQty.Clear();
        _selectedMotivo = "Vencido";
        _customMotivo = "";
        _showModal = true;
        StateHasChanged();
    }

    private void OpenEdit(Return dev)
    {
        _isEditing = true;
        _errorMessage = "";
        _form = new Return
        {
            Id = dev.Id,
            IdPedido = dev.IdPedido,
            Reason = dev.Reason,
            Observations = dev.Observations,
            Quantity = dev.Quantity,
            Amount = dev.Amount,
            RegisteredBy = dev.RegisteredBy,
            Detalles = dev.Detalles != null ? dev.Detalles.Select(d => new DetalleDevolucionApi
            {
                IdProducto = d.IdProducto,
                NombreProducto = d.NombreProducto,
                PrecioUnitario = d.PrecioUnitario,
                Cantidad = d.Cantidad
            }).ToList() : new List<DetalleDevolucionApi>()
        };

        if (dev.Reason == "Vencido" || dev.Reason == "Dañado")
        {
            _selectedMotivo = dev.Reason;
            _customMotivo = "";
        }
        else
        {
            _selectedMotivo = "Otro";
            _customMotivo = dev.Reason ?? "";
        }

        if (dev.IdPedido.HasValue)
        {
            _selectedOrder = SalesSvc.GetRecentOrders().FirstOrDefault(o => o.Id == $"PED-{dev.IdPedido.Value:D4}");
            if (_selectedOrder != null)
            {
                _orderSearchTerm = _selectedOrder.Id.Replace("PED-", "SHI-2024-") + " - " + _selectedOrder.Customer;
                _productSelected.Clear();
                _productReturnQty.Clear();
                foreach (var item in _selectedOrder.Products)
                {
                    var existingDetail = _form.Detalles.FirstOrDefault(d => d.IdProducto == item.Id);
                    _productSelected[item.Id] = existingDetail != null;
                    _productReturnQty[item.Id] = existingDetail != null ? existingDetail.Cantidad : 1;
                }
            }
        }
        else
        {
            _orderSearchTerm = "";
            _selectedOrder = null;
        }

        _showModal = true;
        StateHasChanged();
    }

    private void OnSearchOrderInput(ChangeEventArgs e)
    {
        _orderSearchTerm = e.Value?.ToString() ?? "";
        if (string.IsNullOrWhiteSpace(_orderSearchTerm))
        {
            _orderMatches.Clear();
        }
        else
        {
            _orderMatches = SalesSvc.GetRecentOrders()
                .Where(o => o.Id.Replace("PED-", "SHI-2024-").Contains(_orderSearchTerm, StringComparison.OrdinalIgnoreCase) ||
                            o.Customer.Contains(_orderSearchTerm, StringComparison.OrdinalIgnoreCase))
                .Take(6)
                .ToList();
        }
    }

    private void SelectOrder(Order order)
    {
        _selectedOrder = order;
        _form.IdPedido = int.TryParse(order.Id.Replace("PED-", ""), out var numId) ? numId : 0;
        _productSelected.Clear();
        _productReturnQty.Clear();
        _orderMatches.Clear();
        _orderSearchTerm = order.Id.Replace("PED-", "SHI-2024-") + " - " + order.Customer;

        foreach (var item in order.Products)
        {
            _productSelected[item.Id] = false;
            _productReturnQty[item.Id] = 1;
        }

        _formDirty = true;
    }

    private bool GetProductChecked(int productId) => _productSelected.ContainsKey(productId) && _productSelected[productId];
    private void OnProductCheckedChange(int productId, bool val)
    {
        _productSelected[productId] = val;
        _formDirty = true; // ← agrega
    }
    private int GetProductReturnQty(int productId) => _productReturnQty.ContainsKey(productId) ? _productReturnQty[productId] : 1;
    private void OnProductReturnQtyChange(int productId, int val)
    {
        _productReturnQty[productId] = val;
        _formDirty = true; // ← agrega
    }

    private string GetEstadoBadge(Return r)
    {
        var estado = r.Estado?.ToLower();

        return estado switch
        {
            "aprobado" => "bg-success text-white",
            "rechazado" => "bg-danger text-white",
            _ => "bg-warning text-dark"
        };
    }

    private async Task Save()
    {
        _errorMessage = "";

        // Validar sesion activa
        if (Auth.CurrentUser == null || Auth.CurrentUser.IdUsuario <= 0)
        {
            _errorMessage = "Debe iniciar sesion para registrar una devolucion.";
            return;
        }

        _form.Reason = _selectedMotivo == "Otro" ? _customMotivo : _selectedMotivo;
        _form.Detalles.Clear();
        if (_selectedOrder != null)
        {
            foreach (var item in _selectedOrder.Products)
            {
                if (GetProductChecked(item.Id))
                {
                    _form.Detalles.Add(new DetalleDevolucionApi
                    {
                        IdProducto = item.Id,
                        NombreProducto = item.Name,
                        PrecioUnitario = (double)item.Price,
                        Cantidad = GetProductReturnQty(item.Id)
                    });
                }
            }
        }

        if (!_form.Detalles.Any())
        {
            _errorMessage = "Debe seleccionar al menos un producto para devolver.";
            return;
        }

        // Auto map header products based on first detail for compatibility
        var firstDetail = _form.Detalles.First();
        _form.Product = string.Join(", ", _form.Detalles.Select(d => d.NombreProducto));
        _form.ProductCode = string.Join(", ", _form.Detalles.Select(d => $"PROD-{d.IdProducto:D3}"));
        _form.Quantity = _form.Detalles.Sum(d => d.Cantidad);
        _form.Amount = (decimal)_form.Detalles.Sum(d => d.Cantidad * d.PrecioUnitario);

        int idUsuario = Auth.CurrentUser.IdUsuario;
        bool success;

        if (_isEditing)
        {
            success = await ReturnsSvc.UpdateReturnAsync(_form, idUsuario);
        }
        else
        {
            success = await ReturnsSvc.AddReturnAsync(_form, 0, idUsuario);
        }

        if (!success)
        {
            _errorMessage = "Error al guardar la devolucion en el servidor. Verifique su conexion e intente nuevamente.";
            return;
        }

        _showModal = false;
        _formDirty = false;
        await ReturnsSvc.EnsureLoadedAsync(recargar: true);
        _returns = ReturnsSvc.GetReturns();
        StateHasChanged();
    }

 

    private void TryCloseModal()
    {
        if (_formDirty) _showUnsavedConfirm = true;
        else CloseModal();
    }

    private void CloseModal()
    {
        _showUnsavedConfirm = false;
        _showModal = false;
    }
}
