                                    </button>                            
                                    <button type="submit"
                                            class="btn btn-success fw-semibold d-flex align-items-center justify-content-center"
                                            disabled="@(_guardandoDevolucion || _selectedSale == null || !_productSelected.Values.Any(v => v) || (_selectedMotivo == "OTRO" ? string.IsNullOrWhiteSpace(_customMotivo) : string.IsNullOrEmpty(_selectedMotivo)))"
