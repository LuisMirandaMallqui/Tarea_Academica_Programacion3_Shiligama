@* RegistrarVentaPanel.razor — componente compartido para Admin y Trabajador *@
@using shilligama_blazor.Models
@using shilligama_blazor.Services
@implements IDisposable
@inject ProductService ProductSvc
@inject SalesService SalesSvc
@inject AuthService Auth
@inject IJSRuntime JS

<div style="background-color:#f8f9fa;min-height:100vh;width:100%;padding:1.5rem;">

        <!-- Header -->
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <p class="text-muted-foreground small mt-0 mb-0">Registra una nueva venta presencial</p>
            </div>
            <div class="bg-white border border-color-default px-4 py-2 fw-bold text-foreground d-flex align-items-center"
                 style="border-radius:0.6rem;font-size:1.25rem;font-family:monospace;letter-spacing:0.75px;">
                Nueva Venta
            </div>
        </div>

        @if (!string.IsNullOrEmpty(_errorMsg))
        {
            <div class="alert alert-danger py-2 small mb-3">@_errorMsg</div>
        }

        <div class="d-flex flex-column gap-3">

            <!-- Tabla de Líneas de Venta -->
            <div class="card bg-white border border-color-default shadow-sm w-100" style="border-radius:1rem;">
                <div class="p-4 border-bottom border-color-default">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <i class="fas fa-barcode text-primary" style="font-size:1.1rem;"></i>
                        <h5 class="m-0 fw-bold text-foreground" style="font-size:1.05rem;">Escanear Producto</h5>
                    </div>
                    <div class="position-relative">
                        <i class="fas fa-search position-absolute text-muted-foreground"
                           style="left:14px;top:50%;transform:translateY(-50%);font-size:0.9rem;"></i>
                        <input id="scanInput" type="text" @bind="_barcodeInput" @bind:event="oninput"
                               @onkeydown="OnBarcodeKeydown"
                               class="form-control text-foreground w-100"
                               placeholder="Escanear código de barras o escribir código/nombre..."
                               style="padding-left:40px;border-radius:0.5rem;height:44px;" />
                    </div>
                    @if (!string.IsNullOrEmpty(_barcodeError))
                    {
                        <div class="text-danger small mt-2 d-flex align-items-center gap-1">
                            <i class="fas fa-exclamation-triangle"></i> @_barcodeError
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_barcodeSuccess))
                    {
                        <div class="text-success small mt-2 d-flex align-items-center gap-1">
                            <i class="fas fa-check-circle"></i> @_barcodeSuccess
                        </div>
                    }
                </div>
                <div class="p-4 border-bottom border-color-default d-flex justify-content-between align-items-center">
                    <h5 class="m-0 fw-bold text-foreground" style="font-size:1.05rem;">Líneas de Venta</h5>
                    <button class="btn text-white px-3 py-2 d-flex align-items-center gap-2" @onclick="OpenModal"
                            style="background-color:#064420;border-radius:0.5rem;font-size:0.85rem;font-weight:600;border:none;">
                        <i class="fas fa-plus"></i> Agregar Manual
                    </button>
                </div>
                <div class="p-0">
                    @if (!_posCart.Any())
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center py-5 text-center" style="min-height:250px;">
                            <i class="fas fa-receipt text-muted-foreground opacity-50 mb-3" style="font-size:3.5rem;"></i>
                            <h6 class="text-foreground fw-semibold mb-1">No hay productos agregados</h6>
                            <p class="text-muted-foreground small mb-0">Haz clic en "Agregar Producto" para comenzar</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-borderless align-middle mb-0">
                                <thead class="border-bottom border-color-default" style="background-color:#f8f9fa;">
                                    <tr>
                                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;width:15%;">Código</th>
                                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase" style="letter-spacing:.05em;width:35%;">Nombre</th>
                                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-center" style="letter-spacing:.05em;width:15%;">Cantidad</th>
                                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-end" style="letter-spacing:.05em;width:15%;">Precio Unit.</th>
                                        <th class="px-4 py-3 small fw-semibold text-muted-foreground text-uppercase text-end" style="letter-spacing:.05em;width:15%;">Subtotal</th>
                                        <th class="px-4 py-3" style="width:5%;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in _posCart)
                                    {
                                        <tr class="border-bottom border-color-default">
                                            <td class="px-4 py-3 text-muted-foreground small fw-medium">@item.Id.ToString("D4")</td>
                                            <td class="px-4 py-3 fw-bold text-foreground small">@item.Name</td>
                                             <td class="px-4 py-3 text-center">
                                                 <div class="d-flex align-items-center justify-content-center gap-1">
                                                     <button class="btn btn-outline-secondary btn-sm rounded-circle d-flex align-items-center justify-content-center"
                                                             style="width:28px;height:28px;font-size:.7rem;"
                                                             disabled="@(item.Quantity <= 1)"
                                                             @onclick="@(() => ChangeQty(item, -1))">−</button>
                                                     <span class="fw-semibold small text-foreground" style="min-width:24px;text-align:center;">@item.Quantity</span>
                                                     <button class="btn btn-outline-secondary btn-sm rounded-circle d-flex align-items-center justify-content-center"
                                                             style="width:28px;height:28px;font-size:.7rem;"
                                                             disabled="@(item.Quantity >= GetProductStock(item.Id))"
                                                             @onclick="@(() => ChangeQty(item, 1))">+</button>
                                                 </div>
                                             </td>
                                            <td class="px-4 py-3 text-end text-muted-foreground small">S/ @item.Price.ToString("0.00")</td>
                                            <td class="px-4 py-3 text-end text-foreground fw-bold small">S/ @((item.Price * item.Quantity).ToString("0.00"))</td>
                                            <td class="px-4 py-3 text-center">
                                                <button class="btn btn-link text-danger p-0 m-0" @onclick="@(() => RemoveFromCart(item.Id))" title="Eliminar">
                                                    <i class="far fa-trash-alt"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <div class="row g-3">
                <!-- Resumen -->
                <div class="col-12 col-md-5 col-lg-4">
                    <div class="card bg-white border border-color-default shadow-sm h-100" style="border-radius:1rem;">
                        <div class="p-4 border-bottom border-color-default">
                            <h5 class="m-0 fw-bold text-foreground" style="font-size:1.05rem;">Resumen</h5>
                        </div>
                        <div class="p-4 d-flex flex-column justify-content-between h-100">
                            <div class="d-flex flex-column gap-3 mb-4">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-muted-foreground small">Subtotal (sin IGV)</span>
                                    <span class="fw-medium text-foreground small">S/ @SubtotalSinIgv.ToString("0.00")</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-muted-foreground small">IGV (18%)</span>
                                    <span class="fw-medium text-foreground small">S/ @Igv.ToString("0.00")</span>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between align-items-center pt-3 border-top border-color-default mt-auto">
                                <span class="fw-bold text-foreground" style="font-size:1.1rem;">Total</span>
                                <span class="fw-bold" style="font-size:1.25rem;color:#064420;">S/ @Total.ToString("0.00")</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Método de Pago + Cliente -->
                <div class="col-12 col-md-7 col-lg-8">
                    <div class="card bg-white border border-color-default shadow-sm h-100" style="border-radius:1rem;">
                        <div class="p-4 border-bottom border-color-default">
                            <h5 class="m-0 fw-bold text-foreground" style="font-size:1.05rem;">Método de Pago</h5>
                        </div>
                        <div class="p-4 d-flex flex-column gap-3">
                            <div class="d-flex gap-3 flex-wrap">
                                <button type="button" @onclick='@(() => _payMethod="efectivo")' class="btn payment-method-btn @(_payMethod=="efectivo"?"active":"")">
                                    <i class="fas fa-money-bill-wave"></i> Efectivo
                                </button>
                                <button type="button" @onclick='@(() => _payMethod="yape")' class="btn payment-method-btn @(_payMethod=="yape"?"active":"")">
                                    <i class="fas fa-mobile-alt"></i> Yape
                                </button>
                                <button type="button" @onclick='@(() => _payMethod="plin")' class="btn payment-method-btn @(_payMethod=="plin"?"active":"")">
                                    <i class="fas fa-mobile-alt"></i> Plin
                                </button>
                                <button type="button" @onclick='@(() => _payMethod="tarjeta")' class="btn payment-method-btn @(_payMethod=="tarjeta"?"active":"")">
                                    <i class="fas fa-credit-card"></i> Tarjeta
                                </button>
                            </div>
                            <div>
                                <label class="form-label small fw-semibold text-foreground mb-1">Cliente (Opcional)</label>
                                <input type="text" @bind="_customerName" class="form-control form-control-sm text-foreground" placeholder="Público General" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Botones Footer -->
            @if (_posCart.Any())
            {
                <div class="d-flex justify-content-end gap-3 mt-3 pb-4">
                    @if (!_ventaConfirmada)
                    {
                        <button class="btn text-white fw-semibold d-flex align-items-center gap-2 px-4 shadow-sm
                            @(_isProcessing ? "btn-process-blue" : "btn-process-green")"
                                @onclick="ConfirmarVentaPOS"
                                disabled="@_isProcessing"
                                style="border-radius:0.5rem;height:44px;border:none;">
    
                            @if (_isProcessing)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                                <span>Procesando...</span>
                            }
                            else
                            {
                                <i class="fas fa-check-circle"></i>
                                <span>Confirmar Venta</span>
                            }
                        </button>
                    }
                    else
                    {
                        <button class="btn text-white fw-semibold d-flex align-items-center gap-2 px-4 shadow-sm
                            @(_isProcessing ? "btn-process-blue" : "btn-process-green")"
                                @onclick="GenerarBoletaPOS"
                                disabled="@_isProcessing"
                                style="border-radius:0.5rem;height:44px;border:none;">

                            @if (_isProcessing)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                                <span>Generando Boleta...</span>
                            }
                            else
                            {
                                <i class="fas fa-receipt"></i>
                                <span>Generar Boleta Electrónica</span>
                            }
                        </button>

                    }
                </div>
            }

        </div>
    </div>

<!-- Modal de Éxito Nubefact (SUNAT) -->
@if (_showBoletaModal && _boletaResponse != null)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.6);z-index:1070;backdrop-filter:blur(4px);">
        <div class="modal-dialog modal-dialog-centered" style="max-width:520px;">
            <div class="modal-content border-0 shadow-lg" style="border-radius:1.2rem;overflow:hidden;">
                
                <!-- Header with premium green gradient -->
                <div class="p-4 text-center text-white" style="background: linear-gradient(135deg, #064420 0%, #157347 100%);">
                    <div class="d-inline-flex align-items-center justify-content-center bg-white rounded-circle mb-3 shadow-sm" style="width:60px;height:60px;color:#064420;">
                        <Icons Name="Check" style="width:30px;height:30px;" />
                    </div>
                    <h4 class="fw-bold mb-1">¡Comprobante Generado!</h4>
                    <p class="mb-0 opacity-75 small">La boleta electrónica ha sido aceptada por SUNAT</p>
                </div>
                
                <div class="modal-body p-4 bg-light">
                    <!-- General Details Card -->
                    <div class="card p-3 border-0 shadow-sm mb-4" style="border-radius:0.8rem;background-color:#ffffff;">
                        <div class="d-flex justify-content-between mb-2 pb-2 border-bottom" style="border-color:#f1f3f5!important;">
                            <span class="text-muted small">Nro Comprobante:</span>
                            <span class="fw-bold text-primary">@_boletaResponse.Serie - @_boletaResponse.Numero.ToString("D8")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 pb-2 border-bottom" style="border-color:#f1f3f5!important;">
                            <span class="text-muted small">Cliente:</span>
                            <span class="fw-medium text-dark text-truncate" style="max-width:250px;">@_boletaResponse.ClienteDenominacion</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2 pb-2 border-bottom" style="border-color:#f1f3f5!important;">
                            <span class="text-muted small">Monto Total:</span>
                            <span class="fw-bold text-success">S/ @_boletaResponse.Total.ToString("0.00")</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted small">SUNAT Estado:</span>
                            <span class="badge bg-success-subtle text-success border border-success-subtle px-2.5 py-1" style="font-size:0.75rem;">
                                <i class="fas fa-check-circle me-1"></i> ACEPTADA
                            </span>
                        </div>
                    </div>

                    <!-- PDF / XML Links -->
                    <div class="d-flex flex-column gap-2 mb-4">
                        <a href="@_boletaResponse.NubefactEnlacePdf" target="_blank" class="btn btn-primary d-flex align-items-center justify-content-center gap-2 py-2.5" style="border-radius:0.6rem;font-weight:600;background-color:#064420;border:none;">
                            <i class="far fa-file-pdf fs-5"></i> Descargar PDF de Boleta
                        </a>
                        <a href="@_boletaResponse.NubefactEnlaceXml" target="_blank" class="btn btn-outline-secondary d-flex align-items-center justify-content-center gap-2 py-2.5" style="border-radius:0.6rem;font-weight:600;">
                            <i class="far fa-file-code fs-5"></i> Descargar XML (FacturaE)
                        </a>
                    </div>

                    <!-- Hash details -->
                    @if (!string.IsNullOrEmpty(_boletaResponse.NubefactCodigoHash))
                    {
                        <div class="text-center p-3 rounded" style="background-color:#f8f9fa;border:1px dashed #dee2e6;">
                            <span class="text-muted small d-block mb-1">Código Hash SUNAT:</span>
                            <code class="small text-break text-muted">@_boletaResponse.NubefactCodigoHash</code>
                        </div>
                    }
                </div>

                <div class="modal-footer border-0 p-4 bg-light justify-content-center">
                    <button class="btn btn-dark w-100 py-2.5 fw-bold" style="border-radius:0.6rem;" @onclick="ResetPOS">
                        Registrar Nueva Venta
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal Agregar Producto -->
@if (_isModalOpen)
{
    <div class="modal-overlay d-flex align-items-center justify-content-center"
         style="background-color:rgba(0,0,0,0.4);position:fixed;inset:0;z-index:1050;"
         @onclick="CloseModal">
        <div class="bg-white shadow-lg d-flex flex-column"
             style="width:100%;max-width:500px;border-radius:1rem;max-height:90vh;overflow:hidden;"
             @onclick:stopPropagation>

            <div class="p-4 d-flex justify-content-between align-items-start pb-3">
                <div>
                    <h5 class="fw-bold text-foreground mb-1" style="font-size:1.15rem;">Agregar Producto</h5>
                    <p class="text-muted-foreground small m-0">Busca por nombre o categoría</p>
                </div>
                <button class="btn btn-link text-muted-foreground p-0 m-0" style="font-size:1.2rem;" @onclick="CloseModal">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div class="px-4 pb-3">
                <div class="position-relative">
                    <i class="fas fa-search position-absolute text-muted-foreground"
                       style="left:14px;top:50%;transform:translateY(-50%);font-size:0.9rem;"></i>
                    <input type="search" @bind="_modalSearch" @bind:event="oninput"
                           class="form-control text-foreground w-100"
                           placeholder="Buscar producto..."
                           style="padding-left:40px;border-radius:0.5rem;height:42px;"
                           autofocus />
                </div>
            </div>

            <div class="overflow-y-auto px-4 pb-2" style="max-height:300px;border-bottom:1px solid #f1f3f5;">
                <div class="d-flex flex-column gap-2">
                    @foreach (var prod in ModalProducts.Take(15))
                    {
                        bool sel = _selectedProduct?.Id == prod.Id;
                        <div class="p-3 d-flex justify-content-between align-items-center cursor-pointer border"
                             style="border-radius:0.5rem;border-color:@(sel?"#d1e7dd":"#e9ecef")!important;background-color:@(sel?"#eaf4ec":"transparent");transition:all 0.2s;"
                             @onclick="@(() => SelectProduct(prod))">
                            <div class="d-flex flex-column">
                                <span class="fw-bold text-foreground" style="font-size:0.9rem;">@prod.Name</span>
                                <span class="text-muted-foreground" style="font-size:0.75rem;">Código: @prod.Id | Stock: @prod.Stock</span>
                            </div>
                            <span class="fw-bold text-foreground" style="font-size:0.95rem;">S/ @prod.Price.ToString("0.00")</span>
                        </div>
                    }
                    @if (!ModalProducts.Any())
                    {
                        <div class="text-center py-4">
                            <p class="text-muted-foreground small m-0">No se encontraron productos.</p>
                        </div>
                    }
                </div>
            </div>

            <div class="p-4 bg-white mt-auto">
                <div class="p-3 mb-4" style="background-color:#f6fcf8;border-radius:0.5rem;">
                    <div class="d-flex justify-content-between mb-2 align-items-center">
                        <span class="text-muted-foreground small">Producto seleccionado</span>
                        <span class="fw-bold text-foreground small">@(_selectedProduct?.Name ?? "-")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2 align-items-center">
                        <span class="text-muted-foreground small">Precio unitario</span>
                        <span class="fw-medium text-foreground small">@(_selectedProduct != null ? $"S/ {_selectedProduct.Price:0.00}" : "-")</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted-foreground small">Cantidad</span>
                        <div class="input-group" style="width:100px;">
                            <input type="number" class="form-control form-control-sm text-center fw-medium bg-white"
                                   @bind="_selectedQuantity" @bind:event="oninput"
                                   min="1" max="@(_selectedProduct?.Stock ?? 1)"
                                   disabled="@(_selectedProduct == null)"
                                   style="border-radius:0.375rem;" />
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center pt-2 border-top" style="border-color:rgba(6,68,32,0.1)!important;">
                        <span class="fw-bold text-foreground small">Subtotal</span>
                        <span class="fw-bold" style="color:#064420;font-size:1.1rem;">
                            @(_selectedProduct != null ? $"S/ {(_selectedProduct.Price * _selectedQuantity):0.00}" : "S/ 0.00")
                        </span>
                    </div>
                </div>
                <div class="d-flex justify-content-end gap-2">
                    <button class="btn border px-4" @onclick="CloseModal"
                            style="border-radius:0.5rem;font-weight:500;font-size:0.9rem;border-color:#dee2e6;">
                        Cancelar
                    </button>
                    <button class="btn text-white px-4" @onclick="AddSelectedToCart"
                            disabled="@(_selectedProduct == null)"
                            style="background-color:#064420;border-radius:0.5rem;font-weight:600;font-size:0.9rem;">
                        Agregar Línea
                    </button>
                </div>
            </div>

        </div>
    </div>
}

@if (_showSavedToast)
{
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999;">
        <div class="toast show text-white border-0 px-3 py-2" style="background:#1A6B3C;border-radius:var(--radius);min-width:260px;">
            <i class="fa-solid fa-circle-check me-2"></i>
            <span class="small">@_toastMsg</span>
        </div>
    </div>
}

<style>
    .payment-method-btn {
        background-color: #ffffff;
        border: 1px solid #dee2e6;
        color: #495057;
        padding: 0.5rem 1.25rem;
        border-radius: 0.5rem;
        font-size: 0.85rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        transition: all 0.2s ease;
    }
    .payment-method-btn.active {
        background-color: #064420;
        border-color: #064420;
        color: #ffffff;
    }
    .payment-method-btn:hover:not(.active) {
        background-color: #e8f5e9;
        border-color: #064420;
        color: #064420;
    }
    :root.dark .payment-method-btn,
    .dark .payment-method-btn {
        background-color: var(--card);
        border-color: var(--border);
        color: var(--foreground);
    }
</style>

@code {
    [Parameter] public string Rol { get; set; } = "trabajador";

    private List<Product> _products = new();
    private List<CartItem> _posCart = new();

    // Barcode scanner state
    private string _barcodeInput = "";
    private string _barcodeError = "";
    private string _barcodeSuccess = "";
    private Timer? _barcodeTimer;

    // Modal state
    private bool _isModalOpen = false;
    private string _modalSearch = "";
    private Product? _selectedProduct = null;
    private int _selectedQuantity = 1;

    // POS state
    private string _customerName = "";
    private string _payMethod = "efectivo";
    private bool _isProcessing = false;
    private string _receiptId = "";
    private string _errorMsg  = "";

    // POS Nubefact state
    private int _idVentaGenerada = 0;
    private bool _ventaConfirmada = false;
    private BoletaResponse? _boletaResponse = null;
    private bool _showBoletaModal = false;
    private bool _showSavedToast = false;
    private string _toastMsg = "";

    // ── Barcode scanner ────────────────────────────────────────────────────
    private void OnBarcodeInput(ChangeEventArgs e)
    {
        _barcodeInput = e.Value?.ToString() ?? "";
        _barcodeError = "";
        _barcodeSuccess = "";
        _barcodeTimer?.Dispose();
        _barcodeTimer = new Timer(async _ =>
        {
            var code = await JS.InvokeAsync<string>("posHelper.readInputValue", "scanInput");
            _barcodeInput = "";
            await InvokeAsync(async () => await ProcessBarcode(code?.Trim() ?? ""));
        }, null, 300, Timeout.Infinite);
    }

    private async Task OnBarcodeKeydown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _barcodeTimer?.Dispose();
            var code = await JS.InvokeAsync<string>("posHelper.readInputValue", "scanInput");
            _barcodeInput = "";
            await ProcessBarcode(code?.Trim() ?? "");
        }
    }

    private async Task ProcessBarcode(string code)
    {
        _barcodeError = "";
        _barcodeSuccess = "";
        if (string.IsNullOrEmpty(code)) { await FocusBarcode(); return; }

        try
        {
            var product = await ProductSvc.GetByBarcodeAsync(code);
            if (product == null)
            {
                _barcodeError = $"Codigo '{code}' no encontrado. Intenta de nuevo.";
                StateHasChanged();
                await FocusBarcode();
                return;
            }
            if (product.Stock <= 0)
            {
                _barcodeError = $"{product.Name} sin stock disponible.";
                StateHasChanged();
                await FocusBarcode();
                return;
            }
            AddProductToCart(product, 1);
            _barcodeSuccess = $"{product.Name} agregado al carrito.";
            StateHasChanged();
            _ = Task.Run(async () => { await Task.Delay(2000); _barcodeSuccess = ""; await InvokeAsync(StateHasChanged); });
        }
        catch
        {
            _barcodeError = "Error de conexion con el servidor.";
        }
        await FocusBarcode();
    }

    private async Task FocusBarcode()
    {
        try { await JS.InvokeVoidAsync("posHelper.focusElement", "scanInput"); } catch { }
    }

    // ── Cart operations ────────────────────────────────────────────────────
    private void AddProductToCart(Product product, int qty)
    {
        var existing = _posCart.FirstOrDefault(i => i.Id == product.Id);
        if (existing != null)
        {
            existing.Quantity = Math.Min(existing.Quantity + qty, product.Stock);
        }
        else
        {
            _posCart.Add(new CartItem
            {
                Id       = product.Id,
                Name     = product.Name,
                Price    = product.Price,
                Quantity = qty,
                Image    = product.Image
            });
        }
    }

    private void ChangeQty(CartItem item, int delta)
    {
        int stock = GetProductStock(item.Id);
        item.Quantity = Math.Clamp(item.Quantity + delta, 1, stock);
        _ = FocusBarcode();
    }

    private int GetProductStock(int productId) =>
        _products.FirstOrDefault(p => p.Id == productId)?.Stock ?? 0;

    private void RemoveFromCart(int productId)
    {
        var item = _posCart.FirstOrDefault(i => i.Id == productId);
        if (item != null) _posCart.Remove(item);
        _ = FocusBarcode();
    }

    // ── Venta flow ─────────────────────────────────────────────────────────
    private async Task ConfirmarVentaPOS()
    {
        if (!_posCart.Any() || _isProcessing) return;
        _isProcessing = true;
        _errorMsg = "";

        int idUsuario = Auth.CurrentUser?.Id ?? 0;
        if (idUsuario <= 0)
        {
            _errorMsg = "Debe iniciar sesión para registrar ventas.";
            _isProcessing = false;
            return;
        }

        try
        {
            int idGenerado = await SalesSvc.AddPresencialSaleAsync(
                _customerName, _posCart, Total, _payMethod, "boleta", idUsuario);

            if (idGenerado > 0)
            {
                _idVentaGenerada = idGenerado;

                bool confirmado = await SalesSvc.ConfirmPresencialSaleAsync(idGenerado);
                if (confirmado)
                {
                    _ventaConfirmada = true;
                    _receiptId = idGenerado.ToString();
                    foreach (var item in _posCart)
                    {
                        var p = _products.FirstOrDefault(pr => pr.Id == item.Id);
                        if (p != null) p.Stock = Math.Max(0, p.Stock - item.Quantity);
                    }
                    _toastMsg = "La venta se ha realizado correctamente";
                    _showSavedToast = true;
                    StateHasChanged();
                    _ = Task.Run(async () => { await Task.Delay(3000); _showSavedToast = false; await InvokeAsync(StateHasChanged); });
                }
                else
                {
                    _errorMsg = "La venta fue registrada, pero no pudo ser confirmada en el servidor.";
                }
            }
            else
            {
                _errorMsg = "Error al registrar la venta.";
            }
        }
        catch (Exception ex)
        {
            _errorMsg = "Ocurrió un error inesperado: " + ex.Message;
        }
        finally
        {
            _isProcessing = false;
            await FocusBarcode();
        }
    }

    private async Task GenerarBoletaPOS()
    {
        if (_idVentaGenerada <= 0 || _isProcessing) return;
        _isProcessing = true;
        _errorMsg = "";

        try
        {
            var boleta = await SalesSvc.GenerateBoletaAsync(_idVentaGenerada);
            if (boleta != null)
            {
                _boletaResponse = boleta;
                _showBoletaModal = true;
            }
            else
            {
                _errorMsg = string.IsNullOrWhiteSpace(SalesSvc.UltimoErrorBoleta)
                    ? "Error al emitir boleta con Nubefact."
                    : SalesSvc.UltimoErrorBoleta;
            }
        }
        catch (Exception ex)
        {
            _errorMsg = "Excepción al emitir boleta: " + ex.Message;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    // Financial calculations
    private decimal Subtotal       => _posCart.Sum(i => i.Price * i.Quantity);
    private decimal SubtotalSinIgv => Subtotal / 1.18m;
    private decimal Igv            => Subtotal - SubtotalSinIgv;
    private decimal Total          => Subtotal;

    // ── Lifecycle ──────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await ProductSvc.EnsureLoadedAsync();
        _products = ProductSvc.GetProducts();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("posHelper.keepFocus", "scanInput");
            await FocusBarcode();
        }
    }

    // ── Modal (manual search) ──────────────────────────────────────────────
    private IEnumerable<Product> ModalProducts => _products.Where(p =>
        string.IsNullOrEmpty(_modalSearch) ||
        p.Name.Contains(_modalSearch, StringComparison.OrdinalIgnoreCase) ||
        p.Category.Contains(_modalSearch, StringComparison.OrdinalIgnoreCase)
    );

    private void OpenModal()
    {
        _isModalOpen = true;
        _modalSearch = "";
        _selectedProduct = null;
        _selectedQuantity = 1;
    }

    private void CloseModal() => _isModalOpen = false;

    private void SelectProduct(Product p)
    {
        _selectedProduct = p;
        _selectedQuantity = 1;
    }

    private async Task AddSelectedToCart()
    {
        if (_selectedProduct == null || _selectedQuantity <= 0) return;
        AddProductToCart(_selectedProduct, _selectedQuantity);
        CloseModal();
        await FocusBarcode();
    }

    private void ResetPOS()
    {
        _posCart.Clear();
        _customerName = "";
        _payMethod    = "efectivo";
        _receiptId    = "";
        _errorMsg     = "";
        _idVentaGenerada = 0;
        _ventaConfirmada = false;
        _boletaResponse = null;
        _showBoletaModal = false;
        _showSavedToast = false;
    }

    public void Dispose()
    {
        _barcodeTimer?.Dispose();
    }
}
