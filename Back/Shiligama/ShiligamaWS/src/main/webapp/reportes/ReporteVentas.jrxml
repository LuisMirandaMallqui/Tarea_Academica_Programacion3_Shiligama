	<dataset name="Dataset1" uuid="4e5436d0-6c00-45ac-925d-7ce28f61f8b1">
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Conexion MySQL"/>
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<parameter name="fechaInicio" class="java.lang.String"/>
		<parameter name="fechaFin" class="java.lang.String"/>
		<parameter name="agrupacion" class="java.lang.String">
			<description><![CDATA[agrupacion]]></description>
		</parameter>
		<query language="sql"><![CDATA[SELECT
    CASE
        WHEN $P{agrupacion} = 'DIA'
            THEN DATE_FORMAT(v.FECHA_HORA, '%d/%m/%Y')
        WHEN $P{agrupacion} = 'SEMANA'
            THEN CONCAT('Sem. ', WEEK(v.FECHA_HORA, 1), ' - ', YEAR(v.FECHA_HORA))
        WHEN $P{agrupacion} = 'MES'
            THEN DATE_FORMAT(v.FECHA_HORA, '%M %Y')
    END                                             AS periodo,
    v.CANAL_VENTA                                   AS canalVenta,
    COUNT(DISTINCT v.VENTA_ID)                      AS cantidadVentas,
    SUM(dv.CANTIDAD)                                AS totalUnidades,
    SUM(dv.SUBTOTAL)                                AS totalIngresos,
    SUM(v.MONTO_DESCUENTO)                          AS totalDescuentos,
    SUM(v.MONTO_TOTAL - v.MONTO_DESCUENTO)          AS totalNeto
FROM venta v
JOIN detalle_venta dv ON v.VENTA_ID = dv.VENTA_ID
WHERE v.FECHA_HORA BETWEEN STR_TO_DATE($P{fechaInicio}, '%Y-%m-%d') 
                       AND STR_TO_DATE($P{fechaFin}, '%Y-%m-%d')
  AND v.ESTADO_VENTA = 'COMPLETADA'
  AND v.ACTIVO = 1
GROUP BY
    CASE
        WHEN $P{agrupacion} = 'DIA'   THEN DATE(v.FECHA_HORA)
        WHEN $P{agrupacion} = 'SEMANA' THEN YEARWEEK(v.FECHA_HORA, 1)
        WHEN $P{agrupacion} = 'MES'   THEN DATE_FORMAT(v.FECHA_HORA, '%Y%m')
    END,
    v.CANAL_VENTA
ORDER BY
    CASE
        WHEN $P{agrupacion} = 'DIA'   THEN DATE(v.FECHA_HORA)
        WHEN $P{agrupacion} = 'SEMANA' THEN YEARWEEK(v.FECHA_HORA, 1)
        WHEN $P{agrupacion} = 'MES'   THEN DATE_FORMAT(v.FECHA_HORA, '%Y%m')
    END ASC,
    v.CANAL_VENTA]]></query>
		<field name="periodo" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.name" value="periodo"/>
			<property name="com.jaspersoft.studio.field.label" value="periodo"/>
		</field>
