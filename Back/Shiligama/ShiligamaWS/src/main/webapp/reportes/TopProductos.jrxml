	<query language="sql"><![CDATA[SELECT
    p.NOMBRE                                        AS productoNombre,
    cat.NOMBRE                                      AS categoriaNombre,
    p.CODIGO_BARRAS                                 AS codigoBarras,
    SUM(CASE WHEN v.CANAL_VENTA = 'PRESENCIAL'
        THEN dv.CANTIDAD ELSE 0 END)                AS unidadesPresencial,
    SUM(CASE WHEN v.CANAL_VENTA = 'PRESENCIAL'
        THEN dv.SUBTOTAL ELSE 0 END)                AS ingresosPresencial,
    SUM(CASE WHEN v.CANAL_VENTA = 'WEB'
        THEN dv.CANTIDAD ELSE 0 END)                AS unidadesWeb,
    SUM(CASE WHEN v.CANAL_VENTA = 'WEB'
        THEN dv.SUBTOTAL ELSE 0 END)                AS ingresosWeb,
    SUM(dv.CANTIDAD)                                AS totalUnidades,
    SUM(dv.SUBTOTAL)                                AS totalIngresos,
    ROUND(
        SUM(dv.SUBTOTAL) * 100.0 /
        NULLIF((
            SELECT SUM(MONTO_TOTAL)
            FROM venta
            WHERE FECHA_HORA BETWEEN STR_TO_DATE($P{fechaInicio}, '%Y-%m-%d') 
                                 AND STR_TO_DATE($P{fechaFin}, '%Y-%m-%d')
              AND ESTADO_VENTA = 'COMPLETADA'
              AND ACTIVO = 1
        ), 0)
    , 2)                                            AS porcentajeVentas,
    p.STOCK                                         AS stockActual
FROM detalle_venta dv
JOIN venta v        ON dv.VENTA_ID    = v.VENTA_ID
JOIN producto p     ON dv.PRODUCTO_ID = p.PRODUCTO_ID
JOIN categoria cat  ON p.CATEGORIA_ID = cat.CATEGORIA_ID
WHERE v.FECHA_HORA BETWEEN STR_TO_DATE($P{fechaInicio}, '%Y-%m-%d') 
                       AND STR_TO_DATE($P{fechaFin}, '%Y-%m-%d')
  AND v.ESTADO_VENTA = 'COMPLETADA'
  AND v.ACTIVO = 1
GROUP BY p.PRODUCTO_ID, p.NOMBRE, cat.NOMBRE, p.CODIGO_BARRAS, p.STOCK
ORDER BY totalIngresos DESC
LIMIT 10;]]></query>
