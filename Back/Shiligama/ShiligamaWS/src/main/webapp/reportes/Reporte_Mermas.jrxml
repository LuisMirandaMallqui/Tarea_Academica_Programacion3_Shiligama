	<dataset name="Dataset1" uuid="474643ad-2b3d-4a6f-85b2-7af0398dc4a2">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Conexion MySQL"/>
		<parameter name="FECHA_INICIO" class="java.lang.String"/>
		<parameter name="FECHA_FIN" class="java.lang.String"/>
		<parameter name="ESTADO" class="java.lang.String"/>
		<parameter name="Parameter1" class="java.lang.String"/>
		<query language="SQL"><![CDATA[SELECT
    d.DEVOLUCION_ID                                 AS devolucionId,
    d.FECHA_HORA                                    AS fechaHora,
    p.NOMBRE                                        AS productoNombre,
    cat.NOMBRE                                      AS categoriaNombre,
    p.CODIGO_BARRAS                                 AS codigoBarras,
    dd.CANTIDAD                                     AS cantidad,
    p.PRECIO_UNITARIO                               AS precioUnitario,
    (dd.CANTIDAD * p.PRECIO_UNITARIO)               AS valorPerdida,
    d.MOTIVO                                        AS motivo,
    d.OBSERVACIONES                                 AS observaciones,
    d.ESTADO_DEVOLUCION                             AS estadoDevolucion,
    CONCAT(u.NOMBRES, ' ', u.APELLIDOS)             AS registradoPor,
    d.PEDIDO_ID                                     AS pedidoId
FROM devolucion d
JOIN detalle_devolucion dd  ON d.DEVOLUCION_ID       = dd.DEVOLUCION_ID
JOIN producto p             ON dd.PRODUCTO_ID        = p.PRODUCTO_ID
JOIN categoria cat          ON p.CATEGORIA_ID        = cat.CATEGORIA_ID
LEFT JOIN usuario u         ON d.USUARIO_REGISTRA_ID = u.USUARIO_ID
WHERE d.FECHA_HORA BETWEEN STR_TO_DATE($P{FECHA_INICIO}, '%Y-%m-%d') 
                       AND STR_TO_DATE($P{FECHA_FIN}, '%Y-%m-%d')
  AND d.ACTIVO = 1
  AND ($P{ESTADO} = 'TODOS' OR d.ESTADO_DEVOLUCION = $P{ESTADO})
ORDER BY d.FECHA_HORA DESC;]]></query>
