	<dataset name="Dataset2" uuid="dd95bb4b-7ffd-4cb9-8d6e-9f17dd26412a">
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Conexion MySQL"/>
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<parameter name="DIAS_ALERTA" class="java.lang.Integer"/>
		<query language="sql"><![CDATA[SELECT
    l.LOTE_ID                                       AS loteId,
    l.NUMERO_LOTE                                   AS numeroLote,
    p.NOMBRE                                        AS productoNombre,
    cat.NOMBRE                                      AS categoriaNombre,
    p.CODIGO_BARRAS                                 AS codigoBarras,
    l.CANTIDAD_ACTUAL                               AS cantidadEnRiesgo,
    p.PRECIO_UNITARIO                               AS precioUnitario,
    (l.CANTIDAD_ACTUAL * p.PRECIO_UNITARIO)         AS valorEnRiesgo,
    l.FECHA_VENCIMIENTO                             AS fechaVencimiento,
    DATEDIFF(l.FECHA_VENCIMIENTO, CURDATE())        AS diasRestantes,
    CASE
        WHEN l.FECHA_VENCIMIENTO < CURDATE()
            THEN 'VENCIDO'
        WHEN DATEDIFF(l.FECHA_VENCIMIENTO, CURDATE()) <= 7
            THEN 'CRÍTICO'
        WHEN DATEDIFF(l.FECHA_VENCIMIENTO, CURDATE()) <= 30
            THEN 'PRÓXIMO'
        ELSE 'VIGENTE'
    END                                             AS estadoVencimiento,
    CONCAT(u.NOMBRES, ' ', u.APELLIDOS)             AS registradoPor
FROM lote l
JOIN producto p     ON l.PRODUCTO_ID  = p.PRODUCTO_ID
JOIN categoria cat  ON p.CATEGORIA_ID = cat.CATEGORIA_ID
LEFT JOIN usuario u ON l.TRABAJADOR_ID = u.USUARIO_ID
WHERE l.ACTIVO = 1
  AND l.CANTIDAD_ACTUAL > 0
  AND l.FECHA_VENCIMIENTO <= DATE_ADD(CURDATE(), INTERVAL $P{DIAS_ALERTA} DAY)
ORDER BY l.FECHA_VENCIMIENTO ASC;]]></query>
